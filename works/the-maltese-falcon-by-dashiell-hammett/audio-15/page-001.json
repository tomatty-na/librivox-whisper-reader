{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-15",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_15_hammett.mp3",
  "chapter_title": "Chapter 15 - Officials",
  "reader_name": "Mark Nelson",
  "page_num": 1,
  "page_total": 6,
  "page_start_sec": 6.66,
  "page_end_sec": 247.52,
  "para_gap_threshold": 0.734,
  "segments": [
    {
      "start": 6.66,
      "end": 11.18,
      "text": "CHAPTER XV."
    },
    {
      "start": 11.26,
      "end": 12.9,
      "text": "OFFICIALS"
    },
    {
      "start": 15.04,
      "end": 17.56,
      "text": "Spade and Detective Sergeant Polehouse ate",
      "para_break": true
    },
    {
      "start": 17.56,
      "end": 19.88,
      "text": "pickled pig's feet at one of John's tables"
    },
    {
      "start": 20.06,
      "end": 21.3,
      "text": "at the State's Hofbrau."
    },
    {
      "start": 21.5,
      "end": 21.6,
      "text": "Polehouse,"
    },
    {
      "start": 23.4,
      "end": 26.18,
      "text": "balancing pale bright jelly on a fork halfway between",
      "para_break": true
    },
    {
      "start": 26.42,
      "end": 27.08,
      "text": "plate and mouth,"
    },
    {
      "start": 27.2,
      "end": 27.46,
      "text": "said,"
    },
    {
      "start": 28.17,
      "end": 28.82,
      "text": "\"'Hey,"
    },
    {
      "start": 28.84,
      "end": 29.1,
      "text": "listen,"
    },
    {
      "start": 29.22,
      "end": 29.46,
      "text": "Sam,"
    },
    {
      "start": 29.7,
      "end": 31.22,
      "text": "forget about the other night."
    },
    {
      "start": 31.88,
      "end": 32.74,
      "text": "He was dead wrong,"
    },
    {
      "start": 32.98,
      "end": 34.68,
      "text": "but you know anybody's liable"
    },
    {
      "start": 34.68,
      "end": 37.088,
      "text": "to lose their head if you ride them like that.'"
    },
    {
      "start": 38.176,
      "end": 40.12,
      "text": "Spade looked thoughtfully at the police detective.",
      "para_break": true
    },
    {
      "start": 41.42,
      "end": 44.04,
      "text": "\"'Was that what you wanted to see me about?' he asked.",
      "para_break": true
    },
    {
      "start": 45.216,
      "end": 45.98,
      "text": "Polehouse nodded,",
      "para_break": true
    },
    {
      "start": 46.44,
      "end": 48.22,
      "text": "put the forkful of jelly into his mouth,"
    },
    {
      "start": 48.42,
      "end": 49.18,
      "text": "swallowed it,"
    },
    {
      "start": 49.3,
      "end": 50.54,
      "text": "and qualified his nod."
    },
    {
      "start": 51.12,
      "end": 52.28,
      "text": "\"'Mostly.'"
    },
    {
      "start": 53.472,
      "end": 54.432,
      "text": "Dundee send you?\"",
      "para_break": true
    },
    {
      "start": 55.232,
      "end": 56.88,
      "text": "Polehouse made a disgusted mouth.",
      "para_break": true
    },
    {
      "start": 57.7,
      "end": 58.86,
      "text": "\"'You know he didn't.",
      "para_break": true
    },
    {
      "start": 58.92,
      "end": 61.088,
      "text": "He's as bull-headed as you are.'"
    },
    {
      "start": 62.08,
      "end": 63.66,
      "text": "Spade smiled and shook his head.",
      "para_break": true
    },
    {
      "start": 64.38,
      "end": 65.1,
      "text": "\"'No,"
    },
    {
      "start": 65.1,
      "end": 65.6,
      "text": "he's not,"
    },
    {
      "start": 65.72,
      "end": 66.78,
      "text": "Tom,' he said."
    },
    {
      "start": 67.36,
      "end": 68.74,
      "text": "\"'He just thinks he is.'"
    },
    {
      "start": 69.696,
      "end": 72.54,
      "text": "Tom scowled and chopped at his pig's foot with his knife.",
      "para_break": true
    },
    {
      "start": 74.176,
      "end": 76.48,
      "text": "\"'Ain't you ever gonna grow up?' he grumbled.",
      "para_break": true
    },
    {
      "start": 77.4,
      "end": 78.68,
      "text": "\"'What have you got to beef about?",
      "para_break": true
    },
    {
      "start": 79.48,
      "end": 80.26,
      "text": "He didn't hurt you.",
      "para_break": true
    },
    {
      "start": 81.0,
      "end": 82.0,
      "text": "You came out on top.",
      "para_break": true
    },
    {
      "start": 82.68,
      "end": 84.98,
      "text": "What's the sense of making a grudge of it?"
    },
    {
      "start": 85.792,
      "end": 87.74,
      "text": "You're just making a lot of grief for yourself.",
      "para_break": true
    },
    {
      "start": 89.408,
      "end": 92.4,
      "text": "Spade placed his knife and fork carefully together on his plate",
      "para_break": true
    },
    {
      "start": 92.54,
      "end": 95.18,
      "text": "and put his hands on the table beside his plate."
    },
    {
      "start": 95.7,
      "end": 98.24,
      "text": "His smile was faint and devoid of warmth."
    },
    {
      "start": 99.9,
      "end": 101.36,
      "text": "With every bull in town working",
      "para_break": true
    },
    {
      "start": 101.36,
      "end": 103.52,
      "text": "overtime trying to pile up grief for me,"
    },
    {
      "start": 103.64,
      "end": 104.84,
      "text": "a little more won't hurt."
    },
    {
      "start": 105.72,
      "end": 107.06,
      "text": "I won't even know it's there.",
      "para_break": true
    },
    {
      "start": 108.384,
      "end": 109.88,
      "text": "Polehouse's ruddiness deepened.",
      "para_break": true
    },
    {
      "start": 109.92,
      "end": 110.52,
      "text": "He said,"
    },
    {
      "start": 111.06,
      "end": 113.44,
      "text": "That's a swell thing to say to me.\""
    },
    {
      "start": 114.464,
      "end": 116.88,
      "text": "Spade picked up his knife and fork and began to eat.",
      "para_break": true
    },
    {
      "start": 117.824,
      "end": 118.44,
      "text": "Polehouse ate.",
      "para_break": true
    },
    {
      "start": 119.12,
      "end": 119.72,
      "text": "Presently,"
    },
    {
      "start": 119.74,
      "end": 120.58,
      "text": "Spade asked,"
    },
    {
      "start": 121.54,
      "end": 123.26,
      "text": "\"'See the boat on fire in the bay?'",
      "para_break": true
    },
    {
      "start": 123.66,
      "end": 125.0,
      "text": "I saw the smoke."
    },
    {
      "start": 125.792,
      "end": 126.64,
      "text": "Be reasonable,",
      "para_break": true
    },
    {
      "start": 126.86,
      "end": 127.1,
      "text": "Sam."
    },
    {
      "start": 127.776,
      "end": 129.36,
      "text": "Dundee was wrong and he knows it."
    },
    {
      "start": 129.98,
      "end": 131.52,
      "text": "Why don't you let it go at that?'"
    },
    {
      "start": 132.896,
      "end": 134.3,
      "text": "\"'Think I ought to go around and tell",
      "para_break": true
    },
    {
      "start": 134.3,
      "end": 136.56,
      "text": "him I hope my chin didn't hurt his fist?'"
    },
    {
      "start": 137.888,
      "end": 139.88,
      "text": "Polehouse cut savagely at his pig's foot.",
      "para_break": true
    },
    {
      "start": 140.672,
      "end": 141.18,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 142.528,
      "end": 144.83,
      "text": "\"'Phil Archer been in with any more hot tips?'",
      "para_break": true
    },
    {
      "start": 145.68,
      "end": 146.28,
      "text": "\"'Aw,",
      "para_break": true
    },
    {
      "start": 146.28,
      "end": 146.54,
      "text": "hell,"
    },
    {
      "start": 146.82,
      "end": 148.54,
      "text": "Dundee didn't think you shot Miles."
    },
    {
      "start": 149.38,
      "end": 151.44,
      "text": "But what else could he do except run the lead",
      "para_break": true
    },
    {
      "start": 151.52,
      "end": 151.8,
      "text": "down?"
    },
    {
      "start": 152.64,
      "end": 154.34,
      "text": "You'd have done the same thing in his place,",
      "para_break": true
    },
    {
      "start": 154.44,
      "end": 155.2,
      "text": "and you know it.'"
    },
    {
      "start": 156.42,
      "end": 159.62,
      "text": "\"'Yes.' Malice glittered in Spade's eyes.",
      "para_break": true
    },
    {
      "start": 160.96,
      "end": 162.58,
      "text": "\"'What made him think I didn't do it?",
      "para_break": true
    },
    {
      "start": 163.44,
      "end": 164.96,
      "text": "What makes you think I didn't?",
      "para_break": true
    },
    {
      "start": 164.98,
      "end": 166.04,
      "text": "Or don't you?'"
    },
    {
      "start": 166.14,
      "end": 166.272,
      "text": "you.\""
    },
    {
      "start": 167.296,
      "end": 169.12,
      "text": "Polhaus's ruddy face flushed again.",
      "para_break": true
    },
    {
      "start": 169.48,
      "end": 170.14,
      "text": "He said,"
    },
    {
      "start": 171.296,
      "end": 172.7,
      "text": "\"'Thursby shot Miles.'",
      "para_break": true
    },
    {
      "start": 173.64,
      "end": 174.68,
      "text": "\"'You think he did?'",
      "para_break": true
    },
    {
      "start": 175.22,
      "end": 175.58,
      "text": "\"'He did."
    },
    {
      "start": 176.48,
      "end": 177.44,
      "text": "That Wembley was his,",
      "para_break": true
    },
    {
      "start": 177.48,
      "end": 177.98,
      "text": "all right,"
    },
    {
      "start": 178.06,
      "end": 180.48,
      "text": "and the slug in Miles came out of it.'"
    },
    {
      "start": 181.14,
      "end": 183.36,
      "text": "\"'Sure?' Spade demanded."
    },
    {
      "start": 184.192,
      "end": 187.28,
      "text": "\"'Dead sure,' the police detective replied,",
      "para_break": true
    },
    {
      "start": 187.82,
      "end": 189.92,
      "text": "in the tone of one without the least doubt."
    },
    {
      "start": 190.94,
      "end": 192.66,
      "text": "We got hold of a kid,",
      "para_break": true
    },
    {
      "start": 192.8,
      "end": 194.28,
      "text": "a bellhop at his hotel,"
    },
    {
      "start": 194.63,
      "end": 197.18,
      "text": "that had seen it in his room just that morning."
    },
    {
      "start": 198.02,
      "end": 201.46,
      "text": "He noticed it particular because he never saw one like it before.",
      "para_break": true
    },
    {
      "start": 202.38,
      "end": 203.3,
      "text": "I never saw one.",
      "para_break": true
    },
    {
      "start": 204.92,
      "end": 206.52,
      "text": "You say they don't make them any more.",
      "para_break": true
    },
    {
      "start": 207.26,
      "end": 209.04,
      "text": "It ain't likely there'd be another around.",
      "para_break": true
    },
    {
      "start": 209.68,
      "end": 210.04,
      "text": "And anyway,"
    },
    {
      "start": 210.3,
      "end": 211.58,
      "text": "if it wasn't Thursby's,"
    },
    {
      "start": 211.68,
      "end": 213.18,
      "text": "what happened to his?\""
    },
    {
      "start": 213.96,
      "end": 216.66,
      "text": "He started to put a piece of bread into his mouth,",
      "para_break": true
    },
    {
      "start": 216.82,
      "end": 217.46,
      "text": "withdrew it,"
    },
    {
      "start": 217.5,
      "end": 217.8,
      "text": "and asked,"
    },
    {
      "start": 219.32,
      "end": 220.78,
      "text": "You say you've seen them before.",
      "para_break": true
    },
    {
      "start": 221.58,
      "end": 222.624,
      "text": "Where was that at?\"",
      "para_break": true
    },
    {
      "start": 222.99,
      "end": 224.86,
      "text": "He put the bread into his mouth."
    },
    {
      "start": 226.06,
      "end": 226.5,
      "text": "In England,",
      "para_break": true
    },
    {
      "start": 226.62,
      "end": 227.4,
      "text": "before the war."
    },
    {
      "start": 228.38,
      "end": 228.64,
      "text": "Sure,",
      "para_break": true
    },
    {
      "start": 228.92,
      "end": 229.66,
      "text": "there you are."
    },
    {
      "start": 230.752,
      "end": 231.88,
      "text": "Spade nodded and said,",
      "para_break": true
    },
    {
      "start": 233.088,
      "end": 235.78,
      "text": "Then that leaves Thursby the only one I killed?",
      "para_break": true
    },
    {
      "start": 237.216,
      "end": 239.08,
      "text": "Polehouse squirmed a little in his chair,",
      "para_break": true
    },
    {
      "start": 239.22,
      "end": 241.32,
      "text": "and his face was red and shiny."
    },
    {
      "start": 242.88,
      "end": 243.16,
      "text": "Oh,",
      "para_break": true
    },
    {
      "start": 243.18,
      "end": 243.64,
      "text": "sake!"
    },
    {
      "start": 244.0,
      "end": 245.78,
      "text": "Ain't you ever going to forget that?"
    },
    {
      "start": 246.34,
      "end": 247.52,
      "text": "He complained earnestly."
    }
  ]
}
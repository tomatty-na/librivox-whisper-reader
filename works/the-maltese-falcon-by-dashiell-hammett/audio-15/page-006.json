{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-15",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_15_hammett.mp3",
  "chapter_title": "Chapter 15 - Officials",
  "reader_name": "Mark Nelson",
  "page_num": 6,
  "page_total": 6,
  "page_start_sec": 1224.38,
  "page_end_sec": 1298.78,
  "para_gap_threshold": 0.734,
  "segments": [
    {
      "start": 1224.38,
      "end": 1227.06,
      "text": "And my only chance of ever catching them and tying them",
      "para_break": true
    },
    {
      "start": 1227.06,
      "end": 1230.32,
      "text": "up and bringing them in is in keeping away from you and the police,"
    },
    {
      "start": 1230.54,
      "end": 1231.84,
      "text": "because neither of"
    },
    {
      "start": 1231.84,
      "end": 1234.67,
      "text": "you show any signs of knowing what the hell it's all about.\""
    },
    {
      "start": 1236.01,
      "end": 1238.08,
      "text": "He got up and turned his head over his",
      "para_break": true
    },
    {
      "start": 1238.08,
      "end": 1239.76,
      "text": "shoulder to address the stenographer."
    },
    {
      "start": 1241.248,
      "end": 1241.94,
      "text": "\"'Getting this all right,",
      "para_break": true
    },
    {
      "start": 1242.04,
      "end": 1242.22,
      "text": "son?"
    },
    {
      "start": 1242.5,
      "end": 1244.704,
      "text": "Or am I going too fast for you?'"
    },
    {
      "start": 1245.84,
      "end": 1248.68,
      "text": "The stenographer looked up at him with startled eyes and replied,",
      "para_break": true
    },
    {
      "start": 1249.46,
      "end": 1249.96,
      "text": "\"'No,",
      "para_break": true
    },
    {
      "start": 1249.96,
      "end": 1250.12,
      "text": "sir,"
    },
    {
      "start": 1250.24,
      "end": 1251.58,
      "text": "I'm getting it all right.'"
    },
    {
      "start": 1252.512,
      "end": 1253.88,
      "text": "\"'Good work,' Spade said,",
      "para_break": true
    },
    {
      "start": 1254.06,
      "end": 1255.24,
      "text": "and turned to Bryan again."
    },
    {
      "start": 1256.32,
      "end": 1256.82,
      "text": "\"'Now,",
      "para_break": true
    },
    {
      "start": 1256.82,
      "end": 1259.41,
      "text": "if you want to go to the board and tell them I'm obstructing"
    },
    {
      "start": 1259.52,
      "end": 1261.42,
      "text": "justice and ask them to revoke my license,"
    },
    {
      "start": 1261.68,
      "end": 1262.38,
      "text": "hop to it."
    },
    {
      "start": 1262.81,
      "end": 1263.72,
      "text": "You've tried it"
    },
    {
      "start": 1263.84,
      "end": 1266.22,
      "text": "before and it didn't get you anything but a laugh.'"
    },
    {
      "start": 1266.72,
      "end": 1267.96,
      "text": "He picked up his hat."
    },
    {
      "start": 1269.34,
      "end": 1269.66,
      "text": "Dwayne began,",
      "para_break": true
    },
    {
      "start": 1269.82,
      "end": 1270.82,
      "text": "\"'Look here,"
    },
    {
      "start": 1270.92,
      "end": 1272.46,
      "text": "you,' Spade said,"
    },
    {
      "start": 1273.34,
      "end": 1275.04,
      "text": "\"'and I don't want any more of these informal",
      "para_break": true
    },
    {
      "start": 1275.34,
      "end": 1275.74,
      "text": "talks."
    },
    {
      "start": 1276.62,
      "end": 1277.82,
      "text": "I've got nothing to tell you,",
      "para_break": true
    },
    {
      "start": 1277.94,
      "end": 1280.5,
      "text": "and I'm damn tired of being called things by every"
    },
    {
      "start": 1280.61,
      "end": 1281.96,
      "text": "crackpot on the city payroll."
    },
    {
      "start": 1283.08,
      "end": 1283.88,
      "text": "If you want to see me,",
      "para_break": true
    },
    {
      "start": 1283.98,
      "end": 1286.0,
      "text": "pinch me or subpoena me or something,"
    },
    {
      "start": 1286.18,
      "end": 1287.81,
      "text": "and I'll come down with my lawyer.'"
    },
    {
      "start": 1289.02,
      "end": 1290.26,
      "text": "He put his hat on his head,",
      "para_break": true
    },
    {
      "start": 1290.38,
      "end": 1290.62,
      "text": "said,"
    },
    {
      "start": 1291.58,
      "end": 1292.16,
      "text": "\"'See you at the",
      "para_break": true
    },
    {
      "start": 1292.26,
      "end": 1292.72,
      "text": "inquest,"
    },
    {
      "start": 1292.8,
      "end": 1295.16,
      "text": "maybe,' and stalked out.\""
    },
    {
      "start": 1297.92,
      "end": 1298.78,
      "text": "End of chapter 15",
      "para_break": true
    }
  ]
}
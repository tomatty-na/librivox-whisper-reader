{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-02",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_02_hammett.mp3",
  "chapter_title": "Chapter 2 - Death in the Fog",
  "reader_name": "Mark Nelson",
  "page_num": 1,
  "page_total": 7,
  "page_start_sec": 9.14,
  "page_end_sec": 249.62,
  "para_gap_threshold": 0.753,
  "segments": [
    {
      "start": 9.14,
      "end": 12.4,
      "text": "CHAPTER II DEATH IN THE FOG"
    },
    {
      "start": 13.79,
      "end": 16.1,
      "text": "A telephone bell rang in darkness.",
      "para_break": true
    },
    {
      "start": 16.54,
      "end": 18.06,
      "text": "The third time it rang,"
    },
    {
      "start": 18.26,
      "end": 19.26,
      "text": "bed-springs creaked,"
    },
    {
      "start": 19.56,
      "end": 20.88,
      "text": "fingers fumbled on wood,"
    },
    {
      "start": 21.04,
      "end": 24.02,
      "text": "something small and hard thudded on a carpeted floor,"
    },
    {
      "start": 24.26,
      "end": 25.76,
      "text": "the springs creaked again,"
    },
    {
      "start": 25.92,
      "end": 27.1,
      "text": "and a man's voice said,"
    },
    {
      "start": 27.68,
      "end": 28.22,
      "text": "\"'Hello?'"
    },
    {
      "start": 28.52,
      "end": 29.22,
      "text": "\"'Yes,"
    },
    {
      "start": 29.22,
      "end": 29.78,
      "text": "speaking.'"
    },
    {
      "start": 30.26,
      "end": 30.94,
      "text": "\"'Dead?'"
    },
    {
      "start": 31.26,
      "end": 32.04,
      "text": "\"'Yes."
    },
    {
      "start": 32.08,
      "end": 33.42,
      "text": "Fifteen minutes.'"
    },
    {
      "start": 33.9,
      "end": 34.72,
      "text": "\"'Thanks.'"
    },
    {
      "start": 35.37,
      "end": 36.78,
      "text": "A switch clicked,"
    },
    {
      "start": 36.92,
      "end": 37.78,
      "text": "and a white bowl,"
    },
    {
      "start": 38.0,
      "end": 40.56,
      "text": "hung on three gilded chains from the ceiling center,"
    },
    {
      "start": 40.7,
      "end": 41.82,
      "text": "filled the room with light."
    },
    {
      "start": 42.52,
      "end": 43.54,
      "text": "Spade,"
    },
    {
      "start": 43.95,
      "end": 45.8,
      "text": "barefooted in green and white check pajamas,"
    },
    {
      "start": 46.56,
      "end": 47.82,
      "text": "sat on the side of his bed.",
      "para_break": true
    },
    {
      "start": 48.8,
      "end": 51.02,
      "text": "He scowled thoughtfully at the telephone on the table,",
      "para_break": true
    },
    {
      "start": 51.62,
      "end": 54.28,
      "text": "while his hands took from beside it a packet of"
    },
    {
      "start": 54.28,
      "end": 56.58,
      "text": "brown papers and a sack of Bull Durham tobacco."
    },
    {
      "start": 58.8,
      "end": 61.12,
      "text": "Cold steamy air blew in through two open windows,",
      "para_break": true
    },
    {
      "start": 61.4,
      "end": 62.62,
      "text": "bringing with it,"
    },
    {
      "start": 62.64,
      "end": 64.1,
      "text": "half a dozen times a minute,"
    },
    {
      "start": 64.52,
      "end": 66.78,
      "text": "the Alcatraz foghorn's dull moaning."
    },
    {
      "start": 68.34,
      "end": 69.36,
      "text": "A tinny alarm clock,",
      "para_break": true
    },
    {
      "start": 69.98,
      "end": 71.82,
      "text": "insecurely mounted on a corner of"
    },
    {
      "start": 71.88,
      "end": 74.24,
      "text": "Duke's celebrated Criminal Cases of America,"
    },
    {
      "start": 74.48,
      "end": 76.22,
      "text": "which lay face down on the table,"
    },
    {
      "start": 76.42,
      "end": 77.92,
      "text": "held its hands at five"
    },
    {
      "start": 78.16,
      "end": 79.08,
      "text": "minutes past two."
    },
    {
      "start": 80.736,
      "end": 83.8,
      "text": "Spade's thick fingers made a cigarette with deliberate care,",
      "para_break": true
    },
    {
      "start": 84.08,
      "end": 85.4,
      "text": "sifting a measured"
    },
    {
      "start": 85.52,
      "end": 88.3,
      "text": "quantity of the tanned flakes down into curving paper,"
    },
    {
      "start": 88.81,
      "end": 90.74,
      "text": "spreading the flakes so that they lay"
    },
    {
      "start": 90.88,
      "end": 93.46,
      "text": "equaled at the ends with a slight depression in the middle,"
    },
    {
      "start": 93.65,
      "end": 95.84,
      "text": "thumbs rolling the paper's inner edge"
    },
    {
      "start": 96.02,
      "end": 99.4,
      "text": "down and up under the outer edge as forefingers pressed it over,"
    },
    {
      "start": 99.64,
      "end": 101.82,
      "text": "thumbs and fingers sliding to"
    },
    {
      "start": 101.82,
      "end": 103.14,
      "text": "the paper cylinder's ends,"
    },
    {
      "start": 103.42,
      "end": 105.92,
      "text": "holding it even while tongue licked the flap,"
    },
    {
      "start": 106.2,
      "end": 107.58,
      "text": "left forefinger and thumb"
    },
    {
      "start": 107.72,
      "end": 108.58,
      "text": "pinching their end,"
    },
    {
      "start": 108.68,
      "end": 111.82,
      "text": "while right forefinger and thumb smoothed the damp seam,"
    },
    {
      "start": 112.08,
      "end": 113.24,
      "text": "right forefinger"
    },
    {
      "start": 113.24,
      "end": 116.58,
      "text": "and thumb twisting their end and lifting the other to Spade's mouth."
    },
    {
      "start": 117.84,
      "end": 120.16,
      "text": "He picked up the pigskin and nickel lighter",
      "para_break": true
    },
    {
      "start": 120.16,
      "end": 121.72,
      "text": "that had been knocked off the table,"
    },
    {
      "start": 122.06,
      "end": 122.64,
      "text": "worked it,"
    },
    {
      "start": 122.76,
      "end": 125.98,
      "text": "and with the cigarette burning in a corner of his mouth stood up."
    },
    {
      "start": 126.69,
      "end": 128.36,
      "text": "He took off his pajamas."
    },
    {
      "start": 129.42,
      "end": 130.98,
      "text": "The smooth thickness of his arms,",
      "para_break": true
    },
    {
      "start": 130.98,
      "end": 131.9,
      "text": "legs and body,"
    },
    {
      "start": 132.48,
      "end": 134.38,
      "text": "the sag of his big rounded shoulders,"
    },
    {
      "start": 134.58,
      "end": 136.68,
      "text": "made his body look like a bear's."
    },
    {
      "start": 136.94,
      "end": 139.28,
      "text": "It looked like a shaved bear's."
    },
    {
      "start": 139.4,
      "end": 141.06,
      "text": "His chest was hairless."
    },
    {
      "start": 141.84,
      "end": 144.2,
      "text": "His skin was childishly smooth and pink.",
      "para_break": true
    },
    {
      "start": 145.0,
      "end": 147.9,
      "text": "He scratched the back of his neck and began to dress.",
      "para_break": true
    },
    {
      "start": 148.84,
      "end": 150.62,
      "text": "He put on a thin white union suit,",
      "para_break": true
    },
    {
      "start": 150.98,
      "end": 151.44,
      "text": "gray socks,"
    },
    {
      "start": 151.72,
      "end": 152.46,
      "text": "black garters,"
    },
    {
      "start": 152.54,
      "end": 154.06,
      "text": "and dark brown shoes."
    },
    {
      "start": 155.42,
      "end": 157.24,
      "text": "When he had laced his shoes he picked up the",
      "para_break": true
    },
    {
      "start": 157.28,
      "end": 157.6,
      "text": "telephone,"
    },
    {
      "start": 157.84,
      "end": 159.92,
      "text": "called Greystone 4500,"
    },
    {
      "start": 160.0,
      "end": 161.6,
      "text": "and ordered a taxi cab."
    },
    {
      "start": 162.44,
      "end": 164.22,
      "text": "He put on a green-striped white shirt,",
      "para_break": true
    },
    {
      "start": 164.42,
      "end": 164.46,
      "text": "coat,"
    },
    {
      "start": 164.5,
      "end": 165.72,
      "text": "a soft white collar,"
    },
    {
      "start": 165.94,
      "end": 167.06,
      "text": "a green necktie,"
    },
    {
      "start": 167.32,
      "end": 169.2,
      "text": "the gray suit he had worn that day,"
    },
    {
      "start": 169.44,
      "end": 170.04,
      "text": "a loose"
    },
    {
      "start": 170.14,
      "end": 172.32,
      "text": "tweed overcoat and a dark gray hat."
    },
    {
      "start": 173.43,
      "end": 177.0,
      "text": "The street doorbell rang as he switched off the light.",
      "para_break": true
    },
    {
      "start": 178.62,
      "end": 180.26,
      "text": "Where Bush Street roofed Stockton",
      "para_break": true
    },
    {
      "start": 180.26,
      "end": 182.32,
      "text": "before slipping downhill to Chinatown,"
    },
    {
      "start": 182.5,
      "end": 183.94,
      "text": "Spade paid his fare"
    },
    {
      "start": 184.14,
      "end": 185.38,
      "text": "and left the taxicab."
    },
    {
      "start": 186.432,
      "end": 187.9,
      "text": "San Francisco's night fog,",
      "para_break": true
    },
    {
      "start": 188.2,
      "end": 188.7,
      "text": "thin,"
    },
    {
      "start": 188.88,
      "end": 190.04,
      "text": "clammy and penetrant,"
    },
    {
      "start": 190.16,
      "end": 190.76,
      "text": "blurred the"
    },
    {
      "start": 191.61,
      "end": 195.08,
      "text": "A few yards from where Spade had dismissed the taxi-cab,",
      "para_break": true
    },
    {
      "start": 195.36,
      "end": 197.58,
      "text": "a small group of men stood looking up an alley."
    },
    {
      "start": 198.76,
      "end": 200.74,
      "text": "Two women stood with a man on the other",
      "para_break": true
    },
    {
      "start": 200.74,
      "end": 202.68,
      "text": "side of Bush Street looking at the alley."
    },
    {
      "start": 203.64,
      "end": 204.8,
      "text": "There were faces at windows.",
      "para_break": true
    },
    {
      "start": 206.144,
      "end": 208.08,
      "text": "Spade crossed the sidewalk between iron",
      "para_break": true
    },
    {
      "start": 208.08,
      "end": 210.22,
      "text": "-railed hatchways that opened above bare,"
    },
    {
      "start": 210.38,
      "end": 211.16,
      "text": "ugly stairs,"
    },
    {
      "start": 211.66,
      "end": 212.96,
      "text": "went to the parapet,"
    },
    {
      "start": 213.02,
      "end": 215.04,
      "text": "and resting his hands on the damp coping,"
    },
    {
      "start": 215.24,
      "end": 216.76,
      "text": "looked down onto Stockton Street."
    },
    {
      "start": 217.74,
      "end": 220.1,
      "text": "An automobile popped out of the tunnel",
      "para_break": true
    },
    {
      "start": 220.1,
      "end": 221.84,
      "text": "beneath him with a roaring swish,"
    },
    {
      "start": 222.12,
      "end": 224.46,
      "text": "as if it had been blown out and ran away."
    },
    {
      "start": 225.8,
      "end": 227.24,
      "text": "Not far from the tunnel's mouth,",
      "para_break": true
    },
    {
      "start": 227.38,
      "end": 230.0,
      "text": "a man was hunkered on his heels before a billboard"
    },
    {
      "start": 230.24,
      "end": 233.08,
      "text": "that held advertisements of a moving picture and gasoline"
    },
    {
      "start": 233.42,
      "end": 236.3,
      "text": "across the front of a gap between two store buildings."
    },
    {
      "start": 237.5,
      "end": 239.92,
      "text": "The hunkered man's head was bent almost to the sidewalk,",
      "para_break": true
    },
    {
      "start": 240.56,
      "end": 241.96,
      "text": "so he could look under the billboard."
    },
    {
      "start": 242.94,
      "end": 244.74,
      "text": "A hand flat on the sidewalk,",
      "para_break": true
    },
    {
      "start": 245.04,
      "end": 247.52,
      "text": "a hand clenched on the billboard's green wooden frame,"
    },
    {
      "start": 248.032,
      "end": 249.62,
      "text": "held him in this grotesque position."
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-02",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_02_hammett.mp3",
  "chapter_title": "Chapter 2 - Death in the Fog",
  "reader_name": "Mark Nelson",
  "page_num": 7,
  "page_total": 7,
  "page_start_sec": 1458.688,
  "page_end_sec": 1531.08,
  "para_gap_threshold": 0.753,
  "segments": [
    {
      "start": 1458.688,
      "end": 1459.94,
      "text": "I've never seen Thursby,",
      "para_break": true
    },
    {
      "start": 1460.1,
      "end": 1460.8,
      "text": "he said,"
    },
    {
      "start": 1460.96,
      "end": 1462.38,
      "text": "dead or alive."
    },
    {
      "start": 1464.192,
      "end": 1465.48,
      "text": "Lieutenant Dundee stood up,",
      "para_break": true
    },
    {
      "start": 1465.5,
      "end": 1466.48,
      "text": "looking dissatisfied."
    },
    {
      "start": 1467.936,
      "end": 1468.3,
      "text": "Tom rose,",
      "para_break": true
    },
    {
      "start": 1468.62,
      "end": 1469.58,
      "text": "yawning and stretching."
    },
    {
      "start": 1471.7,
      "end": 1474.24,
      "text": "\"'We've asked you what we came to ask,' Dundee said,",
      "para_break": true
    },
    {
      "start": 1474.34,
      "end": 1476.52,
      "text": "frowning over eyes hard as green pebbles."
    },
    {
      "start": 1476.98,
      "end": 1480.28,
      "text": "He held his mustached upper lip tight against his teeth,"
    },
    {
      "start": 1480.42,
      "end": 1482.56,
      "text": "letting his lower lip push the words out."
    },
    {
      "start": 1484.032,
      "end": 1485.9,
      "text": "\"'We've told you more than you've told us.",
      "para_break": true
    },
    {
      "start": 1486.17,
      "end": 1487.28,
      "text": "That's fair enough."
    },
    {
      "start": 1488.06,
      "end": 1488.58,
      "text": "You know me,",
      "para_break": true
    },
    {
      "start": 1488.66,
      "end": 1488.98,
      "text": "Spade."
    },
    {
      "start": 1489.14,
      "end": 1490.38,
      "text": "If you did or"
    },
    {
      "start": 1490.38,
      "end": 1490.98,
      "text": "you didn't,"
    },
    {
      "start": 1490.98,
      "end": 1493.66,
      "text": "you'll get a square deal out of me and most of the breaks."
    },
    {
      "start": 1494.47,
      "end": 1495.72,
      "text": "I don't know that I blame",
      "para_break": true
    },
    {
      "start": 1495.98,
      "end": 1497.36,
      "text": "you a hell of a lot for dropping him,"
    },
    {
      "start": 1497.46,
      "end": 1499.712,
      "text": "but that won't keep me from nailing you.\""
    },
    {
      "start": 1501.152,
      "end": 1503.14,
      "text": "\"'Fair enough,' Spade agreed evenly.",
      "para_break": true
    },
    {
      "start": 1504.608,
      "end": 1506.74,
      "text": "\"'But I'd feel better about it if you drink your",
      "para_break": true
    },
    {
      "start": 1506.78,
      "end": 1507.26,
      "text": "drink.'"
    },
    {
      "start": 1508.352,
      "end": 1509.86,
      "text": "Lieutenant Dundee turned to the table,",
      "para_break": true
    },
    {
      "start": 1510.06,
      "end": 1512.24,
      "text": "picked up his glass and slowly drained it."
    },
    {
      "start": 1513.16,
      "end": 1513.68,
      "text": "Then he said,",
      "para_break": true
    },
    {
      "start": 1514.82,
      "end": 1516.58,
      "text": "\"'Good-night,' and held out his hand.",
      "para_break": true
    },
    {
      "start": 1516.8,
      "end": 1519.22,
      "text": "They shook hands with marked formality."
    },
    {
      "start": 1520.28,
      "end": 1522.52,
      "text": "Tom and Spade shook hands with marked formality.",
      "para_break": true
    },
    {
      "start": 1522.88,
      "end": 1524.16,
      "text": "Spade let them out,"
    },
    {
      "start": 1524.3,
      "end": 1525.32,
      "text": "then he undressed,"
    },
    {
      "start": 1525.48,
      "end": 1525.68,
      "text": "turned"
    },
    {
      "start": 1525.86,
      "end": 1527.28,
      "text": "off the lights and went to bed."
    },
    {
      "start": 1530.304,
      "end": 1531.08,
      "text": "End of chapter 1",
      "para_break": true
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-02",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_02_hammett.mp3",
  "chapter_title": "Chapter 2 - Death in the Fog",
  "reader_name": "Mark Nelson",
  "page_num": 2,
  "page_total": 7,
  "page_start_sec": 251.22,
  "page_end_sec": 491.64,
  "para_gap_threshold": 0.753,
  "segments": [
    {
      "start": 251.22,
      "end": 252.96,
      "text": "Two other men stood awkwardly close",
      "para_break": true
    },
    {
      "start": 252.96,
      "end": 254.92,
      "text": "together at one end of the billboard,"
    },
    {
      "start": 255.32,
      "end": 257.18,
      "text": "peeping through the few inches of space"
    },
    {
      "start": 257.18,
      "end": 259.34,
      "text": "between it and the building at that end."
    },
    {
      "start": 260.38,
      "end": 262.99,
      "text": "The building at the other end had a blank gray sidewall",
      "para_break": true
    },
    {
      "start": 263.08,
      "end": 265.4,
      "text": "that looked down on the lot behind the billboard."
    },
    {
      "start": 266.72,
      "end": 268.38,
      "text": "Lights flickered on the sidewall and",
      "para_break": true
    },
    {
      "start": 268.38,
      "end": 270.5,
      "text": "the shadows of men moving among lights."
    },
    {
      "start": 271.8,
      "end": 274.16,
      "text": "Spade turned from the parapet and walked up",
      "para_break": true
    },
    {
      "start": 274.16,
      "end": 276.34,
      "text": "Bush Street to the alley where men were grouped."
    },
    {
      "start": 277.34,
      "end": 278.3,
      "text": "A uniformed policeman,",
      "para_break": true
    },
    {
      "start": 278.62,
      "end": 282.14,
      "text": "chewing gum under an enamel sign that said Burrett Street in white"
    },
    {
      "start": 282.2,
      "end": 283.12,
      "text": "against dark blue,"
    },
    {
      "start": 283.32,
      "end": 284.84,
      "text": "put out an arm and asked,"
    },
    {
      "start": 285.44,
      "end": 286.24,
      "text": "What do you want here?"
    },
    {
      "start": 287.46,
      "end": 288.28,
      "text": "I'm Sam Spade.",
      "para_break": true
    },
    {
      "start": 288.48,
      "end": 289.94,
      "text": "Tom Polehouse phoned me."
    },
    {
      "start": 290.944,
      "end": 291.52,
      "text": "Sure you are.",
      "para_break": true
    },
    {
      "start": 292.1,
      "end": 293.52,
      "text": "The policeman's arm went down."
    },
    {
      "start": 294.14,
      "end": 295.48,
      "text": "I didn't know you at first."
    },
    {
      "start": 295.7,
      "end": 296.18,
      "text": "Well,"
    },
    {
      "start": 296.4,
      "end": 297.32,
      "text": "they're back there."
    },
    {
      "start": 297.92,
      "end": 299.86,
      "text": "He jerked a thumb over his shoulder."
    },
    {
      "start": 300.8,
      "end": 301.32,
      "text": "Bad business.",
      "para_break": true
    },
    {
      "start": 302.76,
      "end": 303.16,
      "text": "Bad enough,",
      "para_break": true
    },
    {
      "start": 303.48,
      "end": 304.24,
      "text": "Spade agreed,"
    },
    {
      "start": 304.54,
      "end": 305.54,
      "text": "and went up the alley."
    },
    {
      "start": 306.912,
      "end": 307.56,
      "text": "Halfway up it,",
      "para_break": true
    },
    {
      "start": 307.64,
      "end": 308.8,
      "text": "not far from the entrance,"
    },
    {
      "start": 309.06,
      "end": 310.3,
      "text": "a dark ambulance stood."
    },
    {
      "start": 311.36,
      "end": 312.12,
      "text": "Behind the ambulance,",
      "para_break": true
    },
    {
      "start": 312.32,
      "end": 312.88,
      "text": "on the left,"
    },
    {
      "start": 312.96,
      "end": 315.5,
      "text": "the alley was bounded by a waist-high fence,"
    },
    {
      "start": 316.08,
      "end": 317.44,
      "text": "three strips of rough boarding."
    },
    {
      "start": 318.56,
      "end": 319.22,
      "text": "From the fence,",
      "para_break": true
    },
    {
      "start": 319.32,
      "end": 321.24,
      "text": "dark ground fell away steeply to the"
    },
    {
      "start": 321.24,
      "end": 322.96,
      "text": "billboard on Stockton Street below."
    },
    {
      "start": 324.52,
      "end": 326.32,
      "text": "A ten-foot length of the fence's top",
      "para_break": true
    },
    {
      "start": 326.32,
      "end": 328.72,
      "text": "rail had been torn from a post at one end"
    },
    {
      "start": 328.88,
      "end": 330.48,
      "text": "and hung dangling from the other."
    },
    {
      "start": 331.648,
      "end": 334.7,
      "text": "Fifteen feet down the slope a flat boulder stuck out.",
      "para_break": true
    },
    {
      "start": 335.8,
      "end": 336.3,
      "text": "In the notch",
      "para_break": true
    },
    {
      "start": 336.38,
      "end": 339.32,
      "text": "between boulder and slope Miles Archer lay on his back."
    },
    {
      "start": 340.3,
      "end": 340.92,
      "text": "Two men stood",
      "para_break": true
    },
    {
      "start": 341.08,
      "end": 341.42,
      "text": "over him."
    },
    {
      "start": 342.336,
      "end": 345.12,
      "text": "One of them held an electric torch's beam on the dead man.",
      "para_break": true
    },
    {
      "start": 346.1,
      "end": 348.22,
      "text": "Other men with lights moved up and down the slope.",
      "para_break": true
    },
    {
      "start": 349.96,
      "end": 351.2,
      "text": "One of them hailed Spade.",
      "para_break": true
    },
    {
      "start": 352.24,
      "end": 352.68,
      "text": "\"'Hullo,",
      "para_break": true
    },
    {
      "start": 352.68,
      "end": 355.42,
      "text": "Sam,' and clambered up to the alley,"
    },
    {
      "start": 355.62,
      "end": 356.72,
      "text": "his shadow running up"
    },
    {
      "start": 356.82,
      "end": 357.34,
      "text": "before him."
    },
    {
      "start": 358.24,
      "end": 361.44,
      "text": "He was a barrel-bellied tall man with shrewd small eyes,",
      "para_break": true
    },
    {
      "start": 361.66,
      "end": 361.82,
      "text": "a"
    },
    {
      "start": 361.82,
      "end": 362.36,
      "text": "thick mouth,"
    },
    {
      "start": 362.6,
      "end": 364.88,
      "text": "and carelessly shaven dark jowls."
    },
    {
      "start": 365.82,
      "end": 366.22,
      "text": "His shoes,",
      "para_break": true
    },
    {
      "start": 366.36,
      "end": 366.6,
      "text": "knees,"
    },
    {
      "start": 366.7,
      "end": 367.06,
      "text": "hands"
    },
    {
      "start": 367.06,
      "end": 369.02,
      "text": "and chin were daubed with brown loam."
    },
    {
      "start": 370.8,
      "end": 372.34,
      "text": "\"'I figured you went to see it before",
      "para_break": true
    },
    {
      "start": 372.34,
      "end": 374.46,
      "text": "we took him away,' he said as he"
    },
    {
      "start": 374.58,
      "end": 375.86,
      "text": "stepped over the broken fence."
    },
    {
      "start": 376.7,
      "end": 377.38,
      "text": "\"'Yes.",
      "para_break": true
    },
    {
      "start": 377.44,
      "end": 377.98,
      "text": "Thanks,"
    },
    {
      "start": 378.1,
      "end": 379.4,
      "text": "Tom,' Spade said."
    },
    {
      "start": 380.3,
      "end": 380.96,
      "text": "\"'What happened?'",
      "para_break": true
    },
    {
      "start": 381.51,
      "end": 385.02,
      "text": "He put an elbow on a fence post and looked down at the men below,"
    },
    {
      "start": 385.26,
      "end": 387.06,
      "text": "nodding to those who nodded to him."
    },
    {
      "start": 388.5,
      "end": 391.64,
      "text": "Tom Pohaus poked his own left breast with a dirty finger.",
      "para_break": true
    },
    {
      "start": 392.8,
      "end": 394.72,
      "text": "Got him right through the pump with this.",
      "para_break": true
    },
    {
      "start": 395.5,
      "end": 399.04,
      "text": "He took a fat revolver from his coat pocket and held it out to Spade.",
      "para_break": true
    },
    {
      "start": 400.288,
      "end": 402.8,
      "text": "Mud inlaid the depressions in the revolver's surface.",
      "para_break": true
    },
    {
      "start": 404.2,
      "end": 404.68,
      "text": "A Webley.",
      "para_break": true
    },
    {
      "start": 405.03,
      "end": 405.48,
      "text": "English,"
    },
    {
      "start": 405.64,
      "end": 405.92,
      "text": "ain't it?"
    },
    {
      "start": 407.104,
      "end": 408.8,
      "text": "Spade took his elbow from the fence post",
      "para_break": true
    },
    {
      "start": 408.8,
      "end": 410.5,
      "text": "and leaned down to look at the weapon,"
    },
    {
      "start": 410.62,
      "end": 411.82,
      "text": "but he did not touch it."
    },
    {
      "start": 413.14,
      "end": 413.5,
      "text": "Yes,",
      "para_break": true
    },
    {
      "start": 413.78,
      "end": 414.38,
      "text": "he said."
    },
    {
      "start": 414.67,
      "end": 417.64,
      "text": "\"'Webley Fosbury semi-automatic revolver."
    },
    {
      "start": 417.76,
      "end": 418.86,
      "text": "That's it."
    },
    {
      "start": 419.66,
      "end": 420.18,
      "text": "Thirty-eight,",
      "para_break": true
    },
    {
      "start": 420.22,
      "end": 420.82,
      "text": "eight shot."
    },
    {
      "start": 421.8,
      "end": 422.26,
      "text": "They don't make",
      "para_break": true
    },
    {
      "start": 422.26,
      "end": 422.76,
      "text": "them any more."
    },
    {
      "start": 423.78,
      "end": 424.96,
      "text": "How many gone out of it?'",
      "para_break": true
    },
    {
      "start": 425.76,
      "end": 426.54,
      "text": "\"'One shot.'",
      "para_break": true
    },
    {
      "start": 427.24,
      "end": 428.42,
      "text": "Tom poked his breast again."
    },
    {
      "start": 429.48,
      "end": 431.7,
      "text": "\"'He must have been dead when he cracked the fence.'",
      "para_break": true
    },
    {
      "start": 432.66,
      "end": 433.94,
      "text": "He raised the muddy revolver.",
      "para_break": true
    },
    {
      "start": 435.232,
      "end": 436.33,
      "text": "\"'You've seen this before?'",
      "para_break": true
    },
    {
      "start": 437.312,
      "end": 438.0,
      "text": "Spade nodded.",
      "para_break": true
    },
    {
      "start": 439.328,
      "end": 442.12,
      "text": "\"'I've seen Webley Fosbury's,' he said indifferently,",
      "para_break": true
    },
    {
      "start": 442.24,
      "end": 443.42,
      "text": "and then spoke rapidly."
    },
    {
      "start": 444.54,
      "end": 445.68,
      "text": "He was shot up here,",
      "para_break": true
    },
    {
      "start": 445.82,
      "end": 445.98,
      "text": "huh?"
    },
    {
      "start": 446.38,
      "end": 447.6,
      "text": "Standing where you are,"
    },
    {
      "start": 447.66,
      "end": 448.82,
      "text": "with his back to the fence."
    },
    {
      "start": 449.52,
      "end": 451.54,
      "text": "The man that shot him stands here."
    },
    {
      "start": 452.52,
      "end": 455.4,
      "text": "He went around in front of Tom and raised a hand breast high,",
      "para_break": true
    },
    {
      "start": 455.48,
      "end": 456.66,
      "text": "with leveled forefinger."
    },
    {
      "start": 458.08,
      "end": 459.84,
      "text": "Let's him have it and Miles goes back,",
      "para_break": true
    },
    {
      "start": 459.98,
      "end": 461.46,
      "text": "taking the top off the fence"
    },
    {
      "start": 461.64,
      "end": 464.18,
      "text": "and going on through and down till the rock catches him."
    },
    {
      "start": 465.0,
      "end": 465.26,
      "text": "That it?",
      "para_break": true
    },
    {
      "start": 466.496,
      "end": 466.92,
      "text": "That's it,",
      "para_break": true
    },
    {
      "start": 467.08,
      "end": 468.38,
      "text": "Tom replied slowly,"
    },
    {
      "start": 468.66,
      "end": 469.86,
      "text": "working his brows together."
    },
    {
      "start": 470.44,
      "end": 472.0,
      "text": "The shot burned his coat."
    },
    {
      "start": 473.18,
      "end": 473.82,
      "text": "Who found him?",
      "para_break": true
    },
    {
      "start": 474.54,
      "end": 475.72,
      "text": "The man on the beat,"
    },
    {
      "start": 475.88,
      "end": 476.18,
      "text": "Schilling."
    },
    {
      "start": 476.8,
      "end": 478.02,
      "text": "He was coming down Bush,"
    },
    {
      "start": 478.3,
      "end": 479.52,
      "text": "and just as he got here,"
    },
    {
      "start": 479.88,
      "end": 481.68,
      "text": "a machine turning around threw headlights"
    },
    {
      "start": 481.68,
      "end": 483.82,
      "text": "up here and he saw the top rail off."
    },
    {
      "start": 484.44,
      "end": 485.88,
      "text": "So he came up and found him."
    },
    {
      "start": 487.36,
      "end": 489.1,
      "text": "What about the machine that was turning around?",
      "para_break": true
    },
    {
      "start": 490.28,
      "end": 491.4,
      "text": "Not a damn thing about it,",
      "para_break": true
    },
    {
      "start": 491.48,
      "end": 491.64,
      "text": "Sam."
    }
  ]
}
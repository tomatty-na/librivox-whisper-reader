{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-06",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_06_hammett.mp3",
  "chapter_title": "Chapter 6 - The Undersized Shadow",
  "reader_name": "Mark Nelson",
  "page_num": 5,
  "page_total": 5,
  "page_start_sec": 981.74,
  "page_end_sec": 1048.12,
  "para_gap_threshold": 0.735,
  "segments": [
    {
      "start": 981.74,
      "end": 983.78,
      "text": "Do you mean I oughtn't chase after you?"
    },
    {
      "start": 984.54,
      "end": 985.46,
      "text": "If that's what you mean,",
      "para_break": true
    },
    {
      "start": 985.62,
      "end": 987.34,
      "text": "why don't you say it right out?"
    },
    {
      "start": 988.54,
      "end": 988.78,
      "text": "Now,",
      "para_break": true
    },
    {
      "start": 988.8,
      "end": 989.14,
      "text": "Iva,"
    },
    {
      "start": 989.16,
      "end": 991.14,
      "text": "you've got no right to take that attitude."
    },
    {
      "start": 992.22,
      "end": 993.34,
      "text": "I know I haven't.",
      "para_break": true
    },
    {
      "start": 993.84,
      "end": 995.16,
      "text": "I haven't any rights at all,"
    },
    {
      "start": 995.18,
      "end": 995.56,
      "text": "it seems,"
    },
    {
      "start": 995.68,
      "end": 996.48,
      "text": "where you're concerned."
    },
    {
      "start": 997.04,
      "end": 998.08,
      "text": "I thought I did."
    },
    {
      "start": 998.32,
      "end": 1001.38,
      "text": "I thought your pretending to love me gave me some right,"
    },
    {
      "start": 1001.54,
      "end": 1003.46,
      "text": "but--\" Spade said wearily."
    },
    {
      "start": 1004.38,
      "end": 1006.46,
      "text": "\"'This is no time to be arguing about that,",
      "para_break": true
    },
    {
      "start": 1006.52,
      "end": 1006.8,
      "text": "precious."
    },
    {
      "start": 1007.27,
      "end": 1009.472,
      "text": "What was it you wanted to see me about?'"
    },
    {
      "start": 1009.96,
      "end": 1011.32,
      "text": "\"'I can't talk to you here,"
    },
    {
      "start": 1011.48,
      "end": 1011.7,
      "text": "Sam."
    },
    {
      "start": 1011.92,
      "end": 1013.14,
      "text": "Can't I come in?'"
    },
    {
      "start": 1013.84,
      "end": 1014.54,
      "text": "\"'Not now.'"
    },
    {
      "start": 1015.456,
      "end": 1016.34,
      "text": "\"'Why can't I?'",
      "para_break": true
    },
    {
      "start": 1017.28,
      "end": 1018.08,
      "text": "Spade said nothing.",
      "para_break": true
    },
    {
      "start": 1019.2,
      "end": 1020.86,
      "text": "She made a thin line of her mouth,",
      "para_break": true
    },
    {
      "start": 1021.1,
      "end": 1023.02,
      "text": "squirmed around straight behind the wheel,"
    },
    {
      "start": 1023.26,
      "end": 1024.36,
      "text": "and started the engine,"
    },
    {
      "start": 1024.56,
      "end": 1025.82,
      "text": "staring angrily ahead."
    },
    {
      "start": 1027.28,
      "end": 1028.7,
      "text": "When the sedan began to move,",
      "para_break": true
    },
    {
      "start": 1028.92,
      "end": 1029.66,
      "text": "Spade said,"
    },
    {
      "start": 1030.38,
      "end": 1030.76,
      "text": "\"'Good night,"
    },
    {
      "start": 1030.84,
      "end": 1032.48,
      "text": "Iva,' closed the door,"
    },
    {
      "start": 1032.62,
      "end": 1034.12,
      "text": "and stood at the curb with his"
    },
    {
      "start": 1034.2,
      "end": 1036.32,
      "text": "hat in his hand until it had been driven away."
    },
    {
      "start": 1037.46,
      "end": 1038.34,
      "text": "Then he went indoors",
      "para_break": true
    },
    {
      "start": 1038.48,
      "end": 1038.82,
      "text": "again."
    },
    {
      "start": 1040.128,
      "end": 1043.52,
      "text": "Bridget O'Shaughnessy rose smiling cheerfully from the bench and they",
      "para_break": true
    },
    {
      "start": 1043.56,
      "end": 1044.4,
      "text": "went up to his apartment."
    },
    {
      "start": 1047.28,
      "end": 1048.12,
      "text": "End of chapter 6",
      "para_break": true
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-03",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_03_hammett.mp3",
  "chapter_title": "Chapter 3 - Three Women",
  "reader_name": "Mark Nelson",
  "page_num": 2,
  "page_total": 4,
  "page_start_sec": 255.54,
  "page_end_sec": 497.04,
  "para_gap_threshold": 0.755,
  "segments": [
    {
      "start": 255.54,
      "end": 256.76,
      "text": "\"'Be kind to me,",
      "para_break": true
    },
    {
      "start": 256.86,
      "end": 257.36,
      "text": "Sam,'"
    },
    {
      "start": 258.0,
      "end": 258.84,
      "text": "she said humbly."
    },
    {
      "start": 259.24,
      "end": 260.82,
      "text": "He laughed at her,"
    },
    {
      "start": 260.92,
      "end": 262.4,
      "text": "his eyes still glittering."
    },
    {
      "start": 263.38,
      "end": 264.38,
      "text": "\"'You killed my husband,",
      "para_break": true
    },
    {
      "start": 264.54,
      "end": 264.84,
      "text": "Sam."
    },
    {
      "start": 265.44,
      "end": 266.62,
      "text": "Be kind to me.'"
    },
    {
      "start": 267.16,
      "end": 269.32,
      "text": "He clapped his palms together and said,"
    },
    {
      "start": 270.144,
      "end": 271.2,
      "text": "\"'Great God!'",
      "para_break": true
    },
    {
      "start": 272.3,
      "end": 273.76,
      "text": "She began to cry audibly,",
      "para_break": true
    },
    {
      "start": 273.98,
      "end": 276.12,
      "text": "holding a white handkerchief to her face."
    },
    {
      "start": 276.72,
      "end": 279.08,
      "text": "He got up and stood close behind her."
    },
    {
      "start": 279.28,
      "end": 281.18,
      "text": "He put his arms around her."
    },
    {
      "start": 281.82,
      "end": 284.1,
      "text": "He kissed her neck between ear and coat collar."
    },
    {
      "start": 284.6,
      "end": 285.02,
      "text": "He said,"
    },
    {
      "start": 285.48,
      "end": 286.44,
      "text": "Now,"
    },
    {
      "start": 286.5,
      "end": 286.88,
      "text": "Iva,"
    },
    {
      "start": 286.9,
      "end": 287.46,
      "text": "don't."
    },
    {
      "start": 288.32,
      "end": 289.82,
      "text": "His face was expressionless.",
      "para_break": true
    },
    {
      "start": 291.34,
      "end": 292.32,
      "text": "When she had stopped crying,",
      "para_break": true
    },
    {
      "start": 292.52,
      "end": 294.54,
      "text": "he put his mouth to her ear and murmured,"
    },
    {
      "start": 295.06,
      "end": 296.7,
      "text": "You shouldn't have come here today,"
    },
    {
      "start": 296.84,
      "end": 297.1,
      "text": "precious."
    },
    {
      "start": 297.82,
      "end": 298.46,
      "text": "It wasn't wise."
    },
    {
      "start": 299.1,
      "end": 300.0,
      "text": "You can't stay."
    },
    {
      "start": 300.78,
      "end": 301.5,
      "text": "You ought to be home.",
      "para_break": true
    },
    {
      "start": 302.9,
      "end": 304.82,
      "text": "She turned around in his arms to face him,",
      "para_break": true
    },
    {
      "start": 304.88,
      "end": 305.18,
      "text": "asking,"
    },
    {
      "start": 306.18,
      "end": 306.68,
      "text": "You'll come tonight?",
      "para_break": true
    },
    {
      "start": 307.33,
      "end": 309.22,
      "text": "He shook his head gently."
    },
    {
      "start": 310.24,
      "end": 310.66,
      "text": "Not tonight.",
      "para_break": true
    },
    {
      "start": 311.42,
      "end": 312.1,
      "text": "Soon?",
      "para_break": true
    },
    {
      "start": 312.82,
      "end": 313.26,
      "text": "Soon."
    },
    {
      "start": 314.3,
      "end": 314.84,
      "text": "How soon?",
      "para_break": true
    },
    {
      "start": 316.04,
      "end": 316.98,
      "text": "As soon as I can.",
      "para_break": true
    },
    {
      "start": 317.6,
      "end": 318.94,
      "text": "He kissed her mouth,"
    },
    {
      "start": 319.16,
      "end": 320.06,
      "text": "led her to the door,"
    },
    {
      "start": 320.18,
      "end": 320.78,
      "text": "opened it,"
    },
    {
      "start": 320.86,
      "end": 321.74,
      "text": "said goodbye,"
    },
    {
      "start": 321.96,
      "end": 322.18,
      "text": "Iva,"
    },
    {
      "start": 322.32,
      "end": 323.18,
      "text": "bowed,"
    },
    {
      "start": 323.18,
      "end": 323.88,
      "text": "shut the door,"
    },
    {
      "start": 323.92,
      "end": 325.12,
      "text": "and returned to his desk."
    },
    {
      "start": 325.98,
      "end": 329.08,
      "text": "He took tobacco and cigarette papers from his vest pockets,",
      "para_break": true
    },
    {
      "start": 329.26,
      "end": 330.54,
      "text": "but did not roll a cigarette."
    },
    {
      "start": 331.03,
      "end": 333.64,
      "text": "He sat holding the papers in one hand,"
    },
    {
      "start": 333.72,
      "end": 334.82,
      "text": "the tobacco in the other,"
    },
    {
      "start": 334.94,
      "end": 338.06,
      "text": "and looked with brooding eyes at his dead partner's desk."
    },
    {
      "start": 339.936,
      "end": 341.84,
      "text": "Effie Perrine opened the door and came in.",
      "para_break": true
    },
    {
      "start": 342.32,
      "end": 343.96,
      "text": "Her brown eyes were uneasy."
    },
    {
      "start": 344.76,
      "end": 345.92,
      "text": "Her voice was careless.",
      "para_break": true
    },
    {
      "start": 346.62,
      "end": 347.02,
      "text": "She asked,"
    },
    {
      "start": 347.58,
      "end": 347.94,
      "text": "Well?"
    },
    {
      "start": 349.152,
      "end": 350.06,
      "text": "Spade said nothing.",
      "para_break": true
    },
    {
      "start": 350.9,
      "end": 353.7,
      "text": "His brooding gaze did not move from his partner's desk.",
      "para_break": true
    },
    {
      "start": 354.6,
      "end": 356.58,
      "text": "The girl frowned and came around to his side.",
      "para_break": true
    },
    {
      "start": 357.62,
      "end": 357.98,
      "text": "Well?",
      "para_break": true
    },
    {
      "start": 358.66,
      "end": 359.92,
      "text": "She asked in a louder voice."
    },
    {
      "start": 360.8,
      "end": 362.64,
      "text": "How did you and the widow make out?'",
      "para_break": true
    },
    {
      "start": 364.16,
      "end": 366.8,
      "text": "\"'She thinks I shot Miles,' he said,",
      "para_break": true
    },
    {
      "start": 366.98,
      "end": 368.16,
      "text": "only his lips moving."
    },
    {
      "start": 369.472,
      "end": 370.784,
      "text": "\"'So you can marry her?'",
      "para_break": true
    },
    {
      "start": 371.68,
      "end": 373.16,
      "text": "Spade made no reply to that.",
      "para_break": true
    },
    {
      "start": 374.56,
      "end": 377.3,
      "text": "The girl took his hat from his head and put it on the desk,",
      "para_break": true
    },
    {
      "start": 377.44,
      "end": 379.1,
      "text": "then leaned over and took"
    },
    {
      "start": 379.1,
      "end": 381.9,
      "text": "the tobacco sack and the papers from his inert fingers."
    },
    {
      "start": 383.74,
      "end": 386.22,
      "text": "\"'The police think I shot Thursby,' he said.",
      "para_break": true
    },
    {
      "start": 387.34,
      "end": 388.84,
      "text": "\"'Who is he?' she asked,",
      "para_break": true
    },
    {
      "start": 388.94,
      "end": 390.62,
      "text": "separating a paper from the packet,"
    },
    {
      "start": 390.78,
      "end": 392.08,
      "text": "sifting tobacco into it."
    },
    {
      "start": 393.18,
      "end": 395.6,
      "text": "\"'Who do you think I shot?' he asked.",
      "para_break": true
    },
    {
      "start": 396.8,
      "end": 397.94,
      "text": "When she ignored the question,",
      "para_break": true
    },
    {
      "start": 398.08,
      "end": 398.5,
      "text": "he said,"
    },
    {
      "start": 399.648,
      "end": 401.22,
      "text": "\"'There's the piece the guy Miles was supposed",
      "para_break": true
    },
    {
      "start": 401.22,
      "end": 403.28,
      "text": "to be shadowing for the Wonderly Girl.'"
    },
    {
      "start": 403.9,
      "end": 406.36,
      "text": "Her thin fingers finished shaping the cigarette."
    },
    {
      "start": 406.71,
      "end": 407.78,
      "text": "She licked it,"
    },
    {
      "start": 407.88,
      "end": 408.58,
      "text": "smoothed it,"
    },
    {
      "start": 408.864,
      "end": 409.54,
      "text": "twisted the ends,"
    },
    {
      "start": 409.64,
      "end": 411.26,
      "text": "and placed it between Spade's lips."
    },
    {
      "start": 411.46,
      "end": 413.02,
      "text": "He said,"
    },
    {
      "start": 413.48,
      "end": 414.08,
      "text": "\"'Thanks,"
    },
    {
      "start": 414.16,
      "end": 414.54,
      "text": "honey.'"
    },
    {
      "start": 415.04,
      "end": 416.98,
      "text": "Put an arm around her slim waist and"
    },
    {
      "start": 416.98,
      "end": 418.94,
      "text": "rested his cheek wearily against her hip,"
    },
    {
      "start": 419.16,
      "end": 420.0,
      "text": "shutting his eyes."
    },
    {
      "start": 422.14,
      "end": 424.16,
      "text": "\"'Are you going to marry Iva?' she asked,",
      "para_break": true
    },
    {
      "start": 424.26,
      "end": 426.1,
      "text": "looking down at his pale brown hair."
    },
    {
      "start": 427.22,
      "end": 428.82,
      "text": "\"'Don't be silly,' he muttered.",
      "para_break": true
    },
    {
      "start": 429.86,
      "end": 431.54,
      "text": "The unlighted cigarette bobbed up and",
      "para_break": true
    },
    {
      "start": 431.54,
      "end": 433.1,
      "text": "down with the movement of his lips."
    },
    {
      "start": 434.368,
      "end": 435.5,
      "text": "\"'She doesn't think it's silly.",
      "para_break": true
    },
    {
      "start": 436.16,
      "end": 436.82,
      "text": "Why should she,"
    },
    {
      "start": 436.9,
      "end": 438.624,
      "text": "the way you played around with her?'"
    },
    {
      "start": 439.1,
      "end": 440.74,
      "text": "He sighed and said,"
    },
    {
      "start": 440.99,
      "end": 443.64,
      "text": "I wish to God I'd never seen her."
    },
    {
      "start": 445.088,
      "end": 445.92,
      "text": "Maybe you do now.",
      "para_break": true
    },
    {
      "start": 446.66,
      "end": 449.64,
      "text": "A trace of spitefulness came into the girl's voice."
    },
    {
      "start": 450.592,
      "end": 451.62,
      "text": "But there was a time.",
      "para_break": true
    },
    {
      "start": 452.64,
      "end": 456.4,
      "text": "I never know what to do or say to women except that way,",
      "para_break": true
    },
    {
      "start": 457.18,
      "end": 457.6,
      "text": "he grumbled,",
      "para_break": true
    },
    {
      "start": 458.14,
      "end": 460.04,
      "text": "and then I didn't like Miles."
    },
    {
      "start": 461.536,
      "end": 462.06,
      "text": "That's a lie,",
      "para_break": true
    },
    {
      "start": 462.2,
      "end": 462.44,
      "text": "Sam,"
    },
    {
      "start": 462.7,
      "end": 463.78,
      "text": "the girl said."
    },
    {
      "start": 465.1,
      "end": 466.64,
      "text": "You know I think she's a louse,",
      "para_break": true
    },
    {
      "start": 467.2,
      "end": 470.02,
      "text": "but I'd be a louse too if I could have a body like that."
    },
    {
      "start": 471.584,
      "end": 474.08,
      "text": "Spade rubbed his face impatiently against her hip,",
      "para_break": true
    },
    {
      "start": 474.16,
      "end": 475.08,
      "text": "but said nothing."
    },
    {
      "start": 476.48,
      "end": 477.98,
      "text": "Effie Perrine bit her lower lip,",
      "para_break": true
    },
    {
      "start": 478.304,
      "end": 479.02,
      "text": "wrinkled her forehead,"
    },
    {
      "start": 479.24,
      "end": 479.96,
      "text": "and bending"
    },
    {
      "start": 480.06,
      "end": 481.76,
      "text": "down for a better view of his face,"
    },
    {
      "start": 481.88,
      "end": 482.2,
      "text": "asked,"
    },
    {
      "start": 482.64,
      "end": 485.12,
      "text": "\"'Do you suppose she could have killed him?'"
    },
    {
      "start": 486.56,
      "end": 489.2,
      "text": "Spade sat up straight and took his arm from her waist.",
      "para_break": true
    },
    {
      "start": 490.14,
      "end": 490.88,
      "text": "He smiled at",
      "para_break": true
    },
    {
      "start": 490.88,
      "end": 491.06,
      "text": "her."
    },
    {
      "start": 491.76,
      "end": 493.36,
      "text": "His smile held nothing but amusement."
    },
    {
      "start": 493.88,
      "end": 495.26,
      "text": "He took out his lighter,"
    },
    {
      "start": 495.64,
      "end": 496.32,
      "text": "snapped it on,"
    },
    {
      "start": 496.36,
      "end": 497.04,
      "text": "and lit a cigarette."
    }
  ]
}
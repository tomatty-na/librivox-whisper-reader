{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-20",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_20_hammett.mp3",
  "chapter_title": "Chapter 20 - If They Hang You",
  "reader_name": "Mark Nelson",
  "page_num": 7,
  "page_total": 7,
  "page_start_sec": 1466.66,
  "page_end_sec": 1542.52,
  "para_gap_threshold": 0.648,
  "segments": [
    {
      "start": 1466.66,
      "end": 1467.34,
      "text": "You did that,",
      "para_break": true
    },
    {
      "start": 1467.52,
      "end": 1467.86,
      "text": "Sam,"
    },
    {
      "start": 1468.04,
      "end": 1468.54,
      "text": "to her?"
    },
    {
      "start": 1469.84,
      "end": 1470.36,
      "text": "He nodded.",
      "para_break": true
    },
    {
      "start": 1471.264,
      "end": 1472.2,
      "text": "You're Sam's a detective.",
      "para_break": true
    },
    {
      "start": 1472.44,
      "end": 1472.46,
      "text": "active."
    },
    {
      "start": 1473.08,
      "end": 1474.72,
      "text": "He looked sharply at her."
    },
    {
      "start": 1475.0,
      "end": 1476.96,
      "text": "He put his arm around her waist,"
    },
    {
      "start": 1477.08,
      "end": 1477.98,
      "text": "his hand on her hip."
    },
    {
      "start": 1479.3,
      "end": 1480.44,
      "text": "She did kill Miles,",
      "para_break": true
    },
    {
      "start": 1480.58,
      "end": 1480.78,
      "text": "Angel,"
    },
    {
      "start": 1480.94,
      "end": 1482.2,
      "text": "he said gently."
    },
    {
      "start": 1482.47,
      "end": 1483.52,
      "text": "Offhand,"
    },
    {
      "start": 1483.66,
      "end": 1484.32,
      "text": "like that."
    },
    {
      "start": 1485.12,
      "end": 1486.12,
      "text": "He snapped fingers of",
      "para_break": true
    },
    {
      "start": 1486.12,
      "end": 1486.74,
      "text": "his other hand."
    },
    {
      "start": 1488.08,
      "end": 1491.08,
      "text": "She moved away from his encircling arm as if it had hurt her.",
      "para_break": true
    },
    {
      "start": 1492.0,
      "end": 1492.6,
      "text": "Don't,",
      "para_break": true
    },
    {
      "start": 1492.6,
      "end": 1492.88,
      "text": "please,"
    },
    {
      "start": 1493.08,
      "end": 1494.06,
      "text": "don't touch me,"
    },
    {
      "start": 1494.18,
      "end": 1495.54,
      "text": "she said brokenly."
    },
    {
      "start": 1496.12,
      "end": 1496.52,
      "text": "I know,"
    },
    {
      "start": 1496.72,
      "end": 1497.88,
      "text": "I know you're right,"
    },
    {
      "start": 1498.06,
      "end": 1499.0,
      "text": "you're right,"
    },
    {
      "start": 1499.9,
      "end": 1500.66,
      "text": "don't touch me now,",
      "para_break": true
    },
    {
      "start": 1500.86,
      "end": 1501.83,
      "text": "not now.\""
    },
    {
      "start": 1503.488,
      "end": 1505.64,
      "text": "Spade's face became pale as his collar.",
      "para_break": true
    },
    {
      "start": 1506.0,
      "end": 1508.36,
      "text": "The corridor door's knob rattled."
    },
    {
      "start": 1509.088,
      "end": 1509.58,
      "text": "Effie Perrine",
      "para_break": true
    },
    {
      "start": 1509.58,
      "end": 1511.62,
      "text": "turned quickly and went into the outer office,"
    },
    {
      "start": 1511.82,
      "end": 1513.02,
      "text": "shutting the door behind her."
    },
    {
      "start": 1514.08,
      "end": 1514.6,
      "text": "When she came",
      "para_break": true
    },
    {
      "start": 1514.6,
      "end": 1516.36,
      "text": "in again she shut it behind her."
    },
    {
      "start": 1517.5,
      "end": 1518.54,
      "text": "She said in a small,",
      "para_break": true
    },
    {
      "start": 1518.68,
      "end": 1519.28,
      "text": "flat voice,"
    },
    {
      "start": 1520.736,
      "end": 1521.54,
      "text": "\"'Iva is here.'",
      "para_break": true
    },
    {
      "start": 1522.25,
      "end": 1523.0,
      "text": "Spade,",
      "para_break": true
    },
    {
      "start": 1523.12,
      "end": 1524.44,
      "text": "looking down at his desk,"
    },
    {
      "start": 1524.56,
      "end": 1526.05,
      "text": "nodded almost imperceptibly."
    },
    {
      "start": 1527.01,
      "end": 1529.82,
      "text": "\"'Yes,' he said and shivered.",
      "para_break": true
    },
    {
      "start": 1530.34,
      "end": 1530.86,
      "text": "\"'Iva."
    },
    {
      "start": 1530.98,
      "end": 1531.104,
      "text": "Well,"
    },
    {
      "start": 1532.06,
      "end": 1533.28,
      "text": "send her in.'\"",
      "para_break": true
    },
    {
      "start": 1536.096,
      "end": 1537.23,
      "text": "End of Chapter 20",
      "para_break": true
    },
    {
      "start": 1539.2,
      "end": 1542.52,
      "text": "The End of The Maltese Falcon by Dashiell Hammett",
      "para_break": true
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-09",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_09_hammett.mp3",
  "chapter_title": "Chapter 9 - The Liar",
  "reader_name": "Mark Nelson",
  "page_num": 1,
  "page_total": 4,
  "page_start_sec": 8.13,
  "page_end_sec": 248.18,
  "para_gap_threshold": 0.742,
  "segments": [
    {
      "start": 8.13,
      "end": 10.04,
      "text": "CHAPTER IX."
    },
    {
      "start": 10.06,
      "end": 11.08,
      "text": "THE LIAR"
    },
    {
      "start": 13.696,
      "end": 17.02,
      "text": "Spade returned to the living-room and sat on an end of the sofa,",
      "para_break": true
    },
    {
      "start": 17.26,
      "end": 18.48,
      "text": "elbows on knees,"
    },
    {
      "start": 18.74,
      "end": 19.72,
      "text": "cheeks in hands,"
    },
    {
      "start": 20.416,
      "end": 22.98,
      "text": "looking at the floor and nodded Bridget O'Shaughnessy,"
    },
    {
      "start": 23.33,
      "end": 24.94,
      "text": "smiling weakly at him from the"
    },
    {
      "start": 25.14,
      "end": 25.36,
      "text": "armchair."
    },
    {
      "start": 26.52,
      "end": 27.58,
      "text": "His eyes were sultry.",
      "para_break": true
    },
    {
      "start": 27.8,
      "end": 30.88,
      "text": "The creases between brows above his nose were deep."
    },
    {
      "start": 31.2,
      "end": 31.76,
      "text": "His"
    },
    {
      "start": 31.86,
      "end": 33.84,
      "text": "nostrils moved in and out with his breathing."
    },
    {
      "start": 35.392,
      "end": 36.26,
      "text": "Bridget O'Shaughnessy,",
      "para_break": true
    },
    {
      "start": 36.38,
      "end": 37.44,
      "text": "when it became apparent"
    },
    {
      "start": 37.44,
      "end": 39.14,
      "text": "that he was not going to look up at her,"
    },
    {
      "start": 39.28,
      "end": 42.37,
      "text": "stopped smiling and regarded him with some uneasiness."
    },
    {
      "start": 44.032,
      "end": 46.14,
      "text": "Red rage came suddenly into his face,",
      "para_break": true
    },
    {
      "start": 46.26,
      "end": 48.2,
      "text": "and he began to talk in a harsh,"
    },
    {
      "start": 48.36,
      "end": 49.02,
      "text": "guttural voice."
    },
    {
      "start": 49.8,
      "end": 52.26,
      "text": "Holding his maddened face in his hands,",
      "para_break": true
    },
    {
      "start": 52.4,
      "end": 53.36,
      "text": "glaring at the floor,"
    },
    {
      "start": 53.56,
      "end": 55.66,
      "text": "he cursed Dundee for five minutes"
    },
    {
      "start": 55.76,
      "end": 56.36,
      "text": "without break,"
    },
    {
      "start": 56.6,
      "end": 58.0,
      "text": "cursed him obscenely,"
    },
    {
      "start": 58.08,
      "end": 59.12,
      "text": "blasphemously,"
    },
    {
      "start": 59.38,
      "end": 60.26,
      "text": "repetitiously,"
    },
    {
      "start": 60.56,
      "end": 61.22,
      "text": "in a harsh,"
    },
    {
      "start": 61.36,
      "end": 62.12,
      "text": "guttural voice."
    },
    {
      "start": 64.08,
      "end": 65.82,
      "text": "Then he took his face out of his hands,",
      "para_break": true
    },
    {
      "start": 66.0,
      "end": 66.88,
      "text": "looked at the girl,"
    },
    {
      "start": 67.08,
      "end": 68.36,
      "text": "grinned sheepishly,"
    },
    {
      "start": 68.36,
      "end": 68.72,
      "text": "and said,"
    },
    {
      "start": 69.59,
      "end": 70.34,
      "text": "\"'Childish,",
      "para_break": true
    },
    {
      "start": 70.34,
      "end": 70.5,
      "text": "huh?"
    },
    {
      "start": 70.64,
      "end": 71.62,
      "text": "I know."
    },
    {
      "start": 71.82,
      "end": 72.3,
      "text": "But,"
    },
    {
      "start": 72.36,
      "end": 72.78,
      "text": "by God,"
    },
    {
      "start": 73.32,
      "end": 75.58,
      "text": "I do hate being hit without hitting back.'"
    },
    {
      "start": 75.6,
      "end": 75.68,
      "text": "back."
    },
    {
      "start": 76.3,
      "end": 79.0,
      "text": "He touched his chin with careful fingers."
    },
    {
      "start": 80.5,
      "end": 82.44,
      "text": "Not that it was so much of a sock at that.",
      "para_break": true
    },
    {
      "start": 83.392,
      "end": 84.76,
      "text": "He laughed and lounged back",
      "para_break": true
    },
    {
      "start": 84.76,
      "end": 85.42,
      "text": "on the sofa,"
    },
    {
      "start": 85.56,
      "end": 86.58,
      "text": "crossing his legs."
    },
    {
      "start": 87.41,
      "end": 89.84,
      "text": "A cheap enough price to pay for winning.",
      "para_break": true
    },
    {
      "start": 90.98,
      "end": 93.2,
      "text": "His brows drew together in a fleeting frown.",
      "para_break": true
    },
    {
      "start": 94.24,
      "end": 95.7,
      "text": "Though I won't forget it.",
      "para_break": true
    },
    {
      "start": 96.88,
      "end": 97.36,
      "text": "The girl,",
      "para_break": true
    },
    {
      "start": 97.48,
      "end": 98.42,
      "text": "smiling again,"
    },
    {
      "start": 98.72,
      "end": 101.32,
      "text": "left her chair and sat on the sofa beside him."
    },
    {
      "start": 102.78,
      "end": 106.34,
      "text": "\"'You're absolutely the wildest person I've ever known,' she said.",
      "para_break": true
    },
    {
      "start": 107.22,
      "end": 109.472,
      "text": "\"'Do you always carry on so high-handed?'",
      "para_break": true
    },
    {
      "start": 110.48,
      "end": 111.24,
      "text": "\"'I let him hit me,",
      "para_break": true
    },
    {
      "start": 111.3,
      "end": 111.8,
      "text": "didn't I?'"
    },
    {
      "start": 112.58,
      "end": 112.84,
      "text": "\"'Oh,",
      "para_break": true
    },
    {
      "start": 112.84,
      "end": 113.08,
      "text": "yes,"
    },
    {
      "start": 113.12,
      "end": 114.43,
      "text": "but a police official.'"
    },
    {
      "start": 115.4,
      "end": 117.5,
      "text": "\"'It wasn't that,' Spade explained.",
      "para_break": true
    },
    {
      "start": 118.52,
      "end": 120.24,
      "text": "\"'It was that in losing his head and",
      "para_break": true
    },
    {
      "start": 120.24,
      "end": 122.3,
      "text": "slugging me he overplayed his hand."
    },
    {
      "start": 123.14,
      "end": 125.76,
      "text": "If I'd mixed it up with him he couldn't have backed down.",
      "para_break": true
    },
    {
      "start": 126.74,
      "end": 128.6,
      "text": "He'd have had to go through with it and we'd have",
      "para_break": true
    },
    {
      "start": 128.6,
      "end": 130.63,
      "text": "had to tell that goofy story at headquarters.'"
    },
    {
      "start": 131.7,
      "end": 133.34,
      "text": "He stared thoughtfully at the girl,",
      "para_break": true
    },
    {
      "start": 133.42,
      "end": 134.22,
      "text": "and then asked,"
    },
    {
      "start": 134.87,
      "end": 136.75,
      "text": "\"'What did you do to Cairo?'"
    },
    {
      "start": 137.18,
      "end": 138.36,
      "text": "\"'Nothing.'"
    },
    {
      "start": 138.7,
      "end": 140.12,
      "text": "Her face flushed."
    },
    {
      "start": 140.94,
      "end": 143.64,
      "text": "\"'I tried to frighten him into keeping quiet until they had gone,",
      "para_break": true
    },
    {
      "start": 143.98,
      "end": 146.86,
      "text": "and he either got too frightened or stubborn and yelled."
    },
    {
      "start": 148.22,
      "end": 149.78,
      "text": "\"'And then you beamed him with a gun?'",
      "para_break": true
    },
    {
      "start": 150.62,
      "end": 151.18,
      "text": "\"'I had to.",
      "para_break": true
    },
    {
      "start": 151.72,
      "end": 152.72,
      "text": "He attacked me.'"
    },
    {
      "start": 154.08,
      "end": 155.41,
      "text": "\"'You don't know what you're doing.'",
      "para_break": true
    },
    {
      "start": 156.256,
      "end": 159.42,
      "text": "Spade's smile did not quite succeed in concealing annoyance.",
      "para_break": true
    },
    {
      "start": 160.8,
      "end": 162.1,
      "text": "It's just what I told you.",
      "para_break": true
    },
    {
      "start": 162.28,
      "end": 165.2,
      "text": "You're fumbling along by guess and by God."
    },
    {
      "start": 166.9,
      "end": 167.28,
      "text": "I'm sorry,",
      "para_break": true
    },
    {
      "start": 167.5,
      "end": 168.44,
      "text": "she said,"
    },
    {
      "start": 168.56,
      "end": 170.48,
      "text": "face and voice soft with contrition."
    },
    {
      "start": 170.68,
      "end": 170.78,
      "text": "Sam?"
    },
    {
      "start": 172.928,
      "end": 173.48,
      "text": "Sure you are,",
      "para_break": true
    },
    {
      "start": 173.6,
      "end": 174.4,
      "text": "he said,"
    },
    {
      "start": 174.48,
      "end": 175.96,
      "text": "no longer showing annoyance."
    },
    {
      "start": 176.864,
      "end": 178.5,
      "text": "He took tobacco and papers from his",
      "para_break": true
    },
    {
      "start": 178.5,
      "end": 180.08,
      "text": "pocket and began to make a cigarette."
    },
    {
      "start": 181.78,
      "end": 183.24,
      "text": "Now you've had your talk with Cairo.",
      "para_break": true
    },
    {
      "start": 183.42,
      "end": 184.96,
      "text": "Now you can talk to me."
    },
    {
      "start": 186.4,
      "end": 188.04,
      "text": "She put a fingertip to her mouth,",
      "para_break": true
    },
    {
      "start": 188.2,
      "end": 191.02,
      "text": "staring across the room at nothing with widened eyes,"
    },
    {
      "start": 191.54,
      "end": 192.16,
      "text": "and then,"
    },
    {
      "start": 192.24,
      "end": 193.24,
      "text": "with narrower eyes,"
    },
    {
      "start": 193.42,
      "end": 194.94,
      "text": "glanced quickly at Spade."
    },
    {
      "start": 195.76,
      "end": 198.16,
      "text": "He was engrossed in the making of his cigarette.",
      "para_break": true
    },
    {
      "start": 199.46,
      "end": 200.14,
      "text": "\"'Oh,",
      "para_break": true
    },
    {
      "start": 200.22,
      "end": 201.32,
      "text": "yes,' she began."
    },
    {
      "start": 202.0,
      "end": 202.64,
      "text": "\"'Of course.'"
    },
    {
      "start": 203.78,
      "end": 205.48,
      "text": "She took the finger away from her mouth",
      "para_break": true
    },
    {
      "start": 205.48,
      "end": 207.48,
      "text": "and smoothed her blue dress over her knees."
    },
    {
      "start": 208.58,
      "end": 209.72,
      "text": "She frowned at her knees.",
      "para_break": true
    },
    {
      "start": 210.976,
      "end": 212.0,
      "text": "Spade licked his cigarette,",
      "para_break": true
    },
    {
      "start": 212.18,
      "end": 212.74,
      "text": "sealed it,"
    },
    {
      "start": 212.76,
      "end": 213.08,
      "text": "and asked,"
    },
    {
      "start": 213.68,
      "end": 214.28,
      "text": "Well,"
    },
    {
      "start": 214.56,
      "end": 215.38,
      "text": "well,"
    },
    {
      "start": 215.4,
      "end": 216.4,
      "text": "he felt for his lighter."
    },
    {
      "start": 218.32,
      "end": 219.82,
      "text": "But I didn't,",
      "para_break": true
    },
    {
      "start": 219.82,
      "end": 220.96,
      "text": "she said,"
    },
    {
      "start": 221.14,
      "end": 222.82,
      "text": "with short pauses between words,"
    },
    {
      "start": 222.88,
      "end": 225.08,
      "text": "as if she were selecting them with great care."
    },
    {
      "start": 226.56,
      "end": 228.72,
      "text": "Have time to finish talking to him.",
      "para_break": true
    },
    {
      "start": 229.8,
      "end": 232.84,
      "text": "She stopped frowning at her knees and looked at Spade with clear,",
      "para_break": true
    },
    {
      "start": 232.84,
      "end": 233.66,
      "text": "candid eyes."
    },
    {
      "start": 235.32,
      "end": 237.72,
      "text": "We were interrupted almost before we had begun.",
      "para_break": true
    },
    {
      "start": 239.36,
      "end": 242.36,
      "text": "Spade lighted his cigarette and laughed his mouth empty of smoke.",
      "para_break": true
    },
    {
      "start": 243.38,
      "end": 245.5,
      "text": "Want me to call him up and ask him to come back?\"",
      "para_break": true
    },
    {
      "start": 246.72,
      "end": 248.18,
      "text": "She shook her head without smiling.",
      "para_break": true
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-18",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_18_hammett.mp3",
  "chapter_title": "Chapter 18 - The Fall-Guy",
  "reader_name": "Mark Nelson",
  "page_num": 1,
  "page_total": 9,
  "page_start_sec": 9.09,
  "page_end_sec": 254.44,
  "para_gap_threshold": 0.691,
  "segments": [
    {
      "start": 9.09,
      "end": 10.56,
      "text": "CHAPTER XVIII."
    },
    {
      "start": 10.68,
      "end": 11.96,
      "text": "THE FALL GUY."
    },
    {
      "start": 13.55,
      "end": 14.3,
      "text": "Spade,",
      "para_break": true
    },
    {
      "start": 14.4,
      "end": 16.42,
      "text": "with his arms around Bridget O'Shaughnessy,"
    },
    {
      "start": 16.58,
      "end": 19.04,
      "text": "smiled meagerly over her head and said,"
    },
    {
      "start": 19.5,
      "end": 19.98,
      "text": "Sure,"
    },
    {
      "start": 20.24,
      "end": 20.94,
      "text": "we'll talk."
    },
    {
      "start": 22.176,
      "end": 23.98,
      "text": "Gutman's bulbs jounced as he took three",
      "para_break": true
    },
    {
      "start": 23.98,
      "end": 26.0,
      "text": "waddling backward steps away from the"
    },
    {
      "start": 26.12,
      "end": 26.22,
      "text": "door."
    },
    {
      "start": 27.424,
      "end": 28.74,
      "text": "Spade and the girl went in together.",
      "para_break": true
    },
    {
      "start": 29.7,
      "end": 31.34,
      "text": "The boy and Cairo followed them in.",
      "para_break": true
    },
    {
      "start": 32.192,
      "end": 32.74,
      "text": "Cairo stopped",
      "para_break": true
    },
    {
      "start": 32.74,
      "end": 33.36,
      "text": "in the doorway."
    },
    {
      "start": 33.92,
      "end": 37.78,
      "text": "The boy put away one of his pistols and came up close behind Spade."
    },
    {
      "start": 39.328,
      "end": 41.38,
      "text": "Spade turned his head far around to look",
      "para_break": true
    },
    {
      "start": 41.38,
      "end": 43.44,
      "text": "down over his shoulder at the boy and said,"
    },
    {
      "start": 44.28,
      "end": 44.64,
      "text": "Get away.",
      "para_break": true
    },
    {
      "start": 44.94,
      "end": 46.44,
      "text": "You're not going to frisk me."
    },
    {
      "start": 46.85,
      "end": 48.08,
      "text": "The boy said,"
    },
    {
      "start": 48.18,
      "end": 49.04,
      "text": "Shut up."
    },
    {
      "start": 49.16,
      "end": 49.92,
      "text": "Stand still."
    },
    {
      "start": 51.1,
      "end": 53.76,
      "text": "Spade's nostrils went in and out with his breathing.",
      "para_break": true
    },
    {
      "start": 54.36,
      "end": 55.5,
      "text": "His voice was level."
    },
    {
      "start": 56.672,
      "end": 57.06,
      "text": "Get away.",
      "para_break": true
    },
    {
      "start": 57.84,
      "end": 58.8,
      "text": "Put your paw on me,",
      "para_break": true
    },
    {
      "start": 58.9,
      "end": 60.68,
      "text": "and I'm going to make you use the gun."
    },
    {
      "start": 61.792,
      "end": 64.42,
      "text": "Ask your boss if he wants me shot up before we talk.",
      "para_break": true
    },
    {
      "start": 65.984,
      "end": 66.56,
      "text": "Never mind,",
      "para_break": true
    },
    {
      "start": 66.62,
      "end": 66.88,
      "text": "Wilmer,"
    },
    {
      "start": 67.64,
      "end": 68.5,
      "text": "the fat man said.",
      "para_break": true
    },
    {
      "start": 69.08,
      "end": 70.9,
      "text": "He frowned indulgently at Spade."
    },
    {
      "start": 72.26,
      "end": 74.46,
      "text": "You are certainly a most headstrong individual.",
      "para_break": true
    },
    {
      "start": 75.34,
      "end": 75.62,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 75.8,
      "end": 76.7,
      "text": "let's be seated."
    },
    {
      "start": 78.016,
      "end": 78.5,
      "text": "Spade said.",
      "para_break": true
    },
    {
      "start": 78.74,
      "end": 81.36,
      "text": "I told you I didn't like that punk,"
    },
    {
      "start": 82.12,
      "end": 84.62,
      "text": "and took Bridget O'Shaughnessy to the sofa by the windows.",
      "para_break": true
    },
    {
      "start": 85.2,
      "end": 86.54,
      "text": "They sat close together,"
    },
    {
      "start": 86.82,
      "end": 88.64,
      "text": "her head against his left shoulder,"
    },
    {
      "start": 88.8,
      "end": 90.68,
      "text": "his left arm around her shoulders."
    },
    {
      "start": 92.04,
      "end": 93.06,
      "text": "She had stopped trembling,",
      "para_break": true
    },
    {
      "start": 93.34,
      "end": 94.46,
      "text": "had stopped panting."
    },
    {
      "start": 95.3,
      "end": 96.98,
      "text": "The appearance of Gutman and his companions",
      "para_break": true
    },
    {
      "start": 97.36,
      "end": 99.54,
      "text": "seemed to have robbed her of that freedom of"
    },
    {
      "start": 99.54,
      "end": 102.0,
      "text": "personal movement and emotion which is animal,"
    },
    {
      "start": 102.42,
      "end": 103.38,
      "text": "leaving her alive,"
    },
    {
      "start": 103.6,
      "end": 104.06,
      "text": "conscious,"
    },
    {
      "start": 104.26,
      "end": 105.5,
      "text": "but quiescent as a plant."
    },
    {
      "start": 107.072,
      "end": 109.38,
      "text": "Gutman lowered himself into the padded rocking-chair.",
      "para_break": true
    },
    {
      "start": 110.304,
      "end": 111.98,
      "text": "Cairo chose the armchair by the table.",
      "para_break": true
    },
    {
      "start": 112.5,
      "end": 114.46,
      "text": "The boy Wilmer did not sit down."
    },
    {
      "start": 115.08,
      "end": 117.58,
      "text": "He stood in the doorway where Cairo had stood,"
    },
    {
      "start": 117.96,
      "end": 120.86,
      "text": "letting his one visible pistol hang down at his side,"
    },
    {
      "start": 121.472,
      "end": 123.96,
      "text": "looking under curling lashes at Spade's body."
    },
    {
      "start": 125.152,
      "end": 127.34,
      "text": "Cairo put his pistol on the table beside him.",
      "para_break": true
    },
    {
      "start": 128.736,
      "end": 131.62,
      "text": "Spade took off his hat and tossed it to the other end of the sofa.",
      "para_break": true
    },
    {
      "start": 132.72,
      "end": 133.7,
      "text": "He grinned at Gutman.",
      "para_break": true
    },
    {
      "start": 134.19,
      "end": 137.52,
      "text": "The looseness of his lower lip and the droop of his upper eyelids"
    },
    {
      "start": 137.72,
      "end": 141.84,
      "text": "combined with the V's in his face to make his grin lewd as a satyr's."
    },
    {
      "start": 143.74,
      "end": 146.32,
      "text": "\"'That daughter of yours has a nice belly,' he said.",
      "para_break": true
    },
    {
      "start": 147.2,
      "end": 149.17,
      "text": "\"'Too nice to be scratched up with pins.'",
      "para_break": true
    },
    {
      "start": 150.656,
      "end": 151.86,
      "text": "Gutman's smile was affable,",
      "para_break": true
    },
    {
      "start": 152.04,
      "end": 152.98,
      "text": "if a bit oily."
    },
    {
      "start": 154.1,
      "end": 156.18,
      "text": "The boy in the doorway took a short step forward,",
      "para_break": true
    },
    {
      "start": 156.608,
      "end": 158.68,
      "text": "raising his pistol as far as his hip."
    },
    {
      "start": 160.16,
      "end": 161.74,
      "text": "Everyone in the room looked at him.",
      "para_break": true
    },
    {
      "start": 162.54,
      "end": 164.6,
      "text": "In the dissimilar eyes with which Brigitte",
      "para_break": true
    },
    {
      "start": 164.66,
      "end": 166.78,
      "text": "O'Shaughnessy and Joel Cairo looked at him,"
    },
    {
      "start": 167.02,
      "end": 167.58,
      "text": "there was,"
    },
    {
      "start": 167.8,
      "end": 168.14,
      "text": "oddly,"
    },
    {
      "start": 168.3,
      "end": 170.04,
      "text": "something identically reproving."
    },
    {
      "start": 170.8,
      "end": 172.38,
      "text": "The boy blushed,",
      "para_break": true
    },
    {
      "start": 172.38,
      "end": 173.88,
      "text": "drew back his advanced foot,"
    },
    {
      "start": 174.08,
      "end": 175.26,
      "text": "straightened his legs,"
    },
    {
      "start": 175.4,
      "end": 176.26,
      "text": "lowered the pistol,"
    },
    {
      "start": 176.42,
      "end": 178.32,
      "text": "and stood as he had stood before,"
    },
    {
      "start": 178.64,
      "end": 182.24,
      "text": "looking under lashes that hid his eyes at Spade's chest."
    },
    {
      "start": 183.54,
      "end": 186.38,
      "text": "The blush was pale enough and lasted only an instant,",
      "para_break": true
    },
    {
      "start": 187.04,
      "end": 188.84,
      "text": "but it was startling on his face that"
    },
    {
      "start": 188.84,
      "end": 190.6,
      "text": "habitually was so cold and composed."
    },
    {
      "start": 192.352,
      "end": 195.06,
      "text": "Gutman turned his sleek-eyed fat smile on Spade again.",
      "para_break": true
    },
    {
      "start": 196.06,
      "end": 197.8,
      "text": "His voice was a suave purring.",
      "para_break": true
    },
    {
      "start": 198.92,
      "end": 199.62,
      "text": "\"'Yes,",
      "para_break": true
    },
    {
      "start": 199.62,
      "end": 199.88,
      "text": "sir,"
    },
    {
      "start": 199.96,
      "end": 201.26,
      "text": "that was a shame."
    },
    {
      "start": 201.84,
      "end": 205.216,
      "text": "But you must admit that it served its purpose pretty well.'"
    },
    {
      "start": 206.336,
      "end": 207.98,
      "text": "Spade's brows twitched together.",
      "para_break": true
    },
    {
      "start": 209.504,
      "end": 211.76,
      "text": "\"'Anything would have,' he said impatiently.",
      "para_break": true
    },
    {
      "start": 212.28,
      "end": 212.82,
      "text": "\"'Naturally."
    },
    {
      "start": 212.86,
      "end": 215.28,
      "text": "I wanted to see you as soon as I had the Falcon."
    },
    {
      "start": 215.68,
      "end": 216.72,
      "text": "Cash customers,"
    },
    {
      "start": 217.04,
      "end": 217.62,
      "text": "why not?'"
    },
    {
      "start": 217.64,
      "end": 217.72,
      "text": "that."
    },
    {
      "start": 218.29,
      "end": 221.56,
      "text": "I went to Burlingame expecting to run into this sort of meeting."
    },
    {
      "start": 222.32,
      "end": 223.02,
      "text": "I didn't know you",
      "para_break": true
    },
    {
      "start": 223.02,
      "end": 223.86,
      "text": "were blundering around,"
    },
    {
      "start": 224.1,
      "end": 224.92,
      "text": "half an hour late,"
    },
    {
      "start": 225.14,
      "end": 227.3,
      "text": "trying to get me out of the way so you could"
    },
    {
      "start": 227.42,
      "end": 229.856,
      "text": "find Jacobi again before he found me.\""
    },
    {
      "start": 231.104,
      "end": 231.74,
      "text": "Gutman chuckled.",
      "para_break": true
    },
    {
      "start": 232.42,
      "end": 234.58,
      "text": "His chuckles seemed to hold nothing but satisfaction."
    },
    {
      "start": 235.82,
      "end": 236.06,
      "text": "\"'Well,",
      "para_break": true
    },
    {
      "start": 236.1,
      "end": 237.26,
      "text": "sir,' he said,"
    },
    {
      "start": 237.34,
      "end": 238.36,
      "text": "\"'in any case,"
    },
    {
      "start": 238.42,
      "end": 239.16,
      "text": "here we are,"
    },
    {
      "start": 239.32,
      "end": 240.58,
      "text": "having our little meeting,"
    },
    {
      "start": 240.78,
      "end": 241.36,
      "text": "if that's"
    },
    {
      "start": 241.36,
      "end": 241.97,
      "text": "what you wanted.'"
    },
    {
      "start": 243.04,
      "end": 243.8,
      "text": "\"'That's what I wanted.",
      "para_break": true
    },
    {
      "start": 244.57,
      "end": 247.48,
      "text": "How soon are you ready to make your first payment and take the",
      "para_break": true
    },
    {
      "start": 247.5,
      "end": 248.8,
      "text": "bird off my hands.\""
    },
    {
      "start": 250.24,
      "end": 251.76,
      "text": "Bridget O'Shaughnessy sat up straight",
      "para_break": true
    },
    {
      "start": 251.76,
      "end": 253.58,
      "text": "and looked at Spade with surprised"
    },
    {
      "start": 253.66,
      "end": 254.44,
      "text": "blue eyes."
    }
  ]
}
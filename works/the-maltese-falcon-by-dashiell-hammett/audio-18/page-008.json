{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-18",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_18_hammett.mp3",
  "chapter_title": "Chapter 18 - The Fall-Guy",
  "reader_name": "Mark Nelson",
  "page_num": 8,
  "page_total": 9,
  "page_start_sec": 1715.264,
  "page_end_sec": 1958.14,
  "para_gap_threshold": 0.691,
  "segments": [
    {
      "start": 1715.264,
      "end": 1716.3,
      "text": "Spade addressed Gutman.",
      "para_break": true
    },
    {
      "start": 1717.02,
      "end": 1720.44,
      "text": "\"'I hope you're not letting yourself be influenced by the guns these",
      "para_break": true
    },
    {
      "start": 1720.54,
      "end": 1722.592,
      "text": "pocket-edition desperados are waving.'"
    },
    {
      "start": 1723.776,
      "end": 1724.82,
      "text": "Gutman opened his eyes.",
      "para_break": true
    },
    {
      "start": 1725.792,
      "end": 1729.18,
      "text": "Cairo stopped whispering and stood erect behind the fat man's chair.",
      "para_break": true
    },
    {
      "start": 1730.336,
      "end": 1731.0,
      "text": "Spade continued.",
      "para_break": true
    },
    {
      "start": 1732.38,
      "end": 1734.4,
      "text": "I've practiced taking them away from both of them,",
      "para_break": true
    },
    {
      "start": 1734.48,
      "end": 1735.36,
      "text": "so there'll be no"
    },
    {
      "start": 1735.44,
      "end": 1735.98,
      "text": "trouble there."
    },
    {
      "start": 1736.94,
      "end": 1737.62,
      "text": "The punk is—'",
      "para_break": true
    },
    {
      "start": 1738.34,
      "end": 1740.92,
      "text": "In a voice choked horribly with emotion the boy cried,",
      "para_break": true
    },
    {
      "start": 1741.92,
      "end": 1745.04,
      "text": "\"'All right,' and jerked his pistol up in front of his chest.",
      "para_break": true
    },
    {
      "start": 1746.208,
      "end": 1748.34,
      "text": "Gutman flung a fat hand out at the boy's wrist,",
      "para_break": true
    },
    {
      "start": 1748.5,
      "end": 1749.68,
      "text": "caught the wrist and"
    },
    {
      "start": 1749.78,
      "end": 1753.06,
      "text": "bore it and the gun down while Gutman's fat body was rising in haste"
    },
    {
      "start": 1753.06,
      "end": 1753.86,
      "text": "from the rocking-chair."
    },
    {
      "start": 1754.86,
      "end": 1757.78,
      "text": "Joel Cairo scurried around to the boy's other side and grasped his",
      "para_break": true
    },
    {
      "start": 1757.86,
      "end": 1758.4,
      "text": "other arm."
    },
    {
      "start": 1758.67,
      "end": 1760.14,
      "text": "They wrestled with the boy,"
    },
    {
      "start": 1760.3,
      "end": 1761.48,
      "text": "forcing his arms down,"
    },
    {
      "start": 1761.86,
      "end": 1762.56,
      "text": "holding them down,"
    },
    {
      "start": 1763.08,
      "end": 1763.64,
      "text": "while his small,"
    },
    {
      "start": 1763.76,
      "end": 1765.92,
      "text": "wiry body writhed futilely against them."
    },
    {
      "start": 1767.06,
      "end": 1768.7,
      "text": "Words came out of the squirming group,",
      "para_break": true
    },
    {
      "start": 1769.28,
      "end": 1771.18,
      "text": "fragments of the boy's incoherent speech."
    },
    {
      "start": 1771.86,
      "end": 1772.18,
      "text": "Right."
    },
    {
      "start": 1772.4,
      "end": 1772.5,
      "text": "Go."
    },
    {
      "start": 1773.1,
      "end": 1773.88,
      "text": "Smoke."
    },
    {
      "start": 1774.26,
      "end": 1775.14,
      "text": "Gutmans."
    },
    {
      "start": 1775.34,
      "end": 1775.8,
      "text": "Now,"
    },
    {
      "start": 1775.92,
      "end": 1776.16,
      "text": "now,"
    },
    {
      "start": 1776.24,
      "end": 1776.56,
      "text": "Wilmer,"
    },
    {
      "start": 1776.74,
      "end": 1778.26,
      "text": "repeated many times."
    },
    {
      "start": 1778.76,
      "end": 1779.18,
      "text": "Kairos."
    },
    {
      "start": 1779.38,
      "end": 1780.0,
      "text": "No,"
    },
    {
      "start": 1780.1,
      "end": 1781.0,
      "text": "please don't."
    },
    {
      "start": 1781.0,
      "end": 1782.3,
      "text": "And don't do that,"
    },
    {
      "start": 1782.38,
      "end": 1782.66,
      "text": "Wilmer."
    },
    {
      "start": 1783.808,
      "end": 1785.18,
      "text": "Wooden-faced and dreamy-eyed,",
      "para_break": true
    },
    {
      "start": 1785.632,
      "end": 1787.94,
      "text": "Spade got up from the sofa and went over to the group."
    },
    {
      "start": 1788.2,
      "end": 1789.14,
      "text": "The boy,"
    },
    {
      "start": 1789.4,
      "end": 1791.48,
      "text": "unable to cope with the weight against him,"
    },
    {
      "start": 1791.56,
      "end": 1792.46,
      "text": "had stopped struggling."
    },
    {
      "start": 1793.44,
      "end": 1795.04,
      "text": "Cairo stood partly in front of him,",
      "para_break": true
    },
    {
      "start": 1795.1,
      "end": 1796.42,
      "text": "talking to him soothingly,"
    },
    {
      "start": 1796.48,
      "end": 1798.28,
      "text": "still holding one of his arms."
    },
    {
      "start": 1799.584,
      "end": 1802.28,
      "text": "Spade pushed Cairo aside gently and drove",
      "para_break": true
    },
    {
      "start": 1802.28,
      "end": 1804.1,
      "text": "his left fist against the boy's chin."
    },
    {
      "start": 1805.1,
      "end": 1806.72,
      "text": "The boy's head snapped back as far",
      "para_break": true
    },
    {
      "start": 1806.72,
      "end": 1808.5,
      "text": "as it could while his arms were held,"
    },
    {
      "start": 1808.58,
      "end": 1810.04,
      "text": "and then sank forward."
    },
    {
      "start": 1811.456,
      "end": 1812.58,
      "text": "Gutman began a desperate,",
      "para_break": true
    },
    {
      "start": 1812.76,
      "end": 1813.34,
      "text": "Hey,"
    },
    {
      "start": 1814.21,
      "end": 1816.98,
      "text": "you—Spade drove his right fist against the boy's chin.",
      "para_break": true
    },
    {
      "start": 1818.1,
      "end": 1820.08,
      "text": "The boy collapsed against Gutman's great",
      "para_break": true
    },
    {
      "start": 1820.08,
      "end": 1822.66,
      "text": "round belly as Cairo dropped his other arm."
    },
    {
      "start": 1823.872,
      "end": 1825.18,
      "text": "Cairo sprang at Spade,",
      "para_break": true
    },
    {
      "start": 1825.36,
      "end": 1827.42,
      "text": "clawing at his face with the curved,"
    },
    {
      "start": 1827.52,
      "end": 1829.02,
      "text": "stiff fingers of both hands."
    },
    {
      "start": 1830.272,
      "end": 1833.26,
      "text": "Spade blew his breath out sharply and pushed the Levantine away.",
      "para_break": true
    },
    {
      "start": 1834.336,
      "end": 1835.6,
      "text": "Cairo sprang at him again.",
      "para_break": true
    },
    {
      "start": 1836.544,
      "end": 1839.72,
      "text": "Tears were in Cairo's eyes and his red lips worked angrily,",
      "para_break": true
    },
    {
      "start": 1839.74,
      "end": 1840.72,
      "text": "forming words,"
    },
    {
      "start": 1840.98,
      "end": 1841.74,
      "text": "but no sound"
    },
    {
      "start": 1841.74,
      "end": 1842.76,
      "text": "came from between them."
    },
    {
      "start": 1843.648,
      "end": 1845.14,
      "text": "Spade laughed grimly at him,",
      "para_break": true
    },
    {
      "start": 1845.22,
      "end": 1845.5,
      "text": "grunted,"
    },
    {
      "start": 1845.6,
      "end": 1845.68,
      "text": "said,"
    },
    {
      "start": 1845.68,
      "end": 1845.792,
      "text": "\"'Eh,"
    },
    {
      "start": 1846.68,
      "end": 1850.74,
      "text": "you're a darb,' and cuffed the side of his face with a big open hand,",
      "para_break": true
    },
    {
      "start": 1850.88,
      "end": 1851.38,
      "text": "knocking"
    },
    {
      "start": 1851.48,
      "end": 1853.12,
      "text": "Cairo over against the table."
    },
    {
      "start": 1854.848,
      "end": 1857.58,
      "text": "Cairo regained his balance and sprang at Spade the third",
      "para_break": true
    },
    {
      "start": 1857.7,
      "end": 1857.86,
      "text": "time."
    },
    {
      "start": 1858.816,
      "end": 1860.84,
      "text": "Spade stopped him with both palms held",
      "para_break": true
    },
    {
      "start": 1860.84,
      "end": 1863.18,
      "text": "out on long stiff arms against his face."
    },
    {
      "start": 1863.8,
      "end": 1864.3,
      "text": "Cairo,"
    },
    {
      "start": 1864.58,
      "end": 1867.1,
      "text": "failing to reach Spade's face with his shorter arms,"
    },
    {
      "start": 1867.26,
      "end": 1868.48,
      "text": "thumped Spade's arms."
    },
    {
      "start": 1869.728,
      "end": 1871.44,
      "text": "\"'Stop it,' Spade growled.",
      "para_break": true
    },
    {
      "start": 1871.5,
      "end": 1872.44,
      "text": "\"'I'll hurt you.'"
    },
    {
      "start": 1872.46,
      "end": 1872.64,
      "text": "you!\""
    },
    {
      "start": 1873.504,
      "end": 1874.0,
      "text": "Cairo cried,",
      "para_break": true
    },
    {
      "start": 1874.56,
      "end": 1874.84,
      "text": "\"'Oh,"
    },
    {
      "start": 1874.88,
      "end": 1877.44,
      "text": "you big coward!' and backed away from him."
    },
    {
      "start": 1878.624,
      "end": 1880.32,
      "text": "Spade stooped to pick up Cairo's pistol",
      "para_break": true
    },
    {
      "start": 1880.32,
      "end": 1882.26,
      "text": "from the floor and then the boy's."
    },
    {
      "start": 1882.98,
      "end": 1883.7,
      "text": "He straightened up,",
      "para_break": true
    },
    {
      "start": 1884.096,
      "end": 1885.38,
      "text": "holding them in his left hand,"
    },
    {
      "start": 1885.52,
      "end": 1889.04,
      "text": "dangling them upside down by the trigger guards from his forefinger."
    },
    {
      "start": 1890.24,
      "end": 1892.04,
      "text": "Gutman had put the unconscious boy in the",
      "para_break": true
    },
    {
      "start": 1892.04,
      "end": 1894.16,
      "text": "rocking-chair and stood looking down at him"
    },
    {
      "start": 1894.16,
      "end": 1896.82,
      "text": "with troubled eyes and an uncertainly puckered face."
    },
    {
      "start": 1898.016,
      "end": 1899.76,
      "text": "Cairo was on his knees beside the chair,",
      "para_break": true
    },
    {
      "start": 1900.0,
      "end": 1901.86,
      "text": "chafing one of the boy's limp hands."
    },
    {
      "start": 1903.456,
      "end": 1905.92,
      "text": "Spade leaned over and felt the boy's chin with his fingers.",
      "para_break": true
    },
    {
      "start": 1907.232,
      "end": 1908.56,
      "text": "\"'Nothing broken,' he said.",
      "para_break": true
    },
    {
      "start": 1909.4,
      "end": 1910.61,
      "text": "\"'We'll spread him on the sofa.'",
      "para_break": true
    },
    {
      "start": 1911.12,
      "end": 1914.46,
      "text": "He put his right arm under the boy's arm and around his back,"
    },
    {
      "start": 1914.56,
      "end": 1915.96,
      "text": "put his left forearm under"
    },
    {
      "start": 1915.96,
      "end": 1916.58,
      "text": "the boy's knees,"
    },
    {
      "start": 1916.76,
      "end": 1918.26,
      "text": "lifted him without apparent effort,"
    },
    {
      "start": 1918.38,
      "end": 1919.62,
      "text": "and carried him to the sofa."
    },
    {
      "start": 1920.96,
      "end": 1922.38,
      "text": "Bridget O'Shaughnessy got up quickly,",
      "para_break": true
    },
    {
      "start": 1922.52,
      "end": 1924.06,
      "text": "and Spade laid the boy there."
    },
    {
      "start": 1925.32,
      "end": 1927.62,
      "text": "With his right hand Spade patted the boy's clothes,",
      "para_break": true
    },
    {
      "start": 1927.9,
      "end": 1929.44,
      "text": "found the boy's second pistol,"
    },
    {
      "start": 1930.016,
      "end": 1931.58,
      "text": "added it to the others in his left hand,"
    },
    {
      "start": 1931.74,
      "end": 1933.46,
      "text": "and turned his back on the sofa."
    },
    {
      "start": 1934.528,
      "end": 1936.74,
      "text": "Cairo was already sitting beside the boy's head.",
      "para_break": true
    },
    {
      "start": 1938.112,
      "end": 1939.76,
      "text": "Spade clinked the pistols together in",
      "para_break": true
    },
    {
      "start": 1939.76,
      "end": 1941.8,
      "text": "his hand and smiled cheerfully at Gutman."
    },
    {
      "start": 1942.88,
      "end": 1943.1,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 1943.32,
      "end": 1943.84,
      "text": "he said,"
    },
    {
      "start": 1943.96,
      "end": 1945.14,
      "text": "there's our fall guy."
    },
    {
      "start": 1946.56,
      "end": 1949.0,
      "text": "Gutman's face was grayish and his eyes were troubled.",
      "para_break": true
    },
    {
      "start": 1949.58,
      "end": 1951.1,
      "text": "He did not look at Spade."
    },
    {
      "start": 1951.68,
      "end": 1954.2,
      "text": "He looked at the floor and he did not say anything."
    },
    {
      "start": 1955.552,
      "end": 1956.06,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 1957.0,
      "end": 1958.14,
      "text": "Don't be a damn fool again.",
      "para_break": true
    }
  ]
}
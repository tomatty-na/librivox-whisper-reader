  "chapter_title": "Chapter 18 - The Fall-Guy",
  "reader_name": "Mark Nelson",
  "page_num": 9,
  "page_total": 9,
  "page_start_sec": 1958.44,
  "page_end_sec": 2003.26,
  "para_gap_threshold": 0.691,
  "segments": [
    {
      "start": 1958.44,
      "end": 1960.42,
      "text": "You let Kyra whisper to you,"
    },
    {
      "start": 1960.48,
      "end": 1962.42,
      "text": "and you held the kid while I pasted him."
    },
    {
      "start": 1962.8,
      "end": 1964.08,
      "text": "You can't laugh that off,"
    },
    {
      "start": 1964.2,
      "end": 1966.624,
      "text": "and you're likely to get yourself shot trying to.\""
    },
    {
      "start": 1967.936,
      "end": 1970.66,
      "text": "Cutman moved his feet uneasily on the rug and said nothing.",
      "para_break": true
    },
    {
      "start": 1971.808,
      "end": 1972.34,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 1973.64,
      "end": 1974.94,
      "text": "And the other angle to it is,",
      "para_break": true
    },
    {
      "start": 1974.98,
      "end": 1976.56,
      "text": "you'll either say yes right now,"
    },
    {
      "start": 1976.7,
      "end": 1979.38,
      "text": "or I'll turn the Falcon and the whole damn lot of you in."
    },
    {
      "start": 1981.12,
      "end": 1983.24,
      "text": "Cutman raised his head and muttered through his teeth,",
      "para_break": true
    },
    {
      "start": 1983.77,
      "end": 1985.08,
      "text": "I don't like that,"
    },
    {
      "start": 1985.16,
      "end": 1985.36,
      "text": "sir."
    },
    {
      "start": 1986.32,
      "end": 1987.2,
      "text": "You won't like it,",
      "para_break": true
    },
    {
      "start": 1987.26,
      "end": 1988.18,
      "text": "Spade said."
    },
    {
      "start": 1988.64,
      "end": 1989.06,
      "text": "Well?"
    },
    {
      "start": 1989.66,
      "end": 1993.64,
      "text": "The fat man sighed and made a wry face and replied wearily,"
    },
    {
      "start": 1995.08,
      "end": 1995.9,
      "text": "You can have him,",
      "para_break": true
    },
    {
      "start": 1996.02,
      "end": 1997.62,
      "text": "Spade said."
    },
    {
      "start": 1998.656,
      "end": 1999.06,
      "text": "That's swell.",
      "para_break": true
    },
    {
      "start": 2002.38,
      "end": 2003.26,
      "text": "End of chapter 18",
      "para_break": true
    }
  ]
}
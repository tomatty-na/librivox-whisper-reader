{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-08",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_08_hammett.mp3",
  "chapter_title": "Chapter 8 - Horsefeathers",
  "reader_name": "Mark Nelson",
  "page_num": 4,
  "page_total": 5,
  "page_start_sec": 735.5,
  "page_end_sec": 978.5,
  "para_gap_threshold": 0.672,
  "segments": [
    {
      "start": 735.5,
      "end": 736.5,
      "text": "\"'You squawked for help,",
      "para_break": true
    },
    {
      "start": 736.62,
      "end": 737.86,
      "text": "and you've got to take it.'"
    },
    {
      "start": 738.56,
      "end": 739.04,
      "text": "\"'No,",
      "para_break": true
    },
    {
      "start": 739.04,
      "end": 739.44,
      "text": "sir,'"
    },
    {
      "start": 740.032,
      "end": 740.8,
      "text": "Cairo spluttered."
    },
    {
      "start": 741.2,
      "end": 741.96,
      "text": "\"'It was a joke."
    },
    {
      "start": 742.52,
      "end": 744.82,
      "text": "He said you were friends of his and would understand.'"
    },
    {
      "start": 746.272,
      "end": 747.12,
      "text": "Spade laughed.",
      "para_break": true
    },
    {
      "start": 748.032,
      "end": 749.78,
      "text": "Dundee pulled Cairo roughly to him,",
      "para_break": true
    },
    {
      "start": 749.92,
      "end": 752.62,
      "text": "holding him now by the nape of the neck and one wrist."
    },
    {
      "start": 753.88,
      "end": 755.6,
      "text": "\"'I'll take you along for packing the gun,",
      "para_break": true
    },
    {
      "start": 755.66,
      "end": 756.04,
      "text": "anyway.'"
    },
    {
      "start": 756.26,
      "end": 756.82,
      "text": "he said,"
    },
    {
      "start": 757.01,
      "end": 760.27,
      "text": "and I'll take the rest of you along to see who laughs at the joke.\""
    },
    {
      "start": 761.696,
      "end": 765.22,
      "text": "Cairo's alarmed eyes jerked sideways to focus on Spade's face.",
      "para_break": true
    },
    {
      "start": 766.304,
      "end": 766.78,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 767.712,
      "end": 768.64,
      "text": "\"'Don't be a damn fool,",
      "para_break": true
    },
    {
      "start": 768.82,
      "end": 769.06,
      "text": "Dundee."
    },
    {
      "start": 769.33,
      "end": 771.2,
      "text": "The gun was part of the plant."
    },
    {
      "start": 772.0,
      "end": 772.68,
      "text": "It's one of mine.",
      "para_break": true
    },
    {
      "start": 772.98,
      "end": 773.08,
      "text": "I've"
    },
    {
      "start": 773.66,
      "end": 775.424,
      "text": "got all the licenses you want.'"
    },
    {
      "start": 776.64,
      "end": 777.7,
      "text": "Dundee released Cairo,",
      "para_break": true
    },
    {
      "start": 777.86,
      "end": 778.84,
      "text": "spun on his heel,"
    },
    {
      "start": 779.24,
      "end": 779.88,
      "text": "and his right fist"
    },
    {
      "start": 780.06,
      "end": 781.32,
      "text": "clicked on Spade's chin."
    },
    {
      "start": 782.752,
      "end": 784.58,
      "text": "Bridget O'Shaughnessy uttered a short cry.",
      "para_break": true
    },
    {
      "start": 786.048,
      "end": 788.62,
      "text": "Spade's smile flickered out at the instant of the impact,",
      "para_break": true
    },
    {
      "start": 789.22,
      "end": 789.66,
      "text": "but returned"
    },
    {
      "start": 789.88,
      "end": 792.02,
      "text": "immediately with a dreamy quality added."
    },
    {
      "start": 793.02,
      "end": 795.34,
      "text": "He steadied himself with a short backward step,",
      "para_break": true
    },
    {
      "start": 795.5,
      "end": 796.9,
      "text": "and his thick sloping"
    },
    {
      "start": 796.92,
      "end": 798.46,
      "text": "shoulders writhed under his coat."
    },
    {
      "start": 799.456,
      "end": 800.7,
      "text": "Before his fist could come up,",
      "para_break": true
    },
    {
      "start": 800.78,
      "end": 802.84,
      "text": "Tom Polehouse had pushed himself in"
    },
    {
      "start": 802.88,
      "end": 803.66,
      "text": "between the two men,"
    },
    {
      "start": 803.84,
      "end": 806.84,
      "text": "facing Spade and cumbering Spade's arms with the"
    },
    {
      "start": 806.9,
      "end": 809.42,
      "text": "closeness of his barrel-bellied body and his own arms."
    },
    {
      "start": 810.06,
      "end": 810.16,
      "text": "\"'No,"
    },
    {
      "start": 811.3,
      "end": 811.58,
      "text": "no.",
      "para_break": true
    },
    {
      "start": 811.76,
      "end": 814.34,
      "text": "For sake!' Tom begged."
    },
    {
      "start": 815.36,
      "end": 816.82,
      "text": "After a long moment of motionlessness,",
      "para_break": true
    },
    {
      "start": 817.26,
      "end": 818.52,
      "text": "Spade's muscles relaxed."
    },
    {
      "start": 820.032,
      "end": 821.94,
      "text": "\"'Then get him out of here quick,' he said.",
      "para_break": true
    },
    {
      "start": 822.66,
      "end": 823.82,
      "text": "His smile had gone away,",
      "para_break": true
    },
    {
      "start": 824.0,
      "end": 826.34,
      "text": "leaving his face sullen and somewhat pale."
    },
    {
      "start": 827.1,
      "end": 827.78,
      "text": "Tom,",
      "para_break": true
    },
    {
      "start": 828.04,
      "end": 829.46,
      "text": "remaining close to Spade,"
    },
    {
      "start": 829.54,
      "end": 831.38,
      "text": "keeping his arms on Spade's arms,"
    },
    {
      "start": 831.56,
      "end": 834.22,
      "text": "turned his head to look over his shoulder at Lieutenant Dundee."
    },
    {
      "start": 835.264,
      "end": 836.96,
      "text": "Tom's small eyes were reproachful.",
      "para_break": true
    },
    {
      "start": 837.93,
      "end": 840.76,
      "text": "Dundee's fist was still clenched in front of his body,",
      "para_break": true
    },
    {
      "start": 840.88,
      "end": 842.56,
      "text": "and his feet were planted firm"
    },
    {
      "start": 842.74,
      "end": 844.18,
      "text": "and a little apart on the floor,"
    },
    {
      "start": 844.38,
      "end": 848.06,
      "text": "but the truculence in his face was modified by the thin rims"
    },
    {
      "start": 848.06,
      "end": 850.84,
      "text": "of white showing between green irises and upper eyelids."
    },
    {
      "start": 852.58,
      "end": 854.6,
      "text": "\"'Get their names and addresses,' he ordered,",
      "para_break": true
    },
    {
      "start": 854.74,
      "end": 856.62,
      "text": "\"'so we can get hold of them when we want"
    },
    {
      "start": 856.68,
      "end": 857.056,
      "text": "them.'"
    },
    {
      "start": 858.02,
      "end": 858.96,
      "text": "Tom looked at Cairo,",
      "para_break": true
    },
    {
      "start": 859.16,
      "end": 859.88,
      "text": "who said quickly,"
    },
    {
      "start": 860.672,
      "end": 861.42,
      "text": "\"'Joel Cairo,",
      "para_break": true
    },
    {
      "start": 861.62,
      "end": 862.944,
      "text": "Hotel Belvedere.'"
    },
    {
      "start": 864.44,
      "end": 866.3,
      "text": "Spade spoke before Tom could question the girl.",
      "para_break": true
    },
    {
      "start": 867.02,
      "end": 870.22,
      "text": "\"'You can always get in touch with Miss O'Shaughnessy through me.'",
      "para_break": true
    },
    {
      "start": 871.32,
      "end": 872.22,
      "text": "Tom looked at Dundee,",
      "para_break": true
    },
    {
      "start": 872.3,
      "end": 872.8,
      "text": "who growled."
    },
    {
      "start": 874.02,
      "end": 874.61,
      "text": "\"'Get her address.'",
      "para_break": true
    },
    {
      "start": 875.776,
      "end": 876.28,
      "text": "Spade said.",
      "para_break": true
    },
    {
      "start": 877.2,
      "end": 879.17,
      "text": "\"'Her address is in care of my office.'",
      "para_break": true
    },
    {
      "start": 880.224,
      "end": 881.08,
      "text": "Dundee moved forward,",
      "para_break": true
    },
    {
      "start": 881.3,
      "end": 882.56,
      "text": "halting in front of the girl."
    },
    {
      "start": 883.936,
      "end": 885.42,
      "text": "\"'Where do you live?' he asked.",
      "para_break": true
    },
    {
      "start": 886.432,
      "end": 887.58,
      "text": "Spade addressed Tom.",
      "para_break": true
    },
    {
      "start": 888.768,
      "end": 889.66,
      "text": "\"'Get him out of here.",
      "para_break": true
    },
    {
      "start": 890.4,
      "end": 891.63,
      "text": "I've had enough of this.'",
      "para_break": true
    },
    {
      "start": 892.94,
      "end": 896.02,
      "text": "Tom looked at Spade's eyes that were hard and glittering and mumbled,",
      "para_break": true
    },
    {
      "start": 897.08,
      "end": 897.58,
      "text": "\"'Take it easy,",
      "para_break": true
    },
    {
      "start": 897.7,
      "end": 898.18,
      "text": "Sam.'"
    },
    {
      "start": 898.86,
      "end": 900.78,
      "text": "He buttoned up his coat and turned to Dundee,",
      "para_break": true
    },
    {
      "start": 900.9,
      "end": 902.4,
      "text": "asking in a voice that"
    },
    {
      "start": 902.46,
      "end": 903.3,
      "text": "aped casualness,"
    },
    {
      "start": 904.15,
      "end": 904.7,
      "text": "\"'Well,",
      "para_break": true
    },
    {
      "start": 904.72,
      "end": 905.42,
      "text": "is that all?'"
    },
    {
      "start": 906.06,
      "end": 907.52,
      "text": "and taking a step toward the door."
    },
    {
      "start": 908.672,
      "end": 910.86,
      "text": "Dundee's scowl failed to conceal indecision.",
      "para_break": true
    },
    {
      "start": 911.616,
      "end": 913.78,
      "text": "Kairos suddenly moved toward the door,",
      "para_break": true
    },
    {
      "start": 913.92,
      "end": 914.38,
      "text": "saying,"
    },
    {
      "start": 915.136,
      "end": 915.72,
      "text": "\"'I'm going too,",
      "para_break": true
    },
    {
      "start": 915.92,
      "end": 916.5,
      "text": "if Mr."
    },
    {
      "start": 916.6,
      "end": 918.38,
      "text": "Spade will give me my coat and hat.'"
    },
    {
      "start": 919.424,
      "end": 920.08,
      "text": "Spade asked,",
      "para_break": true
    },
    {
      "start": 920.8,
      "end": 921.39,
      "text": "What's the hurry?\"",
      "para_break": true
    },
    {
      "start": 922.432,
      "end": 923.66,
      "text": "Dundee said angrily.",
      "para_break": true
    },
    {
      "start": 924.82,
      "end": 925.92,
      "text": "\"'It was all in fun,",
      "para_break": true
    },
    {
      "start": 926.12,
      "end": 928.62,
      "text": "but just the same you're afraid to be left here"
    },
    {
      "start": 928.62,
      "end": 929.216,
      "text": "with them.'"
    },
    {
      "start": 930.4,
      "end": 932.26,
      "text": "\"'Not at all,' the Levantine replied,",
      "para_break": true
    },
    {
      "start": 932.42,
      "end": 933.1,
      "text": "fidgeting,"
    },
    {
      "start": 933.12,
      "end": 934.22,
      "text": "looking at neither of"
    },
    {
      "start": 934.22,
      "end": 934.44,
      "text": "them."
    },
    {
      "start": 935.296,
      "end": 936.3,
      "text": "\"'But it's quite late,",
      "para_break": true
    },
    {
      "start": 936.4,
      "end": 938.02,
      "text": "and—and I'm going."
    },
    {
      "start": 938.94,
      "end": 940.71,
      "text": "I'll go out with you if you don't mind.'",
      "para_break": true
    },
    {
      "start": 941.952,
      "end": 943.6,
      "text": "Dundee put his lips together firmly,",
      "para_break": true
    },
    {
      "start": 943.68,
      "end": 944.7,
      "text": "but said nothing,"
    },
    {
      "start": 944.92,
      "end": 945.98,
      "text": "though a light"
    },
    {
      "start": 946.1,
      "end": 947.4,
      "text": "was glinting in his green eyes."
    },
    {
      "start": 948.42,
      "end": 950.46,
      "text": "Spade went to the closet in the passageway",
      "para_break": true
    },
    {
      "start": 950.52,
      "end": 952.42,
      "text": "and fetched Cairo's coat and hat."
    },
    {
      "start": 953.504,
      "end": 954.76,
      "text": "Spade's face was blank.",
      "para_break": true
    },
    {
      "start": 955.3,
      "end": 958.24,
      "text": "His voice held the same blankness when he stepped back"
    },
    {
      "start": 958.24,
      "end": 960.86,
      "text": "from helping the Levantine into his coat and said to Tom,"
    },
    {
      "start": 961.65,
      "end": 964.74,
      "text": "Tell him to leave that gun of mine that he took from Cairo.",
      "para_break": true
    },
    {
      "start": 966.24,
      "end": 969.14,
      "text": "Dundee took Cairo's pistol from his pocket and put it on the table.",
      "para_break": true
    },
    {
      "start": 970.16,
      "end": 971.08,
      "text": "He went out first,",
      "para_break": true
    },
    {
      "start": 971.16,
      "end": 972.46,
      "text": "with Cairo at his heels."
    },
    {
      "start": 973.76,
      "end": 975.5,
      "text": "Tom halted in front of Spade,",
      "para_break": true
    },
    {
      "start": 975.56,
      "end": 975.86,
      "text": "muttering,"
    },
    {
      "start": 976.66,
      "end": 978.5,
      "text": "I hope to God you know what you're doing.",
      "para_break": true
    }
  ]
}
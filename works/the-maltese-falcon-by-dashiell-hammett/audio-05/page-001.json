{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-05",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_05_hammett.mp3",
  "chapter_title": "Chapter 5 - Cairo's Pockets",
  "reader_name": "Mark Nelson",
  "page_num": 1,
  "page_total": 4,
  "page_start_sec": 7.5,
  "page_end_sec": 251.2,
  "para_gap_threshold": 0.774,
  "segments": [
    {
      "start": 7.5,
      "end": 11.02,
      "text": "CHAPTER V."
    },
    {
      "start": 11.02,
      "end": 13.0,
      "text": "KYRO'S POCKETS"
    },
    {
      "start": 14.4,
      "end": 15.86,
      "text": "Spade did not look at the pistol.",
      "para_break": true
    },
    {
      "start": 16.448,
      "end": 17.86,
      "text": "He raised his arms and,"
    },
    {
      "start": 17.9,
      "end": 18.98,
      "text": "leaning back in his chair,"
    },
    {
      "start": 19.488,
      "end": 22.2,
      "text": "intertwined the fingers of his two hands behind his head."
    },
    {
      "start": 23.32,
      "end": 23.98,
      "text": "But his eyes,",
      "para_break": true
    },
    {
      "start": 24.14,
      "end": 24.82,
      "text": "holding no particular"
    },
    {
      "start": 25.26,
      "end": 28.16,
      "text": "expression remained focused on Cairo's dark face."
    },
    {
      "start": 29.888,
      "end": 31.61,
      "text": "Cairo coughed a little apologetic",
      "para_break": true
    },
    {
      "start": 31.68,
      "end": 34.0,
      "text": "cough and smiled nervously with lips"
    },
    {
      "start": 34.0,
      "end": 35.62,
      "text": "that had lost some of their redness."
    },
    {
      "start": 36.68,
      "end": 38.18,
      "text": "His dark eyes were humid and",
      "para_break": true
    },
    {
      "start": 38.3,
      "end": 39.68,
      "text": "bashful and very earnest."
    },
    {
      "start": 41.48,
      "end": 43.1,
      "text": "\"'I intend to search your office,",
      "para_break": true
    },
    {
      "start": 43.28,
      "end": 43.42,
      "text": "Mr."
    },
    {
      "start": 43.56,
      "end": 44.84,
      "text": "Spade,' he said."
    },
    {
      "start": 45.36,
      "end": 47.54,
      "text": "\"'I warn you that if you attempt to"
    },
    {
      "start": 47.54,
      "end": 49.64,
      "text": "prevent me I shall certainly shoot"
    },
    {
      "start": 49.7,
      "end": 50.04,
      "text": "you.'"
    },
    {
      "start": 51.38,
      "end": 52.128,
      "text": "\"'Go ahead.'",
      "para_break": true
    },
    {
      "start": 53.088,
      "end": 56.32,
      "text": "Spade's voice was as empty of expression as his face.",
      "para_break": true
    },
    {
      "start": 57.74,
      "end": 60.36,
      "text": "\"'You will please stand,' the man with the",
      "para_break": true
    },
    {
      "start": 60.36,
      "end": 62.46,
      "text": "pistol instructed him at whose thick chest"
    },
    {
      "start": 62.46,
      "end": 63.56,
      "text": "the pistol was aimed."
    },
    {
      "start": 64.6,
      "end": 67.01,
      "text": "\"'I shall have to make sure that you are not armed.'",
      "para_break": true
    },
    {
      "start": 68.48,
      "end": 69.32,
      "text": "Spade stood up,",
      "para_break": true
    },
    {
      "start": 69.36,
      "end": 72.6,
      "text": "pushing the chair back with his calves as he straightened his legs."
    },
    {
      "start": 73.888,
      "end": 75.24,
      "text": "Cairo went around behind him.",
      "para_break": true
    },
    {
      "start": 75.776,
      "end": 78.76,
      "text": "He changed the pistol from his right hand to his left."
    },
    {
      "start": 79.0,
      "end": 81.94,
      "text": "He lifted Spade's coattail and looked under it."
    },
    {
      "start": 82.78,
      "end": 84.64,
      "text": "Holding the pistol close to Spade's back,",
      "para_break": true
    },
    {
      "start": 85.12,
      "end": 88.16,
      "text": "he put his right hand around Spade's side and patted his chest."
    },
    {
      "start": 89.62,
      "end": 91.94,
      "text": "The Levantine face was then no more than six",
      "para_break": true
    },
    {
      "start": 91.94,
      "end": 94.52,
      "text": "inches below and behind Spade's right elbow."
    },
    {
      "start": 95.776,
      "end": 98.46,
      "text": "Spade's elbow dropped as Spade spun to the right.",
      "para_break": true
    },
    {
      "start": 99.584,
      "end": 101.9,
      "text": "Cairo's face jerked back not far enough.",
      "para_break": true
    },
    {
      "start": 102.88,
      "end": 105.08,
      "text": "Spade's right heel on the patent-leathered toes",
      "para_break": true
    },
    {
      "start": 105.08,
      "end": 107.2,
      "text": "anchored the smaller man in the elbow's path."
    },
    {
      "start": 107.6,
      "end": 109.78,
      "text": "The elbow struck him beneath the cheekbone,"
    },
    {
      "start": 109.96,
      "end": 112.14,
      "text": "staggering him so that he must have fallen"
    },
    {
      "start": 112.28,
      "end": 114.98,
      "text": "had he not been held by Spade's foot on his foot."
    },
    {
      "start": 116.15,
      "end": 118.96,
      "text": "Spade's elbow went on past the astonished face",
      "para_break": true
    },
    {
      "start": 118.96,
      "end": 121.4,
      "text": "and straightened when Spade's hand struck down"
    },
    {
      "start": 121.4,
      "end": 121.96,
      "text": "at the pistol."
    },
    {
      "start": 123.2,
      "end": 126.6,
      "text": "Cairo let go the pistol the instant that Spade's fingers touched it.",
      "para_break": true
    },
    {
      "start": 127.46,
      "end": 129.44,
      "text": "The pistol was small in Spade's hand.",
      "para_break": true
    },
    {
      "start": 130.624,
      "end": 133.44,
      "text": "Spade took his foot off Cairo's to complete his about face.",
      "para_break": true
    },
    {
      "start": 134.35,
      "end": 135.72,
      "text": "With his left hand,",
      "para_break": true
    },
    {
      "start": 135.88,
      "end": 138.7,
      "text": "Spade gathered together the smaller man's coat lapels,"
    },
    {
      "start": 138.84,
      "end": 139.94,
      "text": "the ruby-set"
    },
    {
      "start": 140.02,
      "end": 142.06,
      "text": "green tie bunching out over his knuckles,"
    },
    {
      "start": 142.74,
      "end": 144.74,
      "text": "while his right hand stowed the captured pistol"
    },
    {
      "start": 144.9,
      "end": 145.98,
      "text": "away in a coat pocket."
    },
    {
      "start": 147.008,
      "end": 148.88,
      "text": "Spade's yellow-gray eyes were somber.",
      "para_break": true
    },
    {
      "start": 149.472,
      "end": 151.5,
      "text": "His face was wooden except for a"
    },
    {
      "start": 151.5,
      "end": 153.4,
      "text": "trace of sullenness around the mouth."
    },
    {
      "start": 154.72,
      "end": 157.28,
      "text": "Cairo's face was twisted with pain and chagrin.",
      "para_break": true
    },
    {
      "start": 158.24,
      "end": 159.88,
      "text": "There were tears in his dark eyes.",
      "para_break": true
    },
    {
      "start": 160.26,
      "end": 163.06,
      "text": "His skin was the complexion of polished lead"
    },
    {
      "start": 163.06,
      "end": 165.36,
      "text": "except where the elbow had reddened his cheek."
    },
    {
      "start": 166.66,
      "end": 167.36,
      "text": "Spade,",
      "para_break": true
    },
    {
      "start": 167.46,
      "end": 170.0,
      "text": "by means of his grip on the Levantine's lapels,"
    },
    {
      "start": 170.14,
      "end": 172.6,
      "text": "turned him slowly and pushed him back"
    },
    {
      "start": 172.84,
      "end": 175.06,
      "text": "until he was standing closer in front"
    },
    {
      "start": 175.06,
      "end": 176.72,
      "text": "of the chair he had lately occupied."
    },
    {
      "start": 177.94,
      "end": 181.4,
      "text": "A puzzled look replaced the look of pain in the lead-colored face.",
      "para_break": true
    },
    {
      "start": 182.94,
      "end": 184.1,
      "text": "Then Spade smiled.",
      "para_break": true
    },
    {
      "start": 185.22,
      "end": 186.34,
      "text": "His smile was gentle,",
      "para_break": true
    },
    {
      "start": 186.52,
      "end": 187.52,
      "text": "even dreamy."
    },
    {
      "start": 187.82,
      "end": 190.34,
      "text": "His right shoulder lifted a few inches."
    },
    {
      "start": 191.24,
      "end": 193.98,
      "text": "His bent right arm was driven up by the shoulder's lift.",
      "para_break": true
    },
    {
      "start": 194.74,
      "end": 195.28,
      "text": "Fist,"
    },
    {
      "start": 195.3,
      "end": 195.62,
      "text": "wrist,"
    },
    {
      "start": 195.84,
      "end": 196.24,
      "text": "forearm,"
    },
    {
      "start": 196.5,
      "end": 197.18,
      "text": "crooked elbow,"
    },
    {
      "start": 197.36,
      "end": 199.94,
      "text": "and upper arm seemed all one rigid piece,"
    },
    {
      "start": 200.5,
      "end": 202.98,
      "text": "with only the limber shoulder giving them motion."
    },
    {
      "start": 203.92,
      "end": 206.36,
      "text": "The fist struck Cairo's face,",
      "para_break": true
    },
    {
      "start": 206.58,
      "end": 209.24,
      "text": "covering for a moment one side of his chin,"
    },
    {
      "start": 209.44,
      "end": 210.7,
      "text": "a corner of his mouth,"
    },
    {
      "start": 211.1,
      "end": 213.88,
      "text": "and most of his cheek between cheekbone and jawbone."
    },
    {
      "start": 215.136,
      "end": 217.06,
      "text": "Cairo shut his eyes and was unconscious.",
      "para_break": true
    },
    {
      "start": 218.848,
      "end": 220.8,
      "text": "Spade lowered the limp body into the chair,",
      "para_break": true
    },
    {
      "start": 220.96,
      "end": 223.14,
      "text": "where it lay with sprawled arms and legs,"
    },
    {
      "start": 223.46,
      "end": 226.04,
      "text": "the head lolling back against the chair's back,"
    },
    {
      "start": 226.24,
      "end": 227.0,
      "text": "the mouth open."
    },
    {
      "start": 228.352,
      "end": 231.16,
      "text": "Spade emptied the unconscious man's pockets one by one,",
      "para_break": true
    },
    {
      "start": 231.3,
      "end": 232.62,
      "text": "working methodically,"
    },
    {
      "start": 232.82,
      "end": 233.64,
      "text": "moving the"
    },
    {
      "start": 233.68,
      "end": 234.8,
      "text": "body when necessary,"
    },
    {
      "start": 235.26,
      "end": 238.2,
      "text": "making a pile of the pocket's contents on the desk."
    },
    {
      "start": 239.62,
      "end": 241.42,
      "text": "When the last pocket had been turned out,",
      "para_break": true
    },
    {
      "start": 241.52,
      "end": 242.92,
      "text": "he returned to his own chair,"
    },
    {
      "start": 243.34,
      "end": 244.76,
      "text": "rolled and lighted a cigarette,"
    },
    {
      "start": 244.98,
      "end": 246.76,
      "text": "and began to examine his spoils."
    },
    {
      "start": 247.68,
      "end": 251.2,
      "text": "He examined them with grave and unhurried thoroughness.",
      "para_break": true
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-13",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_13_hammett.mp3",
  "chapter_title": "Chapter 13 - The Emperor's Gift",
  "reader_name": "Mark Nelson",
  "page_num": 1,
  "page_total": 5,
  "page_start_sec": 8.87,
  "page_end_sec": 249.66,
  "para_gap_threshold": 0.673,
  "segments": [
    {
      "start": 8.87,
      "end": 10.52,
      "text": "XIII."
    },
    {
      "start": 10.76,
      "end": 12.74,
      "text": "THE EMPEROR'S GIFT"
    },
    {
      "start": 14.944,
      "end": 16.08,
      "text": "Gutman opened the door.",
      "para_break": true
    },
    {
      "start": 16.8,
      "end": 19.14,
      "text": "A glad smile lighted his fat face.",
      "para_break": true
    },
    {
      "start": 19.94,
      "end": 21.16,
      "text": "He held out a hand and said,",
      "para_break": true
    },
    {
      "start": 21.8,
      "end": 21.94,
      "text": "\"'Ah,"
    },
    {
      "start": 22.14,
      "end": 22.64,
      "text": "come in,"
    },
    {
      "start": 22.7,
      "end": 22.9,
      "text": "sir."
    },
    {
      "start": 23.1,
      "end": 24.16,
      "text": "Thanks for coming."
    },
    {
      "start": 24.36,
      "end": 24.94,
      "text": "Come in.'"
    },
    {
      "start": 24.96,
      "end": 24.96,
      "text": "in."
    },
    {
      "start": 26.304,
      "end": 27.68,
      "text": "Spade shook the hand and entered.",
      "para_break": true
    },
    {
      "start": 27.96,
      "end": 29.76,
      "text": "The boy went in behind him."
    },
    {
      "start": 30.2,
      "end": 30.58,
      "text": "The"
    },
    {
      "start": 30.64,
      "end": 31.7,
      "text": "fat man shut the door."
    },
    {
      "start": 32.512,
      "end": 34.78,
      "text": "Spade took the pistols from his pockets and held",
      "para_break": true
    },
    {
      "start": 34.78,
      "end": 35.54,
      "text": "them out to Gutman."
    },
    {
      "start": 36.86,
      "end": 37.08,
      "text": "Here.",
      "para_break": true
    },
    {
      "start": 37.46,
      "end": 39.76,
      "text": "You shouldn't let the lad run around with these."
    },
    {
      "start": 40.04,
      "end": 40.66,
      "text": "He'll get"
    },
    {
      "start": 40.74,
      "end": 41.36,
      "text": "himself hurt."
    },
    {
      "start": 42.07,
      "end": 45.1,
      "text": "The fat man laughed merrily and took the pistols.",
      "para_break": true
    },
    {
      "start": 45.94,
      "end": 46.18,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 46.36,
      "end": 46.6,
      "text": "well,"
    },
    {
      "start": 46.82,
      "end": 47.36,
      "text": "he said."
    },
    {
      "start": 47.5,
      "end": 48.56,
      "text": "What's this?"
    },
    {
      "start": 49.31,
      "end": 51.34,
      "text": "He looked from Spade to the boy.",
      "para_break": true
    },
    {
      "start": 52.352,
      "end": 52.82,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 53.2,
      "end": 55.86,
      "text": "A crippled newsboy took them away from him,"
    },
    {
      "start": 55.96,
      "end": 57.58,
      "text": "but I made him give them up."
    },
    {
      "start": 58.35,
      "end": 60.68,
      "text": "The white-faced boy took the pistols",
      "para_break": true
    },
    {
      "start": 60.68,
      "end": 62.56,
      "text": "out of Gutman's hands and pocketed them."
    },
    {
      "start": 63.06,
      "end": 64.44,
      "text": "The boy did not speak."
    },
    {
      "start": 65.696,
      "end": 66.52,
      "text": "Gutman laughed again.",
      "para_break": true
    },
    {
      "start": 67.58,
      "end": 68.24,
      "text": "By gad,",
      "para_break": true
    },
    {
      "start": 68.32,
      "end": 68.64,
      "text": "sir,"
    },
    {
      "start": 68.82,
      "end": 69.88,
      "text": "he told Spade,"
    },
    {
      "start": 70.0,
      "end": 71.76,
      "text": "you're a chap worth knowing,"
    },
    {
      "start": 71.98,
      "end": 73.22,
      "text": "an amazing character."
    },
    {
      "start": 74.04,
      "end": 74.38,
      "text": "Come in,",
      "para_break": true
    },
    {
      "start": 74.52,
      "end": 75.22,
      "text": "sit down,"
    },
    {
      "start": 75.5,
      "end": 76.58,
      "text": "give me your hat."
    },
    {
      "start": 77.79,
      "end": 80.54,
      "text": "The boy left the room by the door to the right of the entrance.",
      "para_break": true
    },
    {
      "start": 80.93,
      "end": 85.08,
      "text": "The fat man installed Spade in a green plush chair by the table,"
    },
    {
      "start": 85.24,
      "end": 86.74,
      "text": "pressed a cigar upon him,"
    },
    {
      "start": 87.24,
      "end": 88.08,
      "text": "held a light to it,"
    },
    {
      "start": 88.14,
      "end": 89.9,
      "text": "mixed whiskey and carbonated water,"
    },
    {
      "start": 90.56,
      "end": 92.08,
      "text": "put one glass in Spade's hand,"
    },
    {
      "start": 92.18,
      "end": 92.42,
      "text": "and"
    },
    {
      "start": 92.5,
      "end": 93.62,
      "text": "holding the other in his own,"
    },
    {
      "start": 93.74,
      "end": 95.38,
      "text": "sat down facing Spade."
    },
    {
      "start": 96.38,
      "end": 97.06,
      "text": "\"'Now,",
      "para_break": true
    },
    {
      "start": 97.18,
      "end": 98.08,
      "text": "sir,' he said,"
    },
    {
      "start": 98.18,
      "end": 100.98,
      "text": "\"'I hope you'll let me apologize for—'"
    },
    {
      "start": 101.42,
      "end": 103.18,
      "text": "\"'Never mind that,' Spade said."
    },
    {
      "start": 103.872,
      "end": 105.36,
      "text": "\"'Let's talk about the black bird.'",
      "para_break": true
    },
    {
      "start": 106.02,
      "end": 108.22,
      "text": "The fat man cocked his head a little to"
    },
    {
      "start": 108.22,
      "end": 110.86,
      "text": "one side and regarded Spade with fond eyes."
    },
    {
      "start": 112.18,
      "end": 112.6,
      "text": "\"'All right,",
      "para_break": true
    },
    {
      "start": 112.6,
      "end": 113.5,
      "text": "sir,' he agreed."
    },
    {
      "start": 113.92,
      "end": 114.42,
      "text": "\"'Let's.'"
    },
    {
      "start": 114.88,
      "end": 116.68,
      "text": "He took a sip from his glass."
    },
    {
      "start": 117.984,
      "end": 121.22,
      "text": "\"'This is going to be the most astounding thing you've ever heard of,",
      "para_break": true
    },
    {
      "start": 121.28,
      "end": 121.48,
      "text": "sir,"
    },
    {
      "start": 121.6,
      "end": 122.5,
      "text": "and I say"
    },
    {
      "start": 122.74,
      "end": 124.76,
      "text": "that knowing that a man of your caliber in"
    },
    {
      "start": 124.76,
      "end": 126.8,
      "text": "your profession must have run across a lot"
    },
    {
      "start": 126.8,
      "end": 127.6,
      "text": "of things.'"
    },
    {
      "start": 128.736,
      "end": 129.9,
      "text": "Spade nodded politely.",
      "para_break": true
    },
    {
      "start": 130.44,
      "end": 132.7,
      "text": "The fat man screwed up his eyes and asked,"
    },
    {
      "start": 133.74,
      "end": 134.48,
      "text": "What do you know,",
      "para_break": true
    },
    {
      "start": 134.64,
      "end": 134.84,
      "text": "sir,"
    },
    {
      "start": 135.0,
      "end": 137.1,
      "text": "about the order of the Hospital of St."
    },
    {
      "start": 137.24,
      "end": 138.08,
      "text": "John of Jerusalem,"
    },
    {
      "start": 138.52,
      "end": 140.96,
      "text": "later called the Knights of Rhodes and other things?"
    },
    {
      "start": 142.304,
      "end": 143.32,
      "text": "Spade waved his cigar.",
      "para_break": true
    },
    {
      "start": 144.48,
      "end": 144.98,
      "text": "Not much,",
      "para_break": true
    },
    {
      "start": 145.12,
      "end": 147.42,
      "text": "only what I can remember from history in school."
    },
    {
      "start": 148.32,
      "end": 149.28,
      "text": "Crusaders or something.",
      "para_break": true
    },
    {
      "start": 150.24,
      "end": 150.66,
      "text": "Very good.",
      "para_break": true
    },
    {
      "start": 151.1,
      "end": 151.3,
      "text": "Now,"
    },
    {
      "start": 151.4,
      "end": 153.34,
      "text": "you don't remember that Suleiman the"
    },
    {
      "start": 153.34,
      "end": 155.97,
      "text": "Magnificent chased them out of Rhodes in 1523?"
    },
    {
      "start": 156.84,
      "end": 157.46,
      "text": "No.",
      "para_break": true
    },
    {
      "start": 157.92,
      "end": 158.32,
      "text": "Well,"
    },
    {
      "start": 158.36,
      "end": 158.6,
      "text": "sir,"
    },
    {
      "start": 158.7,
      "end": 159.2,
      "text": "he did,"
    },
    {
      "start": 159.76,
      "end": 160.94,
      "text": "and they settled in Crete."
    },
    {
      "start": 161.568,
      "end": 164.84,
      "text": "And they stayed there for seven years until 1530,"
    },
    {
      "start": 165.02,
      "end": 168.1,
      "text": "when they persuaded the Emperor Charles V to give"
    },
    {
      "start": 168.73,
      "end": 172.15,
      "text": "them—Gutman held up three puffy fingers and counted them—Malta,"
    },
    {
      "start": 172.92,
      "end": 173.56,
      "text": "Gozo,",
      "para_break": true
    },
    {
      "start": 173.66,
      "end": 174.4,
      "text": "and Tripoli."
    },
    {
      "start": 175.46,
      "end": 175.72,
      "text": "Yes.",
      "para_break": true
    },
    {
      "start": 176.02,
      "end": 177.16,
      "text": "Yes,"
    },
    {
      "start": 177.3,
      "end": 177.4,
      "text": "sir."
    },
    {
      "start": 177.48,
      "end": 178.96,
      "text": "But with these conditions."
    },
    {
      "start": 179.26,
      "end": 182.54,
      "text": "They were to pay the Emperor each year the tribute of"
    },
    {
      "start": 183.44,
      "end": 185.56,
      "text": "one—he held up a finger—falcon in",
      "para_break": true
    },
    {
      "start": 185.56,
      "end": 188.14,
      "text": "acknowledgment that Malta was still under Spain,"
    },
    {
      "start": 188.53,
      "end": 189.44,
      "text": "and if they ever"
    },
    {
      "start": 189.6,
      "end": 191.72,
      "text": "left the island it was to revert to Spain."
    },
    {
      "start": 192.02,
      "end": 192.12,
      "text": "Understand?"
    },
    {
      "start": 193.61,
      "end": 195.06,
      "text": "He was giving it",
      "para_break": true
    },
    {
      "start": 195.06,
      "end": 195.38,
      "text": "to them,"
    },
    {
      "start": 195.48,
      "end": 197.36,
      "text": "but not unless they occupied it,"
    },
    {
      "start": 197.46,
      "end": 198.88,
      "text": "and they couldn't give it or"
    },
    {
      "start": 198.94,
      "end": 200.14,
      "text": "sell it to anybody else."
    },
    {
      "start": 201.22,
      "end": 201.78,
      "text": "Yes.",
      "para_break": true
    },
    {
      "start": 202.98,
      "end": 205.88,
      "text": "The fat man looked over his shoulders at the three closed doors,"
    },
    {
      "start": 206.3,
      "end": 209.06,
      "text": "hunched his chair a few inches closer to Spade's,"
    },
    {
      "start": 209.08,
      "end": 210.42,
      "text": "and reduced his voice"
    },
    {
      "start": 210.42,
      "end": 211.44,
      "text": "to a husky whisper."
    },
    {
      "start": 213.3,
      "end": 215.56,
      "text": "Have you any conception of the extreme,",
      "para_break": true
    },
    {
      "start": 215.84,
      "end": 217.64,
      "text": "the immeasurable wealth of the"
    },
    {
      "start": 217.68,
      "end": 218.54,
      "text": "order at that time?"
    },
    {
      "start": 220.0,
      "end": 220.64,
      "text": "\"'If I remember,",
      "para_break": true
    },
    {
      "start": 221.02,
      "end": 223.14,
      "text": "they were pretty well fixed,' Spade said."
    },
    {
      "start": 224.256,
      "end": 225.68,
      "text": "Gutman smiled indulgently.",
      "para_break": true
    },
    {
      "start": 226.784,
      "end": 227.26,
      "text": "\"'Pretty well,",
      "para_break": true
    },
    {
      "start": 227.28,
      "end": 227.5,
      "text": "sir,"
    },
    {
      "start": 227.6,
      "end": 228.96,
      "text": "is putting it mildly.'"
    },
    {
      "start": 230.22,
      "end": 232.26,
      "text": "His whisper became lower and harsher.",
      "para_break": true
    },
    {
      "start": 233.22,
      "end": 234.48,
      "text": "\"'They were rolling in wealth,",
      "para_break": true
    },
    {
      "start": 234.54,
      "end": 234.8,
      "text": "sir."
    },
    {
      "start": 235.24,
      "end": 236.32,
      "text": "You have no idea."
    },
    {
      "start": 236.75,
      "end": 238.6,
      "text": "None of us has any idea."
    },
    {
      "start": 239.328,
      "end": 241.8,
      "text": "For years they had preyed on the Saracens,",
      "para_break": true
    },
    {
      "start": 242.32,
      "end": 245.06,
      "text": "had taken God-only-knows-what spoils in gems,"
    },
    {
      "start": 245.48,
      "end": 246.24,
      "text": "precious metals,"
    },
    {
      "start": 246.4,
      "end": 246.84,
      "text": "silks,"
    },
    {
      "start": 246.9,
      "end": 247.7,
      "text": "ivories,"
    },
    {
      "start": 247.74,
      "end": 249.66,
      "text": "the top-cream luxuries of the East."
    }
  ]
}
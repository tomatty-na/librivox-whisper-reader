{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-17",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_17_hammett.mp3",
  "chapter_title": "Chapter 17 - Saturday Night",
  "reader_name": "Mark Nelson",
  "page_num": 2,
  "page_total": 6,
  "page_start_sec": 271.86,
  "page_end_sec": 520.18,
  "para_gap_threshold": 0.729,
  "segments": [
    {
      "start": 271.86,
      "end": 272.34,
      "text": "He shook her."
    },
    {
      "start": 273.7,
      "end": 274.78,
      "text": "She moaned in protest,",
      "para_break": true
    },
    {
      "start": 275.1,
      "end": 276.82,
      "text": "but her lids went further up,"
    },
    {
      "start": 277.3,
      "end": 279.54,
      "text": "though her eyes still were without inner light."
    },
    {
      "start": 280.46,
      "end": 282.44,
      "text": "He raised his hand and slapped her cheek",
      "para_break": true
    },
    {
      "start": 282.44,
      "end": 284.26,
      "text": "half a dozen times in quick succession."
    },
    {
      "start": 285.42,
      "end": 287.82,
      "text": "She moaned again and tried to break away from him.",
      "para_break": true
    },
    {
      "start": 288.48,
      "end": 289.4,
      "text": "His arm held her,"
    },
    {
      "start": 289.46,
      "end": 290.64,
      "text": "swept her along beside"
    },
    {
      "start": 290.72,
      "end": 291.9,
      "text": "him from wall to wall."
    },
    {
      "start": 293.344,
      "end": 295.88,
      "text": "\"'Keep walking,' he ordered in a harsh voice,",
      "para_break": true
    },
    {
      "start": 295.96,
      "end": 296.24,
      "text": "and then,"
    },
    {
      "start": 296.82,
      "end": 297.34,
      "text": "\"'Who are you?'"
    },
    {
      "start": 297.36,
      "end": 297.36,
      "text": "you."
    },
    {
      "start": 298.74,
      "end": 301.26,
      "text": "Her Rhea Gutman was thick but intelligible.",
      "para_break": true
    },
    {
      "start": 301.48,
      "end": 302.6,
      "text": "The daughter?"
    },
    {
      "start": 303.03,
      "end": 303.88,
      "text": "Yes."
    },
    {
      "start": 305.504,
      "end": 306.68,
      "text": "Now she was no farther"
    },
    {
      "start": 306.68,
      "end": 308.86,
      "text": "from the final consonant than Sh...."
    },
    {
      "start": 310.176,
      "end": 310.8,
      "text": "Where's Bridget?"
    },
    {
      "start": 311.98,
      "end": 313.76,
      "text": "She twisted convulsively around in",
      "para_break": true
    },
    {
      "start": 313.76,
      "end": 316.74,
      "text": "his arms and caught at one of his hands with both of hers."
    },
    {
      "start": 317.98,
      "end": 319.24,
      "text": "He pulled his hand away quickly",
      "para_break": true
    },
    {
      "start": 319.42,
      "end": 320.1,
      "text": "and looked at it."
    },
    {
      "start": 320.672,
      "end": 323.2,
      "text": "Across its back was a thin red scratch,"
    },
    {
      "start": 323.56,
      "end": 325.04,
      "text": "an inch and a half or more in"
    },
    {
      "start": 325.18,
      "end": 325.4,
      "text": "length."
    },
    {
      "start": 326.88,
      "end": 330.04,
      "text": "\"'What the hell?' he growled and examined her hands.",
      "para_break": true
    },
    {
      "start": 330.752,
      "end": 331.98,
      "text": "Her left hand was empty."
    },
    {
      "start": 333.1,
      "end": 333.6,
      "text": "In her right",
      "para_break": true
    },
    {
      "start": 333.6,
      "end": 333.8,
      "text": "hand,"
    },
    {
      "start": 333.96,
      "end": 334.68,
      "text": "when he opened it,"
    },
    {
      "start": 334.78,
      "end": 337.6,
      "text": "lay a three-inch jade-headed steel bouquet pin."
    },
    {
      "start": 338.816,
      "end": 339.46,
      "text": "\"'What the hell?'",
      "para_break": true
    },
    {
      "start": 340.06,
      "end": 343.04,
      "text": "he growled again and held the pin up in front of her eyes."
    },
    {
      "start": 343.76,
      "end": 346.12,
      "text": "When she saw the pin she whimpered and"
    },
    {
      "start": 346.22,
      "end": 347.24,
      "text": "opened her dressing-gown."
    },
    {
      "start": 348.08,
      "end": 349.54,
      "text": "She pushed aside the cream-colored",
      "para_break": true
    },
    {
      "start": 349.54,
      "end": 351.48,
      "text": "pajama coat under it and showed him"
    },
    {
      "start": 351.64,
      "end": 353.28,
      "text": "her body below her left breast,"
    },
    {
      "start": 353.56,
      "end": 356.64,
      "text": "white flesh crisscrossed with thin red lines,"
    },
    {
      "start": 356.86,
      "end": 357.62,
      "text": "dotted with"
    },
    {
      "start": 357.72,
      "end": 358.54,
      "text": "tiny red dots,"
    },
    {
      "start": 358.78,
      "end": 361.2,
      "text": "where the pin had scratched and punctured it."
    },
    {
      "start": 362.4,
      "end": 363.36,
      "text": "\"'To keep me awake.",
      "para_break": true
    },
    {
      "start": 364.16,
      "end": 364.64,
      "text": "To walk.",
      "para_break": true
    },
    {
      "start": 364.88,
      "end": 365.92,
      "text": "Till you came."
    },
    {
      "start": 366.18,
      "end": 367.96,
      "text": "She said you'd come."
    },
    {
      "start": 368.16,
      "end": 370.74,
      "text": "You were so long coming.'"
    },
    {
      "start": 371.54,
      "end": 372.26,
      "text": "She swayed.",
      "para_break": true
    },
    {
      "start": 373.28,
      "end": 375.28,
      "text": "Spade tightened his arm around her and said,",
      "para_break": true
    },
    {
      "start": 375.93,
      "end": 376.58,
      "text": "\"'Walk.'"
    },
    {
      "start": 377.66,
      "end": 378.88,
      "text": "She fought against the arm,",
      "para_break": true
    },
    {
      "start": 379.02,
      "end": 380.58,
      "text": "squirming around to face him again."
    },
    {
      "start": 380.8,
      "end": 380.96,
      "text": "No."
    },
    {
      "start": 382.02,
      "end": 383.18,
      "text": "Tell you."
    },
    {
      "start": 383.36,
      "end": 384.3,
      "text": "Sleep."
    },
    {
      "start": 385.32,
      "end": 386.08,
      "text": "You go to her.",
      "para_break": true
    },
    {
      "start": 386.76,
      "end": 387.46,
      "text": "Bridget?"
    },
    {
      "start": 387.62,
      "end": 388.32,
      "text": "he demanded."
    },
    {
      "start": 389.24,
      "end": 389.52,
      "text": "Yes.",
      "para_break": true
    },
    {
      "start": 389.86,
      "end": 390.88,
      "text": "Took her."
    },
    {
      "start": 391.12,
      "end": 392.18,
      "text": "Burlingame."
    },
    {
      "start": 393.088,
      "end": 394.12,
      "text": "Twenty-six ancho.",
      "para_break": true
    },
    {
      "start": 394.34,
      "end": 395.24,
      "text": "Hurry."
    },
    {
      "start": 396.24,
      "end": 396.66,
      "text": "Too late.",
      "para_break": true
    },
    {
      "start": 397.47,
      "end": 399.5,
      "text": "Her head fell over on her shoulder.",
      "para_break": true
    },
    {
      "start": 400.512,
      "end": 401.94,
      "text": "Spade pushed her head up roughly.",
      "para_break": true
    },
    {
      "start": 402.86,
      "end": 403.38,
      "text": "Who took her?",
      "para_break": true
    },
    {
      "start": 403.46,
      "end": 404.08,
      "text": "Your father?"
    },
    {
      "start": 404.76,
      "end": 405.36,
      "text": "Yes."
    },
    {
      "start": 405.7,
      "end": 406.64,
      "text": "Wilmer."
    },
    {
      "start": 406.84,
      "end": 407.92,
      "text": "Cairo."
    },
    {
      "start": 408.56,
      "end": 412.12,
      "text": "She writhed and her eyelids twitched but did not open."
    },
    {
      "start": 413.32,
      "end": 413.76,
      "text": "Kill her!",
      "para_break": true
    },
    {
      "start": 414.98,
      "end": 417.6,
      "text": "Her head fell over again and again he pushed it up.",
      "para_break": true
    },
    {
      "start": 418.88,
      "end": 420.02,
      "text": "Who shot Jacobi?",
      "para_break": true
    },
    {
      "start": 421.04,
      "end": 422.64,
      "text": "She did not seem to hear the question.",
      "para_break": true
    },
    {
      "start": 423.38,
      "end": 425.22,
      "text": "She tried pitifully to hold her head up,",
      "para_break": true
    },
    {
      "start": 425.5,
      "end": 426.4,
      "text": "to open her eyes."
    },
    {
      "start": 427.06,
      "end": 427.52,
      "text": "She mumbled,"
    },
    {
      "start": 428.24,
      "end": 428.74,
      "text": "Go."
    },
    {
      "start": 429.64,
      "end": 430.02,
      "text": "She.",
      "para_break": true
    },
    {
      "start": 431.08,
      "end": 432.76,
      "text": "He shook her brutally.",
      "para_break": true
    },
    {
      "start": 433.888,
      "end": 435.16,
      "text": "Stay awake till the doctor comes.",
      "para_break": true
    },
    {
      "start": 436.52,
      "end": 438.58,
      "text": "Fear opened her eyes and pushed for a",
      "para_break": true
    },
    {
      "start": 438.58,
      "end": 440.24,
      "text": "moment the cloudiness from her face."
    },
    {
      "start": 441.1,
      "end": 441.34,
      "text": "No,",
      "para_break": true
    },
    {
      "start": 441.64,
      "end": 442.16,
      "text": "no,"
    },
    {
      "start": 442.96,
      "end": 443.92,
      "text": "she cried thickly.",
      "para_break": true
    },
    {
      "start": 443.98,
      "end": 444.66,
      "text": "Father,"
    },
    {
      "start": 444.92,
      "end": 445.62,
      "text": "kill me."
    },
    {
      "start": 445.72,
      "end": 447.24,
      "text": "Swear you won't."
    },
    {
      "start": 447.84,
      "end": 449.94,
      "text": "He'd know I did for her."
    },
    {
      "start": 450.976,
      "end": 451.92,
      "text": "Promise you won't.",
      "para_break": true
    },
    {
      "start": 452.8,
      "end": 454.06,
      "text": "Sleep all right,",
      "para_break": true
    },
    {
      "start": 454.12,
      "end": 454.7,
      "text": "morning."
    },
    {
      "start": 455.73,
      "end": 456.94,
      "text": "He shook her again.",
      "para_break": true
    },
    {
      "start": 458.24,
      "end": 459.98,
      "text": "You're sure you can sleep at off all right?",
      "para_break": true
    },
    {
      "start": 460.1,
      "end": 460.2,
      "text": "Yeah."
    },
    {
      "start": 462.08,
      "end": 463.26,
      "text": "Her head fell down.",
      "para_break": true
    },
    {
      "start": 464.54,
      "end": 464.96,
      "text": "Where's your bed?",
      "para_break": true
    },
    {
      "start": 465.9,
      "end": 467.04,
      "text": "She tried to raise a hand,",
      "para_break": true
    },
    {
      "start": 467.12,
      "end": 469.32,
      "text": "but the effort had become too much for her before"
    },
    {
      "start": 469.32,
      "end": 471.56,
      "text": "the hand pointed at anything except the floor."
    },
    {
      "start": 472.54,
      "end": 474.12,
      "text": "With a sigh of a tired child,",
      "para_break": true
    },
    {
      "start": 474.32,
      "end": 476.64,
      "text": "she let her whole body relax and crumple."
    },
    {
      "start": 477.984,
      "end": 479.42,
      "text": "Spade caught her up in his arms,",
      "para_break": true
    },
    {
      "start": 479.62,
      "end": 481.02,
      "text": "scooped her up as she sank,"
    },
    {
      "start": 481.1,
      "end": 481.34,
      "text": "and,"
    },
    {
      "start": 481.36,
      "end": 483.02,
      "text": "holding her easily against his chest,"
    },
    {
      "start": 483.28,
      "end": 485.1,
      "text": "went to the nearest of the three doors."
    },
    {
      "start": 486.15,
      "end": 488.8,
      "text": "He turned the knob far enough to release the catch,",
      "para_break": true
    },
    {
      "start": 489.06,
      "end": 489.72,
      "text": "pushed the door"
    },
    {
      "start": 489.72,
      "end": 490.54,
      "text": "open with his foot,"
    },
    {
      "start": 490.68,
      "end": 493.3,
      "text": "and went into a passageway that ran past an open"
    },
    {
      "start": 493.42,
      "end": 494.72,
      "text": "bathroom door to a bedroom."
    },
    {
      "start": 495.17,
      "end": 496.78,
      "text": "He looked into the bathroom,"
    },
    {
      "start": 497.04,
      "end": 497.6,
      "text": "saw it was"
    },
    {
      "start": 497.68,
      "end": 497.92,
      "text": "empty,"
    },
    {
      "start": 498.06,
      "end": 499.74,
      "text": "and carried the girl into the bedroom."
    },
    {
      "start": 500.8,
      "end": 501.5,
      "text": "Nobody was there,",
      "para_break": true
    },
    {
      "start": 501.72,
      "end": 502.18,
      "text": "but the"
    },
    {
      "start": 502.24,
      "end": 503.74,
      "text": "clothing that was visible and the"
    },
    {
      "start": 503.74,
      "end": 505.58,
      "text": "things on the chiffonier said it was"
    },
    {
      "start": 505.58,
      "end": 506.26,
      "text": "a man's room."
    },
    {
      "start": 507.552,
      "end": 509.88,
      "text": "Spade carried the girl back to the green-carpeted room",
      "para_break": true
    },
    {
      "start": 510.1,
      "end": 511.36,
      "text": "and tried the opposite door."
    },
    {
      "start": 512.76,
      "end": 514.08,
      "text": "Through it he passed into another",
      "para_break": true
    },
    {
      "start": 514.54,
      "end": 514.92,
      "text": "passageway,"
    },
    {
      "start": 515.0,
      "end": 516.78,
      "text": "past another empty bathroom,"
    },
    {
      "start": 516.98,
      "end": 518.78,
      "text": "and into a bedroom that was"
    },
    {
      "start": 518.88,
      "end": 520.18,
      "text": "feminine in its accessories."
    }
  ]
}
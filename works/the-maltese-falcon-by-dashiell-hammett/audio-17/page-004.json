{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-17",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_17_hammett.mp3",
  "chapter_title": "Chapter 17 - Saturday Night",
  "reader_name": "Mark Nelson",
  "page_num": 4,
  "page_total": 6,
  "page_start_sec": 762.98,
  "page_end_sec": 1007.12,
  "para_gap_threshold": 0.729,
  "segments": [
    {
      "start": 762.98,
      "end": 764.52,
      "text": "Putting his face close to the card,",
      "para_break": true
    },
    {
      "start": 764.72,
      "end": 766.32,
      "text": "Spade could see it was a"
    },
    {
      "start": 766.42,
      "end": 767.72,
      "text": "FOR SALE OR RENT sign."
    },
    {
      "start": 769.22,
      "end": 770.96,
      "text": "There was no gate between the posts.",
      "para_break": true
    },
    {
      "start": 772.224,
      "end": 774.28,
      "text": "Spade went up the cement walk to the house.",
      "para_break": true
    },
    {
      "start": 775.04,
      "end": 777.14,
      "text": "He stood still on the walk at the foot",
      "para_break": true
    },
    {
      "start": 777.14,
      "end": 778.84,
      "text": "of the porch steps for a long moment."
    },
    {
      "start": 779.72,
      "end": 781.06,
      "text": "No sound came from the house.",
      "para_break": true
    },
    {
      "start": 781.36,
      "end": 785.26,
      "text": "The house was dark except for another pale square card on its door."
    },
    {
      "start": 786.432,
      "end": 787.98,
      "text": "Spade went up to the door and listened.",
      "para_break": true
    },
    {
      "start": 788.54,
      "end": 789.7,
      "text": "He could hear nothing."
    },
    {
      "start": 790.26,
      "end": 792.42,
      "text": "He tried to look through the glass of the door."
    },
    {
      "start": 793.06,
      "end": 795.76,
      "text": "There was no curtain to keep his gaze out but inner darkness."
    },
    {
      "start": 796.94,
      "end": 799.06,
      "text": "He tiptoed to a window and then to another.",
      "para_break": true
    },
    {
      "start": 799.92,
      "end": 800.38,
      "text": "They,",
      "para_break": true
    },
    {
      "start": 800.52,
      "end": 801.2,
      "text": "like the door,"
    },
    {
      "start": 801.3,
      "end": 803.28,
      "text": "were uncurtained except by inner darkness."
    },
    {
      "start": 804.32,
      "end": 805.44,
      "text": "He tried both windows.",
      "para_break": true
    },
    {
      "start": 806.14,
      "end": 806.68,
      "text": "They were locked."
    },
    {
      "start": 807.38,
      "end": 808.24,
      "text": "He tried the door."
    },
    {
      "start": 808.62,
      "end": 809.16,
      "text": "It was locked."
    },
    {
      "start": 809.8,
      "end": 811.54,
      "text": "He left the porch and,"
    },
    {
      "start": 811.56,
      "end": 813.4,
      "text": "stepping carefully over unfamiliar ground,"
    },
    {
      "start": 813.8,
      "end": 815.54,
      "text": "walked through weeds around the house."
    },
    {
      "start": 816.42,
      "end": 818.52,
      "text": "The side windows were too high to be reached.",
      "para_break": true
    },
    {
      "start": 819.76,
      "end": 822.82,
      "text": "The back door and the one back window he could reach were locked.",
      "para_break": true
    },
    {
      "start": 824.128,
      "end": 825.96,
      "text": "Spade went back to the gate-post and,",
      "para_break": true
    },
    {
      "start": 826.02,
      "end": 827.48,
      "text": "cupping the flame between his hands,"
    },
    {
      "start": 828.12,
      "end": 830.28,
      "text": "held his lighter up to the for-sale or rent sign."
    },
    {
      "start": 831.36,
      "end": 832.86,
      "text": "It bore the printed name and address",
      "para_break": true
    },
    {
      "start": 832.86,
      "end": 834.66,
      "text": "of a San Mateo real estate dealer"
    },
    {
      "start": 834.9,
      "end": 836.58,
      "text": "and a line penciled in blue,"
    },
    {
      "start": 836.84,
      "end": 837.92,
      "text": "key at 31."
    },
    {
      "start": 838.84,
      "end": 841.84,
      "text": "Spade went back to the sedan and asked the chauffeur,",
      "para_break": true
    },
    {
      "start": 842.72,
      "end": 843.24,
      "text": "\"'Got a flashlight?'",
      "para_break": true
    },
    {
      "start": 843.74,
      "end": 844.6,
      "text": "\"'Sure.'"
    },
    {
      "start": 845.18,
      "end": 846.16,
      "text": "He gave it to Spade."
    },
    {
      "start": 847.46,
      "end": 849.0,
      "text": "\"'Can I give you a hand at anything?'",
      "para_break": true
    },
    {
      "start": 849.82,
      "end": 850.82,
      "text": "\"'Maybe.'",
      "para_break": true
    },
    {
      "start": 851.584,
      "end": 852.78,
      "text": "Spade got into the sedan.",
      "para_break": true
    },
    {
      "start": 854.336,
      "end": 855.24,
      "text": "\"'We'll ride up to No.",
      "para_break": true
    },
    {
      "start": 855.36,
      "end": 855.76,
      "text": "31."
    },
    {
      "start": 856.52,
      "end": 857.63,
      "text": "You can use your lights.'",
      "para_break": true
    },
    {
      "start": 858.25,
      "end": 859.1,
      "text": "No."
    },
    {
      "start": 859.24,
      "end": 862.52,
      "text": "31 was a square gray house across the street from,"
    },
    {
      "start": 862.6,
      "end": 863.94,
      "text": "but a little farther up than,"
    },
    {
      "start": 863.96,
      "end": 864.34,
      "text": "26."
    },
    {
      "start": 865.76,
      "end": 867.5,
      "text": "Lights glowed in its downstairs windows.",
      "para_break": true
    },
    {
      "start": 868.832,
      "end": 870.76,
      "text": "Spade went up on the porch and rang the bell.",
      "para_break": true
    },
    {
      "start": 871.06,
      "end": 872.72,
      "text": "A dark-haired girl of"
    },
    {
      "start": 872.8,
      "end": 874.42,
      "text": "fourteen or fifteen opened the door."
    },
    {
      "start": 875.02,
      "end": 875.7,
      "text": "Spade,"
    },
    {
      "start": 875.82,
      "end": 876.76,
      "text": "bowing and smiling,"
    },
    {
      "start": 876.96,
      "end": 877.2,
      "text": "said,"
    },
    {
      "start": 878.176,
      "end": 879.38,
      "text": "\"'I'd like to get the key to No.",
      "para_break": true
    },
    {
      "start": 879.54,
      "end": 879.89,
      "text": "26.'"
    },
    {
      "start": 881.62,
      "end": 883.04,
      "text": "\"'I'll call Papa,' she said,",
      "para_break": true
    },
    {
      "start": 883.18,
      "end": 884.5,
      "text": "and went back into the house,"
    },
    {
      "start": 884.54,
      "end": 884.84,
      "text": "calling,"
    },
    {
      "start": 885.36,
      "end": 885.96,
      "text": "\"'Papa!'"
    },
    {
      "start": 886.85,
      "end": 887.96,
      "text": "A plump,",
      "para_break": true
    },
    {
      "start": 887.98,
      "end": 888.86,
      "text": "red-faced man,"
    },
    {
      "start": 889.06,
      "end": 890.82,
      "text": "bald-headed and heavily mustached,"
    },
    {
      "start": 890.86,
      "end": 891.14,
      "text": "appeared"
    },
    {
      "start": 891.34,
      "end": 892.12,
      "text": "carrying a newspaper."
    },
    {
      "start": 893.376,
      "end": 893.82,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 893.94,
      "end": 896.36,
      "text": "\"'I'd like to get the key to 26.'"
    },
    {
      "start": 897.92,
      "end": 899.07,
      "text": "The Plump Man looked doubtful.",
      "para_break": true
    },
    {
      "start": 899.26,
      "end": 899.84,
      "text": "He said,"
    },
    {
      "start": 900.26,
      "end": 901.66,
      "text": "\"'The lights are not on."
    },
    {
      "start": 901.78,
      "end": 903.06,
      "text": "You couldn't see anything.'"
    },
    {
      "start": 903.968,
      "end": 905.1,
      "text": "Spade patted his pocket.",
      "para_break": true
    },
    {
      "start": 906.3,
      "end": 906.81,
      "text": "\"'I have a flashlight.'",
      "para_break": true
    },
    {
      "start": 907.64,
      "end": 910.06,
      "text": "The Plump Man looked more doubtful.",
      "para_break": true
    },
    {
      "start": 910.48,
      "end": 912.5,
      "text": "He cleared his throat uneasily and"
    },
    {
      "start": 912.5,
      "end": 914.12,
      "text": "crumpled the newspaper in his hand."
    },
    {
      "start": 915.104,
      "end": 917.1,
      "text": "Spade showed the man one of his business cards,",
      "para_break": true
    },
    {
      "start": 917.44,
      "end": 918.58,
      "text": "put it back in his pocket,"
    },
    {
      "start": 918.68,
      "end": 920.1,
      "text": "and said in a low voice,"
    },
    {
      "start": 921.32,
      "end": 923.81,
      "text": "\"'We got a tip there might be something hidden over there.'",
      "para_break": true
    },
    {
      "start": 924.56,
      "end": 927.12,
      "text": "The Plump Man's face and voice were eager.",
      "para_break": true
    },
    {
      "start": 928.256,
      "end": 929.4,
      "text": "\"'Wait a minute,' he said.",
      "para_break": true
    },
    {
      "start": 929.9,
      "end": 930.816,
      "text": "\"'I'll go over with you.'"
    },
    {
      "start": 931.41,
      "end": 933.0,
      "text": "When he came back a moment later,"
    },
    {
      "start": 933.12,
      "end": 936.06,
      "text": "he carried a brass key attached to a yellow and red tag."
    },
    {
      "start": 936.992,
      "end": 939.3,
      "text": "Spade beckoned to the chauffeur as they passed the sedan,",
      "para_break": true
    },
    {
      "start": 939.5,
      "end": 940.84,
      "text": "and the chauffeur joined them."
    },
    {
      "start": 942.56,
      "end": 945.36,
      "text": "\"'Anybody been looking at the house lately?' Spade asked.",
      "para_break": true
    },
    {
      "start": 946.208,
      "end": 948.24,
      "text": "\"'Not that I know of,' the plump man replied.",
      "para_break": true
    },
    {
      "start": 949.216,
      "end": 951.51,
      "text": "\"'Nobody's been to me for the key in a couple of months.'",
      "para_break": true
    },
    {
      "start": 952.6,
      "end": 954.22,
      "text": "The plump man marched ahead with the key",
      "para_break": true
    },
    {
      "start": 954.36,
      "end": 955.72,
      "text": "until they had gone up on the porch."
    },
    {
      "start": 956.04,
      "end": 958.58,
      "text": "Then he thrust it into Spade's hand,"
    },
    {
      "start": 958.76,
      "end": 959.14,
      "text": "mumbled,"
    },
    {
      "start": 959.9,
      "end": 960.36,
      "text": "Here you are,",
      "para_break": true
    },
    {
      "start": 960.46,
      "end": 961.38,
      "text": "and stepped aside."
    },
    {
      "start": 962.688,
      "end": 964.48,
      "text": "Spade unlocked the door and pushed it open.",
      "para_break": true
    },
    {
      "start": 965.48,
      "end": 966.82,
      "text": "There was silence and darkness.",
      "para_break": true
    },
    {
      "start": 968.38,
      "end": 969.1,
      "text": "Holding the flashlight,",
      "para_break": true
    },
    {
      "start": 969.4,
      "end": 970.58,
      "text": "dark in his left hand,"
    },
    {
      "start": 970.72,
      "end": 971.52,
      "text": "Spade went in."
    },
    {
      "start": 972.2,
      "end": 974.24,
      "text": "The chauffeur came close behind him,"
    },
    {
      "start": 974.3,
      "end": 975.1,
      "text": "and then,"
    },
    {
      "start": 975.12,
      "end": 976.0,
      "text": "at a little distance,"
    },
    {
      "start": 976.22,
      "end": 977.42,
      "text": "the plump man followed them."
    },
    {
      "start": 978.28,
      "end": 980.34,
      "text": "They searched the house from bottom to top,",
      "para_break": true
    },
    {
      "start": 980.63,
      "end": 981.92,
      "text": "cautiously at first,"
    },
    {
      "start": 982.14,
      "end": 983.22,
      "text": "then finding nothing,"
    },
    {
      "start": 983.42,
      "end": 983.94,
      "text": "boldly."
    },
    {
      "start": 984.33,
      "end": 985.86,
      "text": "The house was empty,"
    },
    {
      "start": 986.02,
      "end": 986.88,
      "text": "unmistakably,"
    },
    {
      "start": 987.2,
      "end": 989.64,
      "text": "and there was nothing to show that it had been visited"
    },
    {
      "start": 989.64,
      "end": 990.22,
      "text": "in weeks."
    },
    {
      "start": 994.176,
      "end": 994.72,
      "text": "Spade saying,",
      "para_break": true
    },
    {
      "start": 994.98,
      "end": 995.66,
      "text": "that's all,"
    },
    {
      "start": 995.7,
      "end": 996.0,
      "text": "thanks,"
    },
    {
      "start": 996.14,
      "end": 997.26,
      "text": "and good night,"
    },
    {
      "start": 997.49,
      "end": 999.38,
      "text": "left the sedan in front of the Alexandria."
    },
    {
      "start": 1000.74,
      "end": 1002.82,
      "text": "He went into the hotel to the desk where a",
      "para_break": true
    },
    {
      "start": 1002.82,
      "end": 1005.26,
      "text": "tall young man with a dark gray face said,"
    },
    {
      "start": 1006.08,
      "end": 1006.48,
      "text": "good evening,",
      "para_break": true
    },
    {
      "start": 1006.54,
      "end": 1006.72,
      "text": "Mr."
    },
    {
      "start": 1006.8,
      "end": 1007.12,
      "text": "Spade."
    }
  ]
}
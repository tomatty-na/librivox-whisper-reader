{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-17",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_17_hammett.mp3",
  "chapter_title": "Chapter 17 - Saturday Night",
  "reader_name": "Mark Nelson",
  "page_num": 6,
  "page_total": 6,
  "page_start_sec": 1249.28,
  "page_end_sec": 1354.22,
  "para_gap_threshold": 0.729,
  "segments": [
    {
      "start": 1249.28,
      "end": 1250.14,
      "text": "She put her arms around",
      "para_break": true
    },
    {
      "start": 1250.14,
      "end": 1251.24,
      "text": "him and hung on him,"
    },
    {
      "start": 1251.26,
      "end": 1251.74,
      "text": "panting,"
    },
    {
      "start": 1251.76,
      "end": 1252.0,
      "text": "Oh,"
    },
    {
      "start": 1252.42,
      "end": 1253.76,
      "text": "I thought you'd never come."
    },
    {
      "start": 1254.5,
      "end": 1255.5,
      "text": "Her face was wan,",
      "para_break": true
    },
    {
      "start": 1255.74,
      "end": 1256.34,
      "text": "distraught,"
    },
    {
      "start": 1256.46,
      "end": 1259.22,
      "text": "shaken by the tremors that shook her from head to foot."
    },
    {
      "start": 1260.2,
      "end": 1261.88,
      "text": "With the hand not supporting her,",
      "para_break": true
    },
    {
      "start": 1261.98,
      "end": 1263.32,
      "text": "he felt for the key again,"
    },
    {
      "start": 1263.52,
      "end": 1264.4,
      "text": "opened the door,"
    },
    {
      "start": 1264.5,
      "end": 1264.96,
      "text": "and half"
    },
    {
      "start": 1265.06,
      "end": 1265.8,
      "text": "lifted her inside."
    },
    {
      "start": 1267.552,
      "end": 1268.18,
      "text": "You've been waiting?",
      "para_break": true
    },
    {
      "start": 1268.66,
      "end": 1269.0,
      "text": "he asked."
    },
    {
      "start": 1269.33,
      "end": 1272.18,
      "text": "\"'Yes,' Panting spaced her words."
    },
    {
      "start": 1272.36,
      "end": 1276.0,
      "text": "\"'In a doorway up the street.'"
    },
    {
      "start": 1277.04,
      "end": 1278.26,
      "text": "\"'Make it all right,' he asked.",
      "para_break": true
    },
    {
      "start": 1278.36,
      "end": 1279.936,
      "text": "\"'Or shall I carry you up?'"
    },
    {
      "start": 1280.78,
      "end": 1282.3,
      "text": "She shook her head against his shoulder.",
      "para_break": true
    },
    {
      "start": 1283.5,
      "end": 1288.07,
      "text": "\"'I'll be all right when I get where I can sit down.'",
      "para_break": true
    },
    {
      "start": 1288.87,
      "end": 1290.88,
      "text": "They rode up to Spade's floor in the",
      "para_break": true
    },
    {
      "start": 1290.88,
      "end": 1292.64,
      "text": "elevator and went around to his apartment."
    },
    {
      "start": 1293.05,
      "end": 1295.64,
      "text": "She left his arm and stood beside him,"
    },
    {
      "start": 1295.66,
      "end": 1296.22,
      "text": "panting,"
    },
    {
      "start": 1296.24,
      "end": 1297.42,
      "text": "both hands to her"
    },
    {
      "start": 1297.54,
      "end": 1297.86,
      "text": "breast,"
    },
    {
      "start": 1297.96,
      "end": 1299.46,
      "text": "while he unlocked his door."
    },
    {
      "start": 1299.83,
      "end": 1301.78,
      "text": "He switched on the passageway"
    },
    {
      "start": 1301.86,
      "end": 1302.0,
      "text": "light."
    },
    {
      "start": 1302.41,
      "end": 1303.38,
      "text": "They went in."
    },
    {
      "start": 1304.23,
      "end": 1305.4,
      "text": "He shut the door,",
      "para_break": true
    },
    {
      "start": 1305.58,
      "end": 1306.82,
      "text": "and with his arm around her"
    },
    {
      "start": 1306.92,
      "end": 1307.18,
      "text": "again,"
    },
    {
      "start": 1307.26,
      "end": 1309.14,
      "text": "half carried her toward the living-room."
    },
    {
      "start": 1310.36,
      "end": 1311.02,
      "text": "When they were within",
      "para_break": true
    },
    {
      "start": 1311.18,
      "end": 1312.46,
      "text": "a step of the living-room door,"
    },
    {
      "start": 1312.7,
      "end": 1314.1,
      "text": "the living-room light went on."
    },
    {
      "start": 1314.42,
      "end": 1314.97,
      "text": "The"
    },
    {
      "start": 1315.2,
      "end": 1316.92,
      "text": "girl cried out and clung to Spade."
    },
    {
      "start": 1318.336,
      "end": 1319.74,
      "text": "Just inside the living-room door,",
      "para_break": true
    },
    {
      "start": 1320.0,
      "end": 1323.06,
      "text": "fat Gutman stood smiling benevolently at them."
    },
    {
      "start": 1324.04,
      "end": 1326.1,
      "text": "The undersized youth Gutman had called Wilmer",
      "para_break": true
    },
    {
      "start": 1326.28,
      "end": 1327.72,
      "text": "came out of the kitchen behind them."
    },
    {
      "start": 1328.48,
      "end": 1331.08,
      "text": "Black pistols were gigantic in his small hands.",
      "para_break": true
    },
    {
      "start": 1332.192,
      "end": 1333.56,
      "text": "Cairo came out of the bathroom.",
      "para_break": true
    },
    {
      "start": 1333.88,
      "end": 1334.46,
      "text": "He,"
    },
    {
      "start": 1334.56,
      "end": 1334.82,
      "text": "too,"
    },
    {
      "start": 1334.94,
      "end": 1335.54,
      "text": "had a pistol."
    },
    {
      "start": 1336.8,
      "end": 1337.26,
      "text": "Gutman said,",
      "para_break": true
    },
    {
      "start": 1337.84,
      "end": 1338.36,
      "text": "\"'Well,"
    },
    {
      "start": 1338.5,
      "end": 1338.76,
      "text": "sir,"
    },
    {
      "start": 1338.92,
      "end": 1340.76,
      "text": "we're all here as you can see."
    },
    {
      "start": 1341.568,
      "end": 1343.86,
      "text": "Now let's come in and sit down and be comfortable",
      "para_break": true
    },
    {
      "start": 1344.24,
      "end": 1345.248,
      "text": "and talk.'\""
    },
    {
      "start": 1347.86,
      "end": 1348.9,
      "text": "End of chapter 17",
      "para_break": true
    },
    {
      "start": 1349.86,
      "end": 1354.22,
      "text": "Thank you.",
      "para_break": true
    }
  ]
}
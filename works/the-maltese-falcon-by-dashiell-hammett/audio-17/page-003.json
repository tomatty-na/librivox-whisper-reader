{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-17",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_17_hammett.mp3",
  "chapter_title": "Chapter 17 - Saturday Night",
  "reader_name": "Mark Nelson",
  "page_num": 3,
  "page_total": 6,
  "page_start_sec": 521.5,
  "page_end_sec": 762.02,
  "para_gap_threshold": 0.729,
  "segments": [
    {
      "start": 521.5,
      "end": 523.26,
      "text": "He turned back the bedclothes and laid the",
      "para_break": true
    },
    {
      "start": 523.26,
      "end": 524.0,
      "text": "girl on the bed,"
    },
    {
      "start": 524.672,
      "end": 525.54,
      "text": "removed her slippers,"
    },
    {
      "start": 526.208,
      "end": 527.56,
      "text": "raised her a little to slide the"
    },
    {
      "start": 527.56,
      "end": 528.64,
      "text": "yellow dressing-gown off,"
    },
    {
      "start": 528.98,
      "end": 531.26,
      "text": "fixed a pillow under her head and put the"
    },
    {
      "start": 531.3,
      "end": 532.24,
      "text": "covers up over her."
    },
    {
      "start": 533.58,
      "end": 535.8,
      "text": "Then he opened the room's two windows and stood with",
      "para_break": true
    },
    {
      "start": 535.9,
      "end": 536.56,
      "text": "his back to them,"
    },
    {
      "start": 536.68,
      "end": 538.3,
      "text": "staring at the sleeping girl."
    },
    {
      "start": 538.73,
      "end": 540.2,
      "text": "Her breathing was heavy"
    },
    {
      "start": 540.42,
      "end": 541.16,
      "text": "but not troubled."
    },
    {
      "start": 541.44,
      "end": 543.2,
      "text": "He frowned and looked around,"
    },
    {
      "start": 543.48,
      "end": 544.64,
      "text": "working his lips together."
    },
    {
      "start": 545.76,
      "end": 546.78,
      "text": "Twilight was dimming",
      "para_break": true
    },
    {
      "start": 546.78,
      "end": 547.12,
      "text": "the room."
    },
    {
      "start": 547.44,
      "end": 551.0,
      "text": "He stood there in the weakening light for perhaps five minutes."
    },
    {
      "start": 552.064,
      "end": 553.3,
      "text": "Finally he shook his",
      "para_break": true
    },
    {
      "start": 553.4,
      "end": 555.94,
      "text": "thick sloping shoulders impatiently and went out,"
    },
    {
      "start": 556.06,
      "end": 557.8,
      "text": "leaving the outer door unlocked."
    },
    {
      "start": 560.096,
      "end": 561.88,
      "text": "Spade went to the Pacific Telephone and",
      "para_break": true
    },
    {
      "start": 561.88,
      "end": 563.54,
      "text": "Telegraph Company's Powell Street station"
    },
    {
      "start": 563.88,
      "end": 564.94,
      "text": "and called Davenport,"
    },
    {
      "start": 565.08,
      "end": 565.4,
      "text": "2020."
    },
    {
      "start": 567.552,
      "end": 568.24,
      "text": "Emergency hospital,",
      "para_break": true
    },
    {
      "start": 568.44,
      "end": 568.74,
      "text": "please."
    },
    {
      "start": 569.66,
      "end": 569.9,
      "text": "Hello,",
      "para_break": true
    },
    {
      "start": 570.12,
      "end": 573.34,
      "text": "there's a girl in suite 12C at the Alexandria Hotel"
    },
    {
      "start": 573.34,
      "end": 574.48,
      "text": "who has been drugged."
    },
    {
      "start": 574.94,
      "end": 575.34,
      "text": "Yes,"
    },
    {
      "start": 575.5,
      "end": 577.34,
      "text": "you'd better send somebody to take a look at her."
    },
    {
      "start": 577.98,
      "end": 578.26,
      "text": "Yes,"
    },
    {
      "start": 578.36,
      "end": 578.92,
      "text": "this is Mr."
    },
    {
      "start": 579.08,
      "end": 580.02,
      "text": "Hooper of the Alexandria."
    },
    {
      "start": 581.07,
      "end": 583.48,
      "text": "He put the receiver on its prong and laughed.",
      "para_break": true
    },
    {
      "start": 584.384,
      "end": 586.04,
      "text": "He called another number and said,",
      "para_break": true
    },
    {
      "start": 586.56,
      "end": 587.04,
      "text": "Hello,"
    },
    {
      "start": 587.08,
      "end": 587.32,
      "text": "Frank,"
    },
    {
      "start": 587.5,
      "end": 588.72,
      "text": "this is Sam Spade."
    },
    {
      "start": 589.5,
      "end": 592.04,
      "text": "Can you let me have a car to go down the peninsula right away?",
      "para_break": true
    },
    {
      "start": 592.44,
      "end": 593.8,
      "text": "Just a couple of hours."
    },
    {
      "start": 594.56,
      "end": 596.54,
      "text": "And give me a driver that will keep his mouth shut,",
      "para_break": true
    },
    {
      "start": 596.62,
      "end": 597.12,
      "text": "will you?\""
    },
    {
      "start": 597.8,
      "end": 597.94,
      "text": "Right."
    },
    {
      "start": 598.63,
      "end": 600.37,
      "text": "Have him pick me up at John's,"
    },
    {
      "start": 600.44,
      "end": 600.96,
      "text": "Ellis Street,"
    },
    {
      "start": 601.12,
      "end": 602.432,
      "text": "as soon as he can make it.\""
    },
    {
      "start": 603.4,
      "end": 604.44,
      "text": "He called another number,",
      "para_break": true
    },
    {
      "start": 604.54,
      "end": 605.4,
      "text": "his own offices,"
    },
    {
      "start": 605.78,
      "end": 607.62,
      "text": "held the receiver to his ear for a little"
    },
    {
      "start": 607.72,
      "end": 608.86,
      "text": "while without saying anything,"
    },
    {
      "start": 609.1,
      "end": 610.46,
      "text": "and replaced it on its hook."
    },
    {
      "start": 611.46,
      "end": 613.08,
      "text": "He went to John's Grill,",
      "para_break": true
    },
    {
      "start": 613.4,
      "end": 615.6,
      "text": "asked the waiter to hurry his order of chops,"
    },
    {
      "start": 615.86,
      "end": 616.46,
      "text": "baked potato,"
    },
    {
      "start": 616.56,
      "end": 617.31,
      "text": "and sliced tomatoes,"
    },
    {
      "start": 617.68,
      "end": 618.9,
      "text": "ate hurriedly,"
    },
    {
      "start": 618.9,
      "end": 620.86,
      "text": "and was smoking a cigarette with his coffee,"
    },
    {
      "start": 621.3,
      "end": 623.14,
      "text": "when a thick-set youngish man,"
    },
    {
      "start": 623.32,
      "end": 626.44,
      "text": "with a plaid cap set askew above pale eyes and a tough,"
    },
    {
      "start": 626.62,
      "end": 627.08,
      "text": "cheery face,"
    },
    {
      "start": 627.4,
      "end": 629.58,
      "text": "came into the grill and to his table."
    },
    {
      "start": 631.08,
      "end": 631.44,
      "text": "\"'All set,",
      "para_break": true
    },
    {
      "start": 631.56,
      "end": 631.66,
      "text": "Mr."
    },
    {
      "start": 631.8,
      "end": 632.08,
      "text": "Spade."
    },
    {
      "start": 632.22,
      "end": 634.26,
      "text": "She's full of gas and raring to go.'"
    },
    {
      "start": 635.14,
      "end": 638.94,
      "text": "\"'Swell.' Spade emptied his cup and went out with the thick-set man.",
      "para_break": true
    },
    {
      "start": 640.192,
      "end": 643.74,
      "text": "\"'Know where Anchoe Avenue or Road or Boulevard is in Burlingame?'",
      "para_break": true
    },
    {
      "start": 644.32,
      "end": 644.82,
      "text": "\"'Nope,"
    },
    {
      "start": 644.86,
      "end": 646.42,
      "text": "but if she's there we can find her.'"
    },
    {
      "start": 647.03,
      "end": 648.04,
      "text": "Let's do that,"
    },
    {
      "start": 648.24,
      "end": 652.36,
      "text": "Spade said as he sat beside the chauffeur in a dark Cadillac sedan."
    },
    {
      "start": 653.952,
      "end": 655.48,
      "text": "Twenty-six is the number we want,",
      "para_break": true
    },
    {
      "start": 655.58,
      "end": 656.72,
      "text": "and the sooner the better,"
    },
    {
      "start": 656.99,
      "end": 658.52,
      "text": "but we don't want to pull up at the"
    },
    {
      "start": 658.52,
      "end": 659.02,
      "text": "front door."
    },
    {
      "start": 659.28,
      "end": 659.38,
      "text": "Correct."
    },
    {
      "start": 661.5,
      "end": 662.74,
      "text": "They rode a half-dozen blocks.",
      "para_break": true
    },
    {
      "start": 663.18,
      "end": 664.38,
      "text": "The chauffeur said,"
    },
    {
      "start": 665.38,
      "end": 666.78,
      "text": "Your partner got knocked off,",
      "para_break": true
    },
    {
      "start": 666.88,
      "end": 667.24,
      "text": "didn't he?"
    },
    {
      "start": 668.08,
      "end": 668.36,
      "text": "Uh-huh.",
      "para_break": true
    },
    {
      "start": 668.46,
      "end": 670.52,
      "text": "The chauffeur clucked."
    },
    {
      "start": 670.75,
      "end": 671.92,
      "text": "She's a tough racket."
    },
    {
      "start": 672.38,
      "end": 672.48,
      "text": "Well,"
    },
    {
      "start": 673.58,
      "end": 675.12,
      "text": "hack drivers don't live forever.",
      "para_break": true
    },
    {
      "start": 676.608,
      "end": 677.56,
      "text": "Maybe that's right,",
      "para_break": true
    },
    {
      "start": 678.14,
      "end": 679.55,
      "text": "the thick-set man conceded,"
    },
    {
      "start": 679.98,
      "end": 681.22,
      "text": "but just the same,"
    },
    {
      "start": 681.3,
      "end": 683.8,
      "text": "it'll always be a surprise to me if I don't."
    },
    {
      "start": 685.472,
      "end": 686.96,
      "text": "Spade stared ahead at nothing,",
      "para_break": true
    },
    {
      "start": 687.62,
      "end": 688.0,
      "text": "and thereafter,"
    },
    {
      "start": 688.58,
      "end": 690.98,
      "text": "until the chauffeur became tired of making conversation,"
    },
    {
      "start": 691.72,
      "end": 694.38,
      "text": "replied with uninterested yeses and noes.",
      "para_break": true
    },
    {
      "start": 696.72,
      "end": 697.94,
      "text": "At a drugstore in Burlingame,",
      "para_break": true
    },
    {
      "start": 698.1,
      "end": 700.1,
      "text": "the chauffeur learned how to reach Ancho Avenue."
    },
    {
      "start": 700.77,
      "end": 702.14,
      "text": "Ten minutes later,"
    },
    {
      "start": 702.18,
      "end": 704.3,
      "text": "he stopped the car near a dark corner,"
    },
    {
      "start": 704.72,
      "end": 705.78,
      "text": "turned off the lights,"
    },
    {
      "start": 705.84,
      "end": 707.5,
      "text": "and waved his hand at the block ahead."
    },
    {
      "start": 708.9,
      "end": 710.3,
      "text": "\"'There she is,' he said.",
      "para_break": true
    },
    {
      "start": 710.98,
      "end": 712.4,
      "text": "\"'She ought to be on the other side,"
    },
    {
      "start": 712.54,
      "end": 714.47,
      "text": "maybe the third or fourth house.'"
    },
    {
      "start": 715.584,
      "end": 716.08,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 717.0,
      "end": 717.4,
      "text": "\"'Right,'",
      "para_break": true
    },
    {
      "start": 718.1,
      "end": 719.04,
      "text": "and got out of the car."
    },
    {
      "start": 720.12,
      "end": 720.94,
      "text": "\"'Keep the engine going.",
      "para_break": true
    },
    {
      "start": 721.1,
      "end": 722.89,
      "text": "We might have to leave in a hurry.'"
    },
    {
      "start": 723.66,
      "end": 725.94,
      "text": "He crossed the street and went up the other side.",
      "para_break": true
    },
    {
      "start": 727.06,
      "end": 727.7,
      "text": "Night had settled.",
      "para_break": true
    },
    {
      "start": 728.02,
      "end": 730.7,
      "text": "Far ahead a lone streetlight burned."
    },
    {
      "start": 731.808,
      "end": 733.96,
      "text": "Warmer lights dotted the night on either side,",
      "para_break": true
    },
    {
      "start": 734.24,
      "end": 736.66,
      "text": "where houses were spaced half a dozen to a block."
    },
    {
      "start": 738.08,
      "end": 741.52,
      "text": "A high thin moon was cold and feeble as the distant streetlight.",
      "para_break": true
    },
    {
      "start": 742.44,
      "end": 744.42,
      "text": "A radio droned through the open window of",
      "para_break": true
    },
    {
      "start": 744.42,
      "end": 746.06,
      "text": "a house on the other side of the street."
    },
    {
      "start": 747.38,
      "end": 750.1,
      "text": "In front of the second house from the corner Spade halted.",
      "para_break": true
    },
    {
      "start": 751.16,
      "end": 753.28,
      "text": "On one of the gate-posts that were massive out",
      "para_break": true
    },
    {
      "start": 753.28,
      "end": 755.3,
      "text": "of all proportion to the fence flanking them,"
    },
    {
      "start": 755.44,
      "end": 759.0,
      "text": "a two and a six of pale metal caught what light there was."
    },
    {
      "start": 759.54,
      "end": 762.02,
      "text": "A square white card was nailed above them."
    }
  ]
}
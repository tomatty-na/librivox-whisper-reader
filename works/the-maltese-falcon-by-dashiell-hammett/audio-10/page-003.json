{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-10",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_10_hammett.mp3",
  "chapter_title": "Chapter 10 - The Belvedere Divan",
  "reader_name": "Mark Nelson",
  "page_num": 3,
  "page_total": 6,
  "page_start_sec": 492.672,
  "page_end_sec": 733.7,
  "para_gap_threshold": 0.74,
  "segments": [
    {
      "start": 492.672,
      "end": 493.5,
      "text": "\"'Shove off,'",
      "para_break": true
    },
    {
      "start": 494.1,
      "end": 495.68,
      "text": "he said from the side of his mouth."
    },
    {
      "start": 496.928,
      "end": 498.02,
      "text": "Spade lit his cigarette,",
      "para_break": true
    },
    {
      "start": 498.26,
      "end": 499.88,
      "text": "leaned back comfortably on the divan,"
    },
    {
      "start": 500.08,
      "end": 501.56,
      "text": "and spoke with good-humored"
    },
    {
      "start": 501.64,
      "end": 502.02,
      "text": "carelessness."
    },
    {
      "start": 503.616,
      "end": 505.44,
      "text": "\"'You'll have to talk to me before you're through,",
      "para_break": true
    },
    {
      "start": 505.56,
      "end": 505.88,
      "text": "sonny."
    },
    {
      "start": 506.592,
      "end": 507.24,
      "text": "Some of you will,"
    },
    {
      "start": 507.38,
      "end": 509.4,
      "text": "and you can tell Gee I said so.\""
    },
    {
      "start": 510.22,
      "end": 513.52,
      "text": "The boy put his paper down quickly and faced Spade,",
      "para_break": true
    },
    {
      "start": 513.68,
      "end": 516.14,
      "text": "staring at his necktie with bleak hazel"
    },
    {
      "start": 516.16,
      "end": 516.3,
      "text": "eyes."
    },
    {
      "start": 517.58,
      "end": 520.26,
      "text": "The boy's small hands were spread flat over his belly.",
      "para_break": true
    },
    {
      "start": 521.8,
      "end": 524.84,
      "text": "\"'Keep asking for it and you're going to get it,' he said.",
      "para_break": true
    },
    {
      "start": 525.32,
      "end": 529.0,
      "text": "\"'Plenty.' His voice was low and flat and threatening."
    },
    {
      "start": 530.02,
      "end": 531.36,
      "text": "\"'I told you to shove off.",
      "para_break": true
    },
    {
      "start": 531.54,
      "end": 532.672,
      "text": "Shove off.'"
    },
    {
      "start": 534.176,
      "end": 537.02,
      "text": "Spade waited until a bespectacled pudgy man and a",
      "para_break": true
    },
    {
      "start": 537.02,
      "end": 539.32,
      "text": "thin-legged blonde girl had passed out of hearing."
    },
    {
      "start": 540.38,
      "end": 541.52,
      "text": "Then he chuckled and said,",
      "para_break": true
    },
    {
      "start": 542.46,
      "end": 544.44,
      "text": "That would go swell back on Seventh Avenue.",
      "para_break": true
    },
    {
      "start": 545.12,
      "end": 546.42,
      "text": "But you're not in Romeville now."
    },
    {
      "start": 547.296,
      "end": 548.04,
      "text": "You're in my burg.\"",
      "para_break": true
    },
    {
      "start": 548.97,
      "end": 552.18,
      "text": "He inhaled cigarette smoke and blew it out in a long,",
      "para_break": true
    },
    {
      "start": 552.28,
      "end": 552.92,
      "text": "pale cloud."
    },
    {
      "start": 553.86,
      "end": 554.16,
      "text": "\"'Well,",
      "para_break": true
    },
    {
      "start": 554.36,
      "end": 555.16,
      "text": "where is he?'"
    },
    {
      "start": 556.26,
      "end": 557.62,
      "text": "The boy spoke two words,",
      "para_break": true
    },
    {
      "start": 557.82,
      "end": 560.02,
      "text": "the first a short guttural verb,"
    },
    {
      "start": 560.2,
      "end": 560.92,
      "text": "the second,"
    },
    {
      "start": 561.24,
      "end": 561.46,
      "text": "you."
    },
    {
      "start": 563.52,
      "end": 565.664,
      "text": "\"'People have lost teeth talking like that.'",
      "para_break": true
    },
    {
      "start": 566.528,
      "end": 568.12,
      "text": "Spade's voice was still amiable,",
      "para_break": true
    },
    {
      "start": 568.32,
      "end": 570.02,
      "text": "though his face had become wooden."
    },
    {
      "start": 570.84,
      "end": 572.32,
      "text": "If you want to hang around,",
      "para_break": true
    },
    {
      "start": 572.62,
      "end": 573.4,
      "text": "you'll be polite."
    },
    {
      "start": 574.14,
      "end": 576.72,
      "text": "The boy repeated his two words.",
      "para_break": true
    },
    {
      "start": 577.984,
      "end": 581.36,
      "text": "Spade dropped his cigarette into a tall stone jar beside the divan",
      "para_break": true
    },
    {
      "start": 581.92,
      "end": 584.34,
      "text": "and with a lifted hand caught the attention of a man"
    },
    {
      "start": 584.48,
      "end": 585.58,
      "text": "who had been for several minutes"
    },
    {
      "start": 585.58,
      "end": 587.44,
      "text": "standing at an end of the cigar stand."
    },
    {
      "start": 588.38,
      "end": 590.26,
      "text": "The man nodded and came toward them.",
      "para_break": true
    },
    {
      "start": 591.18,
      "end": 593.34,
      "text": "He was a middle-aged man of medium height,",
      "para_break": true
    },
    {
      "start": 593.62,
      "end": 595.2,
      "text": "round and sallow of face,"
    },
    {
      "start": 595.808,
      "end": 596.58,
      "text": "compactly built,"
    },
    {
      "start": 596.76,
      "end": 598.42,
      "text": "tidily dressed in dark clothes."
    },
    {
      "start": 599.58,
      "end": 600.28,
      "text": "\"'Hello,",
      "para_break": true
    },
    {
      "start": 600.38,
      "end": 602.3,
      "text": "Sam,' he said as he came up."
    },
    {
      "start": 602.82,
      "end": 603.34,
      "text": "\"'Hello,"
    },
    {
      "start": 603.38,
      "end": 603.8,
      "text": "Luke.'"
    },
    {
      "start": 604.2,
      "end": 605.36,
      "text": "They shook hands,"
    },
    {
      "start": 605.5,
      "end": 606.08,
      "text": "and Luke said,"
    },
    {
      "start": 606.66,
      "end": 607.34,
      "text": "\"'Say,"
    },
    {
      "start": 607.4,
      "end": 609.16,
      "text": "that's too bad about Miles.'"
    },
    {
      "start": 610.38,
      "end": 610.7,
      "text": "\"'Uh-huh.",
      "para_break": true
    },
    {
      "start": 610.74,
      "end": 611.83,
      "text": "A bad break.'"
    },
    {
      "start": 612.896,
      "end": 616.04,
      "text": "Spade jerked his head to indicate the boy on the divan beside him.",
      "para_break": true
    },
    {
      "start": 617.42,
      "end": 620.14,
      "text": "\"'What do you let these cheap gunmen hang out in your lobby for,",
      "para_break": true
    },
    {
      "start": 620.54,
      "end": 622.816,
      "text": "with their tools bulging their clothes?'"
    },
    {
      "start": 623.32,
      "end": 624.64,
      "text": "\"'Yes.'"
    },
    {
      "start": 625.68,
      "end": 627.42,
      "text": "Luke examined the boy with crafty",
      "para_break": true
    },
    {
      "start": 627.42,
      "end": 629.82,
      "text": "brown eyes set in a suddenly hard face."
    },
    {
      "start": 631.18,
      "end": 632.78,
      "text": "\"'What do you want here?' he asked.",
      "para_break": true
    },
    {
      "start": 633.5,
      "end": 634.7,
      "text": "The boy stood up."
    },
    {
      "start": 635.264,
      "end": 636.16,
      "text": "Spade stood up."
    },
    {
      "start": 636.42,
      "end": 637.76,
      "text": "The boy looked at them,"
    },
    {
      "start": 637.84,
      "end": 640.0,
      "text": "at their neckties from one to the other."
    },
    {
      "start": 641.152,
      "end": 642.32,
      "text": "Luke's necktie was black.",
      "para_break": true
    },
    {
      "start": 643.2,
      "end": 645.72,
      "text": "The boy looked like a schoolboy standing in front of them.",
      "para_break": true
    },
    {
      "start": 646.94,
      "end": 647.28,
      "text": "Luke said,",
      "para_break": true
    },
    {
      "start": 647.42,
      "end": 648.44,
      "text": "\"'Well,"
    },
    {
      "start": 648.5,
      "end": 649.38,
      "text": "if you don't want anything,"
    },
    {
      "start": 649.54,
      "end": 650.84,
      "text": "beat it and don't come back.'"
    },
    {
      "start": 650.86,
      "end": 650.94,
      "text": "back."
    },
    {
      "start": 651.52,
      "end": 652.6,
      "text": "The boys said,"
    },
    {
      "start": 653.44,
      "end": 655.86,
      "text": "\"'I won't forget you guys,' and went out.",
      "para_break": true
    },
    {
      "start": 657.18,
      "end": 658.28,
      "text": "They watched him go out.",
      "para_break": true
    },
    {
      "start": 659.296,
      "end": 661.18,
      "text": "Spade took off his hat and wiped his damp",
      "para_break": true
    },
    {
      "start": 661.26,
      "end": 662.38,
      "text": "forehead with a handkerchief."
    },
    {
      "start": 663.2,
      "end": 664.48,
      "text": "The hotel detective asked,",
      "para_break": true
    },
    {
      "start": 665.52,
      "end": 666.02,
      "text": "\"'What is it?'",
      "para_break": true
    },
    {
      "start": 666.848,
      "end": 668.82,
      "text": "\"'Damned if I know,' Spade replied.",
      "para_break": true
    },
    {
      "start": 669.7,
      "end": 670.66,
      "text": "\"'I just spotted him.",
      "para_break": true
    },
    {
      "start": 670.78,
      "end": 673.44,
      "text": "Know anything about Joel Cairo,"
    },
    {
      "start": 673.6,
      "end": 674.55,
      "text": "635?'"
    },
    {
      "start": 674.94,
      "end": 676.12,
      "text": "\"'Oh,"
    },
    {
      "start": 676.14,
      "end": 676.8,
      "text": "her,'"
    },
    {
      "start": 677.34,
      "end": 678.66,
      "text": "the hotel detective leered."
    },
    {
      "start": 679.68,
      "end": 680.56,
      "text": "I've been watching him,",
      "para_break": true
    },
    {
      "start": 680.7,
      "end": 682.82,
      "text": "but I ain't caught him doing anything he oughtn't to."
    },
    {
      "start": 683.72,
      "end": 684.9,
      "text": "How long's he been here?",
      "para_break": true
    },
    {
      "start": 685.9,
      "end": 686.38,
      "text": "Four days.",
      "para_break": true
    },
    {
      "start": 686.58,
      "end": 687.4,
      "text": "This is the fifth."
    },
    {
      "start": 688.62,
      "end": 689.22,
      "text": "What about him?",
      "para_break": true
    },
    {
      "start": 690.208,
      "end": 690.6,
      "text": "Search me.",
      "para_break": true
    },
    {
      "start": 691.42,
      "end": 693.96,
      "text": "I got nothing against him but his looks and that's enough.",
      "para_break": true
    },
    {
      "start": 695.52,
      "end": 696.94,
      "text": "Find out if he was in last night?",
      "para_break": true
    },
    {
      "start": 698.02,
      "end": 698.36,
      "text": "Try to.",
      "para_break": true
    },
    {
      "start": 698.57,
      "end": 701.06,
      "text": "The hotel detective promised and went away."
    },
    {
      "start": 702.432,
      "end": 704.6,
      "text": "Spade sat on the divan until Luke returned.",
      "para_break": true
    },
    {
      "start": 705.56,
      "end": 706.18,
      "text": "No,",
      "para_break": true
    },
    {
      "start": 706.42,
      "end": 707.1,
      "text": "Luke said."
    },
    {
      "start": 707.24,
      "end": 708.32,
      "text": "He didn't sleep here."
    },
    {
      "start": 709.12,
      "end": 709.58,
      "text": "What is it,",
      "para_break": true
    },
    {
      "start": 709.6,
      "end": 710.05,
      "text": "Sam?\""
    },
    {
      "start": 711.0,
      "end": 711.32,
      "text": "Nothing.",
      "para_break": true
    },
    {
      "start": 712.36,
      "end": 712.92,
      "text": "Come clean.",
      "para_break": true
    },
    {
      "start": 713.72,
      "end": 715.28,
      "text": "You know I'll keep my clam shut,",
      "para_break": true
    },
    {
      "start": 715.9,
      "end": 717.64,
      "text": "but if there's anything wrong we ought"
    },
    {
      "start": 717.64,
      "end": 719.5,
      "text": "to know so we can collect our bill.\""
    },
    {
      "start": 720.768,
      "end": 721.48,
      "text": "Nothing like that,",
      "para_break": true
    },
    {
      "start": 721.74,
      "end": 722.82,
      "text": "Spade assured him."
    },
    {
      "start": 723.64,
      "end": 724.55,
      "text": "As a matter of fact,",
      "para_break": true
    },
    {
      "start": 724.6,
      "end": 726.12,
      "text": "I'm doing some work for him."
    },
    {
      "start": 726.752,
      "end": 728.0,
      "text": "I'd tell you if he was wrong."
    },
    {
      "start": 729.376,
      "end": 729.76,
      "text": "You'd better.",
      "para_break": true
    },
    {
      "start": 730.8,
      "end": 732.3,
      "text": "Want me to kind of keep an eye on him?",
      "para_break": true
    },
    {
      "start": 732.84,
      "end": 733.4,
      "text": "Thanks,"
    },
    {
      "start": 733.48,
      "end": 733.7,
      "text": "Luke."
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-10",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_10_hammett.mp3",
  "chapter_title": "Chapter 10 - The Belvedere Divan",
  "reader_name": "Mark Nelson",
  "page_num": 6,
  "page_total": 6,
  "page_start_sec": 1218.16,
  "page_end_sec": 1301.52,
  "para_gap_threshold": 0.74,
  "segments": [
    {
      "start": 1218.16,
      "end": 1220.16,
      "text": "She looked sharply up at him.",
      "para_break": true
    },
    {
      "start": 1221.0,
      "end": 1222.86,
      "text": "I still believe that no matter what",
      "para_break": true
    },
    {
      "start": 1222.86,
      "end": 1224.36,
      "text": "kind of trouble she's gotten into,"
    },
    {
      "start": 1224.66,
      "end": 1225.32,
      "text": "she's all right,"
    },
    {
      "start": 1225.42,
      "end": 1226.34,
      "text": "if that's what you mean."
    },
    {
      "start": 1227.616,
      "end": 1228.24,
      "text": "That's what I mean,",
      "para_break": true
    },
    {
      "start": 1228.4,
      "end": 1228.96,
      "text": "he said."
    },
    {
      "start": 1230.14,
      "end": 1232.34,
      "text": "Are you strong enough for her to give her a lift?",
      "para_break": true
    },
    {
      "start": 1233.26,
      "end": 1233.6,
      "text": "How?",
      "para_break": true
    },
    {
      "start": 1234.86,
      "end": 1236.18,
      "text": "Could you put her up for a few days?",
      "para_break": true
    },
    {
      "start": 1237.26,
      "end": 1237.94,
      "text": "You mean at home?",
      "para_break": true
    },
    {
      "start": 1238.48,
      "end": 1238.92,
      "text": "Yes."
    },
    {
      "start": 1239.74,
      "end": 1240.98,
      "text": "Her joint's been broken into.",
      "para_break": true
    },
    {
      "start": 1241.952,
      "end": 1244.04,
      "text": "That's the second burglary she's had this week.",
      "para_break": true
    },
    {
      "start": 1245.248,
      "end": 1246.88,
      "text": "It'd be better if she wasn't by herself.",
      "para_break": true
    },
    {
      "start": 1247.61,
      "end": 1249.99,
      "text": "It would help a lot if you could take her in.\""
    },
    {
      "start": 1251.424,
      "end": 1252.56,
      "text": "Effie Perrine leaned forward,",
      "para_break": true
    },
    {
      "start": 1252.86,
      "end": 1253.88,
      "text": "asking earnestly,"
    },
    {
      "start": 1255.0,
      "end": 1256.2,
      "text": "\"'Is she really in danger,",
      "para_break": true
    },
    {
      "start": 1256.28,
      "end": 1256.76,
      "text": "Sam?'"
    },
    {
      "start": 1257.68,
      "end": 1258.59,
      "text": "\"'I think she is.'",
      "para_break": true
    },
    {
      "start": 1259.72,
      "end": 1261.49,
      "text": "She scratched her lip with a fingernail.",
      "para_break": true
    },
    {
      "start": 1262.86,
      "end": 1264.9,
      "text": "\"'That would scare Ma into a green hemorrhage.",
      "para_break": true
    },
    {
      "start": 1266.14,
      "end": 1268.38,
      "text": "I'll have to tell her she's a surprise witness or something",
      "para_break": true
    },
    {
      "start": 1268.56,
      "end": 1271.04,
      "text": "that you're keeping undercover till the last minute.'"
    },
    {
      "start": 1272.16,
      "end": 1273.92,
      "text": "\"'You're a darling,' Spade said.",
      "para_break": true
    },
    {
      "start": 1275.104,
      "end": 1276.1,
      "text": "\"'Better take her out there now.",
      "para_break": true
    },
    {
      "start": 1277.34,
      "end": 1278.86,
      "text": "I'll get her key from her and bring",
      "para_break": true
    },
    {
      "start": 1278.86,
      "end": 1280.76,
      "text": "whatever she needs from her apartment later."
    },
    {
      "start": 1282.08,
      "end": 1282.4,
      "text": "Let's see.",
      "para_break": true
    },
    {
      "start": 1283.32,
      "end": 1284.98,
      "text": "You oughtn't to be seen leaving here with her.",
      "para_break": true
    },
    {
      "start": 1285.82,
      "end": 1286.64,
      "text": "You go home now,",
      "para_break": true
    },
    {
      "start": 1286.82,
      "end": 1287.66,
      "text": "take a taxi,"
    },
    {
      "start": 1287.82,
      "end": 1289.74,
      "text": "but make sure you aren't tailed."
    },
    {
      "start": 1290.72,
      "end": 1291.68,
      "text": "You probably won't be,",
      "para_break": true
    },
    {
      "start": 1291.8,
      "end": 1292.5,
      "text": "but make sure."
    },
    {
      "start": 1293.78,
      "end": 1295.88,
      "text": "I'll send her out in another in a little while,",
      "para_break": true
    },
    {
      "start": 1296.04,
      "end": 1297.9,
      "text": "making sure she isn't tailed."
    },
    {
      "start": 1300.64,
      "end": 1301.52,
      "text": "End of chapter 10",
      "para_break": true
    }
  ]
}
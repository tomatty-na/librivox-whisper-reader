{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-10",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_10_hammett.mp3",
  "chapter_title": "Chapter 10 - The Belvedere Divan",
  "reader_name": "Mark Nelson",
  "page_num": 5,
  "page_total": 6,
  "page_start_sec": 975.392,
  "page_end_sec": 1217.34,
  "para_gap_threshold": 0.74,
  "segments": [
    {
      "start": 975.392,
      "end": 975.88,
      "text": "And G.",
      "para_break": true
    },
    {
      "start": 976.08,
      "end": 976.68,
      "text": "called up."
    },
    {
      "start": 977.92,
      "end": 979.1,
      "text": "Spade's eyes brightened.",
      "para_break": true
    },
    {
      "start": 979.42,
      "end": 979.84,
      "text": "He asked,"
    },
    {
      "start": 980.18,
      "end": 980.76,
      "text": "\"'Who?'"
    },
    {
      "start": 981.24,
      "end": 981.64,
      "text": "\"'G."
    },
    {
      "start": 981.78,
      "end": 983.328,
      "text": "That's what he said.'"
    },
    {
      "start": 983.94,
      "end": 986.96,
      "text": "Her air of personal indifference to the subject was flawless."
    },
    {
      "start": 988.3,
      "end": 989.54,
      "text": "When I told him you weren't in,",
      "para_break": true
    },
    {
      "start": 989.58,
      "end": 989.94,
      "text": "he said,"
    },
    {
      "start": 990.14,
      "end": 991.24,
      "text": "When he comes in,"
    },
    {
      "start": 991.3,
      "end": 992.92,
      "text": "will you please tell him that G.,"
    },
    {
      "start": 992.92,
      "end": 993.82,
      "text": "who got his message,"
    },
    {
      "start": 994.0,
      "end": 995.37,
      "text": "phoned and will phone again?\""
    },
    {
      "start": 996.96,
      "end": 999.96,
      "text": "Spade worked his lips together as if tasting something he liked.",
      "para_break": true
    },
    {
      "start": 1000.74,
      "end": 1001.38,
      "text": "\"'Thanks,",
      "para_break": true
    },
    {
      "start": 1001.38,
      "end": 1002.44,
      "text": "darling,' he said."
    },
    {
      "start": 1003.34,
      "end": 1004.77,
      "text": "\"'See if you can get Tom Polehouse.'",
      "para_break": true
    },
    {
      "start": 1006.15,
      "end": 1009.22,
      "text": "He opened the inner door and went into his private office,",
      "para_break": true
    },
    {
      "start": 1009.42,
      "end": 1011.3,
      "text": "pulling the door two behind him."
    },
    {
      "start": 1012.448,
      "end": 1013.26,
      "text": "Bridget O'Shaughnessy,",
      "para_break": true
    },
    {
      "start": 1013.42,
      "end": 1015.58,
      "text": "dressed as on her first visit to the office,"
    },
    {
      "start": 1016.352,
      "end": 1019.32,
      "text": "rose from a chair beside his desk and came quickly toward him.",
      "para_break": true
    },
    {
      "start": 1020.704,
      "end": 1023.27,
      "text": "\"'Somebody has been in my apartment,' she exclaimed.",
      "para_break": true
    },
    {
      "start": 1023.82,
      "end": 1024.74,
      "text": "\"'It's all upside down,"
    },
    {
      "start": 1024.86,
      "end": 1025.984,
      "text": "every which way.'"
    },
    {
      "start": 1026.36,
      "end": 1028.56,
      "text": "He seemed moderately surprised."
    },
    {
      "start": 1029.92,
      "end": 1030.7,
      "text": "\"'Anything taken?'",
      "para_break": true
    },
    {
      "start": 1031.46,
      "end": 1032.18,
      "text": "\"'I don't think so.",
      "para_break": true
    },
    {
      "start": 1032.6,
      "end": 1033.34,
      "text": "I don't know."
    },
    {
      "start": 1033.84,
      "end": 1035.2,
      "text": "I was afraid to stay."
    },
    {
      "start": 1035.9,
      "end": 1038.7,
      "text": "I changed as fast as I could and came down here."
    },
    {
      "start": 1039.42,
      "end": 1039.66,
      "text": "Oh,"
    },
    {
      "start": 1039.66,
      "end": 1039.94,
      "text": "Sam,"
    },
    {
      "start": 1040.42,
      "end": 1042.464,
      "text": "you mustn't let that boy follow you there!'"
    },
    {
      "start": 1043.488,
      "end": 1044.38,
      "text": "Spade shook his head.",
      "para_break": true
    },
    {
      "start": 1045.16,
      "end": 1045.58,
      "text": "\"'No,",
      "para_break": true
    },
    {
      "start": 1045.72,
      "end": 1046.14,
      "text": "Angel.'"
    },
    {
      "start": 1046.74,
      "end": 1049.86,
      "text": "He took an early copy of an afternoon newspaper from his pocket,"
    },
    {
      "start": 1050.0,
      "end": 1050.54,
      "text": "opened it,"
    },
    {
      "start": 1050.62,
      "end": 1051.32,
      "text": "and showed her a"
    },
    {
      "start": 1051.4,
      "end": 1052.22,
      "text": "quarter-column headed,"
    },
    {
      "start": 1052.4,
      "end": 1054.62,
      "text": "Scream Routes Burglars."
    },
    {
      "start": 1055.48,
      "end": 1058.0,
      "text": "A young woman named Carolyn Beale,",
      "para_break": true
    },
    {
      "start": 1058.16,
      "end": 1058.84,
      "text": "who lived alone"
    },
    {
      "start": 1058.84,
      "end": 1060.06,
      "text": "in a Sutter Street apartment,"
    },
    {
      "start": 1060.4,
      "end": 1063.54,
      "text": "had been awakened at four that morning by the sound of somebody"
    },
    {
      "start": 1063.64,
      "end": 1064.62,
      "text": "moving in her bedroom."
    },
    {
      "start": 1065.56,
      "end": 1066.18,
      "text": "She had screamed.",
      "para_break": true
    },
    {
      "start": 1067.0,
      "end": 1067.92,
      "text": "The mover had run away.",
      "para_break": true
    },
    {
      "start": 1069.14,
      "end": 1069.78,
      "text": "Two other women,",
      "para_break": true
    },
    {
      "start": 1069.88,
      "end": 1070.76,
      "text": "who lived alone in"
    },
    {
      "start": 1070.76,
      "end": 1071.32,
      "text": "the same building,"
    },
    {
      "start": 1071.5,
      "end": 1071.94,
      "text": "had discovered,"
    },
    {
      "start": 1072.16,
      "end": 1072.96,
      "text": "later in the morning,"
    },
    {
      "start": 1073.18,
      "end": 1075.04,
      "text": "signs of the burglars having visited"
    },
    {
      "start": 1075.24,
      "end": 1075.78,
      "text": "their apartments."
    },
    {
      "start": 1076.46,
      "end": 1078.76,
      "text": "Nothing had been taken from any of the three."
    },
    {
      "start": 1080.576,
      "end": 1081.38,
      "text": "That's where I shook him,",
      "para_break": true
    },
    {
      "start": 1081.56,
      "end": 1082.62,
      "text": "Spade explained."
    },
    {
      "start": 1083.64,
      "end": 1086.18,
      "text": "I went into that building and ducked out the back door.",
      "para_break": true
    },
    {
      "start": 1087.168,
      "end": 1089.18,
      "text": "That's why all three were women that lived alone.",
      "para_break": true
    },
    {
      "start": 1090.82,
      "end": 1092.36,
      "text": "He tried the apartments that had",
      "para_break": true
    },
    {
      "start": 1092.36,
      "end": 1094.28,
      "text": "women's names in the vestibule register,"
    },
    {
      "start": 1095.008,
      "end": 1096.66,
      "text": "haunting for you under a phony name."
    },
    {
      "start": 1098.34,
      "end": 1100.44,
      "text": "But he was watching your place when we were there,",
      "para_break": true
    },
    {
      "start": 1100.64,
      "end": 1101.72,
      "text": "she objected."
    },
    {
      "start": 1101.84,
      "end": 1103.76,
      "text": "Spade shrugged."
    },
    {
      "start": 1104.544,
      "end": 1105.34,
      "text": "Maybe he's not alone.",
      "para_break": true
    },
    {
      "start": 1106.432,
      "end": 1108.76,
      "text": "Maybe he went to Sutter Street after he began to",
      "para_break": true
    },
    {
      "start": 1108.76,
      "end": 1110.76,
      "text": "think you were going to stay at my place all night."
    },
    {
      "start": 1111.58,
      "end": 1112.62,
      "text": "There are lots of maybes.",
      "para_break": true
    },
    {
      "start": 1113.66,
      "end": 1115.27,
      "text": "But I didn't lead him to the coronet.",
      "para_break": true
    },
    {
      "start": 1116.72,
      "end": 1117.78,
      "text": "She wasn't satisfied.",
      "para_break": true
    },
    {
      "start": 1119.04,
      "end": 1119.74,
      "text": "But he found it,",
      "para_break": true
    },
    {
      "start": 1119.82,
      "end": 1120.86,
      "text": "or somebody did."
    },
    {
      "start": 1121.66,
      "end": 1121.96,
      "text": "Sure.",
      "para_break": true
    },
    {
      "start": 1122.58,
      "end": 1123.98,
      "text": "He frowned at her feet."
    },
    {
      "start": 1125.16,
      "end": 1127.22,
      "text": "I wonder if it could have been Cairo.",
      "para_break": true
    },
    {
      "start": 1128.2,
      "end": 1129.8,
      "text": "He wasn't at his hotel all night.",
      "para_break": true
    },
    {
      "start": 1130.15,
      "end": 1132.18,
      "text": "didn't get in till a few minutes ago."
    },
    {
      "start": 1132.74,
      "end": 1135.1,
      "text": "He told me he had been standing up"
    },
    {
      "start": 1135.1,
      "end": 1137.12,
      "text": "under a quiz at headquarters all night."
    },
    {
      "start": 1137.94,
      "end": 1138.38,
      "text": "I wonder.",
      "para_break": true
    },
    {
      "start": 1139.1,
      "end": 1140.16,
      "text": "He turned,"
    },
    {
      "start": 1140.32,
      "end": 1141.0,
      "text": "opened the door,"
    },
    {
      "start": 1141.04,
      "end": 1142.24,
      "text": "and asked Effie Pryne,"
    },
    {
      "start": 1143.1,
      "end": 1143.72,
      "text": "Got Tom yet?",
      "para_break": true
    },
    {
      "start": 1144.736,
      "end": 1145.3,
      "text": "He's not in.",
      "para_break": true
    },
    {
      "start": 1146.02,
      "end": 1147.2,
      "text": "I'll try again in a few minutes."
    },
    {
      "start": 1148.1,
      "end": 1148.52,
      "text": "Thanks.",
      "para_break": true
    },
    {
      "start": 1149.6,
      "end": 1151.82,
      "text": "Spade shut the door and faced Bridget O'Shaughnessy.",
      "para_break": true
    },
    {
      "start": 1152.86,
      "end": 1154.56,
      "text": "She looked at him with cloudy eyes.",
      "para_break": true
    },
    {
      "start": 1156.24,
      "end": 1157.62,
      "text": "You went to see Joe this morning?",
      "para_break": true
    },
    {
      "start": 1158.16,
      "end": 1158.62,
      "text": "She asked."
    },
    {
      "start": 1159.36,
      "end": 1159.56,
      "text": "Yes.",
      "para_break": true
    },
    {
      "start": 1160.0,
      "end": 1161.28,
      "text": "She hesitated."
    },
    {
      "start": 1161.78,
      "end": 1162.46,
      "text": "Why?"
    },
    {
      "start": 1163.44,
      "end": 1163.72,
      "text": "Why?",
      "para_break": true
    },
    {
      "start": 1164.28,
      "end": 1165.96,
      "text": "He smiled down at her."
    },
    {
      "start": 1166.67,
      "end": 1167.22,
      "text": "Because,"
    },
    {
      "start": 1167.3,
      "end": 1167.84,
      "text": "my dear,"
    },
    {
      "start": 1168.14,
      "end": 1170.2,
      "text": "I've got to keep in some sort of touch"
    },
    {
      "start": 1170.2,
      "end": 1172.06,
      "text": "with the loose ends of this dizzy affair,"
    },
    {
      "start": 1172.5,
      "end": 1174.86,
      "text": "if I'm ever going to make heads or tails of it."
    },
    {
      "start": 1175.78,
      "end": 1177.64,
      "text": "He put an arm around her shoulders",
      "para_break": true
    },
    {
      "start": 1177.64,
      "end": 1179.3,
      "text": "and led her over to his swivel chair."
    },
    {
      "start": 1179.98,
      "end": 1183.68,
      "text": "He kissed the tip of her nose lightly and set her down in the chair."
    },
    {
      "start": 1184.42,
      "end": 1186.38,
      "text": "He sat on the desk in front of her.",
      "para_break": true
    },
    {
      "start": 1186.92,
      "end": 1187.36,
      "text": "He said,"
    },
    {
      "start": 1187.94,
      "end": 1190.38,
      "text": "Now we've got to find a new home for you,"
    },
    {
      "start": 1190.42,
      "end": 1190.92,
      "text": "haven't we?"
    },
    {
      "start": 1192.16,
      "end": 1193.16,
      "text": "She nodded with emphasis.",
      "para_break": true
    },
    {
      "start": 1193.82,
      "end": 1194.94,
      "text": "I won't go back there."
    },
    {
      "start": 1195.8,
      "end": 1199.24,
      "text": "He patted the desk beside his thighs and made a thoughtful face.",
      "para_break": true
    },
    {
      "start": 1200.84,
      "end": 1201.8,
      "text": "I think I've got it,",
      "para_break": true
    },
    {
      "start": 1202.22,
      "end": 1203.02,
      "text": "he said presently."
    },
    {
      "start": 1203.5,
      "end": 1203.9,
      "text": "Wait a minute."
    },
    {
      "start": 1204.78,
      "end": 1205.9,
      "text": "He went into the outer office,",
      "para_break": true
    },
    {
      "start": 1206.02,
      "end": 1207.26,
      "text": "shutting the door behind him."
    },
    {
      "start": 1208.448,
      "end": 1209.94,
      "text": "Effie Perrine reached for the telephone,",
      "para_break": true
    },
    {
      "start": 1210.12,
      "end": 1210.38,
      "text": "saying,"
    },
    {
      "start": 1211.08,
      "end": 1211.64,
      "text": "I'll try again."
    },
    {
      "start": 1212.48,
      "end": 1212.88,
      "text": "Afterwards.",
      "para_break": true
    },
    {
      "start": 1214.04,
      "end": 1215.46,
      "text": "Does your woman's intuition still",
      "para_break": true
    },
    {
      "start": 1215.46,
      "end": 1217.34,
      "text": "tell you she's a Madonna or something?"
    }
  ]
}
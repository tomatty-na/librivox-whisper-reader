{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-10",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_10_hammett.mp3",
  "chapter_title": "Chapter 10 - The Belvedere Divan",
  "reader_name": "Mark Nelson",
  "page_num": 4,
  "page_total": 6,
  "page_start_sec": 733.88,
  "page_end_sec": 974.36,
  "para_gap_threshold": 0.74,
  "segments": [
    {
      "start": 733.88,
      "end": 734.74,
      "text": "It wouldn't hurt."
    },
    {
      "start": 735.4,
      "end": 737.88,
      "text": "You can't know too much about the birds you're working for."
    },
    {
      "start": 739.52,
      "end": 742.42,
      "text": "It was twenty-one minutes past eleven by the",
      "para_break": true
    },
    {
      "start": 742.42,
      "end": 745.2,
      "text": "clock over the elevator doors when Joel Cairo"
    },
    {
      "start": 745.2,
      "end": 746.26,
      "text": "came in from the street."
    },
    {
      "start": 747.38,
      "end": 748.82,
      "text": "His forehead was bandaged.",
      "para_break": true
    },
    {
      "start": 749.38,
      "end": 751.24,
      "text": "His clothes had the limp unfreshness"
    },
    {
      "start": 751.26,
      "end": 753.16,
      "text": "of too many consecutive hours' wear."
    },
    {
      "start": 754.24,
      "end": 755.4,
      "text": "His face was pasty,",
      "para_break": true
    },
    {
      "start": 755.46,
      "end": 757.0,
      "text": "with sagging mouth and eyelids."
    },
    {
      "start": 758.4,
      "end": 760.02,
      "text": "Spade met him in front of the desk.",
      "para_break": true
    },
    {
      "start": 761.54,
      "end": 763.48,
      "text": "\"'Good morning,' Spade said easily.",
      "para_break": true
    },
    {
      "start": 764.704,
      "end": 767.2,
      "text": "Cairo drew his tired body up straight and the drooping",
      "para_break": true
    },
    {
      "start": 767.36,
      "end": 768.64,
      "text": "lines of his face tightened."
    },
    {
      "start": 769.98,
      "end": 770.46,
      "text": "Good morning,",
      "para_break": true
    },
    {
      "start": 771.14,
      "end": 771.56,
      "text": "he responded,"
    },
    {
      "start": 771.78,
      "end": 772.6,
      "text": "without enthusiasm."
    },
    {
      "start": 774.1,
      "end": 774.88,
      "text": "There was a pause.",
      "para_break": true
    },
    {
      "start": 775.936,
      "end": 776.34,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 777.632,
      "end": 779.28,
      "text": "Let's go someplace where we can talk.",
      "para_break": true
    },
    {
      "start": 780.512,
      "end": 781.56,
      "text": "Cairo raised his chin.",
      "para_break": true
    },
    {
      "start": 783.232,
      "end": 784.34,
      "text": "Please excuse me,",
      "para_break": true
    },
    {
      "start": 784.48,
      "end": 785.08,
      "text": "he said."
    },
    {
      "start": 785.2,
      "end": 787.9,
      "text": "Our conversations in private have not been"
    },
    {
      "start": 788.02,
      "end": 790.02,
      "text": "such that I am anxious to continue them."
    },
    {
      "start": 791.072,
      "end": 792.32,
      "text": "Pardon my speaking bluntly,",
      "para_break": true
    },
    {
      "start": 792.58,
      "end": 793.72,
      "text": "but it is the truth."
    },
    {
      "start": 794.78,
      "end": 795.78,
      "text": "You mean last night?",
      "para_break": true
    },
    {
      "start": 796.91,
      "end": 799.8,
      "text": "Spade made an impatient gesture with head and hands.",
      "para_break": true
    },
    {
      "start": 800.84,
      "end": 802.14,
      "text": "\"'What the hell else could I do?",
      "para_break": true
    },
    {
      "start": 802.62,
      "end": 804.24,
      "text": "I thought you'd see that."
    },
    {
      "start": 804.66,
      "end": 806.12,
      "text": "If you pick a fight with her,"
    },
    {
      "start": 806.28,
      "end": 807.58,
      "text": "or let her pick one with you,"
    },
    {
      "start": 807.92,
      "end": 809.22,
      "text": "I've got to throw in with her."
    },
    {
      "start": 810.34,
      "end": 812.04,
      "text": "I don't know where that damn bird is.",
      "para_break": true
    },
    {
      "start": 812.52,
      "end": 813.14,
      "text": "You don't."
    },
    {
      "start": 813.7,
      "end": 814.08,
      "text": "She does."
    },
    {
      "start": 815.08,
      "end": 818.112,
      "text": "How in hell are we going to get it if I don't play along with her?'",
      "para_break": true
    },
    {
      "start": 819.552,
      "end": 820.36,
      "text": "Cairo hesitated,",
      "para_break": true
    },
    {
      "start": 820.6,
      "end": 821.7,
      "text": "said dubiously."
    },
    {
      "start": 823.488,
      "end": 824.02,
      "text": "You've always,",
      "para_break": true
    },
    {
      "start": 824.22,
      "end": 825.08,
      "text": "I must say,"
    },
    {
      "start": 825.22,
      "end": 827.264,
      "text": "a smooth explanation ready.\""
    },
    {
      "start": 828.352,
      "end": 829.22,
      "text": "Spade scowled.",
      "para_break": true
    },
    {
      "start": 830.34,
      "end": 831.3,
      "text": "\"'What do you want me to do?",
      "para_break": true
    },
    {
      "start": 831.712,
      "end": 832.44,
      "text": "Learn to stutter?"
    },
    {
      "start": 833.48,
      "end": 834.816,
      "text": "Well we can talk over here.'",
      "para_break": true
    },
    {
      "start": 835.68,
      "end": 837.02,
      "text": "He led the way to the divan.",
      "para_break": true
    },
    {
      "start": 838.02,
      "end": 839.3,
      "text": "When they were seated he asked,",
      "para_break": true
    },
    {
      "start": 840.416,
      "end": 841.78,
      "text": "\"'Dundee take you down to the hall?'",
      "para_break": true
    },
    {
      "start": 842.12,
      "end": 843.04,
      "text": "\"'Yes.'"
    },
    {
      "start": 844.12,
      "end": 845.36,
      "text": "\"'How long did he work on you?'",
      "para_break": true
    },
    {
      "start": 846.464,
      "end": 847.68,
      "text": "\"'Till a very little while ago,",
      "para_break": true
    },
    {
      "start": 847.84,
      "end": 849.98,
      "text": "and very much against my will.'"
    },
    {
      "start": 851.4,
      "end": 854.16,
      "text": "and indignation were mixed in Cairo's face and voice.",
      "para_break": true
    },
    {
      "start": 855.06,
      "end": 857.28,
      "text": "I shall certainly take up the matter with",
      "para_break": true
    },
    {
      "start": 857.28,
      "end": 859.24,
      "text": "the Consulate General of Greece and with an"
    },
    {
      "start": 859.32,
      "end": 859.64,
      "text": "attorney."
    },
    {
      "start": 860.4,
      "end": 861.26,
      "text": "Go ahead,",
      "para_break": true
    },
    {
      "start": 861.48,
      "end": 862.58,
      "text": "but it won't get you anything."
    },
    {
      "start": 863.94,
      "end": 864.92,
      "text": "What did they get out of you?",
      "para_break": true
    },
    {
      "start": 866.56,
      "end": 869.46,
      "text": "There was prim satisfaction in Cairo's stiff smile.",
      "para_break": true
    },
    {
      "start": 870.784,
      "end": 871.92,
      "text": "Not a single thing.",
      "para_break": true
    },
    {
      "start": 872.68,
      "end": 876.42,
      "text": "I adhered to the course you had indicated earlier in your rooms.",
      "para_break": true
    },
    {
      "start": 877.48,
      "end": 878.42,
      "text": "His smile went away.",
      "para_break": true
    },
    {
      "start": 878.88,
      "end": 882.42,
      "text": "though I certainly wished you had devised a more reasonable story."
    },
    {
      "start": 883.52,
      "end": 886.176,
      "text": "I felt decidedly ridiculous repeating it.\"",
      "para_break": true
    },
    {
      "start": 887.424,
      "end": 888.74,
      "text": "Spade grinned mockingly.",
      "para_break": true
    },
    {
      "start": 889.7,
      "end": 890.86,
      "text": "\"'Sure,' he said.",
      "para_break": true
    },
    {
      "start": 891.648,
      "end": 893.42,
      "text": "\"'But its goofiness is what made it good.",
      "para_break": true
    },
    {
      "start": 894.36,
      "end": 896.09,
      "text": "You're sure you didn't give them anything else?'",
      "para_break": true
    },
    {
      "start": 897.52,
      "end": 898.7,
      "text": "\"'You may rely upon it,",
      "para_break": true
    },
    {
      "start": 898.78,
      "end": 898.92,
      "text": "Mr."
    },
    {
      "start": 899.0,
      "end": 899.38,
      "text": "Spade."
    },
    {
      "start": 899.72,
      "end": 900.84,
      "text": "I did not.'"
    },
    {
      "start": 902.144,
      "end": 904.92,
      "text": "Spade drummed with his fingers on the leather seat between them.",
      "para_break": true
    },
    {
      "start": 906.6,
      "end": 907.92,
      "text": "\"'You'll be hearing from Dundee again.",
      "para_break": true
    },
    {
      "start": 909.08,
      "end": 911.28,
      "text": "Stay dumbing up on him and you'll be all right.",
      "para_break": true
    },
    {
      "start": 912.288,
      "end": 913.88,
      "text": "Don't worry about the story's goofiness.",
      "para_break": true
    },
    {
      "start": 914.42,
      "end": 914.94,
      "text": "A"
    },
    {
      "start": 915.02,
      "end": 917.16,
      "text": "sensible one would have had us all in the cooler.\""
    },
    {
      "start": 918.3,
      "end": 919.28,
      "text": "He rose to his feet.",
      "para_break": true
    },
    {
      "start": 920.48,
      "end": 922.66,
      "text": "\"'You'll want to sleep if you've been in the grease all night.",
      "para_break": true
    },
    {
      "start": 923.38,
      "end": 923.83,
      "text": "See you later.'\""
    },
    {
      "start": 927.232,
      "end": 928.18,
      "text": "Effie Perrine was saying,",
      "para_break": true
    },
    {
      "start": 928.64,
      "end": 929.22,
      "text": "\"'No,"
    },
    {
      "start": 929.22,
      "end": 933.06,
      "text": "not yet,' into the telephone when Spade entered his outer office."
    },
    {
      "start": 933.62,
      "end": 935.2,
      "text": "She looked around at him,"
    },
    {
      "start": 935.26,
      "end": 937.24,
      "text": "and her lips shaped a silent Iva."
    },
    {
      "start": 937.88,
      "end": 939.0,
      "text": "He shook his head."
    },
    {
      "start": 940.0,
      "end": 940.5,
      "text": "\"'Yes,",
      "para_break": true
    },
    {
      "start": 940.6,
      "end": 942.86,
      "text": "I'll have him call you as soon as he comes in,'"
    },
    {
      "start": 943.48,
      "end": 944.0,
      "text": "she said aloud,"
    },
    {
      "start": 944.26,
      "end": 946.16,
      "text": "and replaced the receiver on its prong."
    },
    {
      "start": 947.616,
      "end": 950.84,
      "text": "\"'That's the third time she's called up this morning,' she told Sam.",
      "para_break": true
    },
    {
      "start": 951.94,
      "end": 953.88,
      "text": "He made an impatient growling noise.",
      "para_break": true
    },
    {
      "start": 954.912,
      "end": 957.68,
      "text": "She moved her brown eyes to indicate the inner office door.",
      "para_break": true
    },
    {
      "start": 958.64,
      "end": 960.4,
      "text": "\"'Your Miss O'Shaughnessy's in there.",
      "para_break": true
    },
    {
      "start": 960.57,
      "end": 963.59,
      "text": "She has been waiting since a few minutes after nine.\""
    },
    {
      "start": 964.736,
      "end": 967.24,
      "text": "Spade nodded as if he had expected that and asked,",
      "para_break": true
    },
    {
      "start": 967.92,
      "end": 968.46,
      "text": "\"'What else?'"
    },
    {
      "start": 969.504,
      "end": 970.76,
      "text": "Sergeant Polehouse called up.",
      "para_break": true
    },
    {
      "start": 971.06,
      "end": 972.36,
      "text": "He didn't leave any message."
    },
    {
      "start": 973.56,
      "end": 974.36,
      "text": "\"'Get him for me.'",
      "para_break": true
    }
  ]
}
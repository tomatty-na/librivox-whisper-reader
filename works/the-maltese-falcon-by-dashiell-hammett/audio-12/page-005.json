{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-12",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_12_hammett.mp3",
  "chapter_title": "Chapter 12 - Merry-Go-Round",
  "reader_name": "Mark Nelson",
  "page_num": 5,
  "page_total": 5,
  "page_start_sec": 976.78,
  "page_end_sec": 1104.6,
  "para_gap_threshold": 0.759,
  "segments": [
    {
      "start": 976.78,
      "end": 977.32,
      "text": "Did you ever?",
      "para_break": true
    },
    {
      "start": 978.112,
      "end": 979.14,
      "text": "Spade began and stopped.",
      "para_break": true
    },
    {
      "start": 980.08,
      "end": 982.56,
      "text": "A soft light began to glow in his yellowish eyes.",
      "para_break": true
    },
    {
      "start": 983.14,
      "end": 984.88,
      "text": "He did not address the boy again."
    },
    {
      "start": 986.08,
      "end": 987.3,
      "text": "They went into the Alexandria,",
      "para_break": true
    },
    {
      "start": 987.74,
      "end": 989.04,
      "text": "rode up to the twelfth floor,"
    },
    {
      "start": 989.2,
      "end": 991.28,
      "text": "and walked down the corridor toward Gutman's suite."
    },
    {
      "start": 992.448,
      "end": 993.64,
      "text": "Nobody else was in the corridor.",
      "para_break": true
    },
    {
      "start": 995.136,
      "end": 996.62,
      "text": "Spade lagged a little so that,",
      "para_break": true
    },
    {
      "start": 996.78,
      "end": 998.98,
      "text": "when they were within fifteen feet of Gutman's door,"
    },
    {
      "start": 999.36,
      "end": 1001.82,
      "text": "he was perhaps a foot and a half behind the boy."
    },
    {
      "start": 1002.7,
      "end": 1004.32,
      "text": "He leaned sideways suddenly",
      "para_break": true
    },
    {
      "start": 1004.5,
      "end": 1006.92,
      "text": "and grasped the boy from behind by both arms,"
    },
    {
      "start": 1007.02,
      "end": 1008.34,
      "text": "just beneath the boy's elbows."
    },
    {
      "start": 1009.44,
      "end": 1010.96,
      "text": "He forced the arms forward",
      "para_break": true
    },
    {
      "start": 1011.24,
      "end": 1013.62,
      "text": "so that the boy's hands in his overcoat pockets"
    },
    {
      "start": 1013.9,
      "end": 1015.66,
      "text": "lifted the overcoat up before him."
    },
    {
      "start": 1016.68,
      "end": 1018.06,
      "text": "The boy struggled and writhed,",
      "para_break": true
    },
    {
      "start": 1018.14,
      "end": 1019.84,
      "text": "but he was impotent in Spade's grip."
    },
    {
      "start": 1020.84,
      "end": 1021.72,
      "text": "The boy kicked back,",
      "para_break": true
    },
    {
      "start": 1021.88,
      "end": 1023.44,
      "text": "but his feet went between Spade's"
    },
    {
      "start": 1023.56,
      "end": 1024.3,
      "text": "widespread legs."
    },
    {
      "start": 1025.76,
      "end": 1027.58,
      "text": "Spade lifted the boy straight up from the",
      "para_break": true
    },
    {
      "start": 1027.58,
      "end": 1029.58,
      "text": "floor and then brought him down hard on"
    },
    {
      "start": 1029.58,
      "end": 1030.16,
      "text": "his feet again."
    },
    {
      "start": 1031.18,
      "end": 1033.28,
      "text": "The impact made little noise on the thick carpet.",
      "para_break": true
    },
    {
      "start": 1034.18,
      "end": 1035.1,
      "text": "At the moment of impact,",
      "para_break": true
    },
    {
      "start": 1035.56,
      "end": 1038.96,
      "text": "Spade's big hand slid down and got a fresh grip on the boy's wrists."
    },
    {
      "start": 1040.24,
      "end": 1040.62,
      "text": "The boy,",
      "para_break": true
    },
    {
      "start": 1040.82,
      "end": 1041.86,
      "text": "teeth set hard"
    },
    {
      "start": 1041.98,
      "end": 1042.24,
      "text": "together,"
    },
    {
      "start": 1042.46,
      "end": 1045.62,
      "text": "did not for a moment stop straining against the man's hands,"
    },
    {
      "start": 1046.28,
      "end": 1047.1,
      "text": "but he could not tear"
    },
    {
      "start": 1047.24,
      "end": 1047.78,
      "text": "himself loose,"
    },
    {
      "start": 1048.3,
      "end": 1051.68,
      "text": "could not keep Spade's fingers from crawling down over his own hands."
    },
    {
      "start": 1052.55,
      "end": 1055.1,
      "text": "The boy's teeth ground together audibly,",
      "para_break": true
    },
    {
      "start": 1055.6,
      "end": 1057.96,
      "text": "the sound mingling with the noise of Spade's breathing,"
    },
    {
      "start": 1058.16,
      "end": 1059.9,
      "text": "as Spade crushed his hands."
    },
    {
      "start": 1060.32,
      "end": 1063.38,
      "text": "They were tensely motionless for a long moment."
    },
    {
      "start": 1064.3,
      "end": 1065.82,
      "text": "Then the boy's arms became limp.",
      "para_break": true
    },
    {
      "start": 1066.624,
      "end": 1068.52,
      "text": "Spade released the boy and stepped back.",
      "para_break": true
    },
    {
      "start": 1069.46,
      "end": 1070.66,
      "text": "In each of Spade's hands,",
      "para_break": true
    },
    {
      "start": 1070.86,
      "end": 1072.82,
      "text": "when they came out of the boy's overcoat pockets,"
    },
    {
      "start": 1073.06,
      "end": 1074.62,
      "text": "there was a heavy automatic pistol."
    },
    {
      "start": 1075.46,
      "end": 1077.98,
      "text": "The boy turned and faced Spade.",
      "para_break": true
    },
    {
      "start": 1078.22,
      "end": 1081.14,
      "text": "The boy's face was a ghastly white blank."
    },
    {
      "start": 1081.58,
      "end": 1083.86,
      "text": "He kept his hands in his overcoat pockets."
    },
    {
      "start": 1084.64,
      "end": 1087.08,
      "text": "He looked at Spade's chest and said nothing.",
      "para_break": true
    },
    {
      "start": 1088.576,
      "end": 1091.74,
      "text": "Spade put the pistols in his own pockets and grinned derisively.",
      "para_break": true
    },
    {
      "start": 1093.1,
      "end": 1093.48,
      "text": "Come on,",
      "para_break": true
    },
    {
      "start": 1093.82,
      "end": 1094.3,
      "text": "he said."
    },
    {
      "start": 1094.98,
      "end": 1096.86,
      "text": "This will put you in solid with your boss."
    },
    {
      "start": 1098.4,
      "end": 1100.56,
      "text": "They went to Gutman's door and Spade knocked.",
      "para_break": true
    },
    {
      "start": 1103.712,
      "end": 1104.6,
      "text": "End of chapter 12",
      "para_break": true
    }
  ]
}
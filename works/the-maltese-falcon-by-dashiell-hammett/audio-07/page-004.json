{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-07",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_07_hammett.mp3",
  "chapter_title": "Chapter 7 - G in the Air",
  "reader_name": "Mark Nelson",
  "page_num": 4,
  "page_total": 7,
  "page_start_sec": 747.84,
  "page_end_sec": 990.28,
  "para_gap_threshold": 0.735,
  "segments": [
    {
      "start": 747.84,
      "end": 749.34,
      "text": "Cairo's eyebrows twitched.",
      "para_break": true
    },
    {
      "start": 749.8,
      "end": 750.36,
      "text": "He smiled."
    },
    {
      "start": 751.7,
      "end": 752.34,
      "text": "It is ready.",
      "para_break": true
    },
    {
      "start": 753.44,
      "end": 755.32,
      "text": "He continued to smile at the girl for",
      "para_break": true
    },
    {
      "start": 755.32,
      "end": 756.78,
      "text": "a little while after he had spoken,"
    },
    {
      "start": 756.96,
      "end": 758.24,
      "text": "and then looked at Spade."
    },
    {
      "start": 759.488,
      "end": 760.76,
      "text": "Spade was lighting his cigarette.",
      "para_break": true
    },
    {
      "start": 761.72,
      "end": 763.02,
      "text": "His face was placid.",
      "para_break": true
    },
    {
      "start": 764.24,
      "end": 764.62,
      "text": "In cash?",
      "para_break": true
    },
    {
      "start": 765.0,
      "end": 765.76,
      "text": "she asked."
    },
    {
      "start": 766.06,
      "end": 766.66,
      "text": "\"'Oh,"
    },
    {
      "start": 766.78,
      "end": 768.26,
      "text": "yes,' Cairo replied."
    },
    {
      "start": 769.44,
      "end": 770.14,
      "text": "She frowned,",
      "para_break": true
    },
    {
      "start": 770.26,
      "end": 771.58,
      "text": "put her tongue between her lips,"
    },
    {
      "start": 771.68,
      "end": 772.4,
      "text": "withdrew it,"
    },
    {
      "start": 772.42,
      "end": 772.84,
      "text": "and asked,"
    },
    {
      "start": 774.3,
      "end": 775.94,
      "text": "\"'You were ready to pay us five thousand",
      "para_break": true
    },
    {
      "start": 775.94,
      "end": 778.06,
      "text": "dollars now if we gave you the Falcon?'"
    },
    {
      "start": 779.2,
      "end": 781.06,
      "text": "Cairo held up a wiggling white hand.",
      "para_break": true
    },
    {
      "start": 782.24,
      "end": 783.64,
      "text": "\"'Excuse me,' he said,",
      "para_break": true
    },
    {
      "start": 784.12,
      "end": 785.8,
      "text": "\"'I expressed myself badly."
    },
    {
      "start": 786.42,
      "end": 789.3,
      "text": "I did not mean to say I have the money in my pocket,"
    },
    {
      "start": 789.64,
      "end": 792.04,
      "text": "but that I am prepared to get it on a very few"
    },
    {
      "start": 792.04,
      "end": 794.64,
      "text": "minutes' notice at any time during banking hours.'"
    },
    {
      "start": 795.9,
      "end": 796.48,
      "text": "Oh!\"",
      "para_break": true
    },
    {
      "start": 797.3,
      "end": 799.0,
      "text": "She looked significantly at Spade.",
      "para_break": true
    },
    {
      "start": 800.32,
      "end": 803.34,
      "text": "Spade blew cigarette smoke down the front of his vest and said,",
      "para_break": true
    },
    {
      "start": 804.416,
      "end": 805.34,
      "text": "\"'That's probably right.",
      "para_break": true
    },
    {
      "start": 806.14,
      "end": 809.1,
      "text": "He had only a few hundred in his pockets when I frisked them this",
      "para_break": true
    },
    {
      "start": 809.16,
      "end": 809.984,
      "text": "afternoon.\""
    },
    {
      "start": 811.2,
      "end": 813.54,
      "text": "When her eyes opened round and wide he grinned.",
      "para_break": true
    },
    {
      "start": 814.56,
      "end": 816.08,
      "text": "Cairo bent forward in his chair.",
      "para_break": true
    },
    {
      "start": 816.86,
      "end": 818.42,
      "text": "He barely failed to keep eagerness",
      "para_break": true
    },
    {
      "start": 818.42,
      "end": 820.24,
      "text": "from showing in his eyes and voice."
    },
    {
      "start": 821.82,
      "end": 824.22,
      "text": "I can be quite prepared to give you the money at,",
      "para_break": true
    },
    {
      "start": 824.3,
      "end": 824.56,
      "text": "say,"
    },
    {
      "start": 824.62,
      "end": 826.26,
      "text": "half-past ten in the morning,"
    },
    {
      "start": 826.42,
      "end": 827.008,
      "text": "eh?\""
    },
    {
      "start": 828.16,
      "end": 830.14,
      "text": "Bridget O'Shaughnessy smiled at him and said,",
      "para_break": true
    },
    {
      "start": 831.28,
      "end": 832.7,
      "text": "\"'But I haven't got the falcon.'",
      "para_break": true
    },
    {
      "start": 833.824,
      "end": 836.46,
      "text": "Cairo's face was darkened by a flush of annoyance.",
      "para_break": true
    },
    {
      "start": 837.04,
      "end": 839.96,
      "text": "He put an ugly white hand on either arm of the chair,"
    },
    {
      "start": 840.416,
      "end": 843.28,
      "text": "holding his small boned body erect and stiff between them."
    },
    {
      "start": 844.14,
      "end": 845.38,
      "text": "His dark eyes were angry.",
      "para_break": true
    },
    {
      "start": 846.14,
      "end": 847.32,
      "text": "He did not say anything.",
      "para_break": true
    },
    {
      "start": 848.74,
      "end": 851.16,
      "text": "The girl made a mock placatory face at him.",
      "para_break": true
    },
    {
      "start": 853.152,
      "end": 854.76,
      "text": "\"'I'll have it in a week at the most,",
      "para_break": true
    },
    {
      "start": 854.78,
      "end": 855.92,
      "text": "though,' she said."
    },
    {
      "start": 857.504,
      "end": 858.34,
      "text": "\"'Where is it?'",
      "para_break": true
    },
    {
      "start": 859.232,
      "end": 861.94,
      "text": "Cairo used politeness of Maine to express skepticism.",
      "para_break": true
    },
    {
      "start": 863.58,
      "end": 864.42,
      "text": "\"'Where Floyd hid it.",
      "para_break": true
    },
    {
      "start": 864.54,
      "end": 865.66,
      "text": "Floyd?"
    },
    {
      "start": 865.96,
      "end": 866.06,
      "text": "Thursby?'"
    },
    {
      "start": 867.6,
      "end": 868.1,
      "text": "She nodded.",
      "para_break": true
    },
    {
      "start": 869.568,
      "end": 871.88,
      "text": "\"'And you know where that is?' he asked.",
      "para_break": true
    },
    {
      "start": 872.736,
      "end": 873.66,
      "text": "\"'I think I do.'",
      "para_break": true
    },
    {
      "start": 874.752,
      "end": 876.32,
      "text": "\"'Then why must we wait a week?'",
      "para_break": true
    },
    {
      "start": 877.344,
      "end": 878.52,
      "text": "\"'Perhaps not a whole week.",
      "para_break": true
    },
    {
      "start": 879.13,
      "end": 880.38,
      "text": "Whom are you buying it for,"
    },
    {
      "start": 880.48,
      "end": 880.86,
      "text": "Joe?'"
    },
    {
      "start": 882.016,
      "end": 883.14,
      "text": "Cairo raised his eyebrows.",
      "para_break": true
    },
    {
      "start": 884.54,
      "end": 885.18,
      "text": "\"'I told Mr.",
      "para_break": true
    },
    {
      "start": 885.34,
      "end": 885.68,
      "text": "Spade."
    },
    {
      "start": 885.88,
      "end": 887.36,
      "text": "For its owner.'"
    },
    {
      "start": 888.768,
      "end": 890.82,
      "text": "Surprise illuminated the girl's face.",
      "para_break": true
    },
    {
      "start": 891.872,
      "end": 893.312,
      "text": "\"'So you went back to him?'",
      "para_break": true
    },
    {
      "start": 893.62,
      "end": 894.78,
      "text": "\"'Naturally.'"
    },
    {
      "start": 895.76,
      "end": 897.82,
      "text": "She laughed softly in her throat and said,",
      "para_break": true
    },
    {
      "start": 898.88,
      "end": 900.64,
      "text": "\"'I should have liked to have seen that.'",
      "para_break": true
    },
    {
      "start": 901.504,
      "end": 902.34,
      "text": "Cairo shrugged.",
      "para_break": true
    },
    {
      "start": 903.136,
      "end": 904.14,
      "text": "\"'That was the natural,",
      "para_break": true
    },
    {
      "start": 904.3,
      "end": 905.31,
      "text": "the logical development.'"
    },
    {
      "start": 906.6,
      "end": 909.02,
      "text": "He rubbed the back of one hand with the palm of the other.",
      "para_break": true
    },
    {
      "start": 910.1,
      "end": 912.16,
      "text": "His upper lids came down to shade his eyes.",
      "para_break": true
    },
    {
      "start": 913.38,
      "end": 913.88,
      "text": "Why,",
      "para_break": true
    },
    {
      "start": 914.04,
      "end": 915.86,
      "text": "if I in turn may ask a question,"
    },
    {
      "start": 916.48,
      "end": 917.86,
      "text": "are you willing to sell it to me,"
    },
    {
      "start": 917.96,
      "end": 918.42,
      "text": "Bridget?\""
    },
    {
      "start": 919.84,
      "end": 921.82,
      "text": "\"'I'm afraid,' she said simply,",
      "para_break": true
    },
    {
      "start": 921.98,
      "end": 923.64,
      "text": "after what happened to Floyd."
    },
    {
      "start": 924.46,
      "end": 925.6,
      "text": "That's why I haven't got",
      "para_break": true
    },
    {
      "start": 925.6,
      "end": 925.92,
      "text": "it now."
    },
    {
      "start": 927.64,
      "end": 929.6,
      "text": "I'm afraid to touch it except to turn",
      "para_break": true
    },
    {
      "start": 929.6,
      "end": 931.48,
      "text": "it over to someone else right away.\""
    },
    {
      "start": 932.864,
      "end": 934.92,
      "text": "Spade propped an elbow on the sofa,",
      "para_break": true
    },
    {
      "start": 935.14,
      "end": 937.3,
      "text": "looked at and listened to them impartially."
    },
    {
      "start": 938.62,
      "end": 938.84,
      "text": "In the",
      "para_break": true
    },
    {
      "start": 938.94,
      "end": 940.84,
      "text": "comfortable slackness of his body and"
    },
    {
      "start": 940.84,
      "end": 942.56,
      "text": "the easy stillness of his features,"
    },
    {
      "start": 943.24,
      "end": 943.48,
      "text": "there was"
    },
    {
      "start": 943.48,
      "end": 946.58,
      "text": "no indication of either curiosity or impatience."
    },
    {
      "start": 948.544,
      "end": 951.58,
      "text": "\"'Exactly what?' Cairo asked in a low voice.",
      "para_break": true
    },
    {
      "start": 951.72,
      "end": 953.22,
      "text": "\"'Happened to Floyd?'"
    },
    {
      "start": 954.4,
      "end": 957.7,
      "text": "The tip of her right forefinger traced a swift G in the air.",
      "para_break": true
    },
    {
      "start": 958.912,
      "end": 959.46,
      "text": "Cairo said,",
      "para_break": true
    },
    {
      "start": 959.6,
      "end": 960.8,
      "text": "\"'I see."
    },
    {
      "start": 961.86,
      "end": 964.12,
      "text": "But there was something of doubtfulness in his smile.",
      "para_break": true
    },
    {
      "start": 964.51,
      "end": 966.78,
      "text": "Is he here?"
    },
    {
      "start": 967.44,
      "end": 968.54,
      "text": "I don't know,"
    },
    {
      "start": 968.7,
      "end": 970.44,
      "text": "she spoke impatiently."
    },
    {
      "start": 970.98,
      "end": 972.24,
      "text": "What difference does that make?"
    },
    {
      "start": 972.86,
      "end": 975.64,
      "text": "The doubt in Cairo's smile deepened."
    },
    {
      "start": 977.24,
      "end": 978.48,
      "text": "It might make a difference,",
      "para_break": true
    },
    {
      "start": 979.12,
      "end": 979.46,
      "text": "he said,"
    },
    {
      "start": 979.62,
      "end": 982.0,
      "text": "and rearranged his hands in his lap so that,"
    },
    {
      "start": 982.24,
      "end": 982.96,
      "text": "intentionally or not,"
    },
    {
      "start": 983.12,
      "end": 985.5,
      "text": "a blunt forefinger pointed at Spade."
    },
    {
      "start": 986.24,
      "end": 988.28,
      "text": "The girl glanced at the finger and",
      "para_break": true
    },
    {
      "start": 988.28,
      "end": 990.28,
      "text": "made an impatient motion with her head."
    }
  ]
}
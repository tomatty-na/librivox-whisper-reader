{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-07",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_07_hammett.mp3",
  "chapter_title": "Chapter 7 - G in the Air",
  "reader_name": "Mark Nelson",
  "page_num": 5,
  "page_total": 7,
  "page_start_sec": 991.68,
  "page_end_sec": 1232.02,
  "para_gap_threshold": 0.735,
  "segments": [
    {
      "start": 991.68,
      "end": 992.0,
      "text": "Or me,",
      "para_break": true
    },
    {
      "start": 992.28,
      "end": 992.9,
      "text": "she said."
    },
    {
      "start": 993.36,
      "end": 993.74,
      "text": "Or you."
    },
    {
      "start": 994.42,
      "end": 994.52,
      "text": "\"'Exactly."
    },
    {
      "start": 995.64,
      "end": 997.48,
      "text": "And shall we include,",
      "para_break": true
    },
    {
      "start": 997.66,
      "end": 998.5,
      "text": "with more certainty,"
    },
    {
      "start": 998.68,
      "end": 999.86,
      "text": "the boy outside?'"
    },
    {
      "start": 1000.77,
      "end": 1002.92,
      "text": "\"'Yes,' she agreed and laughed.",
      "para_break": true
    },
    {
      "start": 1003.52,
      "end": 1003.9,
      "text": "\"'Yes,"
    },
    {
      "start": 1003.9,
      "end": 1006.09,
      "text": "unless he's the one you had in Constantinople.'"
    },
    {
      "start": 1007.872,
      "end": 1009.96,
      "text": "Sudden blood mottled Cairo's face.",
      "para_break": true
    },
    {
      "start": 1010.96,
      "end": 1011.55,
      "text": "In a shrill,",
      "para_break": true
    },
    {
      "start": 1011.64,
      "end": 1013.92,
      "text": "enraged voice he spoke a dozen words that"
    },
    {
      "start": 1013.92,
      "end": 1014.66,
      "text": "were neither English,"
    },
    {
      "start": 1014.86,
      "end": 1015.16,
      "text": "French,"
    },
    {
      "start": 1015.34,
      "end": 1015.76,
      "text": "German,"
    },
    {
      "start": 1015.8,
      "end": 1016.52,
      "text": "nor Spanish."
    },
    {
      "start": 1018.176,
      "end": 1020.1,
      "text": "Bridget O'Shaughnessy jumped up from her chair.",
      "para_break": true
    },
    {
      "start": 1020.86,
      "end": 1022.56,
      "text": "Her lower lip was between her teeth.",
      "para_break": true
    },
    {
      "start": 1022.86,
      "end": 1023.68,
      "text": "Her eyes"
    },
    {
      "start": 1023.9,
      "end": 1026.38,
      "text": "were dark and wide in a tense white face."
    },
    {
      "start": 1027.4,
      "end": 1029.44,
      "text": "She took two quick steps toward Cairo.",
      "para_break": true
    },
    {
      "start": 1030.32,
      "end": 1031.22,
      "text": "He started to rise.",
      "para_break": true
    },
    {
      "start": 1031.74,
      "end": 1035.02,
      "text": "Her right hand went out and cracked sharply against his cheek,"
    },
    {
      "start": 1035.14,
      "end": 1036.34,
      "text": "leaving the imprint of its"
    },
    {
      "start": 1036.42,
      "end": 1036.96,
      "text": "fingers there."
    },
    {
      "start": 1038.4,
      "end": 1040.2,
      "text": "Cairo grunted and slapped her cheek,",
      "para_break": true
    },
    {
      "start": 1040.42,
      "end": 1041.64,
      "text": "staggering her sideways,"
    },
    {
      "start": 1042.04,
      "end": 1042.88,
      "text": "bringing from"
    },
    {
      "start": 1043.02,
      "end": 1044.52,
      "text": "her a brief muffled scream."
    },
    {
      "start": 1045.36,
      "end": 1046.48,
      "text": "Spade,",
      "para_break": true
    },
    {
      "start": 1046.56,
      "end": 1047.38,
      "text": "wooden of face,"
    },
    {
      "start": 1047.6,
      "end": 1050.14,
      "text": "was up from the sofa and close to them by then."
    },
    {
      "start": 1050.42,
      "end": 1052.98,
      "text": "He caught Cairo by the throat and shook him."
    },
    {
      "start": 1053.824,
      "end": 1056.18,
      "text": "Cairo gurgled and put a hand inside his coat.",
      "para_break": true
    },
    {
      "start": 1057.184,
      "end": 1058.98,
      "text": "Spade grasped the smaller man's wrist,",
      "para_break": true
    },
    {
      "start": 1059.14,
      "end": 1060.4,
      "text": "wrenched it away from the coat,"
    },
    {
      "start": 1060.6,
      "end": 1061.98,
      "text": "forced it straight out to"
    },
    {
      "start": 1061.98,
      "end": 1064.34,
      "text": "the side and twisted it until the clumsy white"
    },
    {
      "start": 1064.34,
      "end": 1066.9,
      "text": "fingers opened to let the black pistol fall down"
    },
    {
      "start": 1066.9,
      "end": 1067.44,
      "text": "on the rug."
    },
    {
      "start": 1069.088,
      "end": 1071.18,
      "text": "Bridget O'Shaughnessy quickly picked up the pistol.",
      "para_break": true
    },
    {
      "start": 1071.48,
      "end": 1072.44,
      "text": "Cairo,"
    },
    {
      "start": 1072.6,
      "end": 1073.7,
      "text": "speaking with difficulty"
    },
    {
      "start": 1073.9,
      "end": 1075.44,
      "text": "because of the fingers on his throat,"
    },
    {
      "start": 1075.54,
      "end": 1075.72,
      "text": "said,"
    },
    {
      "start": 1076.64,
      "end": 1079.52,
      "text": "This is the second time you put your hands on me.\"",
      "para_break": true
    },
    {
      "start": 1080.84,
      "end": 1081.4,
      "text": "His eyes,",
      "para_break": true
    },
    {
      "start": 1081.58,
      "end": 1084.78,
      "text": "for all that the throttling pressure on his throat made them bulge,"
    },
    {
      "start": 1084.88,
      "end": 1086.02,
      "text": "were cold and menacing."
    },
    {
      "start": 1087.08,
      "end": 1087.56,
      "text": "Yes,",
      "para_break": true
    },
    {
      "start": 1087.88,
      "end": 1089.06,
      "text": "Spade growled,"
    },
    {
      "start": 1089.1,
      "end": 1092.12,
      "text": "and when you're slapped you'll take it and like it."
    },
    {
      "start": 1093.18,
      "end": 1095.82,
      "text": "He released Cairo's wrist and with a thick open hand",
      "para_break": true
    },
    {
      "start": 1095.82,
      "end": 1098.66,
      "text": "struck the sides of his face three times savagely."
    },
    {
      "start": 1100.16,
      "end": 1102.22,
      "text": "Cairo tried to spit into Spade's face,",
      "para_break": true
    },
    {
      "start": 1102.8,
      "end": 1105.44,
      "text": "but the dryness of his mouth made it only an angry gesture."
    },
    {
      "start": 1106.752,
      "end": 1107.9,
      "text": "Spade slapped the mouth,",
      "para_break": true
    },
    {
      "start": 1108.12,
      "end": 1109.52,
      "text": "cutting Cairo's lower lip."
    },
    {
      "start": 1110.0,
      "end": 1111.52,
      "text": "The doorbell rang."
    },
    {
      "start": 1112.832,
      "end": 1115.12,
      "text": "Cairo's eyes jerked into focus on the passageway",
      "para_break": true
    },
    {
      "start": 1115.12,
      "end": 1116.5,
      "text": "that led to the corridor door."
    },
    {
      "start": 1117.64,
      "end": 1119.72,
      "text": "His eyes had become unangry and wary.",
      "para_break": true
    },
    {
      "start": 1120.48,
      "end": 1123.44,
      "text": "The girl had gasped and turned to face the passageway.",
      "para_break": true
    },
    {
      "start": 1124.32,
      "end": 1124.96,
      "text": "Her face was",
      "para_break": true
    },
    {
      "start": 1125.06,
      "end": 1125.3,
      "text": "frightened."
    },
    {
      "start": 1126.24,
      "end": 1128.22,
      "text": "Spade stared gloomily for a moment",
      "para_break": true
    },
    {
      "start": 1128.22,
      "end": 1129.92,
      "text": "at the blood trickling from Cairo's"
    },
    {
      "start": 1130.02,
      "end": 1131.74,
      "text": "lip and then stepped back,"
    },
    {
      "start": 1131.88,
      "end": 1133.82,
      "text": "taking his hand away from the Levantine's"
    },
    {
      "start": 1133.92,
      "end": 1134.06,
      "text": "throat."
    },
    {
      "start": 1135.48,
      "end": 1137.21,
      "text": "\"'Who is it?' the girl whispered,",
      "para_break": true
    },
    {
      "start": 1137.28,
      "end": 1138.34,
      "text": "coming close to Spade,"
    },
    {
      "start": 1138.5,
      "end": 1139.26,
      "text": "and Cairo's"
    },
    {
      "start": 1139.26,
      "end": 1140.84,
      "text": "eyes asked the same question."
    },
    {
      "start": 1141.9,
      "end": 1144.98,
      "text": "\"'I don't know,' Spade replied in an irritable voice.",
      "para_break": true
    },
    {
      "start": 1145.68,
      "end": 1147.0,
      "text": "The bell rang again,"
    },
    {
      "start": 1147.18,
      "end": 1148.08,
      "text": "more insistently."
    },
    {
      "start": 1148.95,
      "end": 1149.6,
      "text": "\"'Well,",
      "para_break": true
    },
    {
      "start": 1149.6,
      "end": 1151.36,
      "text": "keep quiet,' Spade said,"
    },
    {
      "start": 1151.52,
      "end": 1152.58,
      "text": "and went out of the room,"
    },
    {
      "start": 1152.7,
      "end": 1153.2,
      "text": "shutting the"
    },
    {
      "start": 1153.2,
      "end": 1153.96,
      "text": "door behind him."
    },
    {
      "start": 1155.904,
      "end": 1157.08,
      "text": "Spade turned on the light in the",
      "para_break": true
    },
    {
      "start": 1157.08,
      "end": 1158.86,
      "text": "passageway and opened the door to the"
    },
    {
      "start": 1158.92,
      "end": 1159.12,
      "text": "corridor."
    },
    {
      "start": 1160.16,
      "end": 1162.2,
      "text": "Lieutenant Dundee and Tom Polehouse were there.",
      "para_break": true
    },
    {
      "start": 1162.82,
      "end": 1163.84,
      "text": "\"'Hello,"
    },
    {
      "start": 1163.92,
      "end": 1165.24,
      "text": "Sam,' Tom said."
    },
    {
      "start": 1165.74,
      "end": 1168.032,
      "text": "\"'We thought maybe you wouldn't have gone to bed yet.'"
    },
    {
      "start": 1168.96,
      "end": 1169.62,
      "text": "Dundee nodded,",
      "para_break": true
    },
    {
      "start": 1169.62,
      "end": 1170.34,
      "text": "but said nothing."
    },
    {
      "start": 1171.18,
      "end": 1173.78,
      "text": "\"'Hello,' Spade said good-naturedly.",
      "para_break": true
    },
    {
      "start": 1174.5,
      "end": 1176.34,
      "text": "\"'You guys picked swell hours to go calling."
    },
    {
      "start": 1177.1,
      "end": 1177.97,
      "text": "What is it this time?'",
      "para_break": true
    },
    {
      "start": 1179.232,
      "end": 1180.26,
      "text": "Dundee spoke quietly.",
      "para_break": true
    },
    {
      "start": 1181.36,
      "end": 1182.3,
      "text": "\"'We want to talk to you,",
      "para_break": true
    },
    {
      "start": 1182.34,
      "end": 1182.69,
      "text": "Spade.'"
    },
    {
      "start": 1183.48,
      "end": 1184.32,
      "text": "\"'Well?'",
      "para_break": true
    },
    {
      "start": 1185.024,
      "end": 1186.1,
      "text": "Spade stood in the doorway,"
    },
    {
      "start": 1186.2,
      "end": 1186.84,
      "text": "blocking it."
    },
    {
      "start": 1187.46,
      "end": 1188.48,
      "text": "\"'Go ahead and talk.'"
    },
    {
      "start": 1189.5,
      "end": 1190.4,
      "text": "Tom Polehouse advanced,",
      "para_break": true
    },
    {
      "start": 1190.68,
      "end": 1190.94,
      "text": "saying,"
    },
    {
      "start": 1191.31,
      "end": 1193.36,
      "text": "We don't have to do it standing here,"
    },
    {
      "start": 1193.48,
      "end": 1193.984,
      "text": "do we?\""
    },
    {
      "start": 1195.008,
      "end": 1197.0,
      "text": "Spade stood still in the doorway and said,",
      "para_break": true
    },
    {
      "start": 1198.04,
      "end": 1199.0,
      "text": "You can't come in.",
      "para_break": true
    },
    {
      "start": 1199.44,
      "end": 1202.28,
      "text": "His tone was very slightly apologetic."
    },
    {
      "start": 1203.392,
      "end": 1204.64,
      "text": "Tom's thick-featured face,",
      "para_break": true
    },
    {
      "start": 1204.84,
      "end": 1206.46,
      "text": "even in height with Spade's,"
    },
    {
      "start": 1206.48,
      "end": 1209.04,
      "text": "took on an expression of friendly scornfulness,"
    },
    {
      "start": 1209.76,
      "end": 1211.78,
      "text": "though there was a bright gleam in his small,"
    },
    {
      "start": 1211.8,
      "end": 1212.5,
      "text": "shrewd eyes."
    },
    {
      "start": 1214.24,
      "end": 1214.7,
      "text": "What the hell,",
      "para_break": true
    },
    {
      "start": 1214.82,
      "end": 1215.04,
      "text": "Sam?"
    },
    {
      "start": 1215.76,
      "end": 1216.41,
      "text": "he protested,"
    },
    {
      "start": 1216.9,
      "end": 1219.06,
      "text": "and put a big playful hand on Spade's chest."
    },
    {
      "start": 1219.82,
      "end": 1222.36,
      "text": "Spade leaned against the pushing hand,",
      "para_break": true
    },
    {
      "start": 1222.58,
      "end": 1223.78,
      "text": "grinned wolfishly,"
    },
    {
      "start": 1223.78,
      "end": 1224.42,
      "text": "and asked,"
    },
    {
      "start": 1225.312,
      "end": 1226.34,
      "text": "\"'Going to strong-arm me,",
      "para_break": true
    },
    {
      "start": 1226.4,
      "end": 1226.8,
      "text": "Tom?'"
    },
    {
      "start": 1227.904,
      "end": 1228.5,
      "text": "Tom grumbled,",
      "para_break": true
    },
    {
      "start": 1229.2,
      "end": 1229.56,
      "text": "\"'Oh,"
    },
    {
      "start": 1229.6,
      "end": 1232.02,
      "text": "for God's sake,' and stopped pushing."
    }
  ]
}
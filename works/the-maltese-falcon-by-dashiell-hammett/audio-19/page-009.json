{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-19",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_19_hammett.mp3",
  "chapter_title": "Chapter 19 - The Russian's Hand",
  "reader_name": "Mark Nelson",
  "page_num": 9,
  "page_total": 10,
  "page_start_sec": 1957.984,
  "page_end_sec": 2201.52,
  "para_gap_threshold": 0.671,
  "segments": [
    {
      "start": 1957.984,
      "end": 1959.72,
      "text": "Gutman turned the bird upside down and",
      "para_break": true
    },
    {
      "start": 1959.72,
      "end": 1961.8,
      "text": "scraped an edge of its base with his knife."
    },
    {
      "start": 1962.96,
      "end": 1964.82,
      "text": "Black enamel came off in tiny curls,",
      "para_break": true
    },
    {
      "start": 1965.08,
      "end": 1967.0,
      "text": "exposing blackened metal beneath."
    },
    {
      "start": 1968.384,
      "end": 1969.22,
      "text": "Gutman's knife-blade",
      "para_break": true
    },
    {
      "start": 1969.4,
      "end": 1970.16,
      "text": "bit into the metal,"
    },
    {
      "start": 1970.32,
      "end": 1971.52,
      "text": "turning back a thin,"
    },
    {
      "start": 1971.64,
      "end": 1972.46,
      "text": "curved shaving."
    },
    {
      "start": 1973.52,
      "end": 1975.2,
      "text": "The inside of the shaving and the",
      "para_break": true
    },
    {
      "start": 1975.22,
      "end": 1979.56,
      "text": "narrow plain its removal had left had the soft gray sheen of lead."
    },
    {
      "start": 1981.216,
      "end": 1983.04,
      "text": "Gutman's breath hissed between his teeth.",
      "para_break": true
    },
    {
      "start": 1983.712,
      "end": 1985.88,
      "text": "His face became turgid with hot blood.",
      "para_break": true
    },
    {
      "start": 1986.38,
      "end": 1986.86,
      "text": "He"
    },
    {
      "start": 1986.92,
      "end": 1988.98,
      "text": "twisted the bird around and hacked at its head."
    },
    {
      "start": 1989.62,
      "end": 1990.22,
      "text": "There,"
    },
    {
      "start": 1990.28,
      "end": 1990.52,
      "text": "too,"
    },
    {
      "start": 1990.62,
      "end": 1991.98,
      "text": "the edge of his knife bared"
    },
    {
      "start": 1992.08,
      "end": 1992.28,
      "text": "lead."
    },
    {
      "start": 1992.87,
      "end": 1995.12,
      "text": "He let knife and bird bang down on the"
    },
    {
      "start": 1995.12,
      "end": 1997.1,
      "text": "table while he wheeled to confront Spade."
    },
    {
      "start": 1998.4,
      "end": 1998.88,
      "text": "\"'It's a fake!'",
      "para_break": true
    },
    {
      "start": 1999.88,
      "end": 2000.72,
      "text": "he said hoarsely.",
      "para_break": true
    },
    {
      "start": 2001.824,
      "end": 2003.36,
      "text": "Spade's face became somber.",
      "para_break": true
    },
    {
      "start": 2004.064,
      "end": 2005.1,
      "text": "His nod was slow,",
      "para_break": true
    },
    {
      "start": 2005.32,
      "end": 2007.86,
      "text": "but there was no slowness in his hand going out to"
    },
    {
      "start": 2008.06,
      "end": 2009.44,
      "text": "catch Bridget O'Shaughnessy's wrist."
    },
    {
      "start": 2010.48,
      "end": 2013.32,
      "text": "He pulled her to him and grasped her chin with his other hand,",
      "para_break": true
    },
    {
      "start": 2013.54,
      "end": 2014.68,
      "text": "raising her face roughly."
    },
    {
      "start": 2015.98,
      "end": 2018.72,
      "text": "\"'All right,' he growled down into her frightened face.",
      "para_break": true
    },
    {
      "start": 2019.54,
      "end": 2020.62,
      "text": "\"'You've had your little joke.",
      "para_break": true
    },
    {
      "start": 2020.84,
      "end": 2022.32,
      "text": "Now tell us about it.'"
    },
    {
      "start": 2022.34,
      "end": 2022.496,
      "text": "it.\""
    },
    {
      "start": 2023.22,
      "end": 2023.62,
      "text": "She cried,",
      "para_break": true
    },
    {
      "start": 2023.98,
      "end": 2024.38,
      "text": "\"'No,"
    },
    {
      "start": 2024.48,
      "end": 2024.72,
      "text": "Sam,"
    },
    {
      "start": 2024.84,
      "end": 2025.06,
      "text": "no."
    },
    {
      "start": 2025.54,
      "end": 2027.34,
      "text": "That's the one I got from Kamidov."
    },
    {
      "start": 2027.52,
      "end": 2028.54,
      "text": "I swear!'"
    },
    {
      "start": 2029.74,
      "end": 2033.26,
      "text": "Joel Cairo thrust himself between Spade and Gutman and began to emit",
      "para_break": true
    },
    {
      "start": 2033.38,
      "end": 2034.36,
      "text": "words in a shrill,"
    },
    {
      "start": 2034.36,
      "end": 2035.22,
      "text": "spluttering stream."
    },
    {
      "start": 2036.416,
      "end": 2037.1,
      "text": "\"'That's it!",
      "para_break": true
    },
    {
      "start": 2037.24,
      "end": 2038.08,
      "text": "That's it!"
    },
    {
      "start": 2038.3,
      "end": 2039.36,
      "text": "It was the Russian!"
    },
    {
      "start": 2039.66,
      "end": 2040.84,
      "text": "I should have known!"
    },
    {
      "start": 2041.16,
      "end": 2041.78,
      "text": "What"
    },
    {
      "start": 2041.9,
      "end": 2042.98,
      "text": "a fool we thought him,"
    },
    {
      "start": 2043.1,
      "end": 2045.36,
      "text": "and what fools he made of us!'"
    },
    {
      "start": 2046.24,
      "end": 2049.32,
      "text": "Tears ran down the Levantine's cheeks and he danced up and down.",
      "para_break": true
    },
    {
      "start": 2050.4,
      "end": 2052.84,
      "text": "\"'You bungled it!' he screamed at Gutman.",
      "para_break": true
    },
    {
      "start": 2053.408,
      "end": 2056.1,
      "text": "\"'You and your stupid attempt to buy it from him!"
    },
    {
      "start": 2056.66,
      "end": 2057.56,
      "text": "You fat fool!"
    },
    {
      "start": 2058.1,
      "end": 2059.92,
      "text": "You let him know it was valuable,"
    },
    {
      "start": 2060.16,
      "end": 2063.68,
      "text": "and he found out how valuable and made a duplicate for us!"
    },
    {
      "start": 2064.04,
      "end": 2066.56,
      "text": "No wonder we had so little trouble stealing it!"
    },
    {
      "start": 2067.08,
      "end": 2069.18,
      "text": "No wonder he was so willing to send me"
    },
    {
      "start": 2069.18,
      "end": 2070.62,
      "text": "off around the world looking for it!"
    },
    {
      "start": 2071.38,
      "end": 2072.16,
      "text": "You imbecile!",
      "para_break": true
    },
    {
      "start": 2072.66,
      "end": 2074.24,
      "text": "You bloated idiot!'"
    },
    {
      "start": 2074.67,
      "end": 2077.22,
      "text": "He put his hands to his face and blubbered."
    },
    {
      "start": 2078.04,
      "end": 2079.76,
      "text": "Gutman's jaw sagged.",
      "para_break": true
    },
    {
      "start": 2080.32,
      "end": 2081.52,
      "text": "He blinked vacant eyes."
    },
    {
      "start": 2082.5,
      "end": 2083.8,
      "text": "Then he shook himself and was,",
      "para_break": true
    },
    {
      "start": 2083.92,
      "end": 2084.58,
      "text": "by the time"
    },
    {
      "start": 2084.58,
      "end": 2085.9,
      "text": "his bulbs had stopped jouncing,"
    },
    {
      "start": 2086.1,
      "end": 2088.66,
      "text": "again a jovially smiling fat man."
    },
    {
      "start": 2089.92,
      "end": 2090.62,
      "text": "\"'Come,",
      "para_break": true
    },
    {
      "start": 2090.64,
      "end": 2092.7,
      "text": "sir,' he said good-naturedly,"
    },
    {
      "start": 2092.79,
      "end": 2095.14,
      "text": "\"'there's no need of going on like that."
    },
    {
      "start": 2095.4,
      "end": 2096.8,
      "text": "Everybody errs"
    },
    {
      "start": 2096.82,
      "end": 2097.42,
      "text": "at times,"
    },
    {
      "start": 2097.52,
      "end": 2099.94,
      "text": "and you may be sure that this is every"
    },
    {
      "start": 2099.94,
      "end": 2101.92,
      "text": "bit as severe a blow to me as to any"
    },
    {
      "start": 2102.02,
      "end": 2102.48,
      "text": "anyone else."
    },
    {
      "start": 2102.86,
      "end": 2103.56,
      "text": "Yes,"
    },
    {
      "start": 2103.76,
      "end": 2104.98,
      "text": "that is the Russian's hand."
    },
    {
      "start": 2105.27,
      "end": 2106.66,
      "text": "There is no doubt of it."
    },
    {
      "start": 2106.94,
      "end": 2107.68,
      "text": "Well,"
    },
    {
      "start": 2107.74,
      "end": 2107.94,
      "text": "sir,"
    },
    {
      "start": 2108.08,
      "end": 2108.68,
      "text": "what do"
    },
    {
      "start": 2108.68,
      "end": 2109.12,
      "text": "you suggest?"
    },
    {
      "start": 2109.54,
      "end": 2111.8,
      "text": "Shall we stand here and call each other names?"
    },
    {
      "start": 2112.78,
      "end": 2113.72,
      "text": "Or shall we....'",
      "para_break": true
    },
    {
      "start": 2114.52,
      "end": 2116.98,
      "text": "He paused and his smile was at Cherub's.",
      "para_break": true
    },
    {
      "start": 2117.06,
      "end": 2118.68,
      "text": "\"'Go to Constantinople!'"
    },
    {
      "start": 2120.58,
      "end": 2123.9,
      "text": "Now Cairo's jaw sagged while Cairo's eyes bulged.",
      "para_break": true
    },
    {
      "start": 2124.66,
      "end": 2125.96,
      "text": "In a little while he stammered,",
      "para_break": true
    },
    {
      "start": 2126.96,
      "end": 2129.98,
      "text": "You are—Amazement that came with full",
      "para_break": true
    },
    {
      "start": 2129.98,
      "end": 2132.5,
      "text": "comprehension seemed to rob him of further words."
    },
    {
      "start": 2133.664,
      "end": 2136.26,
      "text": "Gutman patted a fat cheek gently with a fat hand.",
      "para_break": true
    },
    {
      "start": 2136.94,
      "end": 2137.88,
      "text": "His eyes twinkled.",
      "para_break": true
    },
    {
      "start": 2138.04,
      "end": 2139.97,
      "text": "His voice was a complacent"
    },
    {
      "start": 2140.06,
      "end": 2140.82,
      "text": "throaty purring."
    },
    {
      "start": 2142.3,
      "end": 2144.48,
      "text": "For seventeen years I have wanted that",
      "para_break": true
    },
    {
      "start": 2144.48,
      "end": 2146.92,
      "text": "little item and have been trying to get it."
    },
    {
      "start": 2147.82,
      "end": 2150.04,
      "text": "If I must spend another year on the quest—well,",
      "para_break": true
    },
    {
      "start": 2150.56,
      "end": 2150.82,
      "text": "sir,"
    },
    {
      "start": 2150.98,
      "end": 2153.36,
      "text": "that will be an additional expenditure in"
    },
    {
      "start": 2153.48,
      "end": 2158.56,
      "text": "time of only—his lips moved silently as he calculated—five and"
    },
    {
      "start": 2158.64,
      "end": 2160.32,
      "text": "fifteenth's seventeenths percent."
    },
    {
      "start": 2161.22,
      "end": 2163.36,
      "text": "The Levantine giggled and cried,",
      "para_break": true
    },
    {
      "start": 2164.0,
      "end": 2164.96,
      "text": "\"'I go with you.'"
    },
    {
      "start": 2165.92,
      "end": 2168.78,
      "text": "Spade suddenly released the girl's wrist and looked around the room.",
      "para_break": true
    },
    {
      "start": 2169.3,
      "end": 2170.5,
      "text": "The boy was not there."
    },
    {
      "start": 2171.648,
      "end": 2173.16,
      "text": "Spade went into the passageway.",
      "para_break": true
    },
    {
      "start": 2173.66,
      "end": 2174.94,
      "text": "The corridor door was open."
    },
    {
      "start": 2175.68,
      "end": 2177.52,
      "text": "Spade made a dissatisfied mouth,",
      "para_break": true
    },
    {
      "start": 2177.7,
      "end": 2178.46,
      "text": "shut the door,"
    },
    {
      "start": 2178.56,
      "end": 2179.42,
      "text": "and returned to the"
    },
    {
      "start": 2179.5,
      "end": 2179.82,
      "text": "living room."
    },
    {
      "start": 2180.5,
      "end": 2183.16,
      "text": "He leaned against the door-frame and looked at Gutman.",
      "para_break": true
    },
    {
      "start": 2183.48,
      "end": 2185.72,
      "text": "He looked at him for a long time,"
    },
    {
      "start": 2185.84,
      "end": 2186.49,
      "text": "sourly."
    },
    {
      "start": 2187.66,
      "end": 2188.24,
      "text": "Then he spoke,",
      "para_break": true
    },
    {
      "start": 2188.44,
      "end": 2190.78,
      "text": "mimicking the fat man's throaty purr."
    },
    {
      "start": 2191.84,
      "end": 2192.26,
      "text": "\"'Well,",
      "para_break": true
    },
    {
      "start": 2192.26,
      "end": 2192.5,
      "text": "sir,"
    },
    {
      "start": 2192.68,
      "end": 2195.36,
      "text": "I must say you're a swell lot of thieves.'"
    },
    {
      "start": 2196.448,
      "end": 2197.06,
      "text": "Cutman chuckled.",
      "para_break": true
    },
    {
      "start": 2198.176,
      "end": 2199.32,
      "text": "\"'We've nothing to boast of,",
      "para_break": true
    },
    {
      "start": 2199.44,
      "end": 2200.34,
      "text": "and that's a fact,"
    },
    {
      "start": 2200.44,
      "end": 2201.52,
      "text": "sir,' he said."
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-19",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_19_hammett.mp3",
  "chapter_title": "Chapter 19 - The Russian's Hand",
  "reader_name": "Mark Nelson",
  "page_num": 6,
  "page_total": 10,
  "page_start_sec": 1226.68,
  "page_end_sec": 1470.16,
  "para_gap_threshold": 0.671,
  "segments": [
    {
      "start": 1226.68,
      "end": 1228.46,
      "text": "He did not raise his voice."
    },
    {
      "start": 1229.66,
      "end": 1231.14,
      "text": "\"'I don't know anything about that.",
      "para_break": true
    },
    {
      "start": 1231.76,
      "end": 1233.32,
      "text": "I've got to know what happened to the bill."
    },
    {
      "start": 1234.0,
      "end": 1234.88,
      "text": "Take them off.'",
      "para_break": true
    },
    {
      "start": 1236.0,
      "end": 1238.1,
      "text": "She looked at his unblinking yellow-gray eyes,",
      "para_break": true
    },
    {
      "start": 1238.22,
      "end": 1240.44,
      "text": "and her face became pink and then white again."
    },
    {
      "start": 1241.984,
      "end": 1243.14,
      "text": "\"'Very well,' she said.",
      "para_break": true
    },
    {
      "start": 1243.94,
      "end": 1245.8,
      "text": "He sat on the side of the bathtub,",
      "para_break": true
    },
    {
      "start": 1245.96,
      "end": 1247.14,
      "text": "watching the open door."
    },
    {
      "start": 1248.06,
      "end": 1249.56,
      "text": "No sound came from the living room.",
      "para_break": true
    },
    {
      "start": 1250.336,
      "end": 1252.08,
      "text": "She removed her clothes swiftly.",
      "para_break": true
    },
    {
      "start": 1253.0,
      "end": 1256.02,
      "text": "In her mien was pride without defiance or embarrassment.",
      "para_break": true
    },
    {
      "start": 1256.8,
      "end": 1258.86,
      "text": "He picked up each piece and examined",
      "para_break": true
    },
    {
      "start": 1258.86,
      "end": 1260.82,
      "text": "it with fingers as well as with eyes."
    },
    {
      "start": 1261.32,
      "end": 1263.42,
      "text": "He did not find the thousand-dollar bill."
    },
    {
      "start": 1264.64,
      "end": 1265.4,
      "text": "When he had finished,",
      "para_break": true
    },
    {
      "start": 1265.52,
      "end": 1266.26,
      "text": "he stood up holding"
    },
    {
      "start": 1266.58,
      "end": 1268.26,
      "text": "her clothes out in his hands to her."
    },
    {
      "start": 1269.25,
      "end": 1270.38,
      "text": "\"'Thanks,' he said.",
      "para_break": true
    },
    {
      "start": 1271.08,
      "end": 1271.936,
      "text": "\"'Now I know.'",
      "para_break": true
    },
    {
      "start": 1273.08,
      "end": 1274.38,
      "text": "She took the clothing from him.",
      "para_break": true
    },
    {
      "start": 1274.92,
      "end": 1276.08,
      "text": "She did not say anything."
    },
    {
      "start": 1276.66,
      "end": 1278.04,
      "text": "He picked up his pistols."
    },
    {
      "start": 1278.52,
      "end": 1281.5,
      "text": "He shut the bathroom door behind him and went into the living room."
    },
    {
      "start": 1282.72,
      "end": 1284.88,
      "text": "Gutman smiled amiably from the rocking-chair.",
      "para_break": true
    },
    {
      "start": 1286.08,
      "end": 1287.36,
      "text": "\"'Find it?' he asked.",
      "para_break": true
    },
    {
      "start": 1288.0,
      "end": 1288.54,
      "text": "Cairo,"
    },
    {
      "start": 1288.72,
      "end": 1290.34,
      "text": "sitting beside the boy on the sofa,"
    },
    {
      "start": 1290.58,
      "end": 1292.46,
      "text": "looked at Spade with questioning,"
    },
    {
      "start": 1292.64,
      "end": 1293.46,
      "text": "opaque eyes."
    },
    {
      "start": 1294.3,
      "end": 1295.5,
      "text": "The boy did not look up.",
      "para_break": true
    },
    {
      "start": 1295.64,
      "end": 1297.26,
      "text": "He was leaning forward,"
    },
    {
      "start": 1297.5,
      "end": 1298.46,
      "text": "head between hands,"
    },
    {
      "start": 1298.64,
      "end": 1299.56,
      "text": "elbows on knees,"
    },
    {
      "start": 1299.82,
      "end": 1301.3,
      "text": "staring at the floor between"
    },
    {
      "start": 1301.3,
      "end": 1301.88,
      "text": "his feet."
    },
    {
      "start": 1303.36,
      "end": 1304.3,
      "text": "Spade told Gutman,",
      "para_break": true
    },
    {
      "start": 1305.04,
      "end": 1305.54,
      "text": "\"'No,",
      "para_break": true
    },
    {
      "start": 1305.68,
      "end": 1306.72,
      "text": "I didn't find it."
    },
    {
      "start": 1307.4,
      "end": 1308.28,
      "text": "You palmed it.'",
      "para_break": true
    },
    {
      "start": 1308.8,
      "end": 1310.16,
      "text": "The fat man chuckled."
    },
    {
      "start": 1310.784,
      "end": 1312.02,
      "text": "\"'I palmed it?'"
    },
    {
      "start": 1312.49,
      "end": 1314.42,
      "text": "\"'Yes,' Spade said,"
    },
    {
      "start": 1314.5,
      "end": 1316.04,
      "text": "jingling the pistols in his hand."
    },
    {
      "start": 1316.58,
      "end": 1317.78,
      "text": "\"'Do you want to say so?"
    },
    {
      "start": 1318.19,
      "end": 1320.11,
      "text": "Or do you want to stand for a frisk?'"
    },
    {
      "start": 1321.152,
      "end": 1322.12,
      "text": "\"'Stand for—'",
      "para_break": true
    },
    {
      "start": 1322.2,
      "end": 1324.52,
      "text": "You're going to admit it,\" Spade said,"
    },
    {
      "start": 1325.02,
      "end": 1326.4,
      "text": "or I'm going to search you."
    },
    {
      "start": 1327.104,
      "end": 1328.288,
      "text": "There's no third way.\"",
      "para_break": true
    },
    {
      "start": 1329.312,
      "end": 1332.2,
      "text": "Gutman looked up at Spade's hard face and laughed outright.",
      "para_break": true
    },
    {
      "start": 1332.96,
      "end": 1333.56,
      "text": "\"'By gad,",
      "para_break": true
    },
    {
      "start": 1333.64,
      "end": 1333.92,
      "text": "sir,"
    },
    {
      "start": 1334.04,
      "end": 1335.26,
      "text": "I believe you would."
    },
    {
      "start": 1335.66,
      "end": 1336.42,
      "text": "I really do."
    },
    {
      "start": 1337.28,
      "end": 1337.8,
      "text": "You're a character,",
      "para_break": true
    },
    {
      "start": 1338.14,
      "end": 1338.38,
      "text": "sir,"
    },
    {
      "start": 1338.54,
      "end": 1340.62,
      "text": "if you don't mind my saying so.\""
    },
    {
      "start": 1341.86,
      "end": 1343.82,
      "text": "\"'You palmed it,' Spade said.",
      "para_break": true
    },
    {
      "start": 1344.43,
      "end": 1345.48,
      "text": "\"'Yes,"
    },
    {
      "start": 1345.48,
      "end": 1345.74,
      "text": "sir,"
    },
    {
      "start": 1345.8,
      "end": 1346.944,
      "text": "that I did.'"
    },
    {
      "start": 1347.43,
      "end": 1350.2,
      "text": "The fat man took a crumpled bill from his vest pocket,"
    },
    {
      "start": 1350.44,
      "end": 1350.5,
      "text": "pocket,"
    },
    {
      "start": 1350.69,
      "end": 1352.34,
      "text": "smoothed it on a wide thigh,"
    },
    {
      "start": 1352.66,
      "end": 1354.96,
      "text": "took the envelope holding the nine bills from his"
    },
    {
      "start": 1354.96,
      "end": 1355.48,
      "text": "coat pocket,"
    },
    {
      "start": 1355.64,
      "end": 1357.76,
      "text": "and put the smooth bill in with the others."
    },
    {
      "start": 1359.1,
      "end": 1361.36,
      "text": "I must have my little joke every now and then,",
      "para_break": true
    },
    {
      "start": 1361.54,
      "end": 1364.06,
      "text": "and I was curious to know what you do in a"
    },
    {
      "start": 1364.16,
      "end": 1365.26,
      "text": "situation of that sort."
    },
    {
      "start": 1366.14,
      "end": 1369.18,
      "text": "I must say you passed the test with flying colors,",
      "para_break": true
    },
    {
      "start": 1369.3,
      "end": 1369.52,
      "text": "sir."
    },
    {
      "start": 1369.7,
      "end": 1370.68,
      "text": "It never"
    },
    {
      "start": 1370.78,
      "end": 1372.9,
      "text": "occurred to me that you'd hit on such a simple"
    },
    {
      "start": 1372.9,
      "end": 1374.96,
      "text": "and direct way of getting at the truth.\""
    },
    {
      "start": 1376.16,
      "end": 1377.96,
      "text": "Spade sneered at him without bitterness.",
      "para_break": true
    },
    {
      "start": 1379.616,
      "end": 1382.71,
      "text": "That's the kind of thing I'd expect from somebody the punk's age.\"",
      "para_break": true
    },
    {
      "start": 1383.68,
      "end": 1384.4,
      "text": "Gutman chuckled.",
      "para_break": true
    },
    {
      "start": 1385.408,
      "end": 1386.24,
      "text": "Bridget O'Shaughnessy,",
      "para_break": true
    },
    {
      "start": 1386.38,
      "end": 1388.28,
      "text": "dressed again except for coat and hat,"
    },
    {
      "start": 1388.42,
      "end": 1389.0,
      "text": "came out"
    },
    {
      "start": 1389.0,
      "end": 1389.43,
      "text": "of the bathroom,"
    },
    {
      "start": 1389.8,
      "end": 1391.38,
      "text": "took a step toward the living room,"
    },
    {
      "start": 1391.56,
      "end": 1392.16,
      "text": "turned around,"
    },
    {
      "start": 1392.46,
      "end": 1392.84,
      "text": "went"
    },
    {
      "start": 1392.92,
      "end": 1393.62,
      "text": "back to the kitchen,"
    },
    {
      "start": 1393.76,
      "end": 1394.78,
      "text": "and turned on the light."
    },
    {
      "start": 1396.448,
      "end": 1400.36,
      "text": "Cairo edged closer to the boy on the sofa and began whispering in his",
      "para_break": true
    },
    {
      "start": 1400.36,
      "end": 1400.8,
      "text": "ear again."
    },
    {
      "start": 1401.78,
      "end": 1403.16,
      "text": "The boy shrugged irritably.",
      "para_break": true
    },
    {
      "start": 1404.32,
      "end": 1404.98,
      "text": "Spade,",
      "para_break": true
    },
    {
      "start": 1405.12,
      "end": 1407.9,
      "text": "looking at the pistols in his hand and then at Gutman,"
    },
    {
      "start": 1408.12,
      "end": 1408.384,
      "text": "went"
    },
    {
      "start": 1408.86,
      "end": 1410.94,
      "text": "out into the passageway to the closet there."
    },
    {
      "start": 1411.38,
      "end": 1412.62,
      "text": "He opened the door,"
    },
    {
      "start": 1412.76,
      "end": 1413.8,
      "text": "put the pistols inside"
    },
    {
      "start": 1413.8,
      "end": 1414.94,
      "text": "on the top of a trunk,"
    },
    {
      "start": 1415.16,
      "end": 1415.98,
      "text": "shut the door,"
    },
    {
      "start": 1416.18,
      "end": 1416.7,
      "text": "locked it,"
    },
    {
      "start": 1417.14,
      "end": 1419.0,
      "text": "put the key in his pants pocket and went"
    },
    {
      "start": 1419.0,
      "end": 1419.74,
      "text": "to the kitchen door."
    },
    {
      "start": 1421.024,
      "end": 1423.55,
      "text": "Bridget O'Shaughnessy was filling an aluminum percolator.",
      "para_break": true
    },
    {
      "start": 1425.024,
      "end": 1426.66,
      "text": "\"'Find everything?' Spade asked.",
      "para_break": true
    },
    {
      "start": 1427.48,
      "end": 1430.04,
      "text": "\"'Yes,' she replied in a cool voice,",
      "para_break": true
    },
    {
      "start": 1430.14,
      "end": 1431.1,
      "text": "not raising her head."
    },
    {
      "start": 1432.12,
      "end": 1433.44,
      "text": "Then she set the percolator aside",
      "para_break": true
    },
    {
      "start": 1433.8,
      "end": 1434.64,
      "text": "and came to the door."
    },
    {
      "start": 1435.46,
      "end": 1438.58,
      "text": "She blushed and her eyes were large and moist and chiding.",
      "para_break": true
    },
    {
      "start": 1439.7,
      "end": 1440.72,
      "text": "\"'You shouldn't have done that,",
      "para_break": true
    },
    {
      "start": 1440.86,
      "end": 1442.72,
      "text": "Sam,' she said softly."
    },
    {
      "start": 1443.78,
      "end": 1444.7,
      "text": "\"'I had to find out,",
      "para_break": true
    },
    {
      "start": 1444.72,
      "end": 1445.14,
      "text": "Angel.'"
    },
    {
      "start": 1445.9,
      "end": 1446.54,
      "text": "He bent down,",
      "para_break": true
    },
    {
      "start": 1446.66,
      "end": 1447.74,
      "text": "kissed her mouth lightly,"
    },
    {
      "start": 1447.82,
      "end": 1448.96,
      "text": "and returned to the living"
    },
    {
      "start": 1449.06,
      "end": 1449.18,
      "text": "room."
    },
    {
      "start": 1450.784,
      "end": 1453.58,
      "text": "Gutman smiled at Spade and offered him the white envelope,",
      "para_break": true
    },
    {
      "start": 1453.76,
      "end": 1454.26,
      "text": "saying,"
    },
    {
      "start": 1455.36,
      "end": 1456.52,
      "text": "\"'This will soon be yours.",
      "para_break": true
    },
    {
      "start": 1456.76,
      "end": 1458.44,
      "text": "You might as well take it now.'"
    },
    {
      "start": 1459.68,
      "end": 1460.92,
      "text": "Spade did not take it.",
      "para_break": true
    },
    {
      "start": 1461.86,
      "end": 1463.56,
      "text": "He sat in the armchair and said,",
      "para_break": true
    },
    {
      "start": 1464.864,
      "end": 1466.26,
      "text": "\"'There's plenty of time for that.",
      "para_break": true
    },
    {
      "start": 1466.44,
      "end": 1467.1,
      "text": "Besides,"
    },
    {
      "start": 1467.82,
      "end": 1468.62,
      "text": "we haven't done enough",
      "para_break": true
    },
    {
      "start": 1468.72,
      "end": 1470.16,
      "text": "talking about the money end yet."
    }
  ]
}
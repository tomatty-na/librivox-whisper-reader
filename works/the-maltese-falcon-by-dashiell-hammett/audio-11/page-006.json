{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-11",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_11_hammett.mp3",
  "chapter_title": "Chapter 11 - Gutman",
  "reader_name": "Mark Nelson",
  "page_num": 6,
  "page_total": 6,
  "page_start_sec": 1220.6,
  "page_end_sec": 1328.52,
  "para_gap_threshold": 0.658,
  "segments": [
    {
      "start": 1220.6,
      "end": 1223.82,
      "text": "The boy's eyes were wide open and dark with wide pupils.",
      "para_break": true
    },
    {
      "start": 1224.92,
      "end": 1227.68,
      "text": "Their gaze ran over Spade's body from shoulders to knees,",
      "para_break": true
    },
    {
      "start": 1227.9,
      "end": 1230.2,
      "text": "and up again to settle on the handkerchief"
    },
    {
      "start": 1230.4,
      "end": 1231.92,
      "text": "whose maroon border peeped from the"
    },
    {
      "start": 1231.92,
      "end": 1233.68,
      "text": "breast pocket of Spade's brown coat."
    },
    {
      "start": 1235.328,
      "end": 1237.14,
      "text": "\"'Another thing,' Spade repeated,",
      "para_break": true
    },
    {
      "start": 1237.36,
      "end": 1238.26,
      "text": "glaring at the boy."
    },
    {
      "start": 1238.53,
      "end": 1240.34,
      "text": "\"'Keep that gunsail away from"
    },
    {
      "start": 1240.34,
      "end": 1241.88,
      "text": "me while you're making up your mind."
    },
    {
      "start": 1242.08,
      "end": 1243.26,
      "text": "I'll kill him."
    },
    {
      "start": 1243.82,
      "end": 1244.56,
      "text": "I don't like him."
    },
    {
      "start": 1244.66,
      "end": 1245.6,
      "text": "He makes me nervous."
    },
    {
      "start": 1246.6,
      "end": 1248.8,
      "text": "I'll kill him the first time he gets in my way.",
      "para_break": true
    },
    {
      "start": 1249.952,
      "end": 1250.8,
      "text": "I'm afraid of him,",
      "para_break": true
    },
    {
      "start": 1250.9,
      "end": 1252.14,
      "text": "and I won't give him an even"
    },
    {
      "start": 1252.26,
      "end": 1252.5,
      "text": "break."
    },
    {
      "start": 1253.36,
      "end": 1254.62,
      "text": "I won't even give him a chance.",
      "para_break": true
    },
    {
      "start": 1255.64,
      "end": 1256.352,
      "text": "I'll kill him.\"",
      "para_break": true
    },
    {
      "start": 1257.2,
      "end": 1259.98,
      "text": "The boy's lips twitched in a shadowy smile.",
      "para_break": true
    },
    {
      "start": 1260.86,
      "end": 1262.78,
      "text": "He neither raised his eyes nor spoke.",
      "para_break": true
    },
    {
      "start": 1263.62,
      "end": 1265.64,
      "text": "The fat man said tolerantly,",
      "para_break": true
    },
    {
      "start": 1266.52,
      "end": 1267.22,
      "text": "\"'Well,",
      "para_break": true
    },
    {
      "start": 1267.22,
      "end": 1267.48,
      "text": "sir,"
    },
    {
      "start": 1267.68,
      "end": 1270.68,
      "text": "I must say you have a most violent temper.'"
    },
    {
      "start": 1271.52,
      "end": 1272.32,
      "text": "\"'Temper!'",
      "para_break": true
    },
    {
      "start": 1273.056,
      "end": 1274.44,
      "text": "Spade laughed crazily.",
      "para_break": true
    },
    {
      "start": 1274.68,
      "end": 1276.48,
      "text": "He crossed to the chair on"
    },
    {
      "start": 1276.56,
      "end": 1277.58,
      "text": "which he had dropped his hat,"
    },
    {
      "start": 1277.72,
      "end": 1279.86,
      "text": "picked up the hat and set it on his head."
    },
    {
      "start": 1280.88,
      "end": 1282.02,
      "text": "He held out a long arm",
      "para_break": true
    },
    {
      "start": 1282.02,
      "end": 1285.02,
      "text": "that ended in a thick forefinger pointing at the fat man's belly."
    },
    {
      "start": 1286.08,
      "end": 1287.6,
      "text": "His angry voice filled the room.",
      "para_break": true
    },
    {
      "start": 1288.8,
      "end": 1289.2,
      "text": "\"'Think it over,",
      "para_break": true
    },
    {
      "start": 1289.28,
      "end": 1290.44,
      "text": "and think like hell."
    },
    {
      "start": 1291.2,
      "end": 1292.84,
      "text": "You've got till five-thirty to do it in.",
      "para_break": true
    },
    {
      "start": 1293.46,
      "end": 1298.12,
      "text": "Then you're either in or out for keeps.' He let his arm drop,"
    },
    {
      "start": 1298.56,
      "end": 1300.16,
      "text": "scowled at the bland fat man for"
    },
    {
      "start": 1300.16,
      "end": 1300.5,
      "text": "a moment,"
    },
    {
      "start": 1300.62,
      "end": 1301.62,
      "text": "scowled at the boy,"
    },
    {
      "start": 1301.82,
      "end": 1303.96,
      "text": "and went to the door through which he had entered."
    },
    {
      "start": 1305.08,
      "end": 1305.38,
      "text": "When he had",
      "para_break": true
    },
    {
      "start": 1305.5,
      "end": 1306.0,
      "text": "open the door,"
    },
    {
      "start": 1306.12,
      "end": 1307.7,
      "text": "he turned and said harshly,"
    },
    {
      "start": 1308.512,
      "end": 1309.34,
      "text": "\"'Five-thirty.",
      "para_break": true
    },
    {
      "start": 1309.48,
      "end": 1311.136,
      "text": "Then the curtain.'"
    },
    {
      "start": 1311.86,
      "end": 1312.82,
      "text": "The boy,",
      "para_break": true
    },
    {
      "start": 1313.02,
      "end": 1314.42,
      "text": "staring at Spade's chest,"
    },
    {
      "start": 1314.64,
      "end": 1317.46,
      "text": "repeated the two words he had twice spoken in the"
    },
    {
      "start": 1317.52,
      "end": 1318.14,
      "text": "Belvedere lobby."
    },
    {
      "start": 1319.28,
      "end": 1320.48,
      "text": "His voice was not loud.",
      "para_break": true
    },
    {
      "start": 1321.26,
      "end": 1321.8,
      "text": "It was bitter.",
      "para_break": true
    },
    {
      "start": 1322.912,
      "end": 1324.84,
      "text": "Spade went out and slammed the door.",
      "para_break": true
    },
    {
      "start": 1327.68,
      "end": 1328.52,
      "text": "End of chapter 11",
      "para_break": true
    }
  ]
}
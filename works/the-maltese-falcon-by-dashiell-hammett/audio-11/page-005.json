{
  "work_slug": "the-maltese-falcon-by-dashiell-hammett",
  "work_title": "Maltese Falcon, Original Serialized Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-11",
  "audio_url": "https://archive.org/download/maltesefalcon_2511_librivox/maltesefalcon_11_hammett.mp3",
  "chapter_title": "Chapter 11 - Gutman",
  "reader_name": "Mark Nelson",
  "page_num": 5,
  "page_total": 6,
  "page_start_sec": 977.408,
  "page_end_sec": 1219.46,
  "para_gap_threshold": 0.658,
  "segments": [
    {
      "start": 977.408,
      "end": 979.46,
      "text": "Spade twizzled his back in a tight smile.",
      "para_break": true
    },
    {
      "start": 980.928,
      "end": 983.32,
      "text": "\"'I'm glad I came to the right place,' he said.",
      "para_break": true
    },
    {
      "start": 983.96,
      "end": 985.36,
      "text": "The fat man smiled,"
    },
    {
      "start": 985.38,
      "end": 985.64,
      "text": "too,"
    },
    {
      "start": 985.8,
      "end": 987.22,
      "text": "but somewhat vaguely."
    },
    {
      "start": 988.16,
      "end": 989.74,
      "text": "Happiness had gone out of his face,",
      "para_break": true
    },
    {
      "start": 989.9,
      "end": 991.28,
      "text": "though he continued to smile,"
    },
    {
      "start": 991.88,
      "end": 993.54,
      "text": "and caution had come into his eyes."
    },
    {
      "start": 994.624,
      "end": 997.1,
      "text": "His face was a watchful-eyed smiling mask",
      "para_break": true
    },
    {
      "start": 997.1,
      "end": 999.28,
      "text": "held up between his thoughts and Spade."
    },
    {
      "start": 1000.48,
      "end": 1001.0,
      "text": "His eyes,",
      "para_break": true
    },
    {
      "start": 1001.18,
      "end": 1002.14,
      "text": "avoiding Spade's,"
    },
    {
      "start": 1002.16,
      "end": 1004.02,
      "text": "shifted to the glass at Spade's elbow."
    },
    {
      "start": 1005.04,
      "end": 1006.08,
      "text": "His face brightened.",
      "para_break": true
    },
    {
      "start": 1007.392,
      "end": 1007.86,
      "text": "\"'By gar,",
      "para_break": true
    },
    {
      "start": 1008.04,
      "end": 1009.06,
      "text": "sir,' he said,"
    },
    {
      "start": 1009.62,
      "end": 1010.9,
      "text": "\"'your glass is empty.'"
    },
    {
      "start": 1012.0,
      "end": 1013.36,
      "text": "He got up and went to the table,",
      "para_break": true
    },
    {
      "start": 1013.78,
      "end": 1015.94,
      "text": "and clattered glasses and siphon and bottle,"
    },
    {
      "start": 1016.0,
      "end": 1016.88,
      "text": "mixing two drinks."
    },
    {
      "start": 1018.016,
      "end": 1020.72,
      "text": "Spade was immobile in his chair until the fat man,",
      "para_break": true
    },
    {
      "start": 1021.08,
      "end": 1023.2,
      "text": "with a flourish and a bow and a jocular,"
    },
    {
      "start": 1023.58,
      "end": 1023.68,
      "text": "\"'Ah,"
    },
    {
      "start": 1024.28,
      "end": 1026.464,
      "text": "this kind of medicine will never hurt you!'"
    },
    {
      "start": 1027.06,
      "end": 1027.92,
      "text": "had handed him his"
    },
    {
      "start": 1028.0,
      "end": 1028.7,
      "text": "refilled glass."
    },
    {
      "start": 1029.6,
      "end": 1032.6,
      "text": "Then Spade rose and stood close to the fat man,",
      "para_break": true
    },
    {
      "start": 1032.78,
      "end": 1034.06,
      "text": "looking down at him."
    },
    {
      "start": 1034.88,
      "end": 1036.56,
      "text": "Spade's eyes were hard and bright.",
      "para_break": true
    },
    {
      "start": 1037.46,
      "end": 1038.4,
      "text": "He raised his glass.",
      "para_break": true
    },
    {
      "start": 1039.18,
      "end": 1039.84,
      "text": "His voice was",
      "para_break": true
    },
    {
      "start": 1039.9,
      "end": 1040.14,
      "text": "sharp,"
    },
    {
      "start": 1040.32,
      "end": 1040.76,
      "text": "challenging."
    },
    {
      "start": 1042.208,
      "end": 1045.05,
      "text": "\"'Here's to plain speaking and clear understanding!'",
      "para_break": true
    },
    {
      "start": 1045.62,
      "end": 1047.92,
      "text": "The fat man chuckled and they drank."
    },
    {
      "start": 1048.8,
      "end": 1050.02,
      "text": "The fat man sat down.",
      "para_break": true
    },
    {
      "start": 1050.86,
      "end": 1052.7,
      "text": "He held his glass against his belly with both",
      "para_break": true
    },
    {
      "start": 1052.9,
      "end": 1054.48,
      "text": "hands and smiled up at Spade."
    },
    {
      "start": 1054.69,
      "end": 1055.46,
      "text": "He said,"
    },
    {
      "start": 1055.68,
      "end": 1055.78,
      "text": "\"'Well,"
    },
    {
      "start": 1056.84,
      "end": 1057.14,
      "text": "sir,",
      "para_break": true
    },
    {
      "start": 1057.34,
      "end": 1058.28,
      "text": "it's surprising,"
    },
    {
      "start": 1058.64,
      "end": 1060.52,
      "text": "but it well may be a fact"
    },
    {
      "start": 1060.52,
      "end": 1063.76,
      "text": "that neither of them does know exactly what that bird is,"
    },
    {
      "start": 1063.92,
      "end": 1066.48,
      "text": "and that nobody in all this whole wide"
    },
    {
      "start": 1066.5,
      "end": 1068.16,
      "text": "sweet world knows what it is,"
    },
    {
      "start": 1068.24,
      "end": 1071.28,
      "text": "saving and accepting only your humble servant,"
    },
    {
      "start": 1071.46,
      "end": 1072.6,
      "text": "Caspar Gutman,"
    },
    {
      "start": 1072.76,
      "end": 1073.568,
      "text": "Esquire.'"
    },
    {
      "start": 1074.86,
      "end": 1077.26,
      "text": "\"'Swell!' Spade stood with legs apart,",
      "para_break": true
    },
    {
      "start": 1077.54,
      "end": 1079.02,
      "text": "one hand in his trouser pocket,"
    },
    {
      "start": 1079.22,
      "end": 1080.54,
      "text": "the other holding his glass."
    },
    {
      "start": 1081.29,
      "end": 1082.66,
      "text": "When you've told me,",
      "para_break": true
    },
    {
      "start": 1082.86,
      "end": 1084.8,
      "text": "there'll be only two of us who know.\""
    },
    {
      "start": 1085.792,
      "end": 1086.7,
      "text": "\"'Mathematically correct,",
      "para_break": true
    },
    {
      "start": 1086.94,
      "end": 1089.42,
      "text": "sir.' The fat man's eyes twinkled."
    },
    {
      "start": 1090.2,
      "end": 1090.7,
      "text": "But—'",
      "para_break": true
    },
    {
      "start": 1091.34,
      "end": 1092.06,
      "text": "His smile spread."
    },
    {
      "start": 1093.02,
      "end": 1095.904,
      "text": "\"'I don't know for certain that I'm going to tell you.'",
      "para_break": true
    },
    {
      "start": 1097.6,
      "end": 1100.42,
      "text": "\"'Don't be a damned fool,' Spade said patiently.",
      "para_break": true
    },
    {
      "start": 1101.56,
      "end": 1102.52,
      "text": "\"'You know what it is.",
      "para_break": true
    },
    {
      "start": 1102.62,
      "end": 1103.9,
      "text": "I know where it is."
    },
    {
      "start": 1104.0,
      "end": 1105.568,
      "text": "That's why we're here.'"
    },
    {
      "start": 1106.16,
      "end": 1106.84,
      "text": "\"'Well,"
    },
    {
      "start": 1106.84,
      "end": 1107.04,
      "text": "sir,"
    },
    {
      "start": 1107.18,
      "end": 1108.192,
      "text": "where is it?'"
    },
    {
      "start": 1109.216,
      "end": 1110.24,
      "text": "Spade ignored the question.",
      "para_break": true
    },
    {
      "start": 1110.81,
      "end": 1112.7,
      "text": "The fat man bunched his lips,"
    },
    {
      "start": 1112.84,
      "end": 1113.68,
      "text": "raised his eyebrows,"
    },
    {
      "start": 1113.9,
      "end": 1115.54,
      "text": "and cocked his head a little to the left."
    },
    {
      "start": 1117.152,
      "end": 1119.22,
      "text": "\"'You see,' he said blandly,",
      "para_break": true
    },
    {
      "start": 1119.9,
      "end": 1121.36,
      "text": "\"'I must tell you what I know,",
      "para_break": true
    },
    {
      "start": 1121.52,
      "end": 1123.54,
      "text": "but you will not tell me what you know."
    },
    {
      "start": 1124.38,
      "end": 1125.48,
      "text": "That is hardly equitable,",
      "para_break": true
    },
    {
      "start": 1125.74,
      "end": 1125.98,
      "text": "sir."
    },
    {
      "start": 1126.22,
      "end": 1126.32,
      "text": "No,"
    },
    {
      "start": 1126.98,
      "end": 1127.22,
      "text": "no,",
      "para_break": true
    },
    {
      "start": 1127.28,
      "end": 1129.696,
      "text": "I don't think we can do business like that.'"
    },
    {
      "start": 1131.104,
      "end": 1133.1,
      "text": "Spade's face became pale and hard.",
      "para_break": true
    },
    {
      "start": 1133.98,
      "end": 1135.46,
      "text": "He spoke rapidly in a low,",
      "para_break": true
    },
    {
      "start": 1135.58,
      "end": 1136.36,
      "text": "furious voice."
    },
    {
      "start": 1137.32,
      "end": 1138.2,
      "text": "Think again,",
      "para_break": true
    },
    {
      "start": 1138.34,
      "end": 1139.2,
      "text": "and think fast."
    },
    {
      "start": 1140.06,
      "end": 1142.72,
      "text": "I told that punk of yours that you'd have to talk to me before",
      "para_break": true
    },
    {
      "start": 1142.78,
      "end": 1143.34,
      "text": "you got through."
    },
    {
      "start": 1144.28,
      "end": 1146.22,
      "text": "I'll tell you now that you'll do your talking today,",
      "para_break": true
    },
    {
      "start": 1146.5,
      "end": 1147.36,
      "text": "or you are through."
    },
    {
      "start": 1148.1,
      "end": 1149.76,
      "text": "What are you wasting my time for?",
      "para_break": true
    },
    {
      "start": 1149.98,
      "end": 1151.68,
      "text": "You and your lousy secret."
    },
    {
      "start": 1152.86,
      "end": 1154.56,
      "text": "I know exactly what that stuff is",
      "para_break": true
    },
    {
      "start": 1154.56,
      "end": 1156.3,
      "text": "they keep in the sub-treasury vaults,"
    },
    {
      "start": 1156.54,
      "end": 1157.92,
      "text": "but what good does that do me?"
    },
    {
      "start": 1158.92,
      "end": 1160.18,
      "text": "I can get along without you,",
      "para_break": true
    },
    {
      "start": 1160.36,
      "end": 1160.84,
      "text": "damn you."
    },
    {
      "start": 1161.18,
      "end": 1162.46,
      "text": "Maybe you could have got"
    },
    {
      "start": 1162.62,
      "end": 1164.64,
      "text": "along without me if you'd kept clear of me."
    },
    {
      "start": 1165.34,
      "end": 1165.9,
      "text": "You can't now.",
      "para_break": true
    },
    {
      "start": 1166.14,
      "end": 1167.26,
      "text": "Not in San Francisco."
    },
    {
      "start": 1167.78,
      "end": 1168.32,
      "text": "You'll"
    },
    {
      "start": 1168.44,
      "end": 1170.98,
      "text": "come in or you'll get out and you'll do it today.\""
    },
    {
      "start": 1171.8,
      "end": 1175.9,
      "text": "He turned and with angry heedlessness tossed his glass on the table.",
      "para_break": true
    },
    {
      "start": 1176.38,
      "end": 1177.96,
      "text": "The glass struck the"
    },
    {
      "start": 1177.96,
      "end": 1178.18,
      "text": "wood,"
    },
    {
      "start": 1178.32,
      "end": 1180.64,
      "text": "burst apart and splashed its contents in"
    },
    {
      "start": 1180.64,
      "end": 1182.56,
      "text": "glittering fragments over table and floor."
    },
    {
      "start": 1183.59,
      "end": 1184.14,
      "text": "Spade,",
      "para_break": true
    },
    {
      "start": 1184.26,
      "end": 1185.66,
      "text": "deaf and blind to the crash,"
    },
    {
      "start": 1185.94,
      "end": 1187.76,
      "text": "wheeled to confront the fat man again."
    },
    {
      "start": 1189.0,
      "end": 1189.48,
      "text": "The fat man",
      "para_break": true
    },
    {
      "start": 1189.62,
      "end": 1192.48,
      "text": "paid no more attention to the glass's fate than Spade did."
    },
    {
      "start": 1193.152,
      "end": 1194.1,
      "text": "Lips pursed,",
      "para_break": true
    },
    {
      "start": 1194.24,
      "end": 1195.2,
      "text": "eyebrows raised,"
    },
    {
      "start": 1195.6,
      "end": 1197.12,
      "text": "head cocked a little to the left,"
    },
    {
      "start": 1197.62,
      "end": 1200.56,
      "text": "he had maintained his pink-faced blandness throughout Spade's"
    },
    {
      "start": 1200.66,
      "end": 1202.68,
      "text": "angry speech and he maintained it now."
    },
    {
      "start": 1204.224,
      "end": 1204.8,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 1205.06,
      "end": 1205.78,
      "text": "still furious,"
    },
    {
      "start": 1206.98,
      "end": 1207.82,
      "text": "\"'And another thing.",
      "para_break": true
    },
    {
      "start": 1207.92,
      "end": 1208.94,
      "text": "I don't want—'"
    },
    {
      "start": 1209.46,
      "end": 1211.18,
      "text": "The door to Spade's left opened."
    },
    {
      "start": 1212.1,
      "end": 1212.7,
      "text": "The boy who",
      "para_break": true
    },
    {
      "start": 1212.76,
      "end": 1214.0,
      "text": "admitted Spade came in."
    },
    {
      "start": 1214.64,
      "end": 1215.58,
      "text": "He shut the door,"
    },
    {
      "start": 1215.76,
      "end": 1217.78,
      "text": "stood in front of it with his hands flat against"
    },
    {
      "start": 1218.0,
      "end": 1219.46,
      "text": "his flanks and looked at Spade."
    }
  ]
}
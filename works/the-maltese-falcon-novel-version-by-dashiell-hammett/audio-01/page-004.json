{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-01",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_01_hammett.mp3",
  "chapter_title": "Spade and Archer",
  "reader_name": "NLizer",
  "page_num": 4,
  "page_total": 4,
  "page_start_sec": 755.06,
  "page_end_sec": 883.94,
  "para_gap_threshold": 0.685,
  "segments": [
    {
      "start": 755.06,
      "end": 756.22,
      "text": "\"I haven't the slightest idea.\""
    },
    {
      "start": 757.12,
      "end": 758.9,
      "text": "\"What time is he coming to see you?\"",
      "para_break": true
    },
    {
      "start": 760.0,
      "end": 760.76,
      "text": "\"After eight o'clock.\"",
      "para_break": true
    },
    {
      "start": 761.15,
      "end": 762.46,
      "text": "\"All right,"
    },
    {
      "start": 762.46,
      "end": 763.04,
      "text": "Miss Wonderly."
    },
    {
      "start": 763.31,
      "end": 764.44,
      "text": "We'll have a man there."
    },
    {
      "start": 764.68,
      "end": 765.696,
      "text": "It'll help if—\""
    },
    {
      "start": 765.98,
      "end": 766.76,
      "text": "\"Mr."
    },
    {
      "start": 766.96,
      "end": 767.4,
      "text": "Spade,"
    },
    {
      "start": 767.52,
      "end": 769.34,
      "text": "could either you or Mr."
    },
    {
      "start": 769.58,
      "end": 769.92,
      "text": "Archer?"
    },
    {
      "start": 770.88,
      "end": 772.9,
      "text": "She made an appealing gesture with both hands.",
      "para_break": true
    },
    {
      "start": 774.08,
      "end": 776.1,
      "text": "Could either of you look after it personally?"
    },
    {
      "start": 776.87,
      "end": 779.6,
      "text": "I don't mean that the man you'd send wouldn't be"
    },
    {
      "start": 779.76,
      "end": 779.94,
      "text": "capable,"
    },
    {
      "start": 780.14,
      "end": 780.38,
      "text": "but—"
    },
    {
      "start": 780.46,
      "end": 780.9,
      "text": "oh!—"
    },
    {
      "start": 781.31,
      "end": 784.03,
      "text": "I'm so afraid of what might happen to Corinne."
    },
    {
      "start": 784.64,
      "end": 785.48,
      "text": "I'm afraid of him."
    },
    {
      "start": 785.68,
      "end": 786.42,
      "text": "Could you?"
    },
    {
      "start": 787.36,
      "end": 787.74,
      "text": "I'd be—"
    },
    {
      "start": 788.23,
      "end": 790.22,
      "text": "I'd expect to be charged more,"
    },
    {
      "start": 790.26,
      "end": 790.68,
      "text": "of course.\""
    },
    {
      "start": 791.68,
      "end": 793.92,
      "text": "She opened her handbag with nervous fingers and",
      "para_break": true
    },
    {
      "start": 794.06,
      "end": 796.1,
      "text": "put two hundred-dollar bills on Spade's desk."
    },
    {
      "start": 797.0,
      "end": 797.74,
      "text": "\"Would that be enough?\"",
      "para_break": true
    },
    {
      "start": 798.0,
      "end": 798.1,
      "text": "\"Yeh,\""
    },
    {
      "start": 799.34,
      "end": 800.42,
      "text": "Archer said,",
      "para_break": true
    },
    {
      "start": 800.62,
      "end": 801.16,
      "text": "\"and I'll"
    },
    {
      "start": 801.26,
      "end": 801.9,
      "text": "look after it myself.\""
    },
    {
      "start": 803.36,
      "end": 804.42,
      "text": "Miss Wonderly stood up,",
      "para_break": true
    },
    {
      "start": 804.46,
      "end": 806.56,
      "text": "impulsively holding a hand out to him."
    },
    {
      "start": 807.26,
      "end": 807.8,
      "text": "\"Thank you!",
      "para_break": true
    },
    {
      "start": 807.82,
      "end": 808.5,
      "text": "Thank you!\""
    },
    {
      "start": 808.66,
      "end": 809.6,
      "text": "she exclaimed,"
    },
    {
      "start": 809.74,
      "end": 811.4,
      "text": "and then gave Spade her hand,"
    },
    {
      "start": 811.46,
      "end": 811.82,
      "text": "repeating:"
    },
    {
      "start": 812.58,
      "end": 813.08,
      "text": "\"Thank you!\""
    },
    {
      "start": 814.34,
      "end": 814.84,
      "text": "\"Not at all,\"",
      "para_break": true
    },
    {
      "start": 814.92,
      "end": 816.06,
      "text": "Spade said over it."
    },
    {
      "start": 816.64,
      "end": 816.92,
      "text": "\"Glad to."
    },
    {
      "start": 817.52,
      "end": 819.44,
      "text": "It'll help some if you either meet"
    },
    {
      "start": 819.54,
      "end": 821.54,
      "text": "Thursby downstairs or let yourself be"
    },
    {
      "start": 821.54,
      "end": 823.3,
      "text": "seen in the lobby with him at some time.\""
    },
    {
      "start": 823.95,
      "end": 824.86,
      "text": "\"I will,\""
    },
    {
      "start": 825.04,
      "end": 825.68,
      "text": "she promised,"
    },
    {
      "start": 825.86,
      "end": 827.06,
      "text": "and thanked the partners again."
    },
    {
      "start": 828.28,
      "end": 829.06,
      "text": "\"And don't look for me,\"",
      "para_break": true
    },
    {
      "start": 829.36,
      "end": 830.34,
      "text": "Archer cautioned her."
    },
    {
      "start": 830.46,
      "end": 831.62,
      "text": "\"I'll see you all right.\""
    },
    {
      "start": 832.96,
      "end": 835.1,
      "text": "Spade went to the corridor-door with Miss Wonderly.",
      "para_break": true
    },
    {
      "start": 835.44,
      "end": 836.84,
      "text": "When he returned to his desk"
    },
    {
      "start": 837.568,
      "end": 839.56,
      "text": "Archer nodded at the hundred-dollar bills there,",
      "para_break": true
    },
    {
      "start": 839.72,
      "end": 840.98,
      "text": "growled complacently,"
    },
    {
      "start": 841.9,
      "end": 842.54,
      "text": "\"They're right enough,\""
    },
    {
      "start": 843.8,
      "end": 844.34,
      "text": "picked one up,"
    },
    {
      "start": 844.42,
      "end": 845.06,
      "text": "folded it,"
    },
    {
      "start": 845.12,
      "end": 846.74,
      "text": "and tucked it into a vest-pocket."
    },
    {
      "start": 847.29,
      "end": 848.04,
      "text": "\"And they had"
    },
    {
      "start": 848.12,
      "end": 848.98,
      "text": "brothers in her bag.\""
    },
    {
      "start": 850.112,
      "end": 852.52,
      "text": "Spade pocketed the other bill before he sat down.",
      "para_break": true
    },
    {
      "start": 852.86,
      "end": 853.38,
      "text": "Then he said:"
    },
    {
      "start": 853.56,
      "end": 853.664,
      "text": "\"Well,"
    },
    {
      "start": 854.5,
      "end": 856.06,
      "text": "don't dynamite her too much."
    },
    {
      "start": 856.41,
      "end": 857.4,
      "text": "What do you think of her?\""
    },
    {
      "start": 857.66,
      "end": 858.56,
      "text": "\"Sweet!"
    },
    {
      "start": 859.04,
      "end": 860.76,
      "text": "And you telling me not to dynamite"
    },
    {
      "start": 860.76,
      "end": 860.94,
      "text": "her.\""
    },
    {
      "start": 861.1,
      "end": 863.74,
      "text": "Archer guffawed suddenly without merriment."
    },
    {
      "start": 864.54,
      "end": 865.4,
      "text": "\"Maybe you saw her first,",
      "para_break": true
    },
    {
      "start": 865.5,
      "end": 865.7,
      "text": "Sam,"
    },
    {
      "start": 865.84,
      "end": 866.82,
      "text": "but I spoke first.\""
    },
    {
      "start": 867.42,
      "end": 870.74,
      "text": "He put his hands in his trousers-pockets and teetered on his heels."
    },
    {
      "start": 871.76,
      "end": 872.58,
      "text": "\"You'll play hell with",
      "para_break": true
    },
    {
      "start": 872.58,
      "end": 872.72,
      "text": "her,"
    },
    {
      "start": 872.8,
      "end": 873.16,
      "text": "you will,\""
    },
    {
      "start": 873.34,
      "end": 874.94,
      "text": "Spade grinned wolfishly,"
    },
    {
      "start": 874.98,
      "end": 877.34,
      "text": "showing the edges of teeth far back in his jaw."
    },
    {
      "start": 878.34,
      "end": 878.92,
      "text": "\"You've got brains,",
      "para_break": true
    },
    {
      "start": 879.1,
      "end": 879.32,
      "text": "yes"
    },
    {
      "start": 879.32,
      "end": 879.7,
      "text": "yes you have.\""
    },
    {
      "start": 879.98,
      "end": 881.46,
      "text": "He began to make a cigarette."
    },
    {
      "start": 882.976,
      "end": 883.94,
      "text": "End of chapter 1",
      "para_break": true
    }
  ]
}
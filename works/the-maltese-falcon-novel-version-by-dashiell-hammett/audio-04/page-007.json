  "chapter_title": "The Black Bird",
  "reader_name": "NLizer",
  "page_num": 7,
  "page_total": 7,
  "page_start_sec": 1464.98,
  "page_end_sec": 1514.22,
  "para_gap_threshold": 0.657,
  "segments": [
    {
      "start": 1464.98,
      "end": 1466.24,
      "text": "Five thousand is a lot of money,",
      "para_break": true
    },
    {
      "start": 1466.44,
      "end": 1467.3,
      "text": "Spade commented,"
    },
    {
      "start": 1467.56,
      "end": 1468.5,
      "text": "looking thoughtfully at"
    },
    {
      "start": 1468.6,
      "end": 1468.88,
      "text": "Cairo."
    },
    {
      "start": 1469.12,
      "end": 1469.22,
      "text": "It..."
    },
    {
      "start": 1471.392,
      "end": 1472.88,
      "text": "Fingers drummed lightly on the door."
    },
    {
      "start": 1473.06,
      "end": 1474.6,
      "text": "When Spade had called,"
    },
    {
      "start": 1474.76,
      "end": 1475.32,
      "text": "come in,"
    },
    {
      "start": 1476.2,
      "end": 1476.68,
      "text": "the door opened",
      "para_break": true
    },
    {
      "start": 1476.8,
      "end": 1479.08,
      "text": "far enough to admit Effie Pryne's head and shoulders."
    },
    {
      "start": 1480.14,
      "end": 1481.84,
      "text": "She had put on a small dark felt hat",
      "para_break": true
    },
    {
      "start": 1482.14,
      "end": 1484.04,
      "text": "and a dark coat with a gray fur collar."
    },
    {
      "start": 1485.14,
      "end": 1486.0,
      "text": "Is there anything else?",
      "para_break": true
    },
    {
      "start": 1486.2,
      "end": 1486.96,
      "text": "She asked."
    },
    {
      "start": 1487.54,
      "end": 1488.14,
      "text": "No."
    },
    {
      "start": 1488.56,
      "end": 1488.9,
      "text": "Good night."
    },
    {
      "start": 1489.78,
      "end": 1490.8,
      "text": "Lock the door when you go,",
      "para_break": true
    },
    {
      "start": 1490.9,
      "end": 1491.28,
      "text": "will you?"
    },
    {
      "start": 1491.88,
      "end": 1494.38,
      "text": "Spade turned in his chair to face Cairo again,"
    },
    {
      "start": 1494.48,
      "end": 1494.84,
      "text": "saying,"
    },
    {
      "start": 1495.7,
      "end": 1496.72,
      "text": "It's an interesting figure.",
      "para_break": true
    },
    {
      "start": 1497.9,
      "end": 1500.74,
      "text": "The sound of the corridor doors closing behind Effie Perrine",
      "para_break": true
    },
    {
      "start": 1500.74,
      "end": 1501.46,
      "text": "came to them."
    },
    {
      "start": 1502.496,
      "end": 1503.8,
      "text": "Cairo smiled and took a short,",
      "para_break": true
    },
    {
      "start": 1503.82,
      "end": 1504.18,
      "text": "compact,"
    },
    {
      "start": 1504.32,
      "end": 1504.58,
      "text": "flat,"
    },
    {
      "start": 1504.7,
      "end": 1505.96,
      "text": "black pistol out of an inner"
    },
    {
      "start": 1506.06,
      "end": 1506.32,
      "text": "pocket."
    },
    {
      "start": 1507.24,
      "end": 1507.82,
      "text": "You will please,",
      "para_break": true
    },
    {
      "start": 1508.08,
      "end": 1508.64,
      "text": "he said."
    },
    {
      "start": 1509.08,
      "end": 1511.78,
      "text": "Clasp your hands together at the back of your neck."
    },
    {
      "start": 1513.024,
      "end": 1514.22,
      "text": "End of chapter 4",
      "para_break": true
    }
  ]
}
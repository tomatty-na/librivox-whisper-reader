{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-20",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_20_hammett.mp3",
  "chapter_title": "If They Hang You",
  "reader_name": "NLizer",
  "page_num": 6,
  "page_total": 6,
  "page_start_sec": 1269.74,
  "page_end_sec": 1509.84,
  "para_gap_threshold": 0.529,
  "segments": [
    {
      "start": 1269.74,
      "end": 1270.18,
      "text": "Look at me,",
      "para_break": true
    },
    {
      "start": 1270.36,
      "end": 1270.92,
      "text": "she said,"
    },
    {
      "start": 1271.1,
      "end": 1272.28,
      "text": "and tell me the truth."
    },
    {
      "start": 1273.14,
      "end": 1273.54,
      "text": "Would you have",
      "para_break": true
    },
    {
      "start": 1273.54,
      "end": 1275.36,
      "text": "done this to me if the falcon had been"
    },
    {
      "start": 1275.36,
      "end": 1277.42,
      "text": "real and you had been paid your money?"
    },
    {
      "start": 1278.36,
      "end": 1279.02,
      "text": "What difference does",
      "para_break": true
    },
    {
      "start": 1279.02,
      "end": 1279.76,
      "text": "that make now?"
    },
    {
      "start": 1280.768,
      "end": 1281.52,
      "text": "Don't be too sure.",
      "para_break": true
    },
    {
      "start": 1281.66,
      "end": 1283.48,
      "text": "I'm as crooked as I'm supposed to be."
    },
    {
      "start": 1284.26,
      "end": 1285.16,
      "text": "That kind of reputation",
      "para_break": true
    },
    {
      "start": 1285.5,
      "end": 1286.52,
      "text": "might be good business,"
    },
    {
      "start": 1286.72,
      "end": 1288.9,
      "text": "bringing in high-priced jobs and making"
    },
    {
      "start": 1288.9,
      "end": 1290.34,
      "text": "it easier to deal with the enemy."
    },
    {
      "start": 1291.22,
      "end": 1291.92,
      "text": "She looked at him,",
      "para_break": true
    },
    {
      "start": 1291.94,
      "end": 1292.56,
      "text": "saying nothing."
    },
    {
      "start": 1293.04,
      "end": 1295.26,
      "text": "He moved his shoulders a little and said,"
    },
    {
      "start": 1295.48,
      "end": 1295.584,
      "text": "well,"
    },
    {
      "start": 1296.48,
      "end": 1298.9,
      "text": "a lot of money would have been at least one",
      "para_break": true
    },
    {
      "start": 1298.9,
      "end": 1301.02,
      "text": "more item on the other side of the scales."
    },
    {
      "start": 1301.9,
      "end": 1303.52,
      "text": "She put her face up to his face.",
      "para_break": true
    },
    {
      "start": 1303.72,
      "end": 1306.74,
      "text": "Her mouth was slightly open with lips a little thrust out."
    },
    {
      "start": 1307.2,
      "end": 1307.88,
      "text": "She whispered,"
    },
    {
      "start": 1308.38,
      "end": 1309.3,
      "text": "if you loved me,"
    },
    {
      "start": 1309.42,
      "end": 1311.46,
      "text": "you'd need nothing more on that side."
    },
    {
      "start": 1312.448,
      "end": 1313.68,
      "text": "Spade set the edges of his",
      "para_break": true
    },
    {
      "start": 1313.68,
      "end": 1315.26,
      "text": "teeth together and said through them,"
    },
    {
      "start": 1316.04,
      "end": 1317.84,
      "text": "I won't play the sap for you.",
      "para_break": true
    },
    {
      "start": 1318.61,
      "end": 1320.28,
      "text": "She put her mouth to his slowly,",
      "para_break": true
    },
    {
      "start": 1320.6,
      "end": 1321.94,
      "text": "her arms around him,"
    },
    {
      "start": 1322.48,
      "end": 1323.68,
      "text": "and came into his arms.",
      "para_break": true
    },
    {
      "start": 1324.34,
      "end": 1326.1,
      "text": "She was in his arms when the doorbell rang.",
      "para_break": true
    },
    {
      "start": 1327.104,
      "end": 1329.36,
      "text": "Spade left arm around Bridget O'Shaughnessy,",
      "para_break": true
    },
    {
      "start": 1329.48,
      "end": 1330.74,
      "text": "opened the corridor door."
    },
    {
      "start": 1332.0,
      "end": 1332.74,
      "text": "Lieutenant Dundee,",
      "para_break": true
    },
    {
      "start": 1332.96,
      "end": 1334.52,
      "text": "Detective Sergeant Tom Polehouse,"
    },
    {
      "start": 1334.96,
      "end": 1336.36,
      "text": "and two other detectives were there."
    },
    {
      "start": 1336.58,
      "end": 1337.62,
      "text": "Spade said,"
    },
    {
      "start": 1338.04,
      "end": 1338.5,
      "text": "Hello,"
    },
    {
      "start": 1338.58,
      "end": 1338.84,
      "text": "Tom."
    },
    {
      "start": 1339.04,
      "end": 1339.54,
      "text": "Get them?"
    },
    {
      "start": 1340.416,
      "end": 1341.04,
      "text": "Polehouse said,",
      "para_break": true
    },
    {
      "start": 1341.2,
      "end": 1341.94,
      "text": "Got them."
    },
    {
      "start": 1342.64,
      "end": 1343.1,
      "text": "Swell,",
      "para_break": true
    },
    {
      "start": 1343.28,
      "end": 1343.76,
      "text": "come in."
    },
    {
      "start": 1343.9,
      "end": 1345.32,
      "text": "Here's another one for you."
    },
    {
      "start": 1345.888,
      "end": 1347.12,
      "text": "Spade pressed the girl forward.",
      "para_break": true
    },
    {
      "start": 1347.34,
      "end": 1348.56,
      "text": "She killed Miles,"
    },
    {
      "start": 1348.76,
      "end": 1349.9,
      "text": "and I've got some exhibits."
    },
    {
      "start": 1350.67,
      "end": 1351.94,
      "text": "The boy's guns,",
      "para_break": true
    },
    {
      "start": 1352.12,
      "end": 1353.12,
      "text": "one of Cairo's,"
    },
    {
      "start": 1353.66,
      "end": 1356.32,
      "text": "a black statuette that all the hell was about,",
      "para_break": true
    },
    {
      "start": 1356.84,
      "end": 1357.58,
      "text": "and a thousand dollar"
    },
    {
      "start": 1357.72,
      "end": 1359.52,
      "text": "bill that I was supposed to be bribed with."
    },
    {
      "start": 1360.32,
      "end": 1361.14,
      "text": "He looked at Dundee,",
      "para_break": true
    },
    {
      "start": 1361.3,
      "end": 1362.44,
      "text": "drew his brows together,"
    },
    {
      "start": 1363.08,
      "end": 1365.16,
      "text": "leaned forward to peer into the lieutenant's face,",
      "para_break": true
    },
    {
      "start": 1365.32,
      "end": 1366.72,
      "text": "and burst out laughing."
    },
    {
      "start": 1367.64,
      "end": 1368.23,
      "text": "What in hell's",
      "para_break": true
    },
    {
      "start": 1368.26,
      "end": 1370.06,
      "text": "the matter with your little playmate,"
    },
    {
      "start": 1370.2,
      "end": 1370.42,
      "text": "Tom?"
    },
    {
      "start": 1371.22,
      "end": 1372.02,
      "text": "He looks heartbroken.",
      "para_break": true
    },
    {
      "start": 1373.0,
      "end": 1373.72,
      "text": "He laughed again.",
      "para_break": true
    },
    {
      "start": 1374.76,
      "end": 1375.68,
      "text": "I bet by God,",
      "para_break": true
    },
    {
      "start": 1375.88,
      "end": 1377.26,
      "text": "when he heard Gutman's story,"
    },
    {
      "start": 1377.4,
      "end": 1378.84,
      "text": "he thought he had me at last."
    },
    {
      "start": 1379.68,
      "end": 1380.06,
      "text": "Cut it out,",
      "para_break": true
    },
    {
      "start": 1380.12,
      "end": 1380.28,
      "text": "Sam,"
    },
    {
      "start": 1380.64,
      "end": 1381.32,
      "text": "Tom grumbled."
    },
    {
      "start": 1381.5,
      "end": 1381.6,
      "text": "We"
    },
    {
      "start": 1382.02,
      "end": 1382.46,
      "text": "didn't think."
    },
    {
      "start": 1383.54,
      "end": 1384.48,
      "text": "Like hell he didn't,",
      "para_break": true
    },
    {
      "start": 1384.5,
      "end": 1385.58,
      "text": "Spade said merrily."
    },
    {
      "start": 1385.76,
      "end": 1387.98,
      "text": "He came up here with his mouth watering,"
    },
    {
      "start": 1388.42,
      "end": 1391.28,
      "text": "thought you'd have sense enough to know I'd been stringing Gutman."
    },
    {
      "start": 1392.26,
      "end": 1392.66,
      "text": "Cut it out,",
      "para_break": true
    },
    {
      "start": 1392.72,
      "end": 1393.66,
      "text": "Tom grumbled again,"
    },
    {
      "start": 1394.4,
      "end": 1396.44,
      "text": "looking uneasily sideways at his superior.",
      "para_break": true
    },
    {
      "start": 1396.88,
      "end": 1397.56,
      "text": "Anyways,"
    },
    {
      "start": 1398.12,
      "end": 1399.1,
      "text": "we got it from Cairo.",
      "para_break": true
    },
    {
      "start": 1399.36,
      "end": 1400.28,
      "text": "Gutman's dead."
    },
    {
      "start": 1400.88,
      "end": 1403.42,
      "text": "The kid had just finished shooting him up when we got there.",
      "para_break": true
    },
    {
      "start": 1403.6,
      "end": 1405.02,
      "text": "Spade nodded."
    },
    {
      "start": 1405.88,
      "end": 1407.12,
      "text": "He ought to have expected that,",
      "para_break": true
    },
    {
      "start": 1407.24,
      "end": 1407.62,
      "text": "he said."
    },
    {
      "start": 1408.544,
      "end": 1411.08,
      "text": "Effie Perrine put down her newspaper and jumped out",
      "para_break": true
    },
    {
      "start": 1411.08,
      "end": 1413.34,
      "text": "of Spade's chair when he came into the office"
    },
    {
      "start": 1413.34,
      "end": 1415.36,
      "text": "a little after nine o'clock Monday morning."
    },
    {
      "start": 1415.9,
      "end": 1416.3,
      "text": "He said,",
      "para_break": true
    },
    {
      "start": 1416.46,
      "end": 1417.34,
      "text": "morning,"
    },
    {
      "start": 1417.42,
      "end": 1417.78,
      "text": "Angel."
    },
    {
      "start": 1418.6,
      "end": 1418.92,
      "text": "Is that",
      "para_break": true
    },
    {
      "start": 1419.78,
      "end": 1420.6,
      "text": "what the papers have?",
      "para_break": true
    },
    {
      "start": 1420.84,
      "end": 1421.5,
      "text": "Right?"
    },
    {
      "start": 1422.24,
      "end": 1422.76,
      "text": "She asked.",
      "para_break": true
    },
    {
      "start": 1422.92,
      "end": 1423.62,
      "text": "Yes,"
    },
    {
      "start": 1423.62,
      "end": 1424.08,
      "text": "ma'am."
    },
    {
      "start": 1424.56,
      "end": 1426.88,
      "text": "He dropped his hat on the desk and sat down."
    },
    {
      "start": 1427.08,
      "end": 1428.96,
      "text": "His face was pasty in color,"
    },
    {
      "start": 1429.34,
      "end": 1430.3,
      "text": "but its lines were strong"
    },
    {
      "start": 1430.5,
      "end": 1430.74,
      "text": "and cheerful,"
    },
    {
      "start": 1431.0,
      "end": 1431.61,
      "text": "and his eyes,"
    },
    {
      "start": 1432.06,
      "end": 1433.36,
      "text": "though still somewhat red-veined,"
    },
    {
      "start": 1433.44,
      "end": 1433.86,
      "text": "were clear."
    },
    {
      "start": 1434.78,
      "end": 1435.94,
      "text": "The girl's brown eyes were",
      "para_break": true
    },
    {
      "start": 1436.36,
      "end": 1437.66,
      "text": "peculiarly enlarged,"
    },
    {
      "start": 1437.7,
      "end": 1439.34,
      "text": "and there was a queer twist to her mouth."
    },
    {
      "start": 1440.12,
      "end": 1441.14,
      "text": "She stood beside him,",
      "para_break": true
    },
    {
      "start": 1441.16,
      "end": 1441.74,
      "text": "staring down"
    },
    {
      "start": 1441.74,
      "end": 1442.12,
      "text": "at him."
    },
    {
      "start": 1442.62,
      "end": 1443.66,
      "text": "He raised his head,"
    },
    {
      "start": 1443.76,
      "end": 1444.26,
      "text": "grinned,"
    },
    {
      "start": 1444.34,
      "end": 1445.18,
      "text": "and said mockingly,"
    },
    {
      "start": 1445.42,
      "end": 1447.32,
      "text": "so much for your woman's intuition."
    },
    {
      "start": 1448.36,
      "end": 1450.84,
      "text": "Her voice was queer as the expression on her face.",
      "para_break": true
    },
    {
      "start": 1451.6,
      "end": 1452.2,
      "text": "You did that,",
      "para_break": true
    },
    {
      "start": 1452.3,
      "end": 1452.58,
      "text": "Sam,"
    },
    {
      "start": 1452.76,
      "end": 1453.22,
      "text": "to her?"
    },
    {
      "start": 1453.52,
      "end": 1454.82,
      "text": "He nodded."
    },
    {
      "start": 1455.62,
      "end": 1456.6,
      "text": "Your Sam's a detective,",
      "para_break": true
    },
    {
      "start": 1457.18,
      "end": 1458.28,
      "text": "he looked sharply at her.",
      "para_break": true
    },
    {
      "start": 1458.64,
      "end": 1460.24,
      "text": "He put his arm around her waist,"
    },
    {
      "start": 1460.68,
      "end": 1461.6,
      "text": "his hand on her hip."
    },
    {
      "start": 1462.46,
      "end": 1463.38,
      "text": "She did kill Miles,",
      "para_break": true
    },
    {
      "start": 1463.54,
      "end": 1463.78,
      "text": "Angel,"
    },
    {
      "start": 1463.96,
      "end": 1464.7,
      "text": "he said gently,"
    },
    {
      "start": 1464.86,
      "end": 1466.04,
      "text": "offhand like that."
    },
    {
      "start": 1466.88,
      "end": 1468.62,
      "text": "He snapped the fingers of his other hand.",
      "para_break": true
    },
    {
      "start": 1469.2,
      "end": 1471.48,
      "text": "She escaped from his arm as if it had hurt her.",
      "para_break": true
    },
    {
      "start": 1472.28,
      "end": 1472.62,
      "text": "Don't,",
      "para_break": true
    },
    {
      "start": 1472.62,
      "end": 1473.72,
      "text": "please don't touch me,"
    },
    {
      "start": 1473.84,
      "end": 1474.88,
      "text": "she said brokenly."
    },
    {
      "start": 1475.28,
      "end": 1475.74,
      "text": "I know,"
    },
    {
      "start": 1475.92,
      "end": 1476.86,
      "text": "I know you're right,"
    },
    {
      "start": 1476.98,
      "end": 1477.56,
      "text": "you're right."
    },
    {
      "start": 1478.3,
      "end": 1479.28,
      "text": "But don't touch me now,",
      "para_break": true
    },
    {
      "start": 1479.42,
      "end": 1479.96,
      "text": "not now."
    },
    {
      "start": 1481.248,
      "end": 1483.18,
      "text": "Spade's face became pale as his collar.",
      "para_break": true
    },
    {
      "start": 1483.8,
      "end": 1486.44,
      "text": "The corridor door's knob rattled.",
      "para_break": true
    },
    {
      "start": 1487.072,
      "end": 1489.36,
      "text": "Effie Perrine turned quickly and went into the outer office,",
      "para_break": true
    },
    {
      "start": 1489.44,
      "end": 1490.52,
      "text": "shutting the door behind her."
    },
    {
      "start": 1490.61,
      "end": 1491.86,
      "text": "When she came in again,"
    },
    {
      "start": 1491.92,
      "end": 1492.98,
      "text": "she shut it behind her."
    },
    {
      "start": 1493.72,
      "end": 1494.48,
      "text": "She said in a small,",
      "para_break": true
    },
    {
      "start": 1494.52,
      "end": 1495.1,
      "text": "flat voice,"
    },
    {
      "start": 1495.34,
      "end": 1496.4,
      "text": "Iva is here."
    },
    {
      "start": 1496.64,
      "end": 1496.74,
      "text": "Spade,"
    },
    {
      "start": 1497.8,
      "end": 1498.8,
      "text": "looking down at his desk,",
      "para_break": true
    },
    {
      "start": 1499.0,
      "end": 1500.49,
      "text": "nodded almost imperceptibly."
    },
    {
      "start": 1500.87,
      "end": 1501.42,
      "text": "Yes,"
    },
    {
      "start": 1501.54,
      "end": 1501.88,
      "text": "he said,"
    },
    {
      "start": 1502.02,
      "end": 1502.72,
      "text": "and shivered."
    },
    {
      "start": 1502.74,
      "end": 1503.24,
      "text": "Well,"
    },
    {
      "start": 1503.38,
      "end": 1504.1,
      "text": "send her in."
    },
    {
      "start": 1505.088,
      "end": 1506.34,
      "text": "End of chapter 20.",
      "para_break": true
    },
    {
      "start": 1507.264,
      "end": 1509.84,
      "text": "End of The Maltese Falcon by Dashiell Hammett"
    }
  ]
}
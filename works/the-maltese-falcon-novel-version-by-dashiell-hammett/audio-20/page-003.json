{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-20",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_20_hammett_128kb.mp3",
  "chapter_title": "If They Hang You",
  "reader_name": "NLizer",
  "page_num": 3,
  "page_total": 6,
  "page_start_sec": 492.41,
  "page_end_sec": 733.48,
  "para_gap_threshold": 0.529,
  "segments": [
    {
      "start": 492.41,
      "end": 494.76,
      "text": "She looked at him with terrified eyes and cried,",
      "para_break": true
    },
    {
      "start": 495.06,
      "end": 495.61,
      "text": "don't,"
    },
    {
      "start": 496.224,
      "end": 497.28,
      "text": "don't talk to me like that,",
      "para_break": true
    },
    {
      "start": 497.38,
      "end": 497.66,
      "text": "Sam."
    },
    {
      "start": 498.38,
      "end": 499.28,
      "text": "You know I didn't,"
    },
    {
      "start": 499.28,
      "end": 499.8,
      "text": "you know."
    },
    {
      "start": 500.06,
      "end": 501.42,
      "text": "Stop it."
    },
    {
      "start": 501.81,
      "end": 503.24,
      "text": "He looked at the watch on his"
    },
    {
      "start": 503.34,
      "end": 503.5,
      "text": "wrist."
    },
    {
      "start": 504.24,
      "end": 506.12,
      "text": "The police will be blowing in any minute",
      "para_break": true
    },
    {
      "start": 506.12,
      "end": 508.06,
      "text": "now and we're sitting on dynamite."
    },
    {
      "start": 508.2,
      "end": 508.9,
      "text": "Talk."
    },
    {
      "start": 510.44,
      "end": 510.68,
      "text": "She put",
      "para_break": true
    },
    {
      "start": 510.68,
      "end": 512.14,
      "text": "the back of a hand on her forehead."
    },
    {
      "start": 512.48,
      "end": 512.58,
      "text": "Oh,"
    },
    {
      "start": 513.06,
      "end": 515.66,
      "text": "why do you accuse me of such a terrible,"
    },
    {
      "start": 515.9,
      "end": 518.02,
      "text": "will you stop it?"
    },
    {
      "start": 518.2,
      "end": 519.42,
      "text": "he demanded in a low,"
    },
    {
      "start": 519.46,
      "end": 520.2,
      "text": "impatient voice."
    },
    {
      "start": 521.16,
      "end": 523.18,
      "text": "This isn't the spot for the schoolgirl act.",
      "para_break": true
    },
    {
      "start": 523.38,
      "end": 524.28,
      "text": "Listen to me."
    },
    {
      "start": 524.9,
      "end": 527.02,
      "text": "The pair of us are sitting under the gallows.",
      "para_break": true
    },
    {
      "start": 527.23,
      "end": 529.56,
      "text": "He took hold of her wrist and made her stand"
    },
    {
      "start": 529.56,
      "end": 530.68,
      "text": "up straight in front of him."
    },
    {
      "start": 530.84,
      "end": 531.56,
      "text": "Talk."
    },
    {
      "start": 531.94,
      "end": 532.04,
      "text": "I,"
    },
    {
      "start": 533.06,
      "end": 533.58,
      "text": "I,",
      "para_break": true
    },
    {
      "start": 533.62,
      "end": 535.28,
      "text": "how did you know he,"
    },
    {
      "start": 535.88,
      "end": 537.32,
      "text": "he licked his lips and looked?",
      "para_break": true
    },
    {
      "start": 538.336,
      "end": 539.41,
      "text": "Spade laughed harshly.",
      "para_break": true
    },
    {
      "start": 540.06,
      "end": 540.82,
      "text": "I knew Miles,",
      "para_break": true
    },
    {
      "start": 541.5,
      "end": 542.34,
      "text": "but never mind that.",
      "para_break": true
    },
    {
      "start": 542.42,
      "end": 543.56,
      "text": "Why did you shoot him?"
    },
    {
      "start": 544.15,
      "end": 546.56,
      "text": "She twisted her wrists out of Spade's fingers",
      "para_break": true
    },
    {
      "start": 546.56,
      "end": 548.84,
      "text": "and put her hands up around the back of his neck,"
    },
    {
      "start": 549.42,
      "end": 552.26,
      "text": "pulling his head down until his mouth all but touched hers.",
      "para_break": true
    },
    {
      "start": 552.49,
      "end": 554.4,
      "text": "Her body was flat against his"
    },
    {
      "start": 554.4,
      "end": 555.32,
      "text": "from knees to chest."
    },
    {
      "start": 555.6,
      "end": 557.26,
      "text": "He put his arms around her,"
    },
    {
      "start": 557.3,
      "end": 558.38,
      "text": "holding her tight to him."
    },
    {
      "start": 559.1,
      "end": 560.22,
      "text": "Her dark-lashed lids",
      "para_break": true
    },
    {
      "start": 560.22,
      "end": 561.86,
      "text": "were half down over velvet eyes."
    },
    {
      "start": 562.16,
      "end": 563.62,
      "text": "Her voice was hushed,"
    },
    {
      "start": 563.62,
      "end": 564.04,
      "text": "throbbing."
    },
    {
      "start": 564.18,
      "end": 565.48,
      "text": "I didn't mean to,"
    },
    {
      "start": 565.66,
      "end": 566.52,
      "text": "at first."
    },
    {
      "start": 567.2,
      "end": 567.68,
      "text": "I didn't,",
      "para_break": true
    },
    {
      "start": 567.68,
      "end": 568.06,
      "text": "really."
    },
    {
      "start": 568.8,
      "end": 569.86,
      "text": "I meant what I told you,",
      "para_break": true
    },
    {
      "start": 569.9,
      "end": 571.66,
      "text": "but when I saw Floyd couldn't be frightened,"
    },
    {
      "start": 571.8,
      "end": 572.06,
      "text": "I..."
    },
    {
      "start": 572.27,
      "end": 574.24,
      "text": "Spade slapped her shoulder."
    },
    {
      "start": 574.42,
      "end": 574.92,
      "text": "He said,"
    },
    {
      "start": 575.08,
      "end": 576.04,
      "text": "that's a lie."
    },
    {
      "start": 576.98,
      "end": 578.92,
      "text": "You asked Miles and me to handle it ourselves.",
      "para_break": true
    },
    {
      "start": 579.68,
      "end": 582.26,
      "text": "You wanted to be sure the shatterer was somebody you knew",
      "para_break": true
    },
    {
      "start": 582.42,
      "end": 584.84,
      "text": "and who knew you so they'd go with you."
    },
    {
      "start": 585.56,
      "end": 587.26,
      "text": "You got the gun from Thursday that day,",
      "para_break": true
    },
    {
      "start": 587.34,
      "end": 588.0,
      "text": "that night."
    },
    {
      "start": 588.9,
      "end": 591.16,
      "text": "You had already rented the apartment at the Coronet.",
      "para_break": true
    },
    {
      "start": 591.86,
      "end": 593.68,
      "text": "You had trunks there and none at the hotel,",
      "para_break": true
    },
    {
      "start": 594.12,
      "end": 595.76,
      "text": "and when I looked the apartment over,"
    },
    {
      "start": 595.84,
      "end": 598.12,
      "text": "I found a rent receipt dated five or six days"
    },
    {
      "start": 598.12,
      "end": 600.1,
      "text": "before the time you told me you rented it."
    },
    {
      "start": 600.32,
      "end": 603.7,
      "text": "she swallowed with difficulty and her voice was humble"
    },
    {
      "start": 604.44,
      "end": 607.82,
      "text": "yes that's a lie sam i did intend to if",
      "para_break": true
    },
    {
      "start": 607.96,
      "end": 611.98,
      "text": "floyd i i can't look at you and tell you this sam"
    },
    {
      "start": 612.38,
      "end": 615.16,
      "text": "she pulled his head farther down until her cheek"
    },
    {
      "start": 615.16,
      "end": 617.68,
      "text": "was against his cheek her mouth by his ear and"
    },
    {
      "start": 617.68,
      "end": 620.8,
      "text": "whispered i knew floyd wouldn't be easily frightened"
    },
    {
      "start": 621.02,
      "end": 624.86,
      "text": "but i thought that if he knew somebody was shadowing him either he'd"
    },
    {
      "start": 625.56,
      "end": 627.08,
      "text": "oh i can't say it sam",
      "para_break": true
    },
    {
      "start": 627.42,
      "end": 628.82,
      "text": "She clung to him,"
    },
    {
      "start": 628.86,
      "end": 629.36,
      "text": "sobbing."
    },
    {
      "start": 630.272,
      "end": 630.78,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 631.62,
      "end": 633.42,
      "text": "You thought Floyd would tackle him,",
      "para_break": true
    },
    {
      "start": 633.74,
      "end": 635.76,
      "text": "and one or the other of them would go down."
    },
    {
      "start": 636.26,
      "end": 637.4,
      "text": "If Thursby was the one,"
    },
    {
      "start": 637.52,
      "end": 638.7,
      "text": "then you were rid of him."
    },
    {
      "start": 639.26,
      "end": 639.96,
      "text": "If Miles was,",
      "para_break": true
    },
    {
      "start": 640.48,
      "end": 641.9,
      "text": "then you could see that Floyd was caught,"
    },
    {
      "start": 642.26,
      "end": 643.18,
      "text": "and you'd be rid of him."
    },
    {
      "start": 643.78,
      "end": 644.12,
      "text": "That it?",
      "para_break": true
    },
    {
      "start": 645.12,
      "end": 646.32,
      "text": "Something like that.",
      "para_break": true
    },
    {
      "start": 647.32,
      "end": 649.82,
      "text": "And when you found that Thursby didn't mean to tackle him,",
      "para_break": true
    },
    {
      "start": 650.18,
      "end": 651.58,
      "text": "you borrowed the gun and did it yourself."
    },
    {
      "start": 652.34,
      "end": 652.7,
      "text": "Right?",
      "para_break": true
    },
    {
      "start": 653.42,
      "end": 653.92,
      "text": "Yes.",
      "para_break": true
    },
    {
      "start": 654.72,
      "end": 655.38,
      "text": "Though not exactly.",
      "para_break": true
    },
    {
      "start": 656.04,
      "end": 659.66,
      "text": "but exact enough and you had that plan up your",
      "para_break": true
    },
    {
      "start": 659.66,
      "end": 662.16,
      "text": "sleeve from the first you thought floyd would"
    },
    {
      "start": 662.16,
      "end": 663.18,
      "text": "be nailed for the killing"
    },
    {
      "start": 664.14,
      "end": 664.24,
      "text": "i",
      "para_break": true
    },
    {
      "start": 665.0,
      "end": 668.04,
      "text": "i thought they'd hold him at least until after captain jacobi had",
      "para_break": true
    },
    {
      "start": 668.14,
      "end": 669.42,
      "text": "arrived with the falcon and"
    },
    {
      "start": 670.3,
      "end": 673.48,
      "text": "and you didn't know then that gutman was here hunting for you",
      "para_break": true
    },
    {
      "start": 673.75,
      "end": 677.7,
      "text": "you didn't suspect that or you wouldn't have shaken your gunman"
    },
    {
      "start": 678.46,
      "end": 679.68,
      "text": "you knew gutman was here as",
      "para_break": true
    },
    {
      "start": 679.68,
      "end": 681.42,
      "text": "soon as you heard thursby had been shot"
    },
    {
      "start": 682.08,
      "end": 685.04,
      "text": "then you knew you needed another protector so you came back",
      "para_break": true
    },
    {
      "start": 685.2,
      "end": 685.46,
      "text": "to me,"
    },
    {
      "start": 685.64,
      "end": 685.99,
      "text": "right?"
    },
    {
      "start": 686.5,
      "end": 686.6,
      "text": "Yes,"
    },
    {
      "start": 687.54,
      "end": 687.88,
      "text": "but,",
      "para_break": true
    },
    {
      "start": 687.88,
      "end": 688.6,
      "text": "oh,"
    },
    {
      "start": 688.62,
      "end": 689.12,
      "text": "sweetheart,"
    },
    {
      "start": 689.66,
      "end": 690.82,
      "text": "it wasn't only that.",
      "para_break": true
    },
    {
      "start": 691.19,
      "end": 693.04,
      "text": "I would have come back to you sooner"
    },
    {
      "start": 693.04,
      "end": 693.48,
      "text": "or later."
    },
    {
      "start": 693.68,
      "end": 695.96,
      "text": "From the first instant I saw you,"
    },
    {
      "start": 696.0,
      "end": 696.5,
      "text": "I knew."
    },
    {
      "start": 697.696,
      "end": 698.79,
      "text": "Spade said tenderly,",
      "para_break": true
    },
    {
      "start": 699.74,
      "end": 700.34,
      "text": "you angel.",
      "para_break": true
    },
    {
      "start": 700.56,
      "end": 700.672,
      "text": "Well,"
    },
    {
      "start": 701.42,
      "end": 702.5,
      "text": "if you get a good break,",
      "para_break": true
    },
    {
      "start": 702.72,
      "end": 705.78,
      "text": "you'll be out of San Quentin in 20 years and you can come back to me"
    },
    {
      "start": 705.78,
      "end": 705.94,
      "text": "then."
    },
    {
      "start": 706.92,
      "end": 708.42,
      "text": "She took her cheek away from his,",
      "para_break": true
    },
    {
      "start": 708.64,
      "end": 711.66,
      "text": "drawing her head far back to stare up without comprehension"
    },
    {
      "start": 712.04,
      "end": 712.42,
      "text": "at him."
    },
    {
      "start": 712.63,
      "end": 713.9,
      "text": "He was pale."
    },
    {
      "start": 714.14,
      "end": 715.46,
      "text": "He said tenderly,"
    },
    {
      "start": 715.69,
      "end": 717.64,
      "text": "I hope to Christ they don't hang you,"
    },
    {
      "start": 717.72,
      "end": 718.0,
      "text": "precious,"
    },
    {
      "start": 718.22,
      "end": 718.74,
      "text": "by that"
    },
    {
      "start": 718.82,
      "end": 719.4,
      "text": "sweet neck."
    },
    {
      "start": 720.28,
      "end": 722.38,
      "text": "He slid his hands up to caress her throat.",
      "para_break": true
    },
    {
      "start": 723.38,
      "end": 723.92,
      "text": "In an instant,",
      "para_break": true
    },
    {
      "start": 723.96,
      "end": 725.14,
      "text": "she was out of his arms,"
    },
    {
      "start": 725.3,
      "end": 726.32,
      "text": "back against the table,"
    },
    {
      "start": 726.36,
      "end": 726.92,
      "text": "crouching,"
    },
    {
      "start": 726.94,
      "end": 728.9,
      "text": "both hands spread over her throat."
    },
    {
      "start": 729.14,
      "end": 730.86,
      "text": "Her face was wild-eyed,"
    },
    {
      "start": 731.16,
      "end": 731.5,
      "text": "haggard."
    },
    {
      "start": 731.9,
      "end": 733.48,
      "text": "Her dry mouth opened and closed."
    }
  ]
}
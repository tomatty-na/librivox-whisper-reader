{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-13",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_13_hammett_128kb.mp3",
  "chapter_title": "The Emperor's Gift",
  "reader_name": "NLizer",
  "page_num": 5,
  "page_total": 5,
  "page_start_sec": 983.74,
  "page_end_sec": 1142.4,
  "para_gap_threshold": 0.579,
  "segments": [
    {
      "start": 983.74,
      "end": 984.16,
      "text": "He said:"
    },
    {
      "start": 984.34,
      "end": 986.58,
      "text": "\"That's a hell of a lot of dough.\""
    },
    {
      "start": 987.6,
      "end": 988.32,
      "text": "The fat man agreed:",
      "para_break": true
    },
    {
      "start": 988.88,
      "end": 990.74,
      "text": "\"That's a hell of a lot of dough.\""
    },
    {
      "start": 991.64,
      "end": 993.44,
      "text": "He leaned forward and patted Spade's knee."
    },
    {
      "start": 993.84,
      "end": 996.26,
      "text": "\"That is the absolute rock-bottom minimum—"
    },
    {
      "start": 996.36,
      "end": 996.92,
      "text": "or Charilaos Konstantinides was a blithering idiot—"
    },
    {
      "start": 1000.78,
      "end": 1001.94,
      "text": "and he wasn't.\""
    },
    {
      "start": 1002.752,
      "end": 1004.62,
      "text": "Spade removed the cigar from his mouth again,",
      "para_break": true
    },
    {
      "start": 1004.95,
      "end": 1006.35,
      "text": "frowned at it with distaste,"
    },
    {
      "start": 1006.52,
      "end": 1008.2,
      "text": "and put it on the smoking-stand."
    },
    {
      "start": 1009.08,
      "end": 1010.06,
      "text": "He shut his eyes hard,"
    },
    {
      "start": 1010.14,
      "end": 1010.9,
      "text": "opened them again."
    },
    {
      "start": 1011.8,
      "end": 1013.16,
      "text": "Their muddiness had thickened."
    },
    {
      "start": 1013.64,
      "end": 1014.02,
      "text": "He said:"
    },
    {
      "start": 1014.76,
      "end": 1015.9,
      "text": "\"The—the minimum,"
    },
    {
      "start": 1016.2,
      "end": 1016.4,
      "text": "huh?"
    },
    {
      "start": 1017.42,
      "end": 1017.94,
      "text": "And the maximum?\""
    },
    {
      "start": 1018.72,
      "end": 1022.34,
      "text": "An unmistakable _sh_ followed the x in maximum"
    },
    {
      "start": 1022.96,
      "end": 1023.66,
      "text": "as he said it."
    },
    {
      "start": 1024.44,
      "end": 1025.1,
      "text": "\"The maximum?\"",
      "para_break": true
    },
    {
      "start": 1025.36,
      "end": 1027.82,
      "text": "Gutman held his empty hand out, palm up."
    },
    {
      "start": 1028.3,
      "end": 1029.52,
      "text": "\"I refuse to"
    },
    {
      "start": 1030.54,
      "end": 1031.42,
      "text": "You think me crazy?"
    },
    {
      "start": 1032.38,
      "end": 1032.92,
      "text": "You'd think me crazy."
    },
    {
      "start": 1033.92,
      "end": 1035.42,
      "text": "There's no telling how high it could go,"
    },
    {
      "start": 1035.48,
      "end": 1035.66,
      "text": "sir,"
    },
    {
      "start": 1035.8,
      "end": 1038.0,
      "text": "and that's the one and only truth about it."
    },
    {
      "start": 1038.784,
      "end": 1041.46,
      "text": "and that's the one and only truth about it.\""
    },
    {
      "start": 1041.92,
      "end": 1043.31,
      "text": "Spade pulled his sagging lower lip tight against the upper.",
      "para_break": true
    },
    {
      "start": 1043.58,
      "end": 1044.64,
      "text": "A sharp,"
    },
    {
      "start": 1044.66,
      "end": 1047.16,
      "text": "A sharp"
    },
    {
      "start": 1047.168,
      "end": 1049.28,
      "text": "frightened gleam awoke in his eyes—and"
    },
    {
      "start": 1049.84,
      "end": 1050.6,
      "text": "He stood up,"
    },
    {
      "start": 1050.6,
      "end": 1053.52,
      "text": "helping himself up with his hands on the arms of his chair."
    },
    {
      "start": 1053.98,
      "end": 1057.16,
      "text": "He shook his head again and took an uncertain step forward."
    },
    {
      "start": 1057.98,
      "end": 1059.5,
      "text": "He laughed thickly and muttered,"
    },
    {
      "start": 1060.26,
      "end": 1060.98,
      "text": "He laughed thickly and muttered:"
    },
    {
      "start": 1062.368,
      "end": 1064.3,
      "text": "\"God damn you.\""
    },
    {
      "start": 1064.94,
      "end": 1066.36,
      "text": "Gutman jumped up and pushed his chair back.",
      "para_break": true
    },
    {
      "start": 1067.0,
      "end": 1069.5,
      "text": "His eyes were dark holes in an oily pink face."
    },
    {
      "start": 1070.656,
      "end": 1072.46,
      "text": "Spade swung his head from side to side"
    },
    {
      "start": 1072.46,
      "end": 1074.18,
      "text": "Spade swung his head from side to side",
      "para_break": true
    },
    {
      "start": 1074.46,
      "end": 1075.56,
      "text": "until his dull eyes were pointed at—"
    },
    {
      "start": 1075.66,
      "end": 1076.22,
      "text": "if not focused on—"
    },
    {
      "start": 1076.84,
      "end": 1078.66,
      "text": "He took another uncertain step."
    },
    {
      "start": 1079.6,
      "end": 1080.85,
      "text": "The fat man called sharply,"
    },
    {
      "start": 1081.4,
      "end": 1081.8,
      "text": "The fat man called sharply:",
      "para_break": true
    },
    {
      "start": 1082.96,
      "end": 1084.8,
      "text": "\"Wilmer!\""
    },
    {
      "start": 1085.76,
      "end": 1086.96,
      "text": "A door opened and the boy came in.",
      "para_break": true
    },
    {
      "start": 1087.88,
      "end": 1089.72,
      "text": "Spade took a third step.",
      "para_break": true
    },
    {
      "start": 1089.72,
      "end": 1091.9,
      "text": "His face was grey now, with jaw-muscles"
    },
    {
      "start": 1092.78,
      "end": 1095.76,
      "text": "His legs did not straighten again after his fourth step"
    },
    {
      "start": 1096.2,
      "end": 1098.4,
      "text": "and his muddy eyes were almost covered by their lids."
    },
    {
      "start": 1098.54,
      "end": 1100.38,
      "text": "He took his fifth step."
    },
    {
      "start": 1100.88,
      "end": 1103.24,
      "text": "The boy walked over and stood close to Spade,"
    },
    {
      "start": 1103.74,
      "end": 1104.76,
      "text": "The boy walked over and stood close to Spade,",
      "para_break": true
    },
    {
      "start": 1104.8,
      "end": 1106.68,
      "text": "but not directly between Spade and the door."
    },
    {
      "start": 1107.5,
      "end": 1110.1,
      "text": "The boy's right hand was inside his coat over his heart."
    },
    {
      "start": 1110.84,
      "end": 1112.4,
      "text": "The corners of his mouth twitched."
    },
    {
      "start": 1113.152,
      "end": 1114.8,
      "text": "Spade essayed his sixth step."
    },
    {
      "start": 1115.9,
      "end": 1118.72,
      "text": "Spade essayed his sixth step.",
      "para_break": true
    },
    {
      "start": 1119.488,
      "end": 1121.22,
      "text": "The boy's leg darted out across Spade's leg, in front.",
      "para_break": true
    },
    {
      "start": 1121.22,
      "end": 1122.82,
      "text": "and crashed face down on the floor."
    },
    {
      "start": 1123.82,
      "end": 1124.1,
      "text": "and crashed face-down on the floor."
    },
    {
      "start": 1124.18,
      "end": 1126.0,
      "text": "keeping his right hand under his coat,"
    },
    {
      "start": 1126.1,
      "end": 1127.24,
      "text": "looked down at Spade."
    },
    {
      "start": 1128.32,
      "end": 1129.32,
      "text": "Spade tried to get up."
    },
    {
      "start": 1129.86,
      "end": 1133.08,
      "text": "The boy drew his right foot far back and kicked Spade's temple."
    },
    {
      "start": 1133.92,
      "end": 1135.86,
      "text": "The kick rolled Spade over on his side."
    },
    {
      "start": 1136.864,
      "end": 1138.14,
      "text": "Once more he tried to get up,"
    },
    {
      "start": 1138.54,
      "end": 1138.94,
      "text": "could not,"
    },
    {
      "start": 1139.14,
      "end": 1140.24,
      "text": "and went to sleep."
    },
    {
      "start": 1141.28,
      "end": 1142.4,
      "text": "End of chapter 13"
    }
  ],
  "corrected": "claude"
}
{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-08",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_08_hammett_128kb.mp3",
  "chapter_title": "Horse Feathers",
  "reader_name": "NLizer",
  "page_num": 4,
  "page_total": 4,
  "page_start_sec": 759.6,
  "page_end_sec": 917.96,
  "para_gap_threshold": 0.588,
  "segments": [
    {
      "start": 759.6,
      "end": 759.7,
      "text": "No,"
    },
    {
      "start": 760.3,
      "end": 760.42,
      "text": "no,",
      "para_break": true
    },
    {
      "start": 760.44,
      "end": 761.3,
      "text": "for Christ's sake,"
    },
    {
      "start": 761.4,
      "end": 762.0,
      "text": "Tom begged."
    },
    {
      "start": 762.36,
      "end": 764.72,
      "text": "After a long moment of motionlessness,"
    },
    {
      "start": 765.12,
      "end": 766.4,
      "text": "Spade's muscles relaxed."
    },
    {
      "start": 767.2,
      "end": 768.6,
      "text": "Then get him out of here quick,",
      "para_break": true
    },
    {
      "start": 769.2,
      "end": 769.56,
      "text": "he said.",
      "para_break": true
    },
    {
      "start": 770.08,
      "end": 771.64,
      "text": "His smile had gone away again,"
    },
    {
      "start": 771.76,
      "end": 773.62,
      "text": "leaving his face sullen and somewhat pale."
    },
    {
      "start": 774.42,
      "end": 774.94,
      "text": "Tom,",
      "para_break": true
    },
    {
      "start": 775.0,
      "end": 776.18,
      "text": "staying close to Spade,"
    },
    {
      "start": 776.26,
      "end": 778.04,
      "text": "keeping his arms on Spade's arms,"
    },
    {
      "start": 778.46,
      "end": 780.96,
      "text": "turned his head to look over his shoulder at Lieutenant Dundee."
    },
    {
      "start": 781.696,
      "end": 783.36,
      "text": "Tom's small eyes were reproachful.",
      "para_break": true
    },
    {
      "start": 784.224,
      "end": 786.18,
      "text": "Dundee's fists were clenched in front of his body,",
      "para_break": true
    },
    {
      "start": 786.24,
      "end": 789.08,
      "text": "and his feet were planted firm and a little apart on the floor."
    },
    {
      "start": 789.24,
      "end": 792.2,
      "text": "but the truculence in his face was modified by"
    },
    {
      "start": 792.2,
      "end": 794.68,
      "text": "thin rims of white showing between green irises"
    },
    {
      "start": 794.72,
      "end": 795.44,
      "text": "and upper eyelids."
    },
    {
      "start": 796.26,
      "end": 797.34,
      "text": "Get their names and addresses,",
      "para_break": true
    },
    {
      "start": 797.86,
      "end": 798.28,
      "text": "he ordered."
    },
    {
      "start": 799.168,
      "end": 799.98,
      "text": "Tom looked at Cairo,",
      "para_break": true
    },
    {
      "start": 800.08,
      "end": 800.76,
      "text": "who said quickly,"
    },
    {
      "start": 801.38,
      "end": 801.96,
      "text": "Joel Cairo,",
      "para_break": true
    },
    {
      "start": 802.04,
      "end": 803.0,
      "text": "Hotel Belvedere."
    },
    {
      "start": 803.872,
      "end": 805.84,
      "text": "Spade spoke before Tom could question the girl.",
      "para_break": true
    },
    {
      "start": 806.52,
      "end": 807.16,
      "text": "You can always get",
      "para_break": true
    },
    {
      "start": 807.16,
      "end": 808.86,
      "text": "in touch with Miss O'Shaughnessy through me."
    },
    {
      "start": 809.824,
      "end": 810.76,
      "text": "Tom looked at Dundee.",
      "para_break": true
    },
    {
      "start": 810.88,
      "end": 812.02,
      "text": "Dundee growled,"
    },
    {
      "start": 812.06,
      "end": 813.24,
      "text": "get her address."
    },
    {
      "start": 814.09,
      "end": 815.08,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 815.32,
      "end": 817.92,
      "text": "her address is in care of my office."
    },
    {
      "start": 818.88,
      "end": 819.94,
      "text": "Dundee took a step forward,",
      "para_break": true
    },
    {
      "start": 820.12,
      "end": 821.24,
      "text": "halting in front of the girl."
    },
    {
      "start": 821.78,
      "end": 822.72,
      "text": "Where do you live,"
    },
    {
      "start": 822.86,
      "end": 823.6,
      "text": "he asked."
    },
    {
      "start": 824.544,
      "end": 825.44,
      "text": "Spade addressed Tom,",
      "para_break": true
    },
    {
      "start": 825.64,
      "end": 827.12,
      "text": "get him out of here."
    },
    {
      "start": 827.9,
      "end": 828.78,
      "text": "I've had enough of this.",
      "para_break": true
    },
    {
      "start": 829.792,
      "end": 831.12,
      "text": "Tom looked at Spade's eyes,",
      "para_break": true
    },
    {
      "start": 831.34,
      "end": 833.02,
      "text": "hard and glittering and mumbled,"
    },
    {
      "start": 833.44,
      "end": 834.02,
      "text": "take it easy,"
    },
    {
      "start": 834.12,
      "end": 834.34,
      "text": "Sam."
    },
    {
      "start": 835.4,
      "end": 836.98,
      "text": "He buttoned his coat and turned to Dundee,",
      "para_break": true
    },
    {
      "start": 837.18,
      "end": 838.99,
      "text": "asking in a voice that aped casualness,"
    },
    {
      "start": 839.48,
      "end": 839.7,
      "text": "well,"
    },
    {
      "start": 839.86,
      "end": 840.5,
      "text": "is that all?"
    },
    {
      "start": 841.14,
      "end": 842.8,
      "text": "And taking a step towards the door.",
      "para_break": true
    },
    {
      "start": 843.872,
      "end": 845.85,
      "text": "Dundee's scowl failed to conceal indecision.",
      "para_break": true
    },
    {
      "start": 847.104,
      "end": 848.54,
      "text": "Cairo moved suddenly towards the door,",
      "para_break": true
    },
    {
      "start": 848.6,
      "end": 848.84,
      "text": "saying,"
    },
    {
      "start": 849.408,
      "end": 849.98,
      "text": "I'm going too,"
    },
    {
      "start": 850.18,
      "end": 850.68,
      "text": "if Mr."
    },
    {
      "start": 850.8,
      "end": 852.9,
      "text": "Spade will be kind enough to give me my hat and coat."
    },
    {
      "start": 853.92,
      "end": 854.44,
      "text": "Spade asked,",
      "para_break": true
    },
    {
      "start": 854.58,
      "end": 855.58,
      "text": "What's the hurry?"
    },
    {
      "start": 856.704,
      "end": 857.51,
      "text": "Dundee said angrily,",
      "para_break": true
    },
    {
      "start": 858.08,
      "end": 859.38,
      "text": "It was all in fun,"
    },
    {
      "start": 859.5,
      "end": 860.36,
      "text": "but just the same,"
    },
    {
      "start": 860.54,
      "end": 861.9,
      "text": "you're afraid to be left here with them?"
    },
    {
      "start": 862.84,
      "end": 863.36,
      "text": "Not at all,",
      "para_break": true
    },
    {
      "start": 863.46,
      "end": 864.42,
      "text": "the Levantine replied,"
    },
    {
      "start": 864.82,
      "end": 865.32,
      "text": "fidgeting,"
    },
    {
      "start": 865.68,
      "end": 866.68,
      "text": "looking at neither of them."
    },
    {
      "start": 866.82,
      "end": 868.0,
      "text": "But it's quite late,"
    },
    {
      "start": 868.06,
      "end": 868.38,
      "text": "and,"
    },
    {
      "start": 868.88,
      "end": 869.52,
      "text": "and I'm going."
    },
    {
      "start": 870.1,
      "end": 871.12,
      "text": "I'll go out with you,"
    },
    {
      "start": 871.32,
      "end": 872.18,
      "text": "if you don't mind."
    },
    {
      "start": 872.63,
      "end": 875.14,
      "text": "Dundee put his lips together firmly and said nothing."
    },
    {
      "start": 875.38,
      "end": 877.02,
      "text": "A light was glinting in"
    },
    {
      "start": 877.02,
      "end": 877.68,
      "text": "his green eyes."
    },
    {
      "start": 878.784,
      "end": 880.41,
      "text": "Spade went to the closet in the passageway",
      "para_break": true
    },
    {
      "start": 880.52,
      "end": 881.84,
      "text": "and fetched Cairo's hat and coat."
    },
    {
      "start": 882.56,
      "end": 883.7,
      "text": "Spade's face was blank.",
      "para_break": true
    },
    {
      "start": 883.92,
      "end": 887.84,
      "text": "His voice held the same blankness when he stepped back from helping"
    },
    {
      "start": 887.96,
      "end": 890.6,
      "text": "the Levantine into his coat and said to Tom,"
    },
    {
      "start": 891.4,
      "end": 892.58,
      "text": "tell him to leave the gun.",
      "para_break": true
    },
    {
      "start": 893.76,
      "end": 894.86,
      "text": "Dundee took Cairo's pistol",
      "para_break": true
    },
    {
      "start": 895.04,
      "end": 897.62,
      "text": "from his overcoat pocket and put it on the table."
    },
    {
      "start": 897.95,
      "end": 900.34,
      "text": "He went out first with Cairo at his heels."
    },
    {
      "start": 901.12,
      "end": 902.42,
      "text": "Tom halted in front of Spade,",
      "para_break": true
    },
    {
      "start": 902.5,
      "end": 902.8,
      "text": "muttering,"
    },
    {
      "start": 903.52,
      "end": 905.16,
      "text": "I hope to God you know what you're doing.",
      "para_break": true
    },
    {
      "start": 906.12,
      "end": 906.78,
      "text": "Got no response,",
      "para_break": true
    },
    {
      "start": 907.12,
      "end": 907.98,
      "text": "sighed,"
    },
    {
      "start": 907.98,
      "end": 909.32,
      "text": "and followed the others out."
    },
    {
      "start": 910.272,
      "end": 912.89,
      "text": "Spade went after them as far as the bend in the passageway",
      "para_break": true
    },
    {
      "start": 913.06,
      "end": 915.74,
      "text": "where he stood until Tom had closed the corridor door."
    },
    {
      "start": 916.8,
      "end": 917.96,
      "text": "End of chapter eight.",
      "para_break": true
    }
  ]
}
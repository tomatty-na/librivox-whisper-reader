{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-10",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_10_hammett.mp3",
  "chapter_title": "The Belvedere Divan",
  "reader_name": "NLizer",
  "page_num": 1,
  "page_total": 5,
  "page_start_sec": 0.84,
  "page_end_sec": 244.9,
  "para_gap_threshold": 0.552,
  "segments": [
    {
      "start": 0.84,
      "end": 3.92,
      "text": "Chapter 10 of The Maltese Falcon by Dashiell Hammett."
    },
    {
      "start": 4.7,
      "end": 7.08,
      "text": "This LibriVox recording is in the public domain.",
      "para_break": true
    },
    {
      "start": 8.02,
      "end": 9.52,
      "text": "The Belvedere Divan.",
      "para_break": true
    },
    {
      "start": 10.11,
      "end": 12.28,
      "text": "Beginning day had reduced night",
      "para_break": true
    },
    {
      "start": 12.9,
      "end": 15.02,
      "text": "to a thin smokiness when Spade sat up.",
      "para_break": true
    },
    {
      "start": 15.72,
      "end": 16.42,
      "text": "At his side,",
      "para_break": true
    },
    {
      "start": 16.46,
      "end": 18.22,
      "text": "Bridget O'Shaughnessy's soft breathing"
    },
    {
      "start": 18.78,
      "end": 20.5,
      "text": "had the regularity of utter sleep.",
      "para_break": true
    },
    {
      "start": 21.536,
      "end": 22.24,
      "text": "Spade was quiet,",
      "para_break": true
    },
    {
      "start": 22.34,
      "end": 25.2,
      "text": "leaving bed and bedroom and shutting the bedroom door."
    },
    {
      "start": 25.54,
      "end": 26.7,
      "text": "He dressed in the"
    },
    {
      "start": 26.82,
      "end": 27.08,
      "text": "bathroom."
    },
    {
      "start": 28.08,
      "end": 30.08,
      "text": "Then he examined the sleeping girl's clothes,",
      "para_break": true
    },
    {
      "start": 30.84,
      "end": 32.6,
      "text": "took a flat brass key from the pocket",
      "para_break": true
    },
    {
      "start": 32.6,
      "end": 33.14,
      "text": "of her coat,"
    },
    {
      "start": 33.24,
      "end": 33.78,
      "text": "and went out."
    },
    {
      "start": 34.27,
      "end": 35.66,
      "text": "He went to the coronet,"
    },
    {
      "start": 36.18,
      "end": 38.6,
      "text": "letting himself into the building and into her"
    },
    {
      "start": 38.68,
      "end": 39.58,
      "text": "apartment with the key."
    },
    {
      "start": 40.5,
      "end": 40.93,
      "text": "To the eye,",
      "para_break": true
    },
    {
      "start": 41.12,
      "end": 43.22,
      "text": "there was nothing furtive about his going in."
    },
    {
      "start": 43.9,
      "end": 44.26,
      "text": "He entered",
      "para_break": true
    },
    {
      "start": 44.38,
      "end": 45.26,
      "text": "boldly and directly."
    },
    {
      "start": 45.66,
      "end": 46.58,
      "text": "To the ear,"
    },
    {
      "start": 46.66,
      "end": 48.6,
      "text": "his going in was almost unnoticeable."
    },
    {
      "start": 48.88,
      "end": 50.56,
      "text": "He made as little sound as"
    },
    {
      "start": 50.62,
      "end": 51.0,
      "text": "might be."
    },
    {
      "start": 52.0,
      "end": 52.72,
      "text": "In the girl's apartment,",
      "para_break": true
    },
    {
      "start": 52.9,
      "end": 54.48,
      "text": "he switched on all the lights."
    },
    {
      "start": 54.71,
      "end": 56.32,
      "text": "He searched the place from wall"
    },
    {
      "start": 56.48,
      "end": 56.78,
      "text": "to wall."
    },
    {
      "start": 57.54,
      "end": 59.38,
      "text": "His eyes and thick fingers moved without",
      "para_break": true
    },
    {
      "start": 59.38,
      "end": 61.8,
      "text": "apparent haste and without ever lingering or"
    },
    {
      "start": 61.88,
      "end": 62.98,
      "text": "fumbling or going back."
    },
    {
      "start": 63.9,
      "end": 65.76,
      "text": "From one inch of their fields to the next,",
      "para_break": true
    },
    {
      "start": 65.86,
      "end": 66.4,
      "text": "probing,"
    },
    {
      "start": 66.44,
      "end": 67.04,
      "text": "scrutinizing,"
    },
    {
      "start": 67.648,
      "end": 68.86,
      "text": "testing with expert certainty.",
      "para_break": true
    },
    {
      "start": 69.92,
      "end": 70.38,
      "text": "Every drawer,",
      "para_break": true
    },
    {
      "start": 70.64,
      "end": 71.02,
      "text": "cupboard,"
    },
    {
      "start": 71.24,
      "end": 71.78,
      "text": "cubbyhole,"
    },
    {
      "start": 72.0,
      "end": 72.48,
      "text": "box,"
    },
    {
      "start": 72.74,
      "end": 73.18,
      "text": "bag,"
    },
    {
      "start": 73.38,
      "end": 73.66,
      "text": "trunk,"
    },
    {
      "start": 73.88,
      "end": 74.62,
      "text": "locked or"
    },
    {
      "start": 74.7,
      "end": 77.2,
      "text": "unlocked was opened and its contents"
    },
    {
      "start": 77.2,
      "end": 79.92,
      "text": "subjected to examination by eyes and fingers."
    },
    {
      "start": 80.96,
      "end": 81.26,
      "text": "Every piece",
      "para_break": true
    },
    {
      "start": 81.44,
      "end": 83.74,
      "text": "of clothing was tested by hands that felt for"
    },
    {
      "start": 83.74,
      "end": 86.62,
      "text": "telltale bulges and ears that listened for the"
    },
    {
      "start": 86.68,
      "end": 88.72,
      "text": "crinkle of paper between pressing fingers."
    },
    {
      "start": 89.07,
      "end": 90.98,
      "text": "He stripped the bed of bedclothes."
    },
    {
      "start": 91.58,
      "end": 92.18,
      "text": "He looked under",
      "para_break": true
    },
    {
      "start": 92.24,
      "end": 94.84,
      "text": "rugs and at the underside of each piece of furniture."
    },
    {
      "start": 95.68,
      "end": 97.18,
      "text": "He pulled down blinds to see that",
      "para_break": true
    },
    {
      "start": 97.24,
      "end": 99.28,
      "text": "nothing had been rolled up in them for concealment."
    },
    {
      "start": 99.64,
      "end": 102.56,
      "text": "He leaned through windows to see that nothing hung"
    },
    {
      "start": 102.74,
      "end": 104.26,
      "text": "below them on the outside."
    },
    {
      "start": 104.62,
      "end": 107.08,
      "text": "He poked with a fork into powder and"
    },
    {
      "start": 107.08,
      "end": 108.9,
      "text": "cream jars on the dressing table."
    },
    {
      "start": 109.78,
      "end": 112.2,
      "text": "He held atomizers and bottles up against the light.",
      "para_break": true
    },
    {
      "start": 112.66,
      "end": 115.88,
      "text": "He examined dishes and pans and food and food containers."
    },
    {
      "start": 116.46,
      "end": 119.24,
      "text": "He emptied the garbage can on spreadsheets of newspaper.",
      "para_break": true
    },
    {
      "start": 120.28,
      "end": 122.4,
      "text": "He opened the top of the flush box in the bathroom,",
      "para_break": true
    },
    {
      "start": 122.66,
      "end": 123.7,
      "text": "drained the box,"
    },
    {
      "start": 123.82,
      "end": 125.18,
      "text": "and peered down into it."
    },
    {
      "start": 126.04,
      "end": 129.28,
      "text": "He examined and tested the metal screens over the drains of bathtub,",
      "para_break": true
    },
    {
      "start": 129.56,
      "end": 130.36,
      "text": "washbowl,"
    },
    {
      "start": 130.36,
      "end": 130.8,
      "text": "sink,"
    },
    {
      "start": 130.94,
      "end": 131.76,
      "text": "and laundry tub."
    },
    {
      "start": 132.6,
      "end": 134.0,
      "text": "He did not find the black bird.",
      "para_break": true
    },
    {
      "start": 134.44,
      "end": 135.96,
      "text": "He found nothing that seemed to have"
    },
    {
      "start": 135.96,
      "end": 137.6,
      "text": "any connection with the black bird."
    },
    {
      "start": 138.44,
      "end": 140.64,
      "text": "The only piece of writing he found was a week-old",
      "para_break": true
    },
    {
      "start": 140.64,
      "end": 142.84,
      "text": "receipt for the month's apartment rent Bridget"
    },
    {
      "start": 142.94,
      "end": 143.88,
      "text": "O'Shaughnessy had paid."
    },
    {
      "start": 144.17,
      "end": 146.08,
      "text": "The only thing he found that interested"
    },
    {
      "start": 146.08,
      "end": 148.08,
      "text": "him enough to delay his search"
    },
    {
      "start": 148.08,
      "end": 150.42,
      "text": "while he looked at it was a double handful of"
    },
    {
      "start": 150.42,
      "end": 153.58,
      "text": "rather fine jewelry in a polychrome box in a"
    },
    {
      "start": 153.64,
      "end": 154.68,
      "text": "locked dressing table drawer."
    },
    {
      "start": 155.58,
      "end": 156.34,
      "text": "When he had finished,",
      "para_break": true
    },
    {
      "start": 156.46,
      "end": 158.18,
      "text": "he made and drank a cup of coffee."
    },
    {
      "start": 158.76,
      "end": 159.02,
      "text": "Then he",
      "para_break": true
    },
    {
      "start": 159.06,
      "end": 160.14,
      "text": "unlocked the kitchen window,"
    },
    {
      "start": 160.69,
      "end": 163.34,
      "text": "scarred the edge of its lock a little with his pocket knife,"
    },
    {
      "start": 163.52,
      "end": 165.72,
      "text": "opened the window over a fire escape,"
    },
    {
      "start": 166.06,
      "end": 169.02,
      "text": "got his hat and overcoat from the settee in the living room,"
    },
    {
      "start": 169.08,
      "end": 171.34,
      "text": "and left the apartment as he had come."
    },
    {
      "start": 171.96,
      "end": 172.96,
      "text": "On his way home,",
      "para_break": true
    },
    {
      "start": 173.0,
      "end": 175.08,
      "text": "he stopped at a store that was being opened"
    },
    {
      "start": 175.32,
      "end": 176.32,
      "text": "by a puffy-eyed,"
    },
    {
      "start": 176.38,
      "end": 176.82,
      "text": "shivering,"
    },
    {
      "start": 176.92,
      "end": 178.92,
      "text": "plump grocer and bought oranges,"
    },
    {
      "start": 179.18,
      "end": 179.62,
      "text": "eggs,"
    },
    {
      "start": 179.86,
      "end": 180.2,
      "text": "rolls,"
    },
    {
      "start": 180.5,
      "end": 180.86,
      "text": "butter,"
    },
    {
      "start": 180.96,
      "end": 181.36,
      "text": "and cream."
    },
    {
      "start": 182.304,
      "end": 184.02,
      "text": "Spade went quietly into his apartment,",
      "para_break": true
    },
    {
      "start": 184.36,
      "end": 186.54,
      "text": "but before he had shut the corridor door behind him,"
    },
    {
      "start": 186.72,
      "end": 188.22,
      "text": "Bridget O'Shaughnessy cried,"
    },
    {
      "start": 188.72,
      "end": 189.32,
      "text": "Who is that?"
    },
    {
      "start": 190.36,
      "end": 191.88,
      "text": "Young Spade bearing breakfast.",
      "para_break": true
    },
    {
      "start": 192.66,
      "end": 192.82,
      "text": "Oh,",
      "para_break": true
    },
    {
      "start": 192.98,
      "end": 193.96,
      "text": "you frightened me."
    },
    {
      "start": 194.9,
      "end": 196.6,
      "text": "The bedroom door he had shut was open.",
      "para_break": true
    },
    {
      "start": 196.96,
      "end": 198.86,
      "text": "The girl sat on the side of the bed trembling,"
    },
    {
      "start": 199.3,
      "end": 201.44,
      "text": "with her right hand out of sight under a pillow."
    },
    {
      "start": 202.304,
      "end": 203.84,
      "text": "Spade put his packages on the kitchen",
      "para_break": true
    },
    {
      "start": 203.84,
      "end": 205.36,
      "text": "table and went into the bedroom."
    },
    {
      "start": 205.96,
      "end": 207.56,
      "text": "He sat on the bed beside the girl,",
      "para_break": true
    },
    {
      "start": 208.0,
      "end": 209.44,
      "text": "kissed her smooth shoulder and said,"
    },
    {
      "start": 210.18,
      "end": 212.06,
      "text": "I wanted to see if that kid was still on",
      "para_break": true
    },
    {
      "start": 212.06,
      "end": 214.0,
      "text": "the job and to get stuff for breakfast."
    },
    {
      "start": 214.92,
      "end": 215.22,
      "text": "Is he?",
      "para_break": true
    },
    {
      "start": 215.62,
      "end": 216.24,
      "text": "No."
    },
    {
      "start": 216.8,
      "end": 218.76,
      "text": "She sighed and leaned against him.",
      "para_break": true
    },
    {
      "start": 219.12,
      "end": 220.64,
      "text": "I awakened and you weren't here,"
    },
    {
      "start": 220.76,
      "end": 222.24,
      "text": "and then I heard someone coming in."
    },
    {
      "start": 222.32,
      "end": 223.0,
      "text": "I was terrified."
    },
    {
      "start": 224.128,
      "end": 225.8,
      "text": "Spade combed her red hair back from",
      "para_break": true
    },
    {
      "start": 225.8,
      "end": 227.52,
      "text": "her face with his fingers and said,"
    },
    {
      "start": 228.192,
      "end": 228.64,
      "text": "I'm sorry,",
      "para_break": true
    },
    {
      "start": 228.74,
      "end": 229.04,
      "text": "Angel."
    },
    {
      "start": 229.46,
      "end": 230.88,
      "text": "I thought you'd sleep through it."
    },
    {
      "start": 231.54,
      "end": 233.66,
      "text": "Did you have that gun under your pillow all night?",
      "para_break": true
    },
    {
      "start": 234.22,
      "end": 234.9,
      "text": "No,",
      "para_break": true
    },
    {
      "start": 234.98,
      "end": 236.18,
      "text": "you know I didn't."
    },
    {
      "start": 236.78,
      "end": 238.64,
      "text": "I jumped up and got it when I was frightened.",
      "para_break": true
    },
    {
      "start": 239.28,
      "end": 241.72,
      "text": "He cooked breakfast and slipped the flat",
      "para_break": true
    },
    {
      "start": 241.72,
      "end": 243.58,
      "text": "brass key into her coat pocket again"
    },
    {
      "start": 243.74,
      "end": 244.9,
      "text": "while she bathed and dressed."
    }
  ]
}
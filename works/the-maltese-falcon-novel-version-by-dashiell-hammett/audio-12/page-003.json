{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-12",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_12_hammett.mp3",
  "chapter_title": "Merry-Go-Round",
  "reader_name": "NLizer",
  "page_num": 3,
  "page_total": 5,
  "page_start_sec": 491.66,
  "page_end_sec": 733.26,
  "para_gap_threshold": 0.597,
  "segments": [
    {
      "start": 491.66,
      "end": 492.84,
      "text": "He came out again."
    },
    {
      "start": 493.68,
      "end": 494.24,
      "text": "Phone your mother,",
      "para_break": true
    },
    {
      "start": 494.42,
      "end": 494.94,
      "text": "he commanded."
    },
    {
      "start": 495.6,
      "end": 496.52,
      "text": "See if she's come yet.",
      "para_break": true
    },
    {
      "start": 497.16,
      "end": 500.18,
      "text": "He walked up and down the office while the girl used the telephone.",
      "para_break": true
    },
    {
      "start": 500.5,
      "end": 500.6,
      "text": "No,"
    },
    {
      "start": 501.56,
      "end": 503.16,
      "text": "she said when she had",
      "para_break": true
    },
    {
      "start": 503.24,
      "end": 503.58,
      "text": "finished."
    },
    {
      "start": 503.84,
      "end": 504.54,
      "text": "Did,"
    },
    {
      "start": 505.16,
      "end": 506.8,
      "text": "did you send her out in a taxi?",
      "para_break": true
    },
    {
      "start": 507.56,
      "end": 509.26,
      "text": "His grunt probably meant yes.",
      "para_break": true
    },
    {
      "start": 510.3,
      "end": 511.02,
      "text": "Are you sure she,",
      "para_break": true
    },
    {
      "start": 511.94,
      "end": 513.2,
      "text": "Somebody must have followed her.",
      "para_break": true
    },
    {
      "start": 514.24,
      "end": 515.54,
      "text": "Spade stopped pacing the floor.",
      "para_break": true
    },
    {
      "start": 516.0,
      "end": 518.62,
      "text": "He put his hands on his hips and glared at the girl."
    },
    {
      "start": 519.14,
      "end": 520.36,
      "text": "He addressed her in a loud,"
    },
    {
      "start": 520.4,
      "end": 521.1,
      "text": "savage voice."
    },
    {
      "start": 521.92,
      "end": 523.44,
      "text": "Nobody followed her.",
      "para_break": true
    },
    {
      "start": 524.16,
      "end": 526.27,
      "text": "Do you think I'm a goddamn schoolboy?",
      "para_break": true
    },
    {
      "start": 527.34,
      "end": 529.36,
      "text": "I made sure of it before I put her in the cab.",
      "para_break": true
    },
    {
      "start": 529.9,
      "end": 532.12,
      "text": "I rode a dozen blocks with her to be more sure,"
    },
    {
      "start": 532.74,
      "end": 535.9,
      "text": "and I checked her another half dozen blocks after I got out.",
      "para_break": true
    },
    {
      "start": 536.66,
      "end": 536.92,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 537.08,
      "end": 537.74,
      "text": "but..."
    },
    {
      "start": 538.44,
      "end": 539.64,
      "text": "But she didn't get there.",
      "para_break": true
    },
    {
      "start": 539.88,
      "end": 541.06,
      "text": "You've told me that."
    },
    {
      "start": 541.56,
      "end": 542.46,
      "text": "I believe it."
    },
    {
      "start": 542.72,
      "end": 544.8,
      "text": "Do you think I think she did get there?"
    },
    {
      "start": 545.856,
      "end": 547.02,
      "text": "Effie Perrine sniffed.",
      "para_break": true
    },
    {
      "start": 547.74,
      "end": 549.9,
      "text": "You certainly act like a goddamn schoolboy,",
      "para_break": true
    },
    {
      "start": 550.02,
      "end": 550.46,
      "text": "she said."
    },
    {
      "start": 551.488,
      "end": 554.48,
      "text": "Spade made a harsh noise in his throat and went to the corridor door.",
      "para_break": true
    },
    {
      "start": 555.5,
      "end": 558.22,
      "text": "I'm going out and find her if I have to dig up sewers,",
      "para_break": true
    },
    {
      "start": 558.36,
      "end": 558.82,
      "text": "he said."
    },
    {
      "start": 559.48,
      "end": 562.02,
      "text": "Stay here till I'm back or you hear from me.",
      "para_break": true
    },
    {
      "start": 562.56,
      "end": 563.38,
      "text": "For Christ's sake,"
    },
    {
      "start": 563.42,
      "end": 564.62,
      "text": "let's do something right."
    },
    {
      "start": 565.58,
      "end": 566.12,
      "text": "He went out,",
      "para_break": true
    },
    {
      "start": 566.2,
      "end": 569.28,
      "text": "walked half the distance to the elevators and retraced his steps."
    },
    {
      "start": 570.14,
      "end": 570.42,
      "text": "F.E.",
      "para_break": true
    },
    {
      "start": 570.44,
      "end": 572.9,
      "text": "Perrine was sitting at her desk when he opened the door."
    },
    {
      "start": 572.98,
      "end": 573.68,
      "text": "He said,"
    },
    {
      "start": 574.16,
      "end": 576.02,
      "text": "You ought to know better than to pay any"
    },
    {
      "start": 576.02,
      "end": 577.76,
      "text": "attention to me when I talk like that."
    },
    {
      "start": 578.58,
      "end": 580.74,
      "text": "If you think I pay any attention to you,",
      "para_break": true
    },
    {
      "start": 580.86,
      "end": 581.58,
      "text": "you're crazy,"
    },
    {
      "start": 581.82,
      "end": 582.28,
      "text": "she replied."
    },
    {
      "start": 583.32,
      "end": 583.6,
      "text": "Only,",
      "para_break": true
    },
    {
      "start": 583.81,
      "end": 586.18,
      "text": "she crossed her arms and felt her shoulders,"
    },
    {
      "start": 586.56,
      "end": 588.22,
      "text": "and her mouth twitched uncertainly."
    },
    {
      "start": 588.96,
      "end": 591.46,
      "text": "I won't be able to wear an evening gown for two weeks,",
      "para_break": true
    },
    {
      "start": 591.52,
      "end": 592.12,
      "text": "you big brute."
    },
    {
      "start": 592.92,
      "end": 593.8,
      "text": "He grinned humbly,",
      "para_break": true
    },
    {
      "start": 593.9,
      "end": 594.26,
      "text": "said,"
    },
    {
      "start": 594.42,
      "end": 595.76,
      "text": "I'm no damn good,"
    },
    {
      "start": 595.86,
      "end": 596.12,
      "text": "darling,"
    },
    {
      "start": 596.78,
      "end": 598.7,
      "text": "made an exaggerated bow and went out again.",
      "para_break": true
    },
    {
      "start": 599.2,
      "end": 601.9,
      "text": "two yellow taxi cabs were at the corner stand"
    },
    {
      "start": 601.9,
      "end": 604.58,
      "text": "to which spade went the chauffeurs were standing"
    },
    {
      "start": 604.74,
      "end": 607.92,
      "text": "together talking spade asked where's the red"
    },
    {
      "start": 607.92,
      "end": 609.7,
      "text": "-faced blonde driver that was here at noon"
    },
    {
      "start": 610.7,
      "end": 613.1,
      "text": "got a load one of the chauffeurs said",
      "para_break": true
    },
    {
      "start": 614.18,
      "end": 618.46,
      "text": "will he be back here i guess so the other chauffeur",
      "para_break": true
    },
    {
      "start": 618.54,
      "end": 619.8,
      "text": "ducked his head to the east"
    },
    {
      "start": 620.38,
      "end": 624.4,
      "text": "here he comes now spade walked down to the corner and stood by the"
    },
    {
      "start": 624.54,
      "end": 626.08,
      "text": "curb until the red-faced blonde"
    },
    {
      "start": 626.08,
      "end": 628.06,
      "text": "chauffeur had parked his cab and got out."
    },
    {
      "start": 628.22,
      "end": 629.74,
      "text": "Then Spade went up"
    },
    {
      "start": 629.74,
      "end": 630.4,
      "text": "to him and said,"
    },
    {
      "start": 630.88,
      "end": 633.44,
      "text": "I got into your cab with a lady at noontime."
    },
    {
      "start": 634.14,
      "end": 635.76,
      "text": "We went out Stockton Street and up",
      "para_break": true
    },
    {
      "start": 635.8,
      "end": 637.74,
      "text": "Sacramento to Jones where I got out."
    },
    {
      "start": 638.27,
      "end": 638.96,
      "text": "Sure,"
    },
    {
      "start": 639.26,
      "end": 640.7,
      "text": "the red-faced man said,"
    },
    {
      "start": 640.8,
      "end": 641.66,
      "text": "I remember that."
    },
    {
      "start": 642.45,
      "end": 643.34,
      "text": "I told you",
      "para_break": true
    },
    {
      "start": 643.34,
      "end": 645.1,
      "text": "to take her to a Ninth Avenue number."
    },
    {
      "start": 645.56,
      "end": 646.72,
      "text": "You didn't take her there."
    },
    {
      "start": 647.54,
      "end": 648.56,
      "text": "Where did you take her?",
      "para_break": true
    },
    {
      "start": 649.34,
      "end": 649.8,
      "text": "The chauffeur",
      "para_break": true
    },
    {
      "start": 650.06,
      "end": 652.96,
      "text": "rubbed his cheek with a grimy hand and looked doubtfully at Spade."
    },
    {
      "start": 654.1,
      "end": 655.4,
      "text": "I don't know about this.",
      "para_break": true
    },
    {
      "start": 656.44,
      "end": 656.9,
      "text": "It's all right,",
      "para_break": true
    },
    {
      "start": 657.12,
      "end": 658.04,
      "text": "Spade assured him,"
    },
    {
      "start": 658.06,
      "end": 659.4,
      "text": "giving him one of his cards."
    },
    {
      "start": 660.18,
      "end": 661.28,
      "text": "If you want to play safe,",
      "para_break": true
    },
    {
      "start": 661.3,
      "end": 661.5,
      "text": "though,"
    },
    {
      "start": 661.76,
      "end": 664.7,
      "text": "we can ride up to your office and get your superintendents okay."
    },
    {
      "start": 666.08,
      "end": 667.1,
      "text": "I guess it's all right.",
      "para_break": true
    },
    {
      "start": 667.88,
      "end": 669.13,
      "text": "I took her to the ferry building.",
      "para_break": true
    },
    {
      "start": 670.18,
      "end": 670.66,
      "text": "By herself?",
      "para_break": true
    },
    {
      "start": 671.2,
      "end": 671.94,
      "text": "Yeah,"
    },
    {
      "start": 672.1,
      "end": 672.32,
      "text": "sure."
    },
    {
      "start": 673.664,
      "end": 675.2,
      "text": "Didn't take her anywhere else first?",
      "para_break": true
    },
    {
      "start": 675.8,
      "end": 676.6,
      "text": "No,",
      "para_break": true
    },
    {
      "start": 676.84,
      "end": 677.98,
      "text": "it was like this."
    },
    {
      "start": 678.94,
      "end": 679.86,
      "text": "After we dropped you,",
      "para_break": true
    },
    {
      "start": 680.44,
      "end": 681.7,
      "text": "I went on out Sacramento,"
    },
    {
      "start": 682.4,
      "end": 683.66,
      "text": "and when we got to Polk,",
      "para_break": true
    },
    {
      "start": 683.76,
      "end": 686.56,
      "text": "she rapped on the glass and said she wanted to get a newspaper,"
    },
    {
      "start": 687.24,
      "end": 689.52,
      "text": "so I stopped at the corner and whistled for a kid,",
      "para_break": true
    },
    {
      "start": 689.58,
      "end": 690.68,
      "text": "and she got her paper."
    },
    {
      "start": 691.74,
      "end": 692.2,
      "text": "Which paper?",
      "para_break": true
    },
    {
      "start": 693.24,
      "end": 693.56,
      "text": "The call.",
      "para_break": true
    },
    {
      "start": 694.88,
      "end": 696.98,
      "text": "Then I went on out Sacramento some more,",
      "para_break": true
    },
    {
      "start": 697.42,
      "end": 699.2,
      "text": "and just after we'd crossed Van Ness,"
    },
    {
      "start": 699.5,
      "end": 700.68,
      "text": "she knocked on the glass again"
    },
    {
      "start": 701.16,
      "end": 702.98,
      "text": "and said take her to the ferry building."
    },
    {
      "start": 703.84,
      "end": 704.96,
      "text": "Was she excited or anything?",
      "para_break": true
    },
    {
      "start": 706.24,
      "end": 707.18,
      "text": "Not so as I noticed.",
      "para_break": true
    },
    {
      "start": 707.84,
      "end": 709.24,
      "text": "And when you got to the ferry building?",
      "para_break": true
    },
    {
      "start": 709.76,
      "end": 712.08,
      "text": "She paid me off and that was all."
    },
    {
      "start": 713.184,
      "end": 714.3,
      "text": "Anybody waiting for her",
      "para_break": true
    },
    {
      "start": 714.38,
      "end": 714.5,
      "text": "there?"
    },
    {
      "start": 715.56,
      "end": 716.9,
      "text": "I didn't see them if they was.",
      "para_break": true
    },
    {
      "start": 718.06,
      "end": 718.88,
      "text": "Which way did she go?",
      "para_break": true
    },
    {
      "start": 719.88,
      "end": 720.33,
      "text": "At the ferry?",
      "para_break": true
    },
    {
      "start": 721.5,
      "end": 721.98,
      "text": "I don't know,",
      "para_break": true
    },
    {
      "start": 722.04,
      "end": 722.26,
      "text": "maybe"
    },
    {
      "start": 722.34,
      "end": 724.02,
      "text": "upstairs or towards the stairs?"
    },
    {
      "start": 725.2,
      "end": 726.3,
      "text": "Take the newspaper with her?",
      "para_break": true
    },
    {
      "start": 726.9,
      "end": 727.42,
      "text": "Yeah,",
      "para_break": true
    },
    {
      "start": 727.54,
      "end": 729.02,
      "text": "she had it tucked under her arm"
    },
    {
      "start": 729.16,
      "end": 729.92,
      "text": "when she paid me."
    },
    {
      "start": 730.92,
      "end": 733.26,
      "text": "With the pink sheet outside or one of the white?",
      "para_break": true
    }
  ]
}
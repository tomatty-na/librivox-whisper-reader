{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-12",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_12_hammett.mp3",
  "chapter_title": "Merry-Go-Round",
  "reader_name": "NLizer",
  "page_num": 4,
  "page_total": 5,
  "page_start_sec": 733.75,
  "page_end_sec": 981.04,
  "para_gap_threshold": 0.597,
  "segments": [
    {
      "start": 733.75,
      "end": 734.4,
      "text": "Hell,"
    },
    {
      "start": 734.44,
      "end": 734.64,
      "text": "Cap,"
    },
    {
      "start": 734.86,
      "end": 735.8,
      "text": "I don't remember that."
    },
    {
      "start": 737.088,
      "end": 738.18,
      "text": "Spade thanked the chauffeur,",
      "para_break": true
    },
    {
      "start": 738.26,
      "end": 738.52,
      "text": "said,"
    },
    {
      "start": 738.68,
      "end": 739.82,
      "text": "get yourself a smoke,"
    },
    {
      "start": 740.0,
      "end": 741.26,
      "text": "and gave him a silver dollar."
    },
    {
      "start": 742.432,
      "end": 742.8,
      "text": "Spade bought",
      "para_break": true
    },
    {
      "start": 742.8,
      "end": 745.08,
      "text": "a copy of the call and carried it into an office"
    },
    {
      "start": 745.08,
      "end": 747.86,
      "text": "building vestibule to examine it out of the wind."
    },
    {
      "start": 748.86,
      "end": 751.14,
      "text": "His eyes ran swiftly over the front page headlines",
      "para_break": true
    },
    {
      "start": 751.17,
      "end": 753.42,
      "text": "and over those on the second and third pages."
    },
    {
      "start": 753.76,
      "end": 756.26,
      "text": "They paused for a moment under suspect"
    },
    {
      "start": 756.26,
      "end": 759.04,
      "text": "arrested as counterfeiter on the fourth page,"
    },
    {
      "start": 759.24,
      "end": 759.76,
      "text": "and again"
    },
    {
      "start": 759.76,
      "end": 763.26,
      "text": "on page five under Bay youth seeks death with bullet."
    },
    {
      "start": 764.224,
      "end": 766.46,
      "text": "Pages six and seven held nothing to interest him.",
      "para_break": true
    },
    {
      "start": 767.24,
      "end": 767.66,
      "text": "On eight,",
      "para_break": true
    },
    {
      "start": 767.78,
      "end": 771.36,
      "text": "three boys arrested as San Francisco burglars after shooting"
    },
    {
      "start": 771.94,
      "end": 772.52,
      "text": "held his attention"
    },
    {
      "start": 772.52,
      "end": 773.24,
      "text": "for a moment,"
    },
    {
      "start": 773.38,
      "end": 774.24,
      "text": "and after that,"
    },
    {
      "start": 774.28,
      "end": 776.34,
      "text": "nothing until he reached the 35th page,"
    },
    {
      "start": 776.54,
      "end": 777.26,
      "text": "which held news"
    },
    {
      "start": 777.58,
      "end": 778.34,
      "text": "of the weather,"
    },
    {
      "start": 778.52,
      "end": 779.18,
      "text": "shipping,"
    },
    {
      "start": 779.48,
      "end": 780.1,
      "text": "produce,"
    },
    {
      "start": 780.4,
      "end": 781.02,
      "text": "finance,"
    },
    {
      "start": 781.38,
      "end": 781.86,
      "text": "divorce,"
    },
    {
      "start": 782.24,
      "end": 783.08,
      "text": "births,"
    },
    {
      "start": 783.08,
      "end": 783.72,
      "text": "marriages,"
    },
    {
      "start": 783.88,
      "end": 784.72,
      "text": "and deaths."
    },
    {
      "start": 785.17,
      "end": 786.64,
      "text": "He read the list of dead,"
    },
    {
      "start": 786.82,
      "end": 789.04,
      "text": "passed over pages 36 and 37,"
    },
    {
      "start": 789.44,
      "end": 790.62,
      "text": "financial news,"
    },
    {
      "start": 790.78,
      "end": 792.38,
      "text": "found nothing to stop his"
    },
    {
      "start": 792.38,
      "end": 794.82,
      "text": "eyes on the 38th and last page,"
    },
    {
      "start": 795.12,
      "end": 795.88,
      "text": "sighed,"
    },
    {
      "start": 795.9,
      "end": 797.0,
      "text": "folded the newspaper,"
    },
    {
      "start": 797.66,
      "end": 798.9,
      "text": "put it in his coat pocket,",
      "para_break": true
    },
    {
      "start": 798.98,
      "end": 799.48,
      "text": "and rolled a"
    },
    {
      "start": 799.56,
      "end": 799.88,
      "text": "cigarette."
    },
    {
      "start": 800.39,
      "end": 802.48,
      "text": "For five minutes he stood there in the"
    },
    {
      "start": 802.48,
      "end": 804.54,
      "text": "office building vestibule smoking and staring"
    },
    {
      "start": 804.92,
      "end": 805.76,
      "text": "sulkily at nothing."
    },
    {
      "start": 806.76,
      "end": 808.3,
      "text": "Then he walked up to Stockton Street,",
      "para_break": true
    },
    {
      "start": 808.78,
      "end": 809.62,
      "text": "hailed a taxi cab,"
    },
    {
      "start": 810.02,
      "end": 810.94,
      "text": "and had himself driven"
    },
    {
      "start": 811.08,
      "end": 811.62,
      "text": "to the Coronet."
    },
    {
      "start": 812.76,
      "end": 814.44,
      "text": "He led himself into the building and into",
      "para_break": true
    },
    {
      "start": 814.44,
      "end": 816.3,
      "text": "Brigid O'Shaughnessy's apartment with"
    },
    {
      "start": 816.3,
      "end": 817.52,
      "text": "the key she had given him."
    },
    {
      "start": 818.56,
      "end": 821.76,
      "text": "The blue gown she had worn the previous night was hanging across the",
      "para_break": true
    },
    {
      "start": 821.76,
      "end": 822.42,
      "text": "foot of her bed."
    },
    {
      "start": 822.6,
      "end": 825.82,
      "text": "Her blue stockings and slippers were on the bedroom floor."
    },
    {
      "start": 826.14,
      "end": 827.88,
      "text": "The polychrome box that"
    },
    {
      "start": 827.88,
      "end": 829.9,
      "text": "had held jewelry in her dressing table drawer"
    },
    {
      "start": 829.9,
      "end": 832.3,
      "text": "now stood empty on the dressing table top."
    },
    {
      "start": 833.216,
      "end": 833.76,
      "text": "Spade frowned",
      "para_break": true
    },
    {
      "start": 833.88,
      "end": 834.18,
      "text": "at it,"
    },
    {
      "start": 834.64,
      "end": 836.06,
      "text": "ran his tongue across his lips,"
    },
    {
      "start": 836.672,
      "end": 839.08,
      "text": "strolled through the rooms looking around but not touching",
      "para_break": true
    },
    {
      "start": 839.22,
      "end": 839.5,
      "text": "anything,"
    },
    {
      "start": 839.8,
      "end": 842.28,
      "text": "then left the coronet and went downtown again."
    },
    {
      "start": 843.44,
      "end": 845.12,
      "text": "In the doorway of Spade's office building,",
      "para_break": true
    },
    {
      "start": 845.26,
      "end": 848.06,
      "text": "he came face to face with the boy he had left at Gutman's."
    },
    {
      "start": 848.23,
      "end": 850.3,
      "text": "The boy put himself in Spade's path,"
    },
    {
      "start": 850.88,
      "end": 851.54,
      "text": "blocking the entrance,"
    },
    {
      "start": 851.64,
      "end": 852.04,
      "text": "and said,"
    },
    {
      "start": 852.88,
      "end": 853.26,
      "text": "come on,",
      "para_break": true
    },
    {
      "start": 853.3,
      "end": 854.7,
      "text": "he wants to see you."
    },
    {
      "start": 855.41,
      "end": 856.98,
      "text": "The boy's hands were in his",
      "para_break": true
    },
    {
      "start": 857.04,
      "end": 857.86,
      "text": "overcoat pockets."
    },
    {
      "start": 858.1,
      "end": 861.46,
      "text": "His pockets bulged more than his hands need have made them bulge."
    },
    {
      "start": 862.46,
      "end": 863.78,
      "text": "Spade grinned and said mockingly,",
      "para_break": true
    },
    {
      "start": 864.18,
      "end": 866.28,
      "text": "I didn't expect you till 525."
    },
    {
      "start": 867.2,
      "end": 868.44,
      "text": "I hope I haven't kept you waiting.",
      "para_break": true
    },
    {
      "start": 869.14,
      "end": 871.36,
      "text": "The boy raised his eyes to Spade's mouth",
      "para_break": true
    },
    {
      "start": 871.52,
      "end": 874.46,
      "text": "and spoke in the strained voice of one in physical pain."
    },
    {
      "start": 875.44,
      "end": 876.32,
      "text": "Keep on riding me,",
      "para_break": true
    },
    {
      "start": 876.82,
      "end": 879.22,
      "text": "and you're going to be picking iron out of your navel."
    },
    {
      "start": 880.224,
      "end": 880.94,
      "text": "Spade chuckled.",
      "para_break": true
    },
    {
      "start": 881.68,
      "end": 882.52,
      "text": "The cheaper the crook,",
      "para_break": true
    },
    {
      "start": 882.56,
      "end": 883.58,
      "text": "the gaudier the patter,"
    },
    {
      "start": 883.76,
      "end": 884.62,
      "text": "he said cheerfully."
    },
    {
      "start": 885.46,
      "end": 885.74,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 885.88,
      "end": 886.64,
      "text": "let's go."
    },
    {
      "start": 887.9,
      "end": 889.64,
      "text": "They walked up Sutter Street side by side.",
      "para_break": true
    },
    {
      "start": 889.92,
      "end": 892.36,
      "text": "The boy kept his hands in his overcoat pockets."
    },
    {
      "start": 892.82,
      "end": 895.02,
      "text": "They walked a little more than a block in silence."
    },
    {
      "start": 895.72,
      "end": 896.8,
      "text": "Then Spade asked pleasantly,",
      "para_break": true
    },
    {
      "start": 897.3,
      "end": 899.78,
      "text": "How long have you been off the gooseberry lay,"
    },
    {
      "start": 899.92,
      "end": 900.12,
      "text": "son?"
    },
    {
      "start": 901.34,
      "end": 903.62,
      "text": "The boy did not show that he had heard the question.",
      "para_break": true
    },
    {
      "start": 904.82,
      "end": 905.4,
      "text": "Did you ever?",
      "para_break": true
    },
    {
      "start": 905.92,
      "end": 906.78,
      "text": "Spade began and stopped."
    },
    {
      "start": 907.7,
      "end": 910.08,
      "text": "A soft light began to glow in his yellowish eyes.",
      "para_break": true
    },
    {
      "start": 911.06,
      "end": 912.66,
      "text": "He did not address the boy again.",
      "para_break": true
    },
    {
      "start": 913.8,
      "end": 915.14,
      "text": "They went into the Alexandria,",
      "para_break": true
    },
    {
      "start": 915.64,
      "end": 917.12,
      "text": "rode up to the twelfth floor,"
    },
    {
      "start": 917.42,
      "end": 920.06,
      "text": "and walked down the corridor towards Gutman's suite."
    },
    {
      "start": 920.94,
      "end": 922.18,
      "text": "Nobody else was in the corridor.",
      "para_break": true
    },
    {
      "start": 923.2,
      "end": 924.82,
      "text": "Spade lagged a little so that when they",
      "para_break": true
    },
    {
      "start": 924.82,
      "end": 926.78,
      "text": "were within 15 feet of Gutman's door,"
    },
    {
      "start": 927.12,
      "end": 929.16,
      "text": "he was perhaps a foot and a half behind the boy."
    },
    {
      "start": 929.92,
      "end": 932.5,
      "text": "He leaned sideways suddenly and grasped the boy from",
      "para_break": true
    },
    {
      "start": 932.5,
      "end": 934.78,
      "text": "behind by both arms just beneath the boy's elbows."
    },
    {
      "start": 935.7,
      "end": 937.6,
      "text": "He forced the boy's arms forward so that",
      "para_break": true
    },
    {
      "start": 937.6,
      "end": 939.38,
      "text": "the boy's hands in his overcoat pockets"
    },
    {
      "start": 939.68,
      "end": 941.38,
      "text": "lifted the overcoat up before him."
    },
    {
      "start": 942.4,
      "end": 943.6,
      "text": "The boy struggled and squirmed,",
      "para_break": true
    },
    {
      "start": 943.66,
      "end": 945.4,
      "text": "but he was impotent in the big man's grip."
    },
    {
      "start": 945.76,
      "end": 947.1,
      "text": "The boy kicked back,"
    },
    {
      "start": 947.36,
      "end": 949.48,
      "text": "but his feet went between Spade's spread legs."
    },
    {
      "start": 950.496,
      "end": 952.32,
      "text": "Spade lifted the boy straight up from the floor",
      "para_break": true
    },
    {
      "start": 952.32,
      "end": 954.24,
      "text": "and brought him down hard on his feet again."
    },
    {
      "start": 954.92,
      "end": 957.28,
      "text": "The impact made little noise on the thick carpet.",
      "para_break": true
    },
    {
      "start": 958.28,
      "end": 959.12,
      "text": "At the moment of impact,",
      "para_break": true
    },
    {
      "start": 959.26,
      "end": 962.3,
      "text": "Spade's hand slid down and got a fresh grip on the boy's wrists."
    },
    {
      "start": 963.2,
      "end": 963.54,
      "text": "The boy,",
      "para_break": true
    },
    {
      "start": 963.7,
      "end": 965.04,
      "text": "teeth set hard together,"
    },
    {
      "start": 965.54,
      "end": 967.94,
      "text": "did not stop straining against the man's big hands,"
    },
    {
      "start": 968.26,
      "end": 969.83,
      "text": "but he could not tear himself loose,"
    },
    {
      "start": 970.0,
      "end": 973.62,
      "text": "could not keep the man's hands from crawling down over his own hands."
    },
    {
      "start": 974.0,
      "end": 976.4,
      "text": "The boy's teeth ground together audibly,"
    },
    {
      "start": 976.5,
      "end": 979.26,
      "text": "making a noise that mingled with the noise of Spade's breathing"
    },
    {
      "start": 979.46,
      "end": 981.04,
      "text": "as Spade crushed the boy's hands."
    }
  ]
}
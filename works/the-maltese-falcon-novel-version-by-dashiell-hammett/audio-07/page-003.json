{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-07",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_07_hammett_128kb.mp3",
  "chapter_title": "G in the Air",
  "reader_name": "NLizer",
  "page_num": 3,
  "page_total": 6,
  "page_start_sec": 485.6,
  "page_end_sec": 726.44,
  "para_gap_threshold": 0.77,
  "corrected": "claude",
  "segments": [
    {
      "start": 485.6,
      "end": 488.0,
      "text": "Her thumb and forefinger twisted a black button on",
      "para_break": true
    },
    {
      "start": 488.08,
      "end": 488.64,
      "text": "his blue coat."
    },
    {
      "start": 488.86,
      "end": 489.9,
      "text": "Spade said,"
    },
    {
      "start": 490.1,
      "end": 490.96,
      "text": "\"That again!\""
    },
    {
      "start": 491.68,
      "end": 492.56,
      "text": "with mock resignation."
    },
    {
      "start": 493.5,
      "end": 494.88,
      "text": "\"But you know it's so,\"",
      "para_break": true
    },
    {
      "start": 495.18,
      "end": 495.8,
      "text": "she insisted."
    },
    {
      "start": 496.36,
      "end": 496.88,
      "text": "\"No,"
    },
    {
      "start": 497.1,
      "end": 498.06,
      "text": "I don't know it.\""
    },
    {
      "start": 498.48,
      "end": 500.6,
      "text": "He patted the hand that was twisting the button."
    },
    {
      "start": 501.4,
      "end": 504.36,
      "text": "\"My asking for reasons why I should trust you brought us here.",
      "para_break": true
    },
    {
      "start": 505.248,
      "end": 506.26,
      "text": "Don't let's confuse things."
    },
    {
      "start": 507.22,
      "end": 508.62,
      "text": "You don't have to trust me, anyhow,"
    },
    {
      "start": 508.82,
      "end": 511.0,
      "text": "as long as you can persuade me to trust you.\""
    },
    {
      "start": 511.98,
      "end": 512.96,
      "text": "She studied his face.",
      "para_break": true
    },
    {
      "start": 513.5,
      "end": 514.8,
      "text": "Her nostrils quivered."
    },
    {
      "start": 515.552,
      "end": 516.1,
      "text": "Spade laughed."
    },
    {
      "start": 516.96,
      "end": 518.38,
      "text": "He patted her hand again and said:",
      "para_break": true
    },
    {
      "start": 519.072,
      "end": 520.2,
      "text": "\"Don't worry about that now."
    },
    {
      "start": 520.8,
      "end": 521.9,
      "text": "He'll be here in a moment."
    },
    {
      "start": 522.5,
      "end": 523.64,
      "text": "Get your business with him over,"
    },
    {
      "start": 523.76,
      "end": 525.52,
      "text": "and then we'll see how we'll stand.\""
    },
    {
      "start": 526.48,
      "end": 527.88,
      "text": "\"And you'll let me go about it--",
      "para_break": true
    },
    {
      "start": 527.92,
      "end": 528.92,
      "text": "with him--"
    },
    {
      "start": 529.06,
      "end": 530.18,
      "text": "in my own way?\""
    },
    {
      "start": 530.4,
      "end": 530.5,
      "text": "\"Sure.\""
    },
    {
      "start": 532.86,
      "end": 534.66,
      "text": "She turned her hand under his so",
      "para_break": true
    },
    {
      "start": 534.66,
      "end": 535.96,
      "text": "that her fingers pressed his."
    },
    {
      "start": 536.58,
      "end": 537.34,
      "text": "She said softly:"
    },
    {
      "start": 537.56,
      "end": 539.38,
      "text": "\"You're a God-send.\""
    },
    {
      "start": 540.64,
      "end": 541.14,
      "text": "Spade said:",
      "para_break": true
    },
    {
      "start": 541.4,
      "end": 542.92,
      "text": "\"Don't overdo it.\""
    },
    {
      "start": 543.28,
      "end": 545.52,
      "text": "She looked reproachfully at him,"
    },
    {
      "start": 545.6,
      "end": 546.24,
      "text": "though smiling,"
    },
    {
      "start": 546.62,
      "end": 548.12,
      "text": "and returned to the padded rocker."
    },
    {
      "start": 549.08,
      "end": 550.22,
      "text": "Joel Cairo was excited.",
      "para_break": true
    },
    {
      "start": 551.14,
      "end": 554.08,
      "text": "His dark eyes seemed all irises and his high-pitched,"
    },
    {
      "start": 554.16,
      "end": 554.96,
      "text": "thin-voiced words"
    },
    {
      "start": 555.26,
      "end": 557.86,
      "text": "were tumbling out before Spade had the door half-open."
    },
    {
      "start": 558.9,
      "end": 560.72,
      "text": "\"That boy is out there watching the house,",
      "para_break": true
    },
    {
      "start": 560.84,
      "end": 560.96,
      "text": "Mr."
    },
    {
      "start": 561.1,
      "end": 561.46,
      "text": "Spade,"
    },
    {
      "start": 561.58,
      "end": 563.0,
      "text": "that boy you showed me,"
    },
    {
      "start": 563.38,
      "end": 565.8,
      "text": "or to whom you showed me, in front of the theatre."
    },
    {
      "start": 566.66,
      "end": 568.18,
      "text": "What am I to understand from that,"
    },
    {
      "start": 568.26,
      "end": 568.5,
      "text": "Mr."
    },
    {
      "start": 568.58,
      "end": 568.9,
      "text": "Spade?"
    },
    {
      "start": 569.04,
      "end": 570.68,
      "text": "I came here in good faith,"
    },
    {
      "start": 570.78,
      "end": 571.8,
      "text": "with no thought of"
    },
    {
      "start": 571.82,
      "end": 572.62,
      "text": "tricks or traps.\""
    },
    {
      "start": 573.22,
      "end": 575.02,
      "text": "\"You were asked in good faith.\"",
      "para_break": true
    },
    {
      "start": 575.2,
      "end": 576.46,
      "text": "Spade frowned thoughtfully."
    },
    {
      "start": 577.16,
      "end": 578.16,
      "text": "\"But I ought to've"
    },
    {
      "start": 578.28,
      "end": 579.52,
      "text": "guessed he might show up."
    },
    {
      "start": 579.72,
      "end": 580.98,
      "text": "He saw you come in?\""
    },
    {
      "start": 581.18,
      "end": 581.28,
      "text": "\"Naturally."
    },
    {
      "start": 582.47,
      "end": 583.78,
      "text": "I could have gone on,",
      "para_break": true
    },
    {
      "start": 584.16,
      "end": 584.58,
      "text": "but that seemed"
    },
    {
      "start": 584.78,
      "end": 587.92,
      "text": "useless, since you had already let him see us together.\""
    },
    {
      "start": 589.024,
      "end": 590.56,
      "text": "Brigid O'Shaughnessy came into the",
      "para_break": true
    },
    {
      "start": 590.72,
      "end": 592.9,
      "text": "passageway behind Spade and asked anxiously:"
    },
    {
      "start": 593.64,
      "end": 594.1,
      "text": "\"What boy?"
    },
    {
      "start": 594.76,
      "end": 595.3,
      "text": "What is it?\""
    },
    {
      "start": 596.352,
      "end": 597.82,
      "text": "Cairo removed his black hat from",
      "para_break": true
    },
    {
      "start": 597.82,
      "end": 598.22,
      "text": "his head,"
    },
    {
      "start": 598.32,
      "end": 599.38,
      "text": "bowed stiffly,"
    },
    {
      "start": 599.38,
      "end": 600.46,
      "text": "and said in a prim voice:"
    },
    {
      "start": 601.34,
      "end": 602.2,
      "text": "\"If you do not know,",
      "para_break": true
    },
    {
      "start": 602.36,
      "end": 603.04,
      "text": "ask Mr."
    },
    {
      "start": 603.22,
      "end": 603.58,
      "text": "Spade."
    },
    {
      "start": 603.78,
      "end": 604.6,
      "text": "I know nothing"
    },
    {
      "start": 604.7,
      "end": 606.2,
      "text": "about it except through him.\""
    },
    {
      "start": 606.57,
      "end": 610.14,
      "text": "\"A kid who's been trying to tail me around town all evening,\""
    },
    {
      "start": 610.44,
      "end": 612.44,
      "text": "Spade said carelessly over his shoulder,"
    },
    {
      "start": 612.9,
      "end": 614.18,
      "text": "not turning to face the girl."
    },
    {
      "start": 615.04,
      "end": 615.42,
      "text": "\"Come on in,",
      "para_break": true
    },
    {
      "start": 615.48,
      "end": 615.78,
      "text": "Cairo."
    },
    {
      "start": 616.0,
      "end": 618.56,
      "text": "There's no use standing here talking for all the neighbors.\""
    },
    {
      "start": 619.648,
      "end": 621.64,
      "text": "Brigid O'Shaughnessy grasped Spade's",
      "para_break": true
    },
    {
      "start": 621.64,
      "end": 622.98,
      "text": "arm above the elbow and demanded:"
    },
    {
      "start": 623.88,
      "end": 625.34,
      "text": "\"Did he follow you to my apartment?\"",
      "para_break": true
    },
    {
      "start": 626.24,
      "end": 626.74,
      "text": "\"No.",
      "para_break": true
    },
    {
      "start": 626.9,
      "end": 628.18,
      "text": "I shook him before that."
    },
    {
      "start": 628.64,
      "end": 631.16,
      "text": "Then I suppose he came back here to try to pick me up again.\""
    },
    {
      "start": 631.99,
      "end": 632.54,
      "text": "Cairo,",
      "para_break": true
    },
    {
      "start": 632.62,
      "end": 635.02,
      "text": "holding his black hat to his belly with both hands,"
    },
    {
      "start": 635.44,
      "end": 636.66,
      "text": "had come into the passageway."
    },
    {
      "start": 637.6,
      "end": 639.04,
      "text": "Spade shut the corridor-door behind"
    },
    {
      "start": 639.04,
      "end": 640.58,
      "text": "him and they went into the living-room."
    },
    {
      "start": 641.12,
      "end": 641.4,
      "text": "There"
    },
    {
      "start": 641.58,
      "end": 644.96,
      "text": "Cairo bowed stiffly over his hat once more and said:"
    },
    {
      "start": 645.4,
      "end": 647.0,
      "text": "\"I am delighted to see you again,"
    },
    {
      "start": 647.18,
      "end": 648.02,
      "text": "Miss O'Shaughnessy.\""
    },
    {
      "start": 649.16,
      "end": 650.08,
      "text": "\"I was sure you would be,",
      "para_break": true
    },
    {
      "start": 650.18,
      "end": 650.4,
      "text": "Joe,\""
    },
    {
      "start": 650.58,
      "end": 651.12,
      "text": "she replied,"
    },
    {
      "start": 651.46,
      "end": 652.62,
      "text": "giving him her hand."
    },
    {
      "start": 653.34,
      "end": 656.34,
      "text": "He made a formal bow over her hand and released it quickly."
    },
    {
      "start": 657.38,
      "end": 660.02,
      "text": "She sat in the padded rocker she had occupied before.",
      "para_break": true
    },
    {
      "start": 660.896,
      "end": 662.66,
      "text": "Cairo sat in the armchair by the table."
    },
    {
      "start": 663.22,
      "end": 663.64,
      "text": "Spade,"
    },
    {
      "start": 663.76,
      "end": 666.14,
      "text": "when he had hung Cairo's hat and coat in the closet,"
    },
    {
      "start": 666.34,
      "end": 669.08,
      "text": "sat on an end of the sofa in front of the"
    },
    {
      "start": 669.08,
      "end": 670.94,
      "text": "windows and began to roll a cigarette."
    },
    {
      "start": 672.032,
      "end": 673.58,
      "text": "Brigid O'Shaughnessy said to Cairo:",
      "para_break": true
    },
    {
      "start": 674.64,
      "end": 676.6,
      "text": "\"Sam told me about your offer for the falcon.",
      "para_break": true
    },
    {
      "start": 677.1,
      "end": 678.66,
      "text": "How soon can you have the money ready?\""
    },
    {
      "start": 679.68,
      "end": 681.12,
      "text": "Cairo's eyebrows twitched.",
      "para_break": true
    },
    {
      "start": 681.4,
      "end": 681.86,
      "text": "He smiled."
    },
    {
      "start": 682.6,
      "end": 683.12,
      "text": "\"It is ready.\""
    },
    {
      "start": 684.02,
      "end": 685.64,
      "text": "He continued to smile at the girl for"
    },
    {
      "start": 685.64,
      "end": 687.3,
      "text": "a little while after he had spoken,"
    },
    {
      "start": 687.82,
      "end": 689.04,
      "text": "and then looked at Spade."
    },
    {
      "start": 690.048,
      "end": 691.26,
      "text": "Spade was lighting his cigarette.",
      "para_break": true
    },
    {
      "start": 691.72,
      "end": 692.82,
      "text": "His face was tranquil."
    },
    {
      "start": 693.88,
      "end": 694.22,
      "text": "\"In cash?\"",
      "para_break": true
    },
    {
      "start": 694.78,
      "end": 695.44,
      "text": "the girl asked."
    },
    {
      "start": 696.3,
      "end": 696.4,
      "text": "\"Oh,"
    },
    {
      "start": 696.52,
      "end": 696.74,
      "text": "yes,\""
    },
    {
      "start": 697.02,
      "end": 697.7,
      "text": "Cairo replied."
    },
    {
      "start": 698.9,
      "end": 699.52,
      "text": "She frowned,",
      "para_break": true
    },
    {
      "start": 699.62,
      "end": 701.26,
      "text": "put her tongue between her lips,"
    },
    {
      "start": 701.36,
      "end": 702.14,
      "text": "withdrew it,"
    },
    {
      "start": 702.14,
      "end": 702.7,
      "text": "and asked:"
    },
    {
      "start": 703.584,
      "end": 707.36,
      "text": "\"You are ready to give us five thousand dollars, now, if we give you the falcon?\"",
      "para_break": true
    },
    {
      "start": 708.48,
      "end": 709.92,
      "text": "Cairo held up a wriggling hand.",
      "para_break": true
    },
    {
      "start": 710.816,
      "end": 711.34,
      "text": "\"Excuse me,\"",
      "para_break": true
    },
    {
      "start": 711.44,
      "end": 711.96,
      "text": "he said."
    },
    {
      "start": 712.3,
      "end": 714.22,
      "text": "\"I expressed myself badly."
    },
    {
      "start": 714.92,
      "end": 717.4,
      "text": "I did not mean to say that I have the money in my pockets,"
    },
    {
      "start": 718.24,
      "end": 720.42,
      "text": "but that I am prepared to get it on a very few"
    },
    {
      "start": 720.42,
      "end": 723.46,
      "text": "minutes' notice at any time during banking hours.\""
    },
    {
      "start": 723.72,
      "end": 723.872,
      "text": "\"Oh!\""
    },
    {
      "start": 725.54,
      "end": 726.44,
      "text": "She looked at Spade.",
      "para_break": true
    }
  ]
}

{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-07",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_07_hammett.mp3",
  "chapter_title": "G in the Air",
  "reader_name": "NLizer",
  "page_num": 5,
  "page_total": 6,
  "page_start_sec": 968.94,
  "page_end_sec": 1209.02,
  "para_gap_threshold": 0.77,
  "segments": [
    {
      "start": 968.94,
      "end": 969.64,
      "text": "Cairo,"
    },
    {
      "start": 969.72,
      "end": 972.32,
      "text": "speaking with difficulty because of the fingers on his throat,"
    },
    {
      "start": 972.36,
      "end": 972.64,
      "text": "said,"
    },
    {
      "start": 973.02,
      "end": 975.74,
      "text": "This is the second time you've put your hands on me."
    },
    {
      "start": 975.98,
      "end": 976.96,
      "text": "His eyes,"
    },
    {
      "start": 977.1,
      "end": 978.08,
      "text": "though the throttling pressure"
    },
    {
      "start": 978.08,
      "end": 979.5,
      "text": "on his throat made them bulge,"
    },
    {
      "start": 979.52,
      "end": 980.74,
      "text": "were cold and menacing."
    },
    {
      "start": 981.02,
      "end": 981.12,
      "text": "Yes,"
    },
    {
      "start": 981.96,
      "end": 982.86,
      "text": "Spade growled,",
      "para_break": true
    },
    {
      "start": 983.26,
      "end": 983.78,
      "text": "and when you're"
    },
    {
      "start": 983.88,
      "end": 984.3,
      "text": "slapped,"
    },
    {
      "start": 984.44,
      "end": 985.88,
      "text": "you'll take it and like it."
    },
    {
      "start": 985.98,
      "end": 989.44,
      "text": "He released Cairo's wrist and with a thick open hand struck"
    },
    {
      "start": 989.62,
      "end": 991.51,
      "text": "the side of his face three times savagely."
    },
    {
      "start": 992.672,
      "end": 994.36,
      "text": "Cairo tried to spit in Spade's face,",
      "para_break": true
    },
    {
      "start": 994.52,
      "end": 995.52,
      "text": "but the dryness of"
    },
    {
      "start": 995.52,
      "end": 998.18,
      "text": "the Levantine's mouth made it only an angry gesture."
    },
    {
      "start": 999.232,
      "end": 1000.18,
      "text": "Spade slapped the mouth,",
      "para_break": true
    },
    {
      "start": 1000.28,
      "end": 1001.16,
      "text": "cutting the lower lip."
    },
    {
      "start": 1001.82,
      "end": 1002.82,
      "text": "The doorbell rang."
    },
    {
      "start": 1004.096,
      "end": 1005.84,
      "text": "Cairo's eyes jerked into focus on the",
      "para_break": true
    },
    {
      "start": 1005.84,
      "end": 1007.96,
      "text": "passageway that led to the corridor door."
    },
    {
      "start": 1008.78,
      "end": 1010.7,
      "text": "His eyes had become unangry and wary.",
      "para_break": true
    },
    {
      "start": 1011.02,
      "end": 1014.16,
      "text": "The girl had gasped and turned to face the passageway."
    },
    {
      "start": 1014.48,
      "end": 1015.68,
      "text": "Her face was frightened."
    },
    {
      "start": 1016.64,
      "end": 1018.5,
      "text": "Spade stared gloomily for a moment at",
      "para_break": true
    },
    {
      "start": 1018.5,
      "end": 1020.26,
      "text": "the blood trickling from Cairo's lip,"
    },
    {
      "start": 1021.02,
      "end": 1021.96,
      "text": "and then stepped back,"
    },
    {
      "start": 1022.14,
      "end": 1024.42,
      "text": "taking his hand from the Levantine's throat."
    },
    {
      "start": 1025.32,
      "end": 1025.84,
      "text": "Who is it?",
      "para_break": true
    },
    {
      "start": 1025.86,
      "end": 1026.94,
      "text": "the girl whispered,"
    },
    {
      "start": 1026.96,
      "end": 1028.46,
      "text": "coming close to Spade,"
    },
    {
      "start": 1029.14,
      "end": 1031.6,
      "text": "and Cairo's eyes jerked back to ask the same question."
    },
    {
      "start": 1032.608,
      "end": 1034.03,
      "text": "Spade gave his answer irritably.",
      "para_break": true
    },
    {
      "start": 1034.66,
      "end": 1035.24,
      "text": "I don't know."
    },
    {
      "start": 1036.38,
      "end": 1037.91,
      "text": "The bell rang again more insistently.",
      "para_break": true
    },
    {
      "start": 1038.84,
      "end": 1039.22,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 1039.32,
      "end": 1040.08,
      "text": "keep quiet,"
    },
    {
      "start": 1040.3,
      "end": 1040.94,
      "text": "Spade said,"
    },
    {
      "start": 1041.1,
      "end": 1042.28,
      "text": "and went out of the room,"
    },
    {
      "start": 1042.34,
      "end": 1043.58,
      "text": "shutting the door behind him."
    },
    {
      "start": 1044.576,
      "end": 1046.36,
      "text": "Spade turned on the light in the passageway",
      "para_break": true
    },
    {
      "start": 1046.38,
      "end": 1047.76,
      "text": "and opened the door to the corridor."
    },
    {
      "start": 1048.608,
      "end": 1050.5,
      "text": "Lieutenant Dundee and Palm Pole House were there.",
      "para_break": true
    },
    {
      "start": 1051.42,
      "end": 1051.62,
      "text": "Hello,",
      "para_break": true
    },
    {
      "start": 1051.7,
      "end": 1051.94,
      "text": "Sam,"
    },
    {
      "start": 1052.16,
      "end": 1052.74,
      "text": "Tom said."
    },
    {
      "start": 1053.46,
      "end": 1055.62,
      "text": "We thought maybe you wouldn't have gone to bed yet."
    },
    {
      "start": 1056.704,
      "end": 1058.16,
      "text": "Dundee nodded but said nothing.",
      "para_break": true
    },
    {
      "start": 1059.232,
      "end": 1060.66,
      "text": "Spade said good-naturedly,",
      "para_break": true
    },
    {
      "start": 1061.04,
      "end": 1061.36,
      "text": "Hello,"
    },
    {
      "start": 1061.54,
      "end": 1064.26,
      "text": "you guys picked swell hours to do your visiting in."
    },
    {
      "start": 1064.92,
      "end": 1065.72,
      "text": "What is it this time?"
    },
    {
      "start": 1067.04,
      "end": 1068.32,
      "text": "Dundee spoke then quietly.",
      "para_break": true
    },
    {
      "start": 1069.28,
      "end": 1070.24,
      "text": "We want to talk to you,",
      "para_break": true
    },
    {
      "start": 1070.28,
      "end": 1070.62,
      "text": "Spade."
    },
    {
      "start": 1071.09,
      "end": 1075.54,
      "text": "well spade stood in the doorway blocking it go ahead and talk"
    },
    {
      "start": 1076.7,
      "end": 1078.1,
      "text": "pom polehouse advanced saying",
      "para_break": true
    },
    {
      "start": 1078.31,
      "end": 1081.25,
      "text": "we don't have to do it standing here do we spade"
    },
    {
      "start": 1081.9,
      "end": 1084.7,
      "text": "stood in the doorway and said you can't come in"
    },
    {
      "start": 1084.94,
      "end": 1089.02,
      "text": "his tone was very slightly apologetic tom's thick"
    },
    {
      "start": 1089.02,
      "end": 1092.32,
      "text": "featured face even in height with spades took on"
    },
    {
      "start": 1092.32,
      "end": 1094.54,
      "text": "an expression of friendly scorn that there"
    },
    {
      "start": 1094.54,
      "end": 1096.6,
      "text": "was a bright gleam in his small shrewd eyes"
    },
    {
      "start": 1097.14,
      "end": 1100.36,
      "text": "what the hell sam he protested and put a big hand"
    },
    {
      "start": 1100.36,
      "end": 1103.98,
      "text": "playfully on spade's chest spade leaned against"
    },
    {
      "start": 1104.08,
      "end": 1106.38,
      "text": "the pushing hand grinned wolfishly and asked"
    },
    {
      "start": 1107.04,
      "end": 1108.38,
      "text": "going to strong arm me tom"
    },
    {
      "start": 1109.58,
      "end": 1110.24,
      "text": "tom grumbled",
      "para_break": true
    },
    {
      "start": 1110.88,
      "end": 1112.1,
      "text": "oh for god's sake"
    },
    {
      "start": 1112.36,
      "end": 1115.64,
      "text": "and took his hand away dundee clicked his teeth"
    },
    {
      "start": 1115.64,
      "end": 1118.79,
      "text": "together and said through them let us in spade's"
    },
    {
      "start": 1119.66,
      "end": 1121.1,
      "text": "lip twitched over his eye tooth",
      "para_break": true
    },
    {
      "start": 1121.66,
      "end": 1122.0,
      "text": "he said"
    },
    {
      "start": 1122.62,
      "end": 1123.48,
      "text": "you're not coming in"
    },
    {
      "start": 1124.24,
      "end": 1125.4,
      "text": "what do you want to do about it"
    },
    {
      "start": 1125.54,
      "end": 1126.36,
      "text": "Try to get in?"
    },
    {
      "start": 1126.53,
      "end": 1128.24,
      "text": "Or do your talking here?"
    },
    {
      "start": 1128.5,
      "end": 1129.52,
      "text": "Or go to hell?"
    },
    {
      "start": 1130.656,
      "end": 1131.56,
      "text": "Tom groaned.",
      "para_break": true
    },
    {
      "start": 1131.58,
      "end": 1131.68,
      "text": "Dundee,"
    },
    {
      "start": 1133.04,
      "end": 1133.96,
      "text": "still speaking through",
      "para_break": true
    },
    {
      "start": 1133.96,
      "end": 1134.32,
      "text": "his teeth,"
    },
    {
      "start": 1134.42,
      "end": 1134.72,
      "text": "said,"
    },
    {
      "start": 1135.7,
      "end": 1137.44,
      "text": "It'd pay you to play along with us a little,",
      "para_break": true
    },
    {
      "start": 1137.54,
      "end": 1137.84,
      "text": "Spade."
    },
    {
      "start": 1138.02,
      "end": 1139.48,
      "text": "You've got a way with this,"
    },
    {
      "start": 1139.56,
      "end": 1140.86,
      "text": "and you've got a way with that,"
    },
    {
      "start": 1141.16,
      "end": 1142.9,
      "text": "but you can't keep it up forever."
    },
    {
      "start": 1144.16,
      "end": 1145.48,
      "text": "Stop me when you can,",
      "para_break": true
    },
    {
      "start": 1146.176,
      "end": 1147.06,
      "text": "Spade replied arrogantly."
    },
    {
      "start": 1148.416,
      "end": 1149.08,
      "text": "That's what I'll do.",
      "para_break": true
    },
    {
      "start": 1149.47,
      "end": 1151.54,
      "text": "Dundee put his hands behind him and thrust his"
    },
    {
      "start": 1151.68,
      "end": 1153.67,
      "text": "hard face up toward the private detectives."
    },
    {
      "start": 1154.56,
      "end": 1156.3,
      "text": "There's talk going around that you and Archer's",
      "para_break": true
    },
    {
      "start": 1156.36,
      "end": 1157.4,
      "text": "wife were cheating on him."
    },
    {
      "start": 1158.432,
      "end": 1158.98,
      "text": "Spade laughed.",
      "para_break": true
    },
    {
      "start": 1159.7,
      "end": 1161.52,
      "text": "That sounds like something you thought up yourself."
    },
    {
      "start": 1162.86,
      "end": 1164.2,
      "text": "Then there's not anything to it?",
      "para_break": true
    },
    {
      "start": 1165.184,
      "end": 1165.68,
      "text": "Not anything.",
      "para_break": true
    },
    {
      "start": 1166.94,
      "end": 1167.48,
      "text": "The talk is,",
      "para_break": true
    },
    {
      "start": 1167.6,
      "end": 1168.14,
      "text": "Dundee said,"
    },
    {
      "start": 1168.36,
      "end": 1169.72,
      "text": "that she tried to get"
    },
    {
      "start": 1169.72,
      "end": 1172.68,
      "text": "a divorce out of him so she could put in with you,"
    },
    {
      "start": 1173.36,
      "end": 1174.48,
      "text": "but he wouldn't give it to her."
    },
    {
      "start": 1174.64,
      "end": 1175.74,
      "text": "Anything to that?"
    },
    {
      "start": 1176.3,
      "end": 1177.14,
      "text": "No."
    },
    {
      "start": 1178.6,
      "end": 1179.24,
      "text": "There's even talk,",
      "para_break": true
    },
    {
      "start": 1179.84,
      "end": 1180.79,
      "text": "Dundee went on stolidly,"
    },
    {
      "start": 1181.46,
      "end": 1183.56,
      "text": "that that's why he was put on the spot."
    },
    {
      "start": 1184.736,
      "end": 1186.46,
      "text": "Spade seemed mildly amused.",
      "para_break": true
    },
    {
      "start": 1187.2,
      "end": 1187.86,
      "text": "Don't be a hog,"
    },
    {
      "start": 1188.08,
      "end": 1188.46,
      "text": "he said."
    },
    {
      "start": 1189.16,
      "end": 1192.16,
      "text": "You oughtn't try to pin more than one murder at a time on me."
    },
    {
      "start": 1192.82,
      "end": 1196.28,
      "text": "Your first idea that I knocked Thursby off because he'd killed Miles"
    },
    {
      "start": 1196.54,
      "end": 1198.88,
      "text": "falls apart if you blame me for killing Miles,"
    },
    {
      "start": 1198.98,
      "end": 1199.16,
      "text": "too."
    },
    {
      "start": 1200.22,
      "end": 1201.86,
      "text": "You haven't heard me say you killed anybody,",
      "para_break": true
    },
    {
      "start": 1202.1,
      "end": 1202.76,
      "text": "Dundee replied."
    },
    {
      "start": 1203.552,
      "end": 1205.38,
      "text": "You're the one that keeps bringing that up.",
      "para_break": true
    },
    {
      "start": 1205.54,
      "end": 1207.16,
      "text": "But suppose I did."
    },
    {
      "start": 1207.82,
      "end": 1209.02,
      "text": "You could have blipped them both."
    }
  ]
}
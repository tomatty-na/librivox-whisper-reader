{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-06",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_06_hammett_128kb.mp3",
  "chapter_title": "The Undersized Shadow",
  "reader_name": "NLizer",
  "page_num": 3,
  "page_total": 4,
  "page_start_sec": 505.02,
  "page_end_sec": 746.98,
  "para_gap_threshold": 0.576,
  "segments": [
    {
      "start": 505.02,
      "end": 505.54,
      "text": "About what?",
      "para_break": true
    },
    {
      "start": 506.56,
      "end": 507.22,
      "text": "She hesitated.",
      "para_break": true
    },
    {
      "start": 508.06,
      "end": 508.5,
      "text": "About me.",
      "para_break": true
    },
    {
      "start": 508.8,
      "end": 509.82,
      "text": "Nothing."
    },
    {
      "start": 510.01,
      "end": 512.26,
      "text": "Spade turned to hold his lighter under the end"
    },
    {
      "start": 512.26,
      "end": 512.83,
      "text": "of her cigarette."
    },
    {
      "start": 513.16,
      "end": 515.72,
      "text": "His eyes were shiny and a wooden Satan's face."
    },
    {
      "start": 516.2,
      "end": 516.8,
      "text": "Well,"
    },
    {
      "start": 516.96,
      "end": 517.82,
      "text": "what did he say?"
    },
    {
      "start": 517.96,
      "end": 518.72,
      "text": "She asked"
    },
    {
      "start": 518.9,
      "end": 520.72,
      "text": "with a half playful petulance."
    },
    {
      "start": 521.13,
      "end": 524.1,
      "text": "He offered me $5,000 for the black bird."
    },
    {
      "start": 525.22,
      "end": 525.6,
      "text": "She started.",
      "para_break": true
    },
    {
      "start": 525.96,
      "end": 527.96,
      "text": "Her teeth tore the end of her cigarette,"
    },
    {
      "start": 528.4,
      "end": 528.85,
      "text": "and her eyes,"
    },
    {
      "start": 529.12,
      "end": 529.74,
      "text": "after a swift,"
    },
    {
      "start": 529.86,
      "end": 530.7,
      "text": "alarmed glance"
    },
    {
      "start": 531.24,
      "end": 531.68,
      "text": "at Spade,"
    },
    {
      "start": 531.78,
      "end": 532.62,
      "text": "turned away from him."
    },
    {
      "start": 533.86,
      "end": 536.72,
      "text": "You're not going to go around poking at the fire and straightening",
      "para_break": true
    },
    {
      "start": 536.76,
      "end": 537.38,
      "text": "up the room again,"
    },
    {
      "start": 537.44,
      "end": 537.78,
      "text": "are you?"
    },
    {
      "start": 537.88,
      "end": 538.9,
      "text": "he asked lazily."
    },
    {
      "start": 540.02,
      "end": 540.8,
      "text": "She laughed a clear,",
      "para_break": true
    },
    {
      "start": 540.86,
      "end": 541.42,
      "text": "merry laugh,"
    },
    {
      "start": 542.112,
      "end": 542.48,
      "text": "dropped the",
      "para_break": true
    },
    {
      "start": 542.52,
      "end": 543.94,
      "text": "mangled cigarette into a tray,"
    },
    {
      "start": 544.06,
      "end": 545.44,
      "text": "and looked at him with clear,"
    },
    {
      "start": 545.48,
      "end": 546.18,
      "text": "merry eyes."
    },
    {
      "start": 547.02,
      "end": 547.58,
      "text": "I won't,",
      "para_break": true
    },
    {
      "start": 547.58,
      "end": 548.2,
      "text": "she promised."
    },
    {
      "start": 548.57,
      "end": 549.84,
      "text": "and what did you say?"
    },
    {
      "start": 551.08,
      "end": 552.78,
      "text": "$5,000 is a lot of money.",
      "para_break": true
    },
    {
      "start": 553.88,
      "end": 554.4,
      "text": "She smiled,",
      "para_break": true
    },
    {
      "start": 555.16,
      "end": 555.52,
      "text": "but when,",
      "para_break": true
    },
    {
      "start": 555.58,
      "end": 556.64,
      "text": "instead of smiling,"
    },
    {
      "start": 556.74,
      "end": 558.1,
      "text": "he looked gravely at her,"
    },
    {
      "start": 558.2,
      "end": 559.64,
      "text": "her smile became faint,"
    },
    {
      "start": 559.82,
      "end": 560.34,
      "text": "confused,"
    },
    {
      "start": 560.58,
      "end": 561.64,
      "text": "and presently vanished."
    },
    {
      "start": 562.44,
      "end": 563.48,
      "text": "In its place came a hurt,",
      "para_break": true
    },
    {
      "start": 563.56,
      "end": 564.28,
      "text": "bewildered look."
    },
    {
      "start": 565.216,
      "end": 567.06,
      "text": "Surely you're not really considering it,",
      "para_break": true
    },
    {
      "start": 567.14,
      "end": 567.56,
      "text": "she said."
    },
    {
      "start": 568.54,
      "end": 568.88,
      "text": "Why not?",
      "para_break": true
    },
    {
      "start": 569.64,
      "end": 571.38,
      "text": "$5,000 is a lot of money.",
      "para_break": true
    },
    {
      "start": 571.58,
      "end": 571.68,
      "text": "But,"
    },
    {
      "start": 572.82,
      "end": 573.04,
      "text": "Mr.",
      "para_break": true
    },
    {
      "start": 573.16,
      "end": 573.42,
      "text": "Spade,"
    },
    {
      "start": 573.44,
      "end": 574.44,
      "text": "you promised to help me."
    },
    {
      "start": 574.62,
      "end": 575.44,
      "text": "Her hands were"
    },
    {
      "start": 575.58,
      "end": 576.01,
      "text": "on his arm."
    },
    {
      "start": 576.2,
      "end": 577.6,
      "text": "I trusted you."
    },
    {
      "start": 577.7,
      "end": 578.62,
      "text": "You can't."
    },
    {
      "start": 579.28,
      "end": 579.92,
      "text": "She broke off,",
      "para_break": true
    },
    {
      "start": 580.26,
      "end": 581.74,
      "text": "took her hands from his sleeve and worked"
    },
    {
      "start": 581.74,
      "end": 582.2,
      "text": "them together."
    },
    {
      "start": 583.52,
      "end": 585.54,
      "text": "Spade smiled gently into her troubled eyes.",
      "para_break": true
    },
    {
      "start": 586.432,
      "end": 587.54,
      "text": "Don't let's try to figure out",
      "para_break": true
    },
    {
      "start": 587.54,
      "end": 588.8,
      "text": "how much you've trusted me,"
    },
    {
      "start": 588.86,
      "end": 589.2,
      "text": "he said."
    },
    {
      "start": 589.42,
      "end": 590.88,
      "text": "I promised to help you,"
    },
    {
      "start": 590.92,
      "end": 591.1,
      "text": "sure,"
    },
    {
      "start": 591.76,
      "end": 592.7,
      "text": "but you didn't say anything",
      "para_break": true
    },
    {
      "start": 592.92,
      "end": 594.26,
      "text": "about any black birds."
    },
    {
      "start": 594.83,
      "end": 598.86,
      "text": "But you must have known or you wouldn't have mentioned it to me."
    },
    {
      "start": 599.52,
      "end": 601.02,
      "text": "you do know now",
      "para_break": true
    },
    {
      "start": 601.58,
      "end": 603.74,
      "text": "you won't you can't treat me like"
    },
    {
      "start": 603.74,
      "end": 606.32,
      "text": "that her eyes were cobalt blue prayers"
    },
    {
      "start": 606.87,
      "end": 609.7,
      "text": "five thousand dollars is he said for the third"
    },
    {
      "start": 609.7,
      "end": 613.24,
      "text": "time a lot of money she lifted her shoulders"
    },
    {
      "start": 613.36,
      "end": 616.18,
      "text": "and hands and let them fall in a gesture that accepted defeat"
    },
    {
      "start": 617.12,
      "end": 618.74,
      "text": "it is she agreed in a small",
      "para_break": true
    },
    {
      "start": 618.82,
      "end": 619.42,
      "text": "dull voice"
    },
    {
      "start": 620.06,
      "end": 622.12,
      "text": "it is far more than i could ever offer you",
      "para_break": true
    },
    {
      "start": 622.4,
      "end": 625.64,
      "text": "if i must bid for your loyalty spade laughed"
    },
    {
      "start": 625.94,
      "end": 628.0,
      "text": "His laughter was brief and somewhat bitter."
    },
    {
      "start": 628.48,
      "end": 629.46,
      "text": "That is good,"
    },
    {
      "start": 629.58,
      "end": 629.9,
      "text": "he said,"
    },
    {
      "start": 630.12,
      "end": 630.88,
      "text": "coming from you."
    },
    {
      "start": 631.76,
      "end": 633.38,
      "text": "What have you given me besides money?",
      "para_break": true
    },
    {
      "start": 634.02,
      "end": 635.68,
      "text": "Have you given me any of your confidence,",
      "para_break": true
    },
    {
      "start": 636.0,
      "end": 636.7,
      "text": "any of the truth,"
    },
    {
      "start": 637.28,
      "end": 638.36,
      "text": "any help in helping you?",
      "para_break": true
    },
    {
      "start": 639.072,
      "end": 641.9,
      "text": "Haven't you tried to buy my loyalty with money and nothing else?",
      "para_break": true
    },
    {
      "start": 642.48,
      "end": 642.68,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 642.86,
      "end": 643.92,
      "text": "if I'm peddling it,"
    },
    {
      "start": 644.4,
      "end": 646.44,
      "text": "why shouldn't I let it go to the highest bidder?"
    },
    {
      "start": 647.54,
      "end": 649.02,
      "text": "I've given you all the money I have.",
      "para_break": true
    },
    {
      "start": 649.22,
      "end": 651.44,
      "text": "Tears glistened in her white-ringed eyes."
    },
    {
      "start": 651.9,
      "end": 652.96,
      "text": "Her voice was hoarse,"
    },
    {
      "start": 653.12,
      "end": 653.72,
      "text": "vibrant."
    },
    {
      "start": 655.08,
      "end": 656.34,
      "text": "I've thrown myself on your mercy,",
      "para_break": true
    },
    {
      "start": 656.46,
      "end": 658.36,
      "text": "told you that without your help I'm"
    },
    {
      "start": 658.38,
      "end": 658.96,
      "text": "utterly lost."
    },
    {
      "start": 659.66,
      "end": 660.42,
      "text": "What else is there?",
      "para_break": true
    },
    {
      "start": 661.34,
      "end": 664.67,
      "text": "She suddenly moved close to him on the settee and cried angrily.",
      "para_break": true
    },
    {
      "start": 665.34,
      "end": 666.74,
      "text": "Can I buy you with my body?",
      "para_break": true
    },
    {
      "start": 667.88,
      "end": 669.4,
      "text": "Their faces were a few inches apart.",
      "para_break": true
    },
    {
      "start": 670.208,
      "end": 671.28,
      "text": "Spade took her face between",
      "para_break": true
    },
    {
      "start": 671.28,
      "end": 674.17,
      "text": "his hands and he kissed her mouth roughly and contemptuously."
    },
    {
      "start": 675.44,
      "end": 676.52,
      "text": "Then he sat back and said,",
      "para_break": true
    },
    {
      "start": 677.16,
      "end": 677.84,
      "text": "I'll think it over.",
      "para_break": true
    },
    {
      "start": 678.2,
      "end": 680.1,
      "text": "His face was hard and furious."
    },
    {
      "start": 680.48,
      "end": 683.62,
      "text": "She sat still holding her numb face where his"
    },
    {
      "start": 683.62,
      "end": 684.52,
      "text": "hands had left it."
    },
    {
      "start": 684.8,
      "end": 688.56,
      "text": "He stood up and said Christ there's no sense to this."
    },
    {
      "start": 688.82,
      "end": 689.94,
      "text": "He took two steps"
    },
    {
      "start": 690.04,
      "end": 692.5,
      "text": "toward the fireplace and stopped glowering at"
    },
    {
      "start": 692.5,
      "end": 694.46,
      "text": "the burning logs grinding his teeth together."
    },
    {
      "start": 695.36,
      "end": 696.16,
      "text": "She did not move.",
      "para_break": true
    },
    {
      "start": 696.69,
      "end": 698.22,
      "text": "He turned to face her."
    },
    {
      "start": 698.3,
      "end": 701.12,
      "text": "The two vertical lines above his nose were deep clefts"
    },
    {
      "start": 701.14,
      "end": 701.98,
      "text": "between red whales."
    },
    {
      "start": 702.38,
      "end": 704.4,
      "text": "I don't give a damn about your honesty"
    },
    {
      "start": 704.4,
      "end": 705.92,
      "text": "he told her trying to make himself"
    },
    {
      "start": 706.14,
      "end": 706.68,
      "text": "speak calmly."
    },
    {
      "start": 707.36,
      "end": 708.98,
      "text": "I don't care what kind of tricks you're up to,",
      "para_break": true
    },
    {
      "start": 709.44,
      "end": 710.34,
      "text": "what your secrets are,"
    },
    {
      "start": 710.88,
      "end": 711.12,
      "text": "but I've"
    },
    {
      "start": 711.12,
      "end": 714.22,
      "text": "got to have something to show that you know what you're doing."
    },
    {
      "start": 715.28,
      "end": 715.88,
      "text": "I do know.",
      "para_break": true
    },
    {
      "start": 715.96,
      "end": 717.22,
      "text": "Please believe that I do"
    },
    {
      "start": 717.42,
      "end": 720.98,
      "text": "and that it's all for the best and show me,"
    },
    {
      "start": 721.14,
      "end": 721.8,
      "text": "he ordered."
    },
    {
      "start": 722.08,
      "end": 723.34,
      "text": "I'm willing to help you."
    },
    {
      "start": 723.48,
      "end": 724.1,
      "text": "I've done what"
    },
    {
      "start": 724.1,
      "end": 724.88,
      "text": "I could so far."
    },
    {
      "start": 725.12,
      "end": 725.92,
      "text": "If necessary,"
    },
    {
      "start": 726.1,
      "end": 727.35,
      "text": "I'll go ahead blindfolded,"
    },
    {
      "start": 727.9,
      "end": 729.32,
      "text": "but I can't do it without more"
    },
    {
      "start": 729.4,
      "end": 730.94,
      "text": "confidence in you than I've got now."
    },
    {
      "start": 731.88,
      "end": 734.26,
      "text": "You've got to convince me that you know what it's all about,",
      "para_break": true
    },
    {
      "start": 734.72,
      "end": 737.9,
      "text": "that you're not simply fiddling around by guess and by God,"
    },
    {
      "start": 738.37,
      "end": 739.92,
      "text": "hoping it'll come out all right"
    },
    {
      "start": 740.06,
      "end": 740.98,
      "text": "somehow in the end."
    },
    {
      "start": 742.08,
      "end": 743.72,
      "text": "Can't you trust me just a little longer?",
      "para_break": true
    },
    {
      "start": 744.62,
      "end": 745.5,
      "text": "How much is a little,",
      "para_break": true
    },
    {
      "start": 745.66,
      "end": 746.04,
      "text": "and what"
    },
    {
      "start": 746.04,
      "end": 746.98,
      "text": "are you waiting for?"
    }
  ]
}
{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-06",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_06_hammett.mp3",
  "chapter_title": "The Undersized Shadow",
  "reader_name": "NLizer",
  "page_num": 4,
  "page_total": 4,
  "page_start_sec": 748.1,
  "page_end_sec": 944.32,
  "para_gap_threshold": 0.576,
  "segments": [
    {
      "start": 748.1,
      "end": 749.38,
      "text": "She bit her lip and looked down.",
      "para_break": true
    },
    {
      "start": 750.04,
      "end": 751.46,
      "text": "I must talk to Joel Cairo,",
      "para_break": true
    },
    {
      "start": 751.6,
      "end": 752.28,
      "text": "she said almost"
    },
    {
      "start": 752.46,
      "end": 752.96,
      "text": "inaudibly."
    },
    {
      "start": 753.48,
      "end": 754.66,
      "text": "You can see him tonight,"
    },
    {
      "start": 754.9,
      "end": 755.4,
      "text": "Spade said,"
    },
    {
      "start": 755.58,
      "end": 756.48,
      "text": "looking at his watch."
    },
    {
      "start": 757.12,
      "end": 758.18,
      "text": "His show will be out soon.",
      "para_break": true
    },
    {
      "start": 758.56,
      "end": 760.52,
      "text": "We can get him on the phone at his hotel."
    },
    {
      "start": 761.22,
      "end": 762.72,
      "text": "She raised her eyes,",
      "para_break": true
    },
    {
      "start": 762.74,
      "end": 763.3,
      "text": "alarmed."
    },
    {
      "start": 763.72,
      "end": 764.68,
      "text": "But he can't come here."
    },
    {
      "start": 765.06,
      "end": 766.5,
      "text": "I can't let him know where I am."
    },
    {
      "start": 766.64,
      "end": 767.1,
      "text": "I'm afraid."
    },
    {
      "start": 768.24,
      "end": 768.64,
      "text": "My place,",
      "para_break": true
    },
    {
      "start": 768.9,
      "end": 769.62,
      "text": "Spade suggested."
    },
    {
      "start": 770.72,
      "end": 771.38,
      "text": "She hesitated,",
      "para_break": true
    },
    {
      "start": 771.48,
      "end": 772.44,
      "text": "working her lips together,"
    },
    {
      "start": 772.56,
      "end": 773.0,
      "text": "then asked,"
    },
    {
      "start": 773.4,
      "end": 774.58,
      "text": "Do you think he'd go there?"
    },
    {
      "start": 775.456,
      "end": 776.28,
      "text": "Spade nodded.",
      "para_break": true
    },
    {
      "start": 777.06,
      "end": 777.36,
      "text": "All right,",
      "para_break": true
    },
    {
      "start": 777.48,
      "end": 778.38,
      "text": "she exclaimed,"
    },
    {
      "start": 778.48,
      "end": 779.16,
      "text": "jumping up,"
    },
    {
      "start": 779.18,
      "end": 780.18,
      "text": "her eyes large and bright."
    },
    {
      "start": 780.84,
      "end": 781.48,
      "text": "Shall we go now?",
      "para_break": true
    },
    {
      "start": 782.68,
      "end": 783.96,
      "text": "She went into the next room.",
      "para_break": true
    },
    {
      "start": 784.256,
      "end": 785.8,
      "text": "Spade went to the table in the corner"
    },
    {
      "start": 785.8,
      "end": 787.78,
      "text": "and silently pulled the drawer out."
    },
    {
      "start": 788.44,
      "end": 790.06,
      "text": "The drawer held two packs of playing cards,",
      "para_break": true
    },
    {
      "start": 790.24,
      "end": 791.7,
      "text": "a pad of scorecards for Bridge,"
    },
    {
      "start": 791.96,
      "end": 792.88,
      "text": "a brass screw,"
    },
    {
      "start": 793.14,
      "end": 794.12,
      "text": "a piece of red string,"
    },
    {
      "start": 794.8,
      "end": 795.6,
      "text": "and a gold pencil.",
      "para_break": true
    },
    {
      "start": 796.36,
      "end": 797.94,
      "text": "He had shut the drawer and was",
      "para_break": true
    },
    {
      "start": 797.94,
      "end": 799.64,
      "text": "lighting a cigarette when she returned,"
    },
    {
      "start": 799.92,
      "end": 802.1,
      "text": "wearing a small dark hat and a gray"
    },
    {
      "start": 802.1,
      "end": 804.32,
      "text": "kidskin coat carrying his hat and coat."
    },
    {
      "start": 805.46,
      "end": 807.84,
      "text": "Their taxicab drew up behind a dark sedan that",
      "para_break": true
    },
    {
      "start": 807.84,
      "end": 809.76,
      "text": "stood directly in front of Spade's street door."
    },
    {
      "start": 810.816,
      "end": 812.24,
      "text": "Iva Archer was alone in the sedan,",
      "para_break": true
    },
    {
      "start": 812.52,
      "end": 813.6,
      "text": "sitting at the wheel."
    },
    {
      "start": 814.496,
      "end": 816.0,
      "text": "Spade lifted his hat to her and went",
      "para_break": true
    },
    {
      "start": 816.0,
      "end": 817.43,
      "text": "indoors with Bridget O'Shaughnessy."
    },
    {
      "start": 817.64,
      "end": 818.72,
      "text": "In the lobby,"
    },
    {
      "start": 818.8,
      "end": 820.86,
      "text": "he halted beside one of the benches and asked,"
    },
    {
      "start": 821.2,
      "end": 822.72,
      "text": "Do you mind waiting here a moment?"
    },
    {
      "start": 823.14,
      "end": 823.74,
      "text": "I won't be long."
    },
    {
      "start": 824.88,
      "end": 825.78,
      "text": "That's perfectly all right,",
      "para_break": true
    },
    {
      "start": 825.96,
      "end": 827.12,
      "text": "Bridget O'Shaughnessy said,"
    },
    {
      "start": 827.22,
      "end": 827.82,
      "text": "sitting down."
    },
    {
      "start": 828.4,
      "end": 829.04,
      "text": "You needn't hurry.",
      "para_break": true
    },
    {
      "start": 830.272,
      "end": 831.28,
      "text": "Spade went out to the sedan.",
      "para_break": true
    },
    {
      "start": 831.92,
      "end": 833.58,
      "text": "When he had to open the sedan's door,",
      "para_break": true
    },
    {
      "start": 833.7,
      "end": 834.5,
      "text": "Iva spoke quickly."
    },
    {
      "start": 835.232,
      "end": 836.02,
      "text": "I've got to talk to you,",
      "para_break": true
    },
    {
      "start": 836.08,
      "end": 836.28,
      "text": "Sam."
    },
    {
      "start": 836.64,
      "end": 837.3,
      "text": "Can I come in?"
    },
    {
      "start": 837.9,
      "end": 839.5,
      "text": "Her face was pale and nervous.",
      "para_break": true
    },
    {
      "start": 840.448,
      "end": 840.82,
      "text": "Not now.",
      "para_break": true
    },
    {
      "start": 841.984,
      "end": 843.82,
      "text": "Iva clicked her teeth together and asked sharply,",
      "para_break": true
    },
    {
      "start": 844.24,
      "end": 844.9,
      "text": "Who is she?"
    },
    {
      "start": 846.18,
      "end": 846.92,
      "text": "I've only a minute,",
      "para_break": true
    },
    {
      "start": 847.02,
      "end": 847.32,
      "text": "Iva,"
    },
    {
      "start": 847.44,
      "end": 848.38,
      "text": "Spade said patiently."
    },
    {
      "start": 848.66,
      "end": 849.26,
      "text": "What is it?"
    },
    {
      "start": 850.2,
      "end": 850.7,
      "text": "Who is she?",
      "para_break": true
    },
    {
      "start": 851.1,
      "end": 851.52,
      "text": "She repeated,"
    },
    {
      "start": 851.78,
      "end": 852.22,
      "text": "nodding at"
    },
    {
      "start": 852.22,
      "end": 852.78,
      "text": "the street door."
    },
    {
      "start": 853.46,
      "end": 855.46,
      "text": "He looked away from her down the street",
      "para_break": true
    },
    {
      "start": 855.46,
      "end": 857.38,
      "text": "in front of a garage on the next corner,"
    },
    {
      "start": 857.98,
      "end": 861.2,
      "text": "an undersized youth of 20 or 21 in neat gray cap",
      "para_break": true
    },
    {
      "start": 861.2,
      "end": 864.04,
      "text": "and overcoat loafed with his back against a wall."
    },
    {
      "start": 865.056,
      "end": 867.74,
      "text": "Spade frowned and returned his gaze to Iva's insistent face.",
      "para_break": true
    },
    {
      "start": 868.56,
      "end": 869.36,
      "text": "What is the matter?",
      "para_break": true
    },
    {
      "start": 869.48,
      "end": 869.98,
      "text": "He asked."
    },
    {
      "start": 870.55,
      "end": 871.9,
      "text": "Has anything happened?"
    },
    {
      "start": 872.46,
      "end": 874.8,
      "text": "You oughtn't to be here at this time of night."
    },
    {
      "start": 875.82,
      "end": 876.96,
      "text": "I'm beginning to believe that,",
      "para_break": true
    },
    {
      "start": 877.08,
      "end": 877.58,
      "text": "she complained."
    },
    {
      "start": 877.98,
      "end": 880.62,
      "text": "You told me I oughtn't to come to the office,"
    },
    {
      "start": 881.06,
      "end": 882.52,
      "text": "and now I oughtn't to come here."
    },
    {
      "start": 883.2,
      "end": 885.34,
      "text": "Do you mean I oughtn't to chase after you?",
      "para_break": true
    },
    {
      "start": 885.46,
      "end": 886.56,
      "text": "If that's what you mean,"
    },
    {
      "start": 886.6,
      "end": 887.74,
      "text": "why don't you say it right"
    },
    {
      "start": 887.86,
      "end": 888.06,
      "text": "out?"
    },
    {
      "start": 888.26,
      "end": 888.36,
      "text": "Now,"
    },
    {
      "start": 889.22,
      "end": 889.68,
      "text": "Iva,",
      "para_break": true
    },
    {
      "start": 889.76,
      "end": 891.64,
      "text": "you've got no right to take that attitude."
    },
    {
      "start": 892.02,
      "end": 893.64,
      "text": "I know I haven't."
    },
    {
      "start": 893.64,
      "end": 894.76,
      "text": "I haven't any rights"
    },
    {
      "start": 894.84,
      "end": 895.12,
      "text": "at all,"
    },
    {
      "start": 895.14,
      "end": 895.56,
      "text": "it seems,"
    },
    {
      "start": 895.68,
      "end": 896.44,
      "text": "where you're concerned."
    },
    {
      "start": 897.28,
      "end": 898.04,
      "text": "I thought I did.",
      "para_break": true
    },
    {
      "start": 898.78,
      "end": 899.82,
      "text": "I thought you're pretending to",
      "para_break": true
    },
    {
      "start": 899.98,
      "end": 900.78,
      "text": "love me gave me."
    },
    {
      "start": 901.696,
      "end": 902.5,
      "text": "Spade said wearily,",
      "para_break": true
    },
    {
      "start": 903.02,
      "end": 905.3,
      "text": "this is no time to be arguing about that,"
    },
    {
      "start": 905.4,
      "end": 905.78,
      "text": "precious."
    },
    {
      "start": 907.02,
      "end": 909.02,
      "text": "What was it you wanted to see me about?",
      "para_break": true
    },
    {
      "start": 909.64,
      "end": 911.06,
      "text": "I can't talk to you here,",
      "para_break": true
    },
    {
      "start": 911.2,
      "end": 911.38,
      "text": "Sam."
    },
    {
      "start": 911.5,
      "end": 912.42,
      "text": "Can't I come in?"
    },
    {
      "start": 913.34,
      "end": 913.82,
      "text": "Not now.",
      "para_break": true
    },
    {
      "start": 915.0,
      "end": 915.82,
      "text": "Why can't I?",
      "para_break": true
    },
    {
      "start": 916.992,
      "end": 917.72,
      "text": "Spade said nothing.",
      "para_break": true
    },
    {
      "start": 918.35,
      "end": 920.0,
      "text": "She made a thin line of her mouth,",
      "para_break": true
    },
    {
      "start": 920.04,
      "end": 921.0,
      "text": "squirmed around"
    },
    {
      "start": 921.16,
      "end": 923.52,
      "text": "straight behind the wheel and started the sedan's engine,"
    },
    {
      "start": 923.68,
      "end": 925.12,
      "text": "staring angrily ahead."
    },
    {
      "start": 925.99,
      "end": 926.62,
      "text": "When the sedan",
      "para_break": true
    },
    {
      "start": 926.84,
      "end": 927.38,
      "text": "began to move,"
    },
    {
      "start": 927.44,
      "end": 927.96,
      "text": "Spade said,"
    },
    {
      "start": 928.12,
      "end": 928.72,
      "text": "Good night,"
    },
    {
      "start": 928.78,
      "end": 929.12,
      "text": "Iva,"
    },
    {
      "start": 929.22,
      "end": 930.32,
      "text": "shut the door,"
    },
    {
      "start": 930.4,
      "end": 932.44,
      "text": "and stood at the curb with his hat in"
    },
    {
      "start": 932.44,
      "end": 934.66,
      "text": "his hand until it had been driven away."
    },
    {
      "start": 935.64,
      "end": 936.84,
      "text": "Then he went indoors again.",
      "para_break": true
    },
    {
      "start": 937.92,
      "end": 939.02,
      "text": "Bridget O'Shaughnessy rose",
      "para_break": true
    },
    {
      "start": 939.08,
      "end": 940.64,
      "text": "smiling cheerfully from the bench,"
    },
    {
      "start": 940.96,
      "end": 942.04,
      "text": "and they went up to his apartment."
    },
    {
      "start": 943.392,
      "end": 944.32,
      "text": "End of chapter six.",
      "para_break": true
    }
  ]
}
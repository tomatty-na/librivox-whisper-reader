{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-16",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_16_hammett.mp3",
  "chapter_title": "The Third Murder",
  "reader_name": "NLizer",
  "page_num": 1,
  "page_total": 5,
  "page_start_sec": 9.6,
  "page_end_sec": 276.2,
  "para_gap_threshold": 0.545,
  "segments": [
    {
      "start": 9.6,
      "end": 10.3,
      "text": "CHAPTER XVI."
    },
    {
      "start": 10.656,
      "end": 12.0,
      "text": "SPADE WENT INTO THE HOTEL"
    },
    {
      "start": 12.0,
      "end": 13.96,
      "text": "SUTTER AND TELEPHONED THE ALEXANDRIA."
    },
    {
      "start": 14.816,
      "end": 15.72,
      "text": "GUTMAN WAS NOT IN.",
      "para_break": true
    },
    {
      "start": 16.64,
      "end": 17.54,
      "text": "NO MEMBER OF GUTMAN'S"
    },
    {
      "start": 17.54,
      "end": 18.3,
      "text": "PARTY WAS IN."
    },
    {
      "start": 19.168,
      "end": 20.62,
      "text": "SPADE TELEPHONED THE BELVEDERE."
    },
    {
      "start": 21.312,
      "end": 22.56,
      "text": "TYRO WAS NOT IN.",
      "para_break": true
    },
    {
      "start": 22.68,
      "end": 24.4,
      "text": "HAD NOT BEEN IN THAT DAY."
    },
    {
      "start": 25.376,
      "end": 26.9,
      "text": "SPADE WENT TO HIS OFFICE."
    },
    {
      "start": 27.37,
      "end": 28.44,
      "text": "A swart,"
    },
    {
      "start": 28.58,
      "end": 32.22,
      "text": "greasy man in notable clothes was waiting in the outer room."
    },
    {
      "start": 33.12,
      "end": 33.64,
      "text": "Effie Perrine,",
      "para_break": true
    },
    {
      "start": 34.02,
      "end": 35.06,
      "text": "indicating the swart man,"
    },
    {
      "start": 35.24,
      "end": 35.52,
      "text": "said,"
    },
    {
      "start": 35.72,
      "end": 38.04,
      "text": "This gentleman wishes to see you,"
    },
    {
      "start": 38.12,
      "end": 38.3,
      "text": "Mr."
    },
    {
      "start": 38.48,
      "end": 38.84,
      "text": "Spade."
    },
    {
      "start": 39.936,
      "end": 42.2,
      "text": "Spade smiled and bowed and opened the inner door.",
      "para_break": true
    },
    {
      "start": 42.98,
      "end": 43.26,
      "text": "Come in.",
      "para_break": true
    },
    {
      "start": 44.44,
      "end": 45.6,
      "text": "Before following the man in,",
      "para_break": true
    },
    {
      "start": 45.82,
      "end": 46.96,
      "text": "Spade asked Effie Perrine,"
    },
    {
      "start": 47.22,
      "end": 49.04,
      "text": "Any news on that other matter?"
    },
    {
      "start": 49.4,
      "end": 50.18,
      "text": "No,"
    },
    {
      "start": 50.18,
      "end": 50.4,
      "text": "sir."
    },
    {
      "start": 50.77,
      "end": 53.52,
      "text": "The swart man was the proprietor"
    },
    {
      "start": 53.62,
      "end": 55.6,
      "text": "of a moving picture theater in Market Street."
    },
    {
      "start": 56.42,
      "end": 58.6,
      "text": "He suspected one of his cashiers and a doorman",
      "para_break": true
    },
    {
      "start": 58.84,
      "end": 60.3,
      "text": "of colluding to defraud him."
    },
    {
      "start": 61.408,
      "end": 62.88,
      "text": "Spade hurried him through the story,",
      "para_break": true
    },
    {
      "start": 63.16,
      "end": 64.62,
      "text": "promised to take care of it,"
    },
    {
      "start": 65.152,
      "end": 66.8,
      "text": "asked for and receive $50,"
    },
    {
      "start": 67.02,
      "end": 69.48,
      "text": "and got rid of him in less than half an hour."
    },
    {
      "start": 70.0,
      "end": 72.94,
      "text": "When the corridor door had closed behind the showman,"
    },
    {
      "start": 73.1,
      "end": 75.18,
      "text": "Effie Perrine came into the inner office."
    },
    {
      "start": 75.64,
      "end": 78.02,
      "text": "Her sunburned face was worried and questioning."
    },
    {
      "start": 78.46,
      "end": 80.08,
      "text": "You haven't found her yet?"
    },
    {
      "start": 80.28,
      "end": 81.02,
      "text": "she asked."
    },
    {
      "start": 81.22,
      "end": 82.06,
      "text": "He shook"
    },
    {
      "start": 82.16,
      "end": 84.08,
      "text": "his head and went on stroking his bruised"
    },
    {
      "start": 84.08,
      "end": 86.12,
      "text": "temple lightly in circles with his fingertips."
    },
    {
      "start": 87.24,
      "end": 87.86,
      "text": "How is it?",
      "para_break": true
    },
    {
      "start": 87.88,
      "end": 88.54,
      "text": "she asked."
    },
    {
      "start": 89.54,
      "end": 89.9,
      "text": "All right,",
      "para_break": true
    },
    {
      "start": 90.02,
      "end": 91.82,
      "text": "but I've got plenty of headache."
    },
    {
      "start": 92.9,
      "end": 94.18,
      "text": "She went around behind him,",
      "para_break": true
    },
    {
      "start": 94.4,
      "end": 95.34,
      "text": "put his hand down,"
    },
    {
      "start": 95.42,
      "end": 97.6,
      "text": "and stroked his temple with her slender fingers."
    },
    {
      "start": 98.0,
      "end": 99.52,
      "text": "He leaned back until the"
    },
    {
      "start": 99.6,
      "end": 102.34,
      "text": "back of his head over the chair top rested against her breast."
    },
    {
      "start": 103.14,
      "end": 103.48,
      "text": "He said,",
      "para_break": true
    },
    {
      "start": 103.6,
      "end": 104.76,
      "text": "you're an angel."
    },
    {
      "start": 105.84,
      "end": 108.88,
      "text": "She bent her head forward over his and looked down into his face.",
      "para_break": true
    },
    {
      "start": 109.86,
      "end": 110.86,
      "text": "You've got to find her,",
      "para_break": true
    },
    {
      "start": 110.92,
      "end": 111.14,
      "text": "Sam."
    },
    {
      "start": 112.18,
      "end": 113.64,
      "text": "It's more than a day and she...",
      "para_break": true
    },
    {
      "start": 113.64,
      "end": 116.46,
      "text": "He stirred and impatiently interrupted her."
    },
    {
      "start": 116.73,
      "end": 118.18,
      "text": "I haven't got to do"
    },
    {
      "start": 118.28,
      "end": 118.6,
      "text": "anything,"
    },
    {
      "start": 119.34,
      "end": 122.08,
      "text": "but if you'll let me rest this damn head a minute or two,",
      "para_break": true
    },
    {
      "start": 122.24,
      "end": 123.78,
      "text": "I'll go out and find her."
    },
    {
      "start": 124.7,
      "end": 125.4,
      "text": "She murmured,",
      "para_break": true
    },
    {
      "start": 125.98,
      "end": 126.58,
      "text": "poor head,",
      "para_break": true
    },
    {
      "start": 127.34,
      "end": 128.88,
      "text": "and stroked it in silence a while.",
      "para_break": true
    },
    {
      "start": 129.66,
      "end": 130.36,
      "text": "Then she asked,",
      "para_break": true
    },
    {
      "start": 131.02,
      "end": 132.08,
      "text": "you know where she is?",
      "para_break": true
    },
    {
      "start": 132.7,
      "end": 133.6,
      "text": "Have you any idea?",
      "para_break": true
    },
    {
      "start": 133.94,
      "end": 135.76,
      "text": "The telephone bell rang."
    },
    {
      "start": 136.864,
      "end": 138.42,
      "text": "Spade picked up the telephone and said,",
      "para_break": true
    },
    {
      "start": 138.56,
      "end": 138.82,
      "text": "hello."
    },
    {
      "start": 139.27,
      "end": 140.02,
      "text": "Yes,"
    },
    {
      "start": 140.02,
      "end": 140.28,
      "text": "Sid."
    },
    {
      "start": 140.5,
      "end": 141.68,
      "text": "It came out all right,"
    },
    {
      "start": 141.68,
      "end": 142.0,
      "text": "thanks."
    },
    {
      "start": 142.92,
      "end": 143.2,
      "text": "No.",
      "para_break": true
    },
    {
      "start": 143.7,
      "end": 144.08,
      "text": "Sure."
    },
    {
      "start": 144.85,
      "end": 146.1,
      "text": "He got snotty,",
      "para_break": true
    },
    {
      "start": 146.28,
      "end": 146.92,
      "text": "but so did I."
    },
    {
      "start": 147.76,
      "end": 149.5,
      "text": "He's nursing a gambler's warpipe dream.",
      "para_break": true
    },
    {
      "start": 150.22,
      "end": 150.62,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 151.08,
      "end": 152.56,
      "text": "we didn't kiss when we parted."
    },
    {
      "start": 153.48,
      "end": 155.48,
      "text": "I declared my weight and walked out on him.",
      "para_break": true
    },
    {
      "start": 156.48,
      "end": 157.8,
      "text": "That's something for you to worry about.",
      "para_break": true
    },
    {
      "start": 158.7,
      "end": 158.98,
      "text": "Right.",
      "para_break": true
    },
    {
      "start": 159.18,
      "end": 159.296,
      "text": "Bye."
    },
    {
      "start": 160.86,
      "end": 163.3,
      "text": "He put the telephone down and leaned back in his chair again.",
      "para_break": true
    },
    {
      "start": 164.32,
      "end": 166.78,
      "text": "Effie Perrine came from behind him and stood at his side.",
      "para_break": true
    },
    {
      "start": 166.96,
      "end": 167.9,
      "text": "She demanded."
    },
    {
      "start": 168.5,
      "end": 170.72,
      "text": "Do you think you know where she is,",
      "para_break": true
    },
    {
      "start": 170.8,
      "end": 171.0,
      "text": "Sam?"
    },
    {
      "start": 171.63,
      "end": 173.18,
      "text": "I know where she went,",
      "para_break": true
    },
    {
      "start": 173.4,
      "end": 175.12,
      "text": "he replied in a grudging tone."
    },
    {
      "start": 175.92,
      "end": 176.16,
      "text": "Where?",
      "para_break": true
    },
    {
      "start": 176.84,
      "end": 177.52,
      "text": "She was excited.",
      "para_break": true
    },
    {
      "start": 178.62,
      "end": 180.02,
      "text": "Down to the boat you saw burning.",
      "para_break": true
    },
    {
      "start": 180.7,
      "end": 183.92,
      "text": "Her eyes opened until their brown was surrounded by white.",
      "para_break": true
    },
    {
      "start": 184.68,
      "end": 185.44,
      "text": "You went down there?",
      "para_break": true
    },
    {
      "start": 185.82,
      "end": 186.68,
      "text": "It was not a question."
    },
    {
      "start": 187.56,
      "end": 188.02,
      "text": "I did not,",
      "para_break": true
    },
    {
      "start": 188.28,
      "end": 189.0,
      "text": "Spade said."
    },
    {
      "start": 189.6,
      "end": 190.24,
      "text": "Sam,",
      "para_break": true
    },
    {
      "start": 190.76,
      "end": 191.77,
      "text": "she cried angrily."
    },
    {
      "start": 192.08,
      "end": 192.64,
      "text": "She may be."
    },
    {
      "start": 193.62,
      "end": 194.54,
      "text": "She went down there,",
      "para_break": true
    },
    {
      "start": 194.66,
      "end": 195.98,
      "text": "he said in a surly voice."
    },
    {
      "start": 196.54,
      "end": 197.36,
      "text": "she wasn't taken.",
      "para_break": true
    },
    {
      "start": 198.28,
      "end": 199.94,
      "text": "She went down there instead of to your",
      "para_break": true
    },
    {
      "start": 199.94,
      "end": 201.88,
      "text": "house when she learned the boat was in."
    },
    {
      "start": 202.7,
      "end": 202.82,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 203.0,
      "end": 203.8,
      "text": "what the hell?"
    },
    {
      "start": 204.84,
      "end": 206.52,
      "text": "Am I supposed to run around after my",
      "para_break": true
    },
    {
      "start": 206.52,
      "end": 208.42,
      "text": "clients begging them to let me help them?"
    },
    {
      "start": 209.18,
      "end": 209.58,
      "text": "But Sam,",
      "para_break": true
    },
    {
      "start": 209.78,
      "end": 211.78,
      "text": "when I told you the boat was on fire."
    },
    {
      "start": 212.98,
      "end": 215.5,
      "text": "That was at noon and I had a date with Paul House",
      "para_break": true
    },
    {
      "start": 215.7,
      "end": 216.7,
      "text": "and another with Brian."
    },
    {
      "start": 217.8,
      "end": 219.8,
      "text": "She glared at him between Titan lids.",
      "para_break": true
    },
    {
      "start": 220.544,
      "end": 221.18,
      "text": "Sam Spade,",
      "para_break": true
    },
    {
      "start": 221.34,
      "end": 221.84,
      "text": "she said,"
    },
    {
      "start": 222.0,
      "end": 222.72,
      "text": "you're the most"
    },
    {
      "start": 223.14,
      "end": 226.22,
      "text": "contemptible man God ever made when you want to be."
    },
    {
      "start": 227.42,
      "end": 229.42,
      "text": "Because she did something without confiding",
      "para_break": true
    },
    {
      "start": 229.42,
      "end": 229.76,
      "text": "in you."
    },
    {
      "start": 229.84,
      "end": 233.46,
      "text": "You'd sit here and do nothing when you know she's in danger,"
    },
    {
      "start": 233.6,
      "end": 235.0,
      "text": "when you know she might be."
    },
    {
      "start": 235.936,
      "end": 237.34,
      "text": "Spade's face flushed.",
      "para_break": true
    },
    {
      "start": 237.34,
      "end": 239.04,
      "text": "He said stubbornly,"
    },
    {
      "start": 239.06,
      "end": 242.32,
      "text": "she's pretty capable of taking care of herself and she"
    },
    {
      "start": 242.4,
      "end": 244.22,
      "text": "knows where to come for help when she"
    },
    {
      "start": 244.22,
      "end": 246.4,
      "text": "thinks she needs it and when it suits her."
    },
    {
      "start": 247.52,
      "end": 247.9,
      "text": "That's spite,",
      "para_break": true
    },
    {
      "start": 248.2,
      "end": 251.8,
      "text": "the girl cried and that's all it is you're sore"
    },
    {
      "start": 251.8,
      "end": 254.58,
      "text": "because she did something on her own hook without"
    },
    {
      "start": 254.72,
      "end": 255.26,
      "text": "telling you"
    },
    {
      "start": 256.12,
      "end": 259.28,
      "text": "why shouldn't she you're not so damn honest",
      "para_break": true
    },
    {
      "start": 259.68,
      "end": 261.46,
      "text": "and you haven't been so much on the level"
    },
    {
      "start": 261.46,
      "end": 263.38,
      "text": "with her that she should trust you"
    },
    {
      "start": 263.38,
      "end": 267.14,
      "text": "completely spade said that's enough of that"
    },
    {
      "start": 268.28,
      "end": 268.88,
      "text": "his tone brought",
      "para_break": true
    },
    {
      "start": 268.88,
      "end": 271.94,
      "text": "a brief uneasy glint into her hot eyes but she"
    },
    {
      "start": 271.94,
      "end": 274.94,
      "text": "tossed her head and the glint vanished her mouth"
    },
    {
      "start": 275.08,
      "end": 276.2,
      "text": "was drawn taut and small."
    }
  ]
}
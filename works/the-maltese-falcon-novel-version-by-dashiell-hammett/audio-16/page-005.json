{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-16",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_16_hammett_128kb.mp3",
  "chapter_title": "The Third Murder",
  "reader_name": "NLizer",
  "page_num": 5,
  "page_total": 5,
  "page_start_sec": 1003.58,
  "page_end_sec": 1190.46,
  "para_gap_threshold": 0.545,
  "segments": [
    {
      "start": 1003.58,
      "end": 1005.02,
      "text": "Her eyes became large.",
      "para_break": true
    },
    {
      "start": 1005.28,
      "end": 1006.08,
      "text": "Yes."
    },
    {
      "start": 1006.24,
      "end": 1006.96,
      "text": "Yes."
    },
    {
      "start": 1007.3,
      "end": 1008.28,
      "text": "Hold the line."
    },
    {
      "start": 1008.54,
      "end": 1010.84,
      "text": "Her mouth suddenly stretched wide and fearful."
    },
    {
      "start": 1011.48,
      "end": 1012.02,
      "text": "She cried,",
      "para_break": true
    },
    {
      "start": 1012.32,
      "end": 1012.94,
      "text": "hello,"
    },
    {
      "start": 1013.24,
      "end": 1014.0,
      "text": "hello,"
    },
    {
      "start": 1014.3,
      "end": 1014.92,
      "text": "hello."
    },
    {
      "start": 1015.81,
      "end": 1018.0,
      "text": "She rattled the prong up and down and cried,",
      "para_break": true
    },
    {
      "start": 1018.2,
      "end": 1018.86,
      "text": "hello,"
    },
    {
      "start": 1018.98,
      "end": 1019.328,
      "text": "twice."
    },
    {
      "start": 1021.52,
      "end": 1023.58,
      "text": "Then she sobbed and spun around to Faye Spade,",
      "para_break": true
    },
    {
      "start": 1023.72,
      "end": 1025.26,
      "text": "who was close beside her by now."
    },
    {
      "start": 1025.96,
      "end": 1027.16,
      "text": "It was Miss O'Shaughnessy,",
      "para_break": true
    },
    {
      "start": 1027.22,
      "end": 1027.96,
      "text": "she said wildly."
    },
    {
      "start": 1028.44,
      "end": 1029.1,
      "text": "She wants you."
    },
    {
      "start": 1029.632,
      "end": 1031.58,
      "text": "She's at the Alexandria in danger."
    },
    {
      "start": 1032.28,
      "end": 1032.94,
      "text": "Her voice was,",
      "para_break": true
    },
    {
      "start": 1033.08,
      "end": 1033.58,
      "text": "oh,"
    },
    {
      "start": 1033.68,
      "end": 1034.82,
      "text": "it was awful,"
    },
    {
      "start": 1034.98,
      "end": 1035.26,
      "text": "Sam."
    },
    {
      "start": 1036.0,
      "end": 1038.46,
      "text": "And something happened to her before she could finish.",
      "para_break": true
    },
    {
      "start": 1039.02,
      "end": 1039.72,
      "text": "Go help her,",
      "para_break": true
    },
    {
      "start": 1039.8,
      "end": 1040.1,
      "text": "Sam."
    },
    {
      "start": 1041.12,
      "end": 1044.16,
      "text": "Spade put the falcon down on the desk and scowled gloomily.",
      "para_break": true
    },
    {
      "start": 1044.98,
      "end": 1046.88,
      "text": "I've got to take care of this fellow first,",
      "para_break": true
    },
    {
      "start": 1047.06,
      "end": 1047.44,
      "text": "he said,"
    },
    {
      "start": 1048.0,
      "end": 1050.2,
      "text": "pointing his thumb at the thin corpse on the floor.",
      "para_break": true
    },
    {
      "start": 1051.38,
      "end": 1052.82,
      "text": "She beat his chest with her fist,",
      "para_break": true
    },
    {
      "start": 1052.92,
      "end": 1053.24,
      "text": "crying."
    },
    {
      "start": 1053.76,
      "end": 1053.88,
      "text": "No,"
    },
    {
      "start": 1054.02,
      "end": 1054.28,
      "text": "no,"
    },
    {
      "start": 1054.34,
      "end": 1055.7,
      "text": "you've got to go to her."
    },
    {
      "start": 1056.46,
      "end": 1057.06,
      "text": "Don't you see,",
      "para_break": true
    },
    {
      "start": 1057.16,
      "end": 1057.46,
      "text": "Sam?"
    },
    {
      "start": 1058.42,
      "end": 1059.74,
      "text": "He had the thing that was hers,",
      "para_break": true
    },
    {
      "start": 1059.8,
      "end": 1061.38,
      "text": "and he came to you with it."
    },
    {
      "start": 1061.72,
      "end": 1062.38,
      "text": "Don't you see?"
    },
    {
      "start": 1063.02,
      "end": 1063.9,
      "text": "He was helping her,",
      "para_break": true
    },
    {
      "start": 1063.98,
      "end": 1064.86,
      "text": "and they killed him,"
    },
    {
      "start": 1065.0,
      "end": 1066.2,
      "text": "and now she's..."
    },
    {
      "start": 1066.44,
      "end": 1066.78,
      "text": "Oh,"
    },
    {
      "start": 1066.78,
      "end": 1067.98,
      "text": "you've got to go."
    },
    {
      "start": 1069.34,
      "end": 1069.98,
      "text": "All right.",
      "para_break": true
    },
    {
      "start": 1071.104,
      "end": 1073.26,
      "text": "Spade pushed her away and bent over his desk,",
      "para_break": true
    },
    {
      "start": 1073.34,
      "end": 1074.54,
      "text": "putting the blackbird back"
    },
    {
      "start": 1074.7,
      "end": 1076.34,
      "text": "into its nest of excelsior,"
    },
    {
      "start": 1076.48,
      "end": 1078.22,
      "text": "bending the paper around it,"
    },
    {
      "start": 1078.72,
      "end": 1079.36,
      "text": "working rapidly,"
    },
    {
      "start": 1079.56,
      "end": 1080.74,
      "text": "making a larger and"
    },
    {
      "start": 1080.8,
      "end": 1081.54,
      "text": "clumsy package."
    },
    {
      "start": 1082.46,
      "end": 1083.34,
      "text": "As soon as I've gone,",
      "para_break": true
    },
    {
      "start": 1083.42,
      "end": 1084.14,
      "text": "phone the police."
    },
    {
      "start": 1084.7,
      "end": 1085.62,
      "text": "Tell them how it happened,",
      "para_break": true
    },
    {
      "start": 1085.68,
      "end": 1086.24,
      "text": "but don't drag"
    },
    {
      "start": 1086.36,
      "end": 1087.06,
      "text": "any names in."
    },
    {
      "start": 1087.72,
      "end": 1088.28,
      "text": "You don't know.",
      "para_break": true
    },
    {
      "start": 1089.34,
      "end": 1090.26,
      "text": "I got the phone call,",
      "para_break": true
    },
    {
      "start": 1090.38,
      "end": 1092.0,
      "text": "and I told you I had to go out,"
    },
    {
      "start": 1092.32,
      "end": 1092.92,
      "text": "but I didn't say"
    },
    {
      "start": 1093.08,
      "end": 1093.22,
      "text": "where?"
    },
    {
      "start": 1093.92,
      "end": 1095.84,
      "text": "He cursed the rope for being tangled,",
      "para_break": true
    },
    {
      "start": 1096.04,
      "end": 1097.92,
      "text": "yanked it into straightness,"
    },
    {
      "start": 1097.98,
      "end": 1099.22,
      "text": "and began to bind the package."
    },
    {
      "start": 1099.98,
      "end": 1100.7,
      "text": "Forget this thing.",
      "para_break": true
    },
    {
      "start": 1100.97,
      "end": 1102.2,
      "text": "Tell it as it happened,"
    },
    {
      "start": 1102.28,
      "end": 1103.7,
      "text": "but forget he had a bundle."
    },
    {
      "start": 1103.88,
      "end": 1105.68,
      "text": "He chewed his lower lip."
    },
    {
      "start": 1106.24,
      "end": 1107.16,
      "text": "Unless they pin you down.",
      "para_break": true
    },
    {
      "start": 1107.92,
      "end": 1109.24,
      "text": "If they seem to know about it,",
      "para_break": true
    },
    {
      "start": 1109.72,
      "end": 1110.66,
      "text": "you'll have to admit it,"
    },
    {
      "start": 1110.68,
      "end": 1111.52,
      "text": "but that's not"
    },
    {
      "start": 1111.62,
      "end": 1111.92,
      "text": "likely."
    },
    {
      "start": 1112.21,
      "end": 1112.96,
      "text": "If they do,"
    },
    {
      "start": 1113.08,
      "end": 1114.66,
      "text": "then I took the bundle away with me,"
    },
    {
      "start": 1114.76,
      "end": 1115.34,
      "text": "unopened."
    },
    {
      "start": 1115.6,
      "end": 1117.44,
      "text": "He finished tying the knot and"
    },
    {
      "start": 1117.68,
      "end": 1119.9,
      "text": "straightened up with the parcel under his left arm."
    },
    {
      "start": 1120.42,
      "end": 1121.18,
      "text": "Get it straight now."
    },
    {
      "start": 1121.38,
      "end": 1123.18,
      "text": "Everything happened the way"
    },
    {
      "start": 1123.18,
      "end": 1123.92,
      "text": "it did happen,"
    },
    {
      "start": 1124.04,
      "end": 1125.34,
      "text": "but without this dingus,"
    },
    {
      "start": 1125.44,
      "end": 1126.88,
      "text": "unless they already know about it."
    },
    {
      "start": 1127.68,
      "end": 1128.28,
      "text": "Don't deny it.",
      "para_break": true
    },
    {
      "start": 1128.34,
      "end": 1128.66,
      "text": "Just"
    },
    {
      "start": 1128.88,
      "end": 1129.56,
      "text": "don't mention it."
    },
    {
      "start": 1130.24,
      "end": 1131.18,
      "text": "And I got the phone call,",
      "para_break": true
    },
    {
      "start": 1131.26,
      "end": 1131.68,
      "text": "not you."
    },
    {
      "start": 1132.52,
      "end": 1134.24,
      "text": "And you don't know anything about anybody",
      "para_break": true
    },
    {
      "start": 1134.38,
      "end": 1136.34,
      "text": "else having any connection with this fellow."
    },
    {
      "start": 1137.06,
      "end": 1138.52,
      "text": "You don't know anything about him,",
      "para_break": true
    },
    {
      "start": 1138.64,
      "end": 1139.52,
      "text": "and you can't talk"
    },
    {
      "start": 1139.74,
      "end": 1141.52,
      "text": "about my business until you see me."
    },
    {
      "start": 1141.58,
      "end": 1142.02,
      "text": "Got it?"
    },
    {
      "start": 1142.6,
      "end": 1143.04,
      "text": "Yes,",
      "para_break": true
    },
    {
      "start": 1143.04,
      "end": 1143.32,
      "text": "Sam."
    },
    {
      "start": 1143.66,
      "end": 1143.76,
      "text": "Who?"
    },
    {
      "start": 1145.38,
      "end": 1146.66,
      "text": "Do you know who he is?",
      "para_break": true
    },
    {
      "start": 1146.9,
      "end": 1148.0,
      "text": "He grinned"
    },
    {
      "start": 1148.12,
      "end": 1148.72,
      "text": "wolfishly."
    },
    {
      "start": 1149.376,
      "end": 1149.7,
      "text": "Uh-huh,",
      "para_break": true
    },
    {
      "start": 1149.82,
      "end": 1150.38,
      "text": "he said,"
    },
    {
      "start": 1150.86,
      "end": 1152.68,
      "text": "but I'd guess he was Captain Jacoby,"
    },
    {
      "start": 1152.9,
      "end": 1154.44,
      "text": "master of La Paloma."
    },
    {
      "start": 1155.26,
      "end": 1155.66,
      "text": "He picked up",
      "para_break": true
    },
    {
      "start": 1155.66,
      "end": 1156.64,
      "text": "his hat and put it on."
    },
    {
      "start": 1156.9,
      "end": 1159.86,
      "text": "He looked thoughtfully at the dead man and then around the room."
    },
    {
      "start": 1160.64,
      "end": 1160.82,
      "text": "Hurry,",
      "para_break": true
    },
    {
      "start": 1160.94,
      "end": 1161.2,
      "text": "Sam,"
    },
    {
      "start": 1161.42,
      "end": 1162.36,
      "text": "the girl begged."
    },
    {
      "start": 1162.6,
      "end": 1162.7,
      "text": "Sure,"
    },
    {
      "start": 1163.56,
      "end": 1164.49,
      "text": "he said absentmindedly.",
      "para_break": true
    },
    {
      "start": 1164.96,
      "end": 1165.58,
      "text": "I'll hurry."
    },
    {
      "start": 1166.32,
      "end": 1167.02,
      "text": "Might not hurt to",
      "para_break": true
    },
    {
      "start": 1167.12,
      "end": 1168.86,
      "text": "get those few scraps of Excelsior"
    },
    {
      "start": 1168.9,
      "end": 1170.5,
      "text": "off the floor before the police come,"
    },
    {
      "start": 1171.2,
      "end": 1171.96,
      "text": "and maybe you ought to",
      "para_break": true
    },
    {
      "start": 1171.96,
      "end": 1173.38,
      "text": "try to get hold of Sid."
    },
    {
      "start": 1173.62,
      "end": 1173.72,
      "text": "No,"
    },
    {
      "start": 1174.9,
      "end": 1176.0,
      "text": "he rubbed his chin.",
      "para_break": true
    },
    {
      "start": 1176.42,
      "end": 1178.26,
      "text": "We'll leave him out of it a while."
    },
    {
      "start": 1178.5,
      "end": 1179.34,
      "text": "It'll look"
    },
    {
      "start": 1179.42,
      "end": 1179.7,
      "text": "better."
    },
    {
      "start": 1180.56,
      "end": 1182.02,
      "text": "I'd keep the door locked till they come.",
      "para_break": true
    },
    {
      "start": 1182.53,
      "end": 1184.7,
      "text": "He took his hand from his chin and rubbed her"
    },
    {
      "start": 1184.78,
      "end": 1185.04,
      "text": "cheek."
    },
    {
      "start": 1185.78,
      "end": 1186.6,
      "text": "You're a damn good man,",
      "para_break": true
    },
    {
      "start": 1186.78,
      "end": 1187.02,
      "text": "sister,"
    },
    {
      "start": 1187.28,
      "end": 1188.52,
      "text": "he said and went out."
    },
    {
      "start": 1189.408,
      "end": 1190.46,
      "text": "End of chapter 16.",
      "para_break": true
    }
  ]
}
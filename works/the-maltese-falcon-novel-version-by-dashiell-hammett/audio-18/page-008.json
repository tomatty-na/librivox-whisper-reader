{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-18",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_18_hammett_128kb.mp3",
  "chapter_title": "The Fall Guy",
  "reader_name": "NLizer",
  "page_num": 8,
  "page_total": 8,
  "page_start_sec": 1722.624,
  "page_end_sec": 1844.32,
  "para_gap_threshold": 0.553,
  "segments": [
    {
      "start": 1722.624,
      "end": 1723.12,
      "text": "\"Stop it,\"",
      "para_break": true
    },
    {
      "start": 1723.22,
      "end": 1724.22,
      "text": "Spade growled."
    },
    {
      "start": 1724.32,
      "end": 1725.26,
      "text": "I'll hurt you."
    },
    {
      "start": 1726.464,
      "end": 1726.94,
      "text": "Cairo cried,",
      "para_break": true
    },
    {
      "start": 1727.34,
      "end": 1727.9,
      "text": "Oh,"
    },
    {
      "start": 1727.98,
      "end": 1728.8,
      "text": "you big coward!\""
    },
    {
      "start": 1728.96,
      "end": 1730.26,
      "text": "and backed away from him."
    },
    {
      "start": 1731.232,
      "end": 1733.0,
      "text": "Spade stooped to pick up Cairo's pistol from the floor,"
    },
    {
      "start": 1733.0,
      "end": 1734.52,
      "text": "and then the boy's."
    },
    {
      "start": 1734.64,
      "end": 1736.06,
      "text": "He straightened up,"
    },
    {
      "start": 1736.06,
      "end": 1737.34,
      "text": "holding them in his left hand,"
    },
    {
      "start": 1737.44,
      "end": 1740.22,
      "text": "dangling them upside-down by their trigger-guards from his"
    },
    {
      "start": 1740.32,
      "end": 1740.86,
      "text": "forefinger."
    },
    {
      "start": 1741.792,
      "end": 1743.82,
      "text": "Gutman had put the boy in the rocking chair",
      "para_break": true
    },
    {
      "start": 1743.82,
      "end": 1745.72,
      "text": "and stood looking at him with troubled eyes"
    },
    {
      "start": 1746.0,
      "end": 1747.66,
      "text": "in an uncertainly puckered face."
    },
    {
      "start": 1748.608,
      "end": 1750.62,
      "text": "Cairo went down on his knees beside the chair"
    },
    {
      "start": 1750.62,
      "end": 1753.1,
      "text": "and began to chafe one of the boy's limp hands."
    },
    {
      "start": 1754.112,
      "end": 1755.92,
      "text": "Spade felt the boy's chin with his fingers.",
      "para_break": true
    },
    {
      "start": 1756.608,
      "end": 1757.02,
      "text": "Nothing cracked,"
    },
    {
      "start": 1757.26,
      "end": 1757.64,
      "text": "he said."
    },
    {
      "start": 1758.32,
      "end": 1759.54,
      "text": "We'll spread him on the sofa."
    },
    {
      "start": 1760.4,
      "end": 1762.32,
      "text": "He put his right arm under the boy's arm"
    },
    {
      "start": 1762.4,
      "end": 1763.36,
      "text": "and around his back,"
    },
    {
      "start": 1763.86,
      "end": 1765.7,
      "text": "put his left forearm under the boy's knees,"
    },
    {
      "start": 1765.94,
      "end": 1767.34,
      "text": "lifted him without apparent effort,"
    },
    {
      "start": 1767.76,
      "end": 1768.92,
      "text": "and carried him to the sofa."
    },
    {
      "start": 1770.176,
      "end": 1771.86,
      "text": "Brigid O'Shaughnessy got up quickly"
    },
    {
      "start": 1772.04,
      "end": 1773.34,
      "text": "and Spade laid the boy there."
    },
    {
      "start": 1773.73,
      "end": 1775.18,
      "text": "With his right hand,"
    },
    {
      "start": 1775.42,
      "end": 1776.94,
      "text": "Spade patted the boy's clothes,"
    },
    {
      "start": 1777.2,
      "end": 1778.54,
      "text": "found his second pistol,"
    },
    {
      "start": 1778.76,
      "end": 1780.92,
      "text": "added it to the others in his left hand,"
    },
    {
      "start": 1781.04,
      "end": 1782.68,
      "text": "and turned his back on the sofa."
    },
    {
      "start": 1783.712,
      "end": 1786.06,
      "text": "Cairo was already sitting beside the boy's head."
    },
    {
      "start": 1787.136,
      "end": 1788.76,
      "text": "Spade clinked the pistols together in",
      "para_break": true
    },
    {
      "start": 1788.76,
      "end": 1790.6,
      "text": "his hand and smiled cheerfully at Gutman."
    },
    {
      "start": 1791.4,
      "end": 1791.58,
      "text": "Well,"
    },
    {
      "start": 1791.7,
      "end": 1792.08,
      "text": "he said,"
    },
    {
      "start": 1792.28,
      "end": 1793.54,
      "text": "there's our fall-guy."
    },
    {
      "start": 1794.592,
      "end": 1796.98,
      "text": "Gutman's face was grey and his eyes were clouded.",
      "para_break": true
    },
    {
      "start": 1797.2,
      "end": 1798.5,
      "text": "He did not look at Spade."
    },
    {
      "start": 1799.18,
      "end": 1800.9,
      "text": "He looked at the floor and did not say anything."
    },
    {
      "start": 1802.048,
      "end": 1802.56,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 1803.5,
      "end": 1804.72,
      "text": "\"Don't be a damned fool again."
    },
    {
      "start": 1805.58,
      "end": 1807.16,
      "text": "You let Cairo whisper to you,"
    },
    {
      "start": 1807.5,
      "end": 1809.44,
      "text": "and you held the kid while I pasted him."
    },
    {
      "start": 1810.06,
      "end": 1811.14,
      "text": "You can't laugh that off,"
    },
    {
      "start": 1811.42,
      "end": 1813.54,
      "text": "and you're likely to get yourself shot trying to."
    },
    {
      "start": 1814.656,
      "end": 1816.8,
      "text": "Gutman moved his feet on the rug and said nothing."
    },
    {
      "start": 1819.08,
      "end": 1822.2,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 1822.46,
      "end": 1825.28,
      "text": "or I'll turn the falcon and the whole God-damned lot of you in.\""
    },
    {
      "start": 1826.368,
      "end": 1828.52,
      "text": "Gutman raised his head and muttered through his teeth,",
      "para_break": true
    },
    {
      "start": 1829.38,
      "end": 1830.08,
      "text": "I don't like that,"
    },
    {
      "start": 1830.14,
      "end": 1830.34,
      "text": "sir."
    },
    {
      "start": 1830.54,
      "end": 1833.46,
      "text": "\"You won't like it,\" Spade said. \"Well?\""
    },
    {
      "start": 1833.66,
      "end": 1837.72,
      "text": "The fat man sighed and made a wry face and replied sadly:",
      "para_break": true
    },
    {
      "start": 1838.0,
      "end": 1839.22,
      "text": "\"You can have him.\""
    }
  ],
  "corrected": "claude"
}
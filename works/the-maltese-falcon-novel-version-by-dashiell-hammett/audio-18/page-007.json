{
  "work_slug": "the-maltese-falcon-novel-version-by-dashiell-hammett",
  "work_title": "Maltese Falcon; Novel Version",
  "work_author": "Dashiell Hammett",
  "audio_file": "audio-18",
  "audio_url": "https://archive.org/download/themaltesefalconnovel_2603_librivox/maltesefalcon_18_hammett_128kb.mp3",
  "chapter_title": "The Fall Guy",
  "reader_name": "NLizer",
  "page_num": 7,
  "page_total": 8,
  "page_start_sec": 1480.42,
  "page_end_sec": 1721.9,
  "para_gap_threshold": 0.553,
  "segments": [
    {
      "start": 1480.42,
      "end": 1482.44,
      "text": "His eyes twinkled between puckered lids.",
      "para_break": true
    },
    {
      "start": 1482.6,
      "end": 1482.7,
      "text": "Presently,"
    },
    {
      "start": 1483.7,
      "end": 1485.36,
      "text": "he gave his genial answer.",
      "para_break": true
    },
    {
      "start": 1486.02,
      "end": 1486.4,
      "text": "Well,",
      "para_break": true
    },
    {
      "start": 1486.44,
      "end": 1486.64,
      "text": "sir,"
    },
    {
      "start": 1487.16,
      "end": 1489.84,
      "text": "there are other means of persuasion besides killing and"
    },
    {
      "start": 1489.92,
      "end": 1490.66,
      "text": "threatening to kill."
    },
    {
      "start": 1490.92,
      "end": 1491.68,
      "text": "Sure,"
    },
    {
      "start": 1491.96,
      "end": 1492.6,
      "text": "Spade agreed,"
    },
    {
      "start": 1492.88,
      "end": 1495.24,
      "text": "but they're not much good unless the threat of death"
    },
    {
      "start": 1495.24,
      "end": 1497.06,
      "text": "is behind them to hold the victim down."
    },
    {
      "start": 1497.9,
      "end": 1498.52,
      "text": "See what I mean?",
      "para_break": true
    },
    {
      "start": 1499.26,
      "end": 1500.94,
      "text": "If you try anything I don't like,",
      "para_break": true
    },
    {
      "start": 1501.26,
      "end": 1502.46,
      "text": "I won't stand for it."
    },
    {
      "start": 1503.02,
      "end": 1505.98,
      "text": "I'll make it a matter of you having to call it off or kill me,",
      "para_break": true
    },
    {
      "start": 1506.5,
      "end": 1507.88,
      "text": "knowing you can't afford to kill me."
    },
    {
      "start": 1508.54,
      "end": 1509.62,
      "text": "I see what you mean,",
      "para_break": true
    },
    {
      "start": 1509.8,
      "end": 1510.56,
      "text": "Gutman chuckled."
    },
    {
      "start": 1511.16,
      "end": 1511.94,
      "text": "That is an attitude,",
      "para_break": true
    },
    {
      "start": 1512.12,
      "end": 1512.3,
      "text": "sir,"
    },
    {
      "start": 1512.36,
      "end": 1515.02,
      "text": "that calls for the most delicate judgment on both sides,"
    },
    {
      "start": 1515.18,
      "end": 1515.72,
      "text": "because,"
    },
    {
      "start": 1515.92,
      "end": 1516.48,
      "text": "as you know,"
    },
    {
      "start": 1516.56,
      "end": 1516.76,
      "text": "sir,"
    },
    {
      "start": 1516.92,
      "end": 1517.58,
      "text": "men are"
    },
    {
      "start": 1517.66,
      "end": 1520.1,
      "text": "likely to forget in the heat of action where their"
    },
    {
      "start": 1520.1,
      "end": 1522.48,
      "text": "best interest lies and let their emotions carry"
    },
    {
      "start": 1522.48,
      "end": 1522.96,
      "text": "them away."
    },
    {
      "start": 1523.64,
      "end": 1524.5,
      "text": "Spade,",
      "para_break": true
    },
    {
      "start": 1524.5,
      "end": 1524.72,
      "text": "too,"
    },
    {
      "start": 1524.8,
      "end": 1526.26,
      "text": "was all smiling blandness."
    },
    {
      "start": 1527.264,
      "end": 1528.56,
      "text": "That's the trick from my side,",
      "para_break": true
    },
    {
      "start": 1528.62,
      "end": 1528.96,
      "text": "he said,"
    },
    {
      "start": 1529.44,
      "end": 1529.92,
      "text": "to make my"
    },
    {
      "start": 1530.0,
      "end": 1532.3,
      "text": "play strong enough that it ties you up,"
    },
    {
      "start": 1532.34,
      "end": 1535.14,
      "text": "but yet not make you mad enough to bump me off against"
    },
    {
      "start": 1535.32,
      "end": 1536.14,
      "text": "your better judgment."
    },
    {
      "start": 1537.152,
      "end": 1538.26,
      "text": "Gutman said fondly,",
      "para_break": true
    },
    {
      "start": 1538.36,
      "end": 1539.04,
      "text": "Bagad,"
    },
    {
      "start": 1539.04,
      "end": 1539.34,
      "text": "sir,"
    },
    {
      "start": 1539.96,
      "end": 1540.9,
      "text": "you are a character.",
      "para_break": true
    },
    {
      "start": 1542.08,
      "end": 1543.2,
      "text": "Joel Cairo jumped up",
      "para_break": true
    },
    {
      "start": 1543.2,
      "end": 1544.72,
      "text": "from his chair and went around behind"
    },
    {
      "start": 1544.72,
      "end": 1546.78,
      "text": "the boy and behind Gutman's chair."
    },
    {
      "start": 1547.36,
      "end": 1548.78,
      "text": "He bent over the back of",
      "para_break": true
    },
    {
      "start": 1548.94,
      "end": 1549.84,
      "text": "Gutman's chair and,"
    },
    {
      "start": 1549.86,
      "end": 1552.64,
      "text": "screaming his mouth and the fat man's ear with his empty hand,"
    },
    {
      "start": 1552.78,
      "end": 1553.28,
      "text": "whispered."
    },
    {
      "start": 1553.984,
      "end": 1554.54,
      "text": "Gutman listened,",
      "para_break": true
    },
    {
      "start": 1554.74,
      "end": 1556.34,
      "text": "attentively shutting his eyes."
    },
    {
      "start": 1557.344,
      "end": 1558.92,
      "text": "Spade grinned at Bridget O'Shaughnessy.",
      "para_break": true
    },
    {
      "start": 1559.42,
      "end": 1559.82,
      "text": "Her lips"
    },
    {
      "start": 1560.0,
      "end": 1561.3,
      "text": "smiled feebly in response,"
    },
    {
      "start": 1561.62,
      "end": 1563.44,
      "text": "but there was no change in her eyes."
    },
    {
      "start": 1563.68,
      "end": 1565.66,
      "text": "They did not lose their numb stare."
    },
    {
      "start": 1566.688,
      "end": 1567.66,
      "text": "Spade turned to the boy.",
      "para_break": true
    },
    {
      "start": 1568.5,
      "end": 1568.98,
      "text": "Two to one,",
      "para_break": true
    },
    {
      "start": 1569.0,
      "end": 1569.76,
      "text": "they're selling you out,"
    },
    {
      "start": 1569.84,
      "end": 1569.98,
      "text": "son."
    },
    {
      "start": 1570.55,
      "end": 1572.26,
      "text": "The boy did not say anything.",
      "para_break": true
    },
    {
      "start": 1573.2,
      "end": 1576.0,
      "text": "A trembling in his knees began to shake the knees of his trousers.",
      "para_break": true
    },
    {
      "start": 1576.36,
      "end": 1578.2,
      "text": "Spade addressed Gutman."
    },
    {
      "start": 1579.1,
      "end": 1580.98,
      "text": "I hope you're not letting yourself be influenced",
      "para_break": true
    },
    {
      "start": 1580.98,
      "end": 1583.74,
      "text": "by the guns these pocket edition desperados are"
    },
    {
      "start": 1583.86,
      "end": 1584.1,
      "text": "waving."
    },
    {
      "start": 1584.31,
      "end": 1586.28,
      "text": "Gutman opened his eyes."
    },
    {
      "start": 1587.2,
      "end": 1589.96,
      "text": "Cairo stopped whispering and stood erect behind the fat man's",
      "para_break": true
    },
    {
      "start": 1589.96,
      "end": 1590.22,
      "text": "chair."
    },
    {
      "start": 1591.168,
      "end": 1591.68,
      "text": "Spade said,",
      "para_break": true
    },
    {
      "start": 1591.92,
      "end": 1595.0,
      "text": "I've practiced taking them away from both of them,"
    },
    {
      "start": 1595.06,
      "end": 1596.3,
      "text": "so there'll be no trouble"
    },
    {
      "start": 1596.46,
      "end": 1596.6,
      "text": "there."
    },
    {
      "start": 1597.28,
      "end": 1597.82,
      "text": "The punk is,",
      "para_break": true
    },
    {
      "start": 1598.88,
      "end": 1600.72,
      "text": "in a voice choked horribly by emotion,",
      "para_break": true
    },
    {
      "start": 1600.96,
      "end": 1601.55,
      "text": "the boy cried,"
    },
    {
      "start": 1601.82,
      "end": 1602.64,
      "text": "all right,"
    },
    {
      "start": 1603.44,
      "end": 1604.06,
      "text": "and jerked his",
      "para_break": true
    },
    {
      "start": 1604.14,
      "end": 1605.96,
      "text": "pistol up in front of his chest."
    },
    {
      "start": 1607.04,
      "end": 1609.68,
      "text": "Gutman flung a fat hand out at the boy's wrist,",
      "para_break": true
    },
    {
      "start": 1610.16,
      "end": 1610.72,
      "text": "caught the wrist,"
    },
    {
      "start": 1610.9,
      "end": 1613.38,
      "text": "and bore it and the gun down while Gutman's fat"
    },
    {
      "start": 1613.38,
      "end": 1615.76,
      "text": "body was rising in haste from the rocking chair."
    },
    {
      "start": 1616.72,
      "end": 1618.56,
      "text": "Joel Cairo scurried around to the boy's",
      "para_break": true
    },
    {
      "start": 1618.56,
      "end": 1620.4,
      "text": "other side and grasped his other arm."
    },
    {
      "start": 1621.26,
      "end": 1622.28,
      "text": "They wrestled with the boy,",
      "para_break": true
    },
    {
      "start": 1622.34,
      "end": 1623.74,
      "text": "forcing his arms down,"
    },
    {
      "start": 1623.88,
      "end": 1624.78,
      "text": "holding them down,"
    },
    {
      "start": 1625.06,
      "end": 1627.06,
      "text": "while he struggled futilely against them."
    },
    {
      "start": 1627.24,
      "end": 1629.36,
      "text": "Words came out of the struggling group,"
    },
    {
      "start": 1630.336,
      "end": 1632.18,
      "text": "fragments of the boy's incoherent speech.",
      "para_break": true
    },
    {
      "start": 1632.48,
      "end": 1633.12,
      "text": "Right,"
    },
    {
      "start": 1633.28,
      "end": 1633.68,
      "text": "go,"
    },
    {
      "start": 1633.92,
      "end": 1634.5,
      "text": "bastard,"
    },
    {
      "start": 1634.74,
      "end": 1635.04,
      "text": "smoke."
    },
    {
      "start": 1635.32,
      "end": 1636.27,
      "text": "Gutman's,"
    },
    {
      "start": 1636.52,
      "end": 1636.62,
      "text": "Now,"
    },
    {
      "start": 1637.1,
      "end": 1637.28,
      "text": "now,"
    },
    {
      "start": 1637.36,
      "end": 1637.7,
      "text": "Wilmer,"
    },
    {
      "start": 1637.92,
      "end": 1639.22,
      "text": "repeated many times."
    },
    {
      "start": 1639.5,
      "end": 1640.28,
      "text": "Cairo's,"
    },
    {
      "start": 1640.4,
      "end": 1640.9,
      "text": "no,"
    },
    {
      "start": 1640.92,
      "end": 1641.68,
      "text": "please don't,"
    },
    {
      "start": 1641.68,
      "end": 1642.76,
      "text": "and don't do that,"
    },
    {
      "start": 1642.88,
      "end": 1643.2,
      "text": "Wilmer."
    },
    {
      "start": 1644.512,
      "end": 1644.94,
      "text": "Wooden-faced,",
      "para_break": true
    },
    {
      "start": 1645.06,
      "end": 1648.06,
      "text": "dreamy-eyed Spade got up from the sofa and went over to the group."
    },
    {
      "start": 1648.9,
      "end": 1649.18,
      "text": "The boy,",
      "para_break": true
    },
    {
      "start": 1649.3,
      "end": 1651.18,
      "text": "unable to cope with the weight against him,"
    },
    {
      "start": 1651.28,
      "end": 1652.22,
      "text": "had stopped struggling."
    },
    {
      "start": 1652.65,
      "end": 1653.5,
      "text": "Cairo,"
    },
    {
      "start": 1653.62,
      "end": 1654.18,
      "text": "still holding"
    },
    {
      "start": 1654.18,
      "end": 1654.86,
      "text": "the boy's arm,"
    },
    {
      "start": 1654.98,
      "end": 1656.34,
      "text": "stood partly in front of him,"
    },
    {
      "start": 1656.42,
      "end": 1657.82,
      "text": "talking to him soothingly."
    },
    {
      "start": 1657.88,
      "end": 1659.4,
      "text": "Spade pushed Cairo"
    },
    {
      "start": 1659.52,
      "end": 1662.24,
      "text": "aside gently and drove his left fist against the boy's chin."
    },
    {
      "start": 1662.56,
      "end": 1664.96,
      "text": "The boy's head snapped back as far"
    },
    {
      "start": 1665.12,
      "end": 1668.22,
      "text": "as it could while his arms were held and then came forward."
    },
    {
      "start": 1669.184,
      "end": 1670.42,
      "text": "Gutman began a desperate,",
      "para_break": true
    },
    {
      "start": 1670.68,
      "end": 1670.78,
      "text": "here,"
    },
    {
      "start": 1671.46,
      "end": 1671.76,
      "text": "what?",
      "para_break": true
    },
    {
      "start": 1672.672,
      "end": 1675.0,
      "text": "Spade drove his right fist against the boy's chin.",
      "para_break": true
    },
    {
      "start": 1676.128,
      "end": 1677.38,
      "text": "Cairo dropped the boy's arm,",
      "para_break": true
    },
    {
      "start": 1677.48,
      "end": 1678.36,
      "text": "letting him collapse"
    },
    {
      "start": 1678.6,
      "end": 1680.12,
      "text": "against Gutman's great round belly."
    },
    {
      "start": 1681.056,
      "end": 1682.38,
      "text": "Cairo sprang at Spade,",
      "para_break": true
    },
    {
      "start": 1682.5,
      "end": 1684.64,
      "text": "clawing at his face with the curved"
    },
    {
      "start": 1684.76,
      "end": 1686.28,
      "text": "stiff fingers of both hands."
    },
    {
      "start": 1687.104,
      "end": 1689.5,
      "text": "Spade blew his breath out and pushed the Levantine away.",
      "para_break": true
    },
    {
      "start": 1689.84,
      "end": 1691.16,
      "text": "Cairo sprang at"
    },
    {
      "start": 1691.3,
      "end": 1691.58,
      "text": "him again."
    },
    {
      "start": 1692.06,
      "end": 1695.66,
      "text": "Tears were in Cairo's eyes and his red lips worked angrily,"
    },
    {
      "start": 1695.66,
      "end": 1696.64,
      "text": "forming words,"
    },
    {
      "start": 1696.84,
      "end": 1697.66,
      "text": "but no sound"
    },
    {
      "start": 1697.66,
      "end": 1698.78,
      "text": "came from between them."
    },
    {
      "start": 1699.648,
      "end": 1700.18,
      "text": "Spade laughed,",
      "para_break": true
    },
    {
      "start": 1700.52,
      "end": 1700.92,
      "text": "grunted,"
    },
    {
      "start": 1701.16,
      "end": 1701.88,
      "text": "Jesus,"
    },
    {
      "start": 1702.04,
      "end": 1702.86,
      "text": "you're a pip,"
    },
    {
      "start": 1703.5,
      "end": 1704.76,
      "text": "and cuffed the side of Cairo's",
      "para_break": true
    },
    {
      "start": 1704.76,
      "end": 1705.84,
      "text": "face with an open hand,"
    },
    {
      "start": 1706.1,
      "end": 1707.94,
      "text": "knocking him over against the table."
    },
    {
      "start": 1708.896,
      "end": 1710.58,
      "text": "Cairo regained his balance and sprang",
      "para_break": true
    },
    {
      "start": 1710.58,
      "end": 1711.78,
      "text": "at Spade the third time."
    },
    {
      "start": 1712.576,
      "end": 1715.56,
      "text": "Spade stopped him with both palms held out on long,",
      "para_break": true
    },
    {
      "start": 1715.62,
      "end": 1716.4,
      "text": "rigid arms against"
    },
    {
      "start": 1716.66,
      "end": 1717.06,
      "text": "his face."
    },
    {
      "start": 1717.34,
      "end": 1717.44,
      "text": "Cairo,"
    },
    {
      "start": 1718.32,
      "end": 1720.74,
      "text": "failing to reach Spade's face with his shorter arms,",
      "para_break": true
    },
    {
      "start": 1720.86,
      "end": 1721.9,
      "text": "thumped Spade's arms."
    }
  ]
}
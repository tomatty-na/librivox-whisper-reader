{
  "work_slug": "alices-adventures-in-wonderland-by-lewis-carroll-5",
  "work_title": "Alice's Adventures in Wonderland (version 4)",
  "work_author": "Lewis Carroll",
  "audio_file": "audio-12",
  "audio_url": "https://archive.org/download/alices_adventures_1005_librivox/wonderland_12_carroll.mp3",
  "chapter_title": "12 - Alice's Evidence",
  "reader_name": "Eric Leach",
  "para_gap_threshold": 0.696,
  "page_num": 1,
  "page_total": 3,
  "page_start_sec": 0.608,
  "page_end_sec": 243.48,
  "segments": [
    {
      "start": 0.608,
      "end": 1.22,
      "text": "CHAPTER XII."
    },
    {
      "start": 1.38,
      "end": 3.56,
      "text": "OF ALICE'S ADVENTURES IN WONDERLAND."
    },
    {
      "start": 3.58,
      "end": 4.32,
      "text": "By Lewis Carroll."
    },
    {
      "start": 5.2,
      "end": 7.58,
      "text": "This LibriVox recording is in the public domain.",
      "para_break": true
    },
    {
      "start": 9.728,
      "end": 10.7,
      "text": "ALICE'S EVIDENCE",
      "para_break": true
    },
    {
      "start": 11.0,
      "end": 11.1,
      "text": "Here!"
    },
    {
      "start": 13.02,
      "end": 13.7,
      "text": "cried Alice,",
      "para_break": true
    },
    {
      "start": 13.84,
      "end": 15.36,
      "text": "quite forgetting in the flurry of the"
    },
    {
      "start": 15.36,
      "end": 17.28,
      "text": "moment how large she had grown in the last"
    },
    {
      "start": 17.28,
      "end": 17.78,
      "text": "few minutes,"
    },
    {
      "start": 17.94,
      "end": 19.96,
      "text": "and she jumped up in such a hurry that"
    },
    {
      "start": 19.96,
      "end": 21.98,
      "text": "she tipped over the jury-box with the edge"
    },
    {
      "start": 21.98,
      "end": 22.54,
      "text": "of her skirt,"
    },
    {
      "start": 22.76,
      "end": 25.62,
      "text": "upsetting all the jury-men on to their heads of the crowd below."
    },
    {
      "start": 25.8,
      "end": 26.82,
      "text": "And there they"
    },
    {
      "start": 27.0,
      "end": 27.78,
      "text": "lay sprawling about,"
    },
    {
      "start": 27.94,
      "end": 29.96,
      "text": "reminding her very much of a globe of"
    },
    {
      "start": 29.96,
      "end": 32.08,
      "text": "goldfish she had accidentally upset the"
    },
    {
      "start": 32.08,
      "end": 32.52,
      "text": "week before."
    },
    {
      "start": 32.78,
      "end": 32.88,
      "text": "Oh,"
    },
    {
      "start": 34.0,
      "end": 35.14,
      "text": "I beg your pardon,",
      "para_break": true
    },
    {
      "start": 35.34,
      "end": 37.26,
      "text": "she exclaimed in a tone of great dismay,"
    },
    {
      "start": 37.36,
      "end": 38.92,
      "text": "and began picking them"
    },
    {
      "start": 38.92,
      "end": 40.54,
      "text": "up again as quickly as she could,"
    },
    {
      "start": 40.86,
      "end": 43.54,
      "text": "for the accident of the goldfish kept running in her head,"
    },
    {
      "start": 43.66,
      "end": 44.24,
      "text": "and she"
    },
    {
      "start": 44.24,
      "end": 46.52,
      "text": "had a vague sort of idea that they must be"
    },
    {
      "start": 46.52,
      "end": 49.12,
      "text": "collected at once and put back into the jury box,"
    },
    {
      "start": 49.36,
      "end": 50.16,
      "text": "or they would die."
    },
    {
      "start": 50.5,
      "end": 52.12,
      "text": "The trial cannot proceed,"
    },
    {
      "start": 52.42,
      "end": 54.34,
      "text": "said the king in a very grave voice,"
    },
    {
      "start": 54.48,
      "end": 55.38,
      "text": "until all the"
    },
    {
      "start": 55.62,
      "end": 57.46,
      "text": "jurymen are back in their proper places."
    },
    {
      "start": 57.72,
      "end": 58.24,
      "text": "All,"
    },
    {
      "start": 58.44,
      "end": 60.38,
      "text": "he repeated with great emphasis,"
    },
    {
      "start": 60.6,
      "end": 62.64,
      "text": "looking hard at Alice as he said so."
    },
    {
      "start": 66.52,
      "end": 69.24,
      "text": "Alice looked at the jury box and saw that in her",
      "para_break": true
    },
    {
      "start": 69.24,
      "end": 71.6,
      "text": "haste she had put the lizard in head downwards"
    },
    {
      "start": 71.88,
      "end": 73.4,
      "text": "and the poor little thing was waving"
    },
    {
      "start": 73.4,
      "end": 75.22,
      "text": "its tail about in a melancholy way,"
    },
    {
      "start": 75.9,
      "end": 76.88,
      "text": "being quite unable to"
    },
    {
      "start": 76.88,
      "end": 77.1,
      "text": "move."
    },
    {
      "start": 78.06,
      "end": 80.14,
      "text": "She soon got it out again and put it right.",
      "para_break": true
    },
    {
      "start": 81.26,
      "end": 82.48,
      "text": "Not that it signifies much,",
      "para_break": true
    },
    {
      "start": 82.62,
      "end": 83.34,
      "text": "she said to herself."
    },
    {
      "start": 83.58,
      "end": 85.92,
      "text": "I should think it would be quite as much"
    },
    {
      "start": 85.92,
      "end": 88.0,
      "text": "use in the trial one way up as the other."
    },
    {
      "start": 89.4,
      "end": 91.1,
      "text": "As soon as the jury had a little",
      "para_break": true
    },
    {
      "start": 91.1,
      "end": 93.04,
      "text": "recovered from the shock of being upset,"
    },
    {
      "start": 93.2,
      "end": 96.18,
      "text": "and their slates and pencils had been found and handed back to them,"
    },
    {
      "start": 96.6,
      "end": 98.5,
      "text": "they set to work very diligently to"
    },
    {
      "start": 98.5,
      "end": 100.04,
      "text": "write out a history of the accident,"
    },
    {
      "start": 100.608,
      "end": 101.44,
      "text": "all except the lizard,"
    },
    {
      "start": 101.58,
      "end": 103.78,
      "text": "who seemed too much overcome to do anything,"
    },
    {
      "start": 104.28,
      "end": 105.48,
      "text": "but sit with its mouth open,"
    },
    {
      "start": 105.62,
      "end": 107.5,
      "text": "gazing up into the roof of the court."
    },
    {
      "start": 108.56,
      "end": 109.8,
      "text": "What do you know about this business?",
      "para_break": true
    },
    {
      "start": 110.06,
      "end": 111.32,
      "text": "the king said to Alice."
    },
    {
      "start": 111.54,
      "end": 112.44,
      "text": "Nothing."
    },
    {
      "start": 113.344,
      "end": 113.86,
      "text": "Nothing whatever,",
      "para_break": true
    },
    {
      "start": 114.22,
      "end": 115.24,
      "text": "persisted the king."
    },
    {
      "start": 116.096,
      "end": 116.6,
      "text": "Nothing whatever,",
      "para_break": true
    },
    {
      "start": 116.96,
      "end": 117.58,
      "text": "said Alice."
    },
    {
      "start": 118.528,
      "end": 119.4,
      "text": "That's very important,",
      "para_break": true
    },
    {
      "start": 119.9,
      "end": 120.4,
      "text": "the king said,"
    },
    {
      "start": 120.5,
      "end": 121.24,
      "text": "turning to the jury."
    },
    {
      "start": 121.66,
      "end": 123.64,
      "text": "They were just beginning to write this down on"
    },
    {
      "start": 123.64,
      "end": 125.66,
      "text": "their slates when the white rabbit interrupted."
    },
    {
      "start": 126.42,
      "end": 126.92,
      "text": "Unimportant,",
      "para_break": true
    },
    {
      "start": 127.04,
      "end": 127.94,
      "text": "your majesty means,"
    },
    {
      "start": 128.08,
      "end": 128.44,
      "text": "of course,"
    },
    {
      "start": 128.58,
      "end": 130.52,
      "text": "he said in a very respectful tone,"
    },
    {
      "start": 130.62,
      "end": 133.06,
      "text": "but frowning and making faces at him as he spoke."
    },
    {
      "start": 134.47,
      "end": 135.12,
      "text": "Unimportant,",
      "para_break": true
    },
    {
      "start": 135.3,
      "end": 135.88,
      "text": "of course,"
    },
    {
      "start": 135.88,
      "end": 136.2,
      "text": "I mean,"
    },
    {
      "start": 136.34,
      "end": 137.5,
      "text": "the king hastily said,"
    },
    {
      "start": 137.62,
      "end": 139.5,
      "text": "and went on himself in an undertone."
    },
    {
      "start": 139.86,
      "end": 140.56,
      "text": "important,"
    },
    {
      "start": 140.78,
      "end": 141.5,
      "text": "unimportant,"
    },
    {
      "start": 141.86,
      "end": 142.38,
      "text": "unimportant,"
    },
    {
      "start": 142.52,
      "end": 142.72,
      "text": "important,"
    },
    {
      "start": 143.68,
      "end": 145.8,
      "text": "as if he were trying which word sounded best.",
      "para_break": true
    },
    {
      "start": 147.34,
      "end": 150.47,
      "text": "Some of the jury wrote it down important and some unimportant.",
      "para_break": true
    },
    {
      "start": 150.8,
      "end": 152.44,
      "text": "Alice could see this as she"
    },
    {
      "start": 152.44,
      "end": 154.14,
      "text": "was near enough to look over their slates."
    },
    {
      "start": 154.84,
      "end": 155.94,
      "text": "But it doesn't matter a bit,",
      "para_break": true
    },
    {
      "start": 156.1,
      "end": 156.86,
      "text": "she thought to herself."
    },
    {
      "start": 157.94,
      "end": 158.54,
      "text": "At this moment,",
      "para_break": true
    },
    {
      "start": 158.62,
      "end": 158.98,
      "text": "the king,"
    },
    {
      "start": 159.18,
      "end": 161.82,
      "text": "who had been for some time busily writing in his notebook,"
    },
    {
      "start": 162.42,
      "end": 162.8,
      "text": "called out,"
    },
    {
      "start": 162.86,
      "end": 163.24,
      "text": "silence,"
    },
    {
      "start": 163.74,
      "end": 165.3,
      "text": "and read out from his book,"
    },
    {
      "start": 165.76,
      "end": 166.4,
      "text": "rule 42,"
    },
    {
      "start": 166.7,
      "end": 169.02,
      "text": "all persons more than a mile high to"
    },
    {
      "start": 169.14,
      "end": 169.76,
      "text": "leave the court."
    },
    {
      "start": 170.56,
      "end": 171.64,
      "text": "Everybody looked at Alice.",
      "para_break": true
    },
    {
      "start": 172.64,
      "end": 173.6,
      "text": "I'm not a mile high,",
      "para_break": true
    },
    {
      "start": 173.86,
      "end": 174.34,
      "text": "said Alice."
    },
    {
      "start": 174.9,
      "end": 175.46,
      "text": "You are,"
    },
    {
      "start": 175.84,
      "end": 176.46,
      "text": "said the king."
    },
    {
      "start": 177.888,
      "end": 179.14,
      "text": "Nearly two miles high,",
      "para_break": true
    },
    {
      "start": 179.46,
      "end": 180.46,
      "text": "added the queen."
    },
    {
      "start": 181.08,
      "end": 181.68,
      "text": "Well,"
    },
    {
      "start": 181.7,
      "end": 183.08,
      "text": "I shan't go at any rate,"
    },
    {
      "start": 183.56,
      "end": 183.92,
      "text": "said Alice."
    },
    {
      "start": 184.06,
      "end": 184.46,
      "text": "Besides,"
    },
    {
      "start": 184.74,
      "end": 185.84,
      "text": "that's not a regular rule."
    },
    {
      "start": 185.94,
      "end": 187.06,
      "text": "You invented it just now."
    },
    {
      "start": 188.704,
      "end": 190.14,
      "text": "It's the oldest rule in the book,",
      "para_break": true
    },
    {
      "start": 190.34,
      "end": 191.08,
      "text": "said the king."
    },
    {
      "start": 191.96,
      "end": 193.18,
      "text": "Then it ought to be number one,",
      "para_break": true
    },
    {
      "start": 193.38,
      "end": 193.92,
      "text": "said Alice."
    },
    {
      "start": 194.54,
      "end": 196.74,
      "text": "The king turned pale and shut his"
    },
    {
      "start": 196.9,
      "end": 197.64,
      "text": "notebook hastily."
    },
    {
      "start": 197.78,
      "end": 199.32,
      "text": "Consider your verdict,"
    },
    {
      "start": 199.56,
      "end": 201.1,
      "text": "he said to the jury in a low,"
    },
    {
      "start": 201.16,
      "end": 201.82,
      "text": "trembling voice."
    },
    {
      "start": 202.944,
      "end": 204.32,
      "text": "There's more evidence to come yet,",
      "para_break": true
    },
    {
      "start": 204.34,
      "end": 205.02,
      "text": "please your majesty,"
    },
    {
      "start": 205.36,
      "end": 206.3,
      "text": "said the White Rabbit,"
    },
    {
      "start": 206.42,
      "end": 207.64,
      "text": "jumping up in a great hurry."
    },
    {
      "start": 208.88,
      "end": 210.82,
      "text": "This paper has just been picked up.",
      "para_break": true
    },
    {
      "start": 212.16,
      "end": 212.66,
      "text": "What's in it?",
      "para_break": true
    },
    {
      "start": 212.85,
      "end": 213.64,
      "text": "said the Queen."
    },
    {
      "start": 213.95,
      "end": 215.5,
      "text": "I haven't opened it yet,"
    },
    {
      "start": 215.66,
      "end": 216.62,
      "text": "said the White Rabbit,"
    },
    {
      "start": 216.7,
      "end": 220.23,
      "text": "but it seems to be a letter written by the prisoner to somebody."
    },
    {
      "start": 222.28,
      "end": 223.08,
      "text": "It must have been that,",
      "para_break": true
    },
    {
      "start": 223.18,
      "end": 223.68,
      "text": "said the King,"
    },
    {
      "start": 223.76,
      "end": 225.22,
      "text": "unless it was written to nobody,"
    },
    {
      "start": 225.42,
      "end": 226.24,
      "text": "which isn't usual,"
    },
    {
      "start": 226.56,
      "end": 226.82,
      "text": "you know."
    },
    {
      "start": 227.91,
      "end": 229.56,
      "text": "Who is it directed to,",
      "para_break": true
    },
    {
      "start": 229.7,
      "end": 230.78,
      "text": "said one of the jurymen."
    },
    {
      "start": 232.18,
      "end": 233.54,
      "text": "It isn't directed at all,",
      "para_break": true
    },
    {
      "start": 234.16,
      "end": 234.88,
      "text": "said the white rabbit."
    },
    {
      "start": 235.02,
      "end": 235.6,
      "text": "In fact,"
    },
    {
      "start": 235.6,
      "end": 237.22,
      "text": "there's nothing written on the outside,"
    },
    {
      "start": 237.52,
      "end": 239.06,
      "text": "he unfolded the paper as"
    },
    {
      "start": 239.06,
      "end": 239.4,
      "text": "he spoke,"
    },
    {
      "start": 239.54,
      "end": 240.24,
      "text": "and added,"
    },
    {
      "start": 240.9,
      "end": 242.32,
      "text": "it isn't a letter after all,"
    },
    {
      "start": 242.4,
      "end": 243.48,
      "text": "it's a set of verses."
    }
  ]
}
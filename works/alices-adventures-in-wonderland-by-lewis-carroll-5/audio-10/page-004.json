      "text": "What trial is it?",
      "para_break": true
    },
    {
      "start": 784.16,
      "end": 785.64,
      "text": "Alice panted as she ran,"
    },
    {
      "start": 786.18,
      "end": 787.52,
      "text": "but the griffin only answered,"
    },
    {
      "start": 788.92,
      "end": 789.24,
      "text": "Come on!",
      "para_break": true
    },
    {
      "start": 789.4,
      "end": 792.36,
      "text": "and ran the faster while more and more faintly came,"
    },
    {
      "start": 792.48,
      "end": 794.38,
      "text": "carried on the breeze that followed them,"
    },
    {
      "start": 794.44,
      "end": 795.66,
      "text": "the melancholy words,"
    },
    {
      "start": 796.512,
      "end": 798.48,
      "text": "Soup of the evening,",
      "para_break": true
    },
    {
      "start": 798.64,

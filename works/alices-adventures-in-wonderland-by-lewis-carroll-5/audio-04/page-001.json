{
  "work_slug": "alices-adventures-in-wonderland-by-lewis-carroll-5",
  "work_title": "Alice's Adventures in Wonderland (version 4)",
  "work_author": "Lewis Carroll",
  "audio_file": "audio-04",
  "audio_url": "https://archive.org/download/alices_adventures_1005_librivox/wonderland_04_carroll.mp3",
  "chapter_title": "04 - The Rabbit sends in a Little Bill",
  "reader_name": "Eric Leach",
  "para_gap_threshold": 0.717,
  "page_num": 1,
